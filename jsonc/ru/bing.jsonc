        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Quick, clever and always on the move—meet the Eurasian red squirrel, a leafy treetop resident found across much of Europe and Asia. While it prefers the shelter of forests, this agile creature easily adapts to gardens and parks. It builds its nest, called a drey, high in the fork of a tree using twigs to form a domed structure about 25 to 30 centimetres wide. The female featured here is gathering moss—one of several soft materials, along with bark, leaves and grass, that line the nest and turn it into a snug, well-insulated retreat. These rodents may also take over tree hollows or abandoned woodpecker holes when available.",
                "Image": {
                    "Url": "/th?id=OHR.SwissSquirrel_ROW7231297165_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.SwissSquirrel_ROW7231297165_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Info",
