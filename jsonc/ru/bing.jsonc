        "copyright": "Christmas market in Leipzig, Germany (© Krzysztof Baranowski/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Leipzig&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251130_LeipzigMarket%22&FORM=HPQUIZ",
