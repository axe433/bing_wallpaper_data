        "urlbase": "/th?id=OHR.PlazaMayor_ROW7184279069",
        "copyright": "Aerial view of Plaza Mayor, Madrid, Spain (© AirPano LLC/Amazing Aerial Agency)",
        "copyrightlink": "https://www.bing.com/search?q=Plaza+Mayor+Madrid&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250829_PlazaMayor%22&FORM=HPQUIZ",
        "wp": true,
