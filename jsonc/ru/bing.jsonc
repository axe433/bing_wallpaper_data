        "urlbase": "/th?id=OHR.WatertowerMannheim_ROW8445149552",
        "copyright": "Mannheim Water Tower, Germany (© no_limit_pictures/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Mannheim+Water+Tower&form=hpcapt",
