        "urlbase": "/th?id=OHR.GermanyNewYear_ROW1011878383",
        "copyright": "Oberbaum Bridge, Berlin, Germany (© spreephoto.de/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Oberbaum+Bridge&form=hpcapt",
        "title": "Info",
