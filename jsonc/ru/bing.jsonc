        "urlbase": "/th?id=OHR.RotatoriaLetras_ROW3601160329",
        "copyright": "Letters Square Roundabout, Manaus, Brazil (© Cristian Lourenço/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Letters+Roundabout+Manaus&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250809_RotatoriaLetras%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "79e01ec5a20fb9b0d6d1a19deea339b6",
