        "urlbase": "/th?id=OHR.OrchardLibrary_ROW7132062115",
        "copyright": "Library@orchard, Singapore (© Darwin Fan/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Library+orchard+Singapore&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250908_OrchardLibrary%22&FORM=HPQUIZ",
        "wp": true,
