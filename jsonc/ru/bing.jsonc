        "copyright": "Ruins of Dunseverick Castle, County Antrim, Northern Ireland (© Krzysztof Rogalski/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Dunseverick+Castle&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260607_DunseverickCastle2026%22&FORM=HPQUIZ",
