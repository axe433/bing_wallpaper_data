        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Spring announces itself across California's Central Valley with the first bursts of wildflowers following the winter rains. Stretching about 720 kilometres from north to south and covering approximately 51,800 square kilometres, the valley is one of the world's most productive agricultural regions. In early spring, however, an older identity briefly resurfaces. From March through April, native annuals such as goldfields, tidy tips and owl's clover quickly germinate once temperature and soil moisture are optimal. They race to complete their life cycles before the long dry season begins.",
                "Image": {
                    "Url": "/th?id=OHR.WildflowerValley_ROW2763453477_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.WildflowerValley_ROW2763453477_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
