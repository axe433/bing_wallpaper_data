    {
        "startdate": "20251012",
        "fullstartdate": "202510120700",
        "enddate": "20251013",
        "url": "/th?id=OHR.SaranacLake_ROW9913011112_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.SaranacLake_ROW9913011112",
        "copyright": "Village of Saranac Lake, Adirondack Mountains, New York, United States (© DenisTangneyJr/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Saranac+Lake+village&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251012_SaranacLake%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "cdc1757c0ef57f795c03d4897e81f19e",
        "hsh": "e46c95841369ca03f198e724dc36d071",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Some places are just stops on the map, but Saranac Lake in the Adirondack Mountains in New York, United States, is a destination that keeps people hooked year-round. Despite its name, this village isn't directly on the Saranac Lakes themselves but rather on Lake Flower, a wide section of the Saranac River. For centuries, the area—nicknamed 'The Capital of the Adirondacks'—was used by Indigenous peoples for hunting and travel. By the late 19th century, it gained fame as a health retreat, where Dr. Edward Livingston Trudeau pioneered fresh-air treatment for tuberculosis. The cure cottages from that era still stand today.",
                "Image": {
                    "Url": "/th?id=OHR.SaranacLake_ROW9913011112_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.SaranacLake_ROW9913011112_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Info",
                "Title": "Village of Saranac Lake, Adirondack Mountains, New York, United States",
                "Copyright": "© DenisTangneyJr/Getty Images",
