        "url": "/th?id=OHR.BadSunset_ROW3111301246_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.BadSunset_ROW3111301246",
        "copyright": "Sunset in Badlands National Park, South Dakota, United States (© Troy Harrison/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Badlands+National+Park&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260613_BadSunset%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "d90896e67fb614f6e6801667781bc801",
        "hsh": "ecb12823c433137d0eb7a88da0d13b7d",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Layered ridges stretch across Badlands National Park in South Dakota. Their bands of pink, grey and gold shift with the light as eroded peaks and valleys come into view. Wind and water continue to shape this terrain, steadily wearing away soft sedimentary rock and exposing millions of years of Earth's history in layers formed by ancient rivers, volcanic ash and periods when shallow seas covered the region.",
