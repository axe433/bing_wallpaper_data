        "copyright": "Trullo buildings in Alberobello, Apulia, Italy (© Feng Wei Photography/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Alberobello&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250826_TrulliHouses%22&FORM=HPQUIZ",
