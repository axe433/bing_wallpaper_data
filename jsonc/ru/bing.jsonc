        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Long before GPS, natural landmarks like Scotts Bluff rose high above the prairie, signalling to travellers that they were on the right path heading west. Before Gering became a town in 1887 and decades before Nebraska achieved statehood in 1867, these sandstone and siltstone formations were already guiding thousands along the Oregon, California and Mormon Trails. Scotts Bluff National Monument is named after Hiram Scott, a fur trader with the Rocky Mountain Fur Company who died under mysterious circumstances nearby in the 1820s.",
                "Image": {
                    "Url": "/th?id=OHR.ScottsBluff_ROW7379733057_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.ScottsBluff_ROW7379733057_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
