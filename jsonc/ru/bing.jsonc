        "copyright": "Sgwd yr Eira waterfall, Bannau Brycheiniog National Park, Wales (© Guy Edwardes/Nature Picture Library)",
        "copyrightlink": "https://www.bing.com/search?q=Bannau+Brycheiniog+National+Park&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260409_WalesWaterfall%22&FORM=HPQUIZ",
