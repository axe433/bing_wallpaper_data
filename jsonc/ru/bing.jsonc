        "copyright": "Lioness in Maasai Mara National Reserve, Kenya (© Tandem Stock/Adobe Stock)",
        "copyrightlink": "https://www.bing.com/search?q=Maasai+Mara+National+Reserve&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250810_LionessKenya%22&FORM=HPQUIZ",
