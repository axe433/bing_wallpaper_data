        "enddate": "20260315",
        "url": "/th?id=OHR.CornwallDolmen_ROW3459140266_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.CornwallDolmen_ROW3459140266",
        "copyright": "Lanyon Quoit, a Neolithic dolmen in Cornwall, England (© Helen Hotson/Alamy)",
        "copyrightlink": "https://www.bing.com/search?q=Lanyon+Quoit&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260314_CornwallDolmen%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "74a6b2f7d0b8cfb33c83afa88a1ed03f",
        "hsh": "e5420f7ca4dc7fc1631d14b2f1dbaa9c",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Time has altered the land around it, but Lanyon Quoit in Cornwall, England, still commands attention. Built in the Neolithic period, 'The Giant's Table' offers a rare chance to consider how early settlers marked their presence. Formed by upright stones holding a massive capstone of about 13,000 kilograms, the monument likely served as a communal burial chamber.",
