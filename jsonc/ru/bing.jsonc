        "url": "/th?id=OHR.LacGentau_ROW3338740451_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.LacGentau_ROW3338740451",
        "copyright": "Lake Gentau in the French Pyrenees, Pyrénées-Atlantiques, France (© MICHAUX Stéphane/Hemis.fr/Alamy)",
        "copyrightlink": "https://www.bing.com/search?q=Lake+Gentau+French+Pyrenees&form=hpcapt",
