        "copyright": "Plains zebras, Etosha National Park, Namibia (© Mogens Trolle/Shutterstock)",
        "copyrightlink": "https://www.bing.com/search?q=Plains+zebras&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260131_EtoshaZebra%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "8c3dca1ab85439e5395c3cba4229c9ee",
