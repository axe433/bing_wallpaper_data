        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Big ears, bigger hearts—elephants are more than just icons of the wild. These majestic giants roam freely across places like Amboseli National Park in Kenya, pictured here. What makes elephants so extraordinary isn't just their size; it's their minds. These animals have incredible memories. Matriarchs, the oldest females, can recall the locations of water sources from decades past, and they use that knowledge to lead their herds through tough times. Their social bonds run just as deep. Elephants live in close-knit families, mourn their dead and have even been observed comforting one another during hard times.",
                "Image": {
                    "Url": "/th?id=OHR.KenyaElephants_ROW4632844635_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.KenyaElephants_ROW4632844635_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
