        "urlbase": "/th?id=OHR.GasparillaLight_ROW6062509878",
        "copyright": "Gasparilla Island Rear Range Light, Boca Grande, Florida, United States (© Wiltser/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Boca+Grande&form=hpcapt",
