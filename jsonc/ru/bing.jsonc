        "copyright": "Alam-Pedja Nature Reserve in Tartu County, Estonia (© Sven Zacek/Nature Picture Library)",
        "copyrightlink": "https://www.bing.com/search?q=Alam+Pedja+Nature+Reserve&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260422_TartuEstonia%22&FORM=HPQUIZ",
