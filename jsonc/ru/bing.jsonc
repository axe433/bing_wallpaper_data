        "urlbase": "/th?id=OHR.GrandPlace_ROW9942052634",
        "copyright": "Buildings on Grand-Place Square in Brussels, Belgium (© Vladislav Zolotov/Getty Images Plus)",
        "copyrightlink": "https://www.bing.com/search?q=Grand+Place+Brussels&form=hpcapt",
