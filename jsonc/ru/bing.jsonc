        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Chefchaouen, known as the 'Blue Pearl' of the Rif Mountains, is one of the most atmospheric cities in Morocco. Its name comes from a blend of Arabic and Berber—Chef, derived from the Arabic word meaning 'to look,' and Echaouen, a Berber term for 'horns'—together meaning 'look at the horns,' a reference to the two mountain peaks that rise above the town.",
                "Image": {
                    "Url": "/th?id=OHR.BlueMorocco_ROW0232801057_1920x1080.webp",
