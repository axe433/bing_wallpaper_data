        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "The Temple of Philae, often called the Temple of Isis, is one of Egypt's most enchanting ancient sites. Originally built on Philae Island, it was moved to nearby Agilkia Island to save it from flooding. The international rescue effort, launched by UNESCO in the 1960s, required a monumental effort that involved moving more than 40,000 stones. Today, it's a peaceful spot surrounded by the Nile—perfect for a scenic boat ride and a journey into the past.",
                "Image": {
                    "Url": "/th?id=OHR.TemplePhilae_ROW9063878443_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.TemplePhilae_ROW9063878443_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
