    {
        "startdate": "20260517",
        "fullstartdate": "202605170700",
        "enddate": "20260518",
        "url": "/th?id=OHR.ShenandoahSunset_ROW7042145908_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.ShenandoahSunset_ROW7042145908",
        "copyright": "Hawksbill Mountain in Shenandoah National Park, Virginia, United States (© John Baggaley/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Hawksbill+Mountain&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260517_ShenandoahSunset%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "60d3fa51eea3cd7a2b77a1b00f81a9d1",
        "hsh": "932fb13cb169dbbd5ee057d86c50eb52",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "How high is high enough for a great view? In the eastern United States, it doesn't take much. Hawksbill Mountain is the highest point in Shenandoah National Park, Virginia, at 1,234 metres, showing how these older mountains rely on openness, not elevation. The park's establishment in 1935 involved reforestation after extensive farming and logging. Today, much of that land has returned to forest, supporting mixed hardwoods, mountain laurel and rhododendron. What else? Some of the rocks found here date back over 1 billion years, among the oldest in the state. The park shelters over 200 bird species and 32 species of fish and remains dog friendly, allowing pets in campgrounds and on most trails.",
                "Image": {
                    "Url": "/th?id=OHR.ShenandoahSunset_ROW7042145908_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.ShenandoahSunset_ROW7042145908_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
