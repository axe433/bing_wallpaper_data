    {
        "startdate": "20260305",
        "fullstartdate": "202603050800",
        "enddate": "20260306",
        "url": "/th?id=OHR.GoremeTwilight_ROW5000170185_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.GoremeTwilight_ROW5000170185",
        "copyright": "Göreme, Cappadocia, Türkiye (© ONNAJA/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=G%C3%B6reme+T%C3%BCrkiye&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260305_GoremeTwilight%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "40e9b42b77b328eab06b29c5260a327c",
        "hsh": "36c36e9a4e0c8149ba0fdbbd5d97e1bd",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "As evening settles over the town of Göreme in the heart of the Cappadocia region of Türkiye, dusk reveals a landscape forged by nature and centuries of human presence. This scene is part of Göreme National Park and the Rock Sites of Cappadocia, a UNESCO World Heritage Site inscribed in 1985 for its exceptional combination of early cultural history and geological formations. These formations, often called 'fairy chimneys' or hoodoos, began as layers of volcanic ash that hardened into soft stone following eruptions of ancient Anatolian volcanoes. Over time, wind and water carved the pillars, ridges and valleys that define the region today.",
                "Image": {
                    "Url": "/th?id=OHR.GoremeTwilight_ROW5000170185_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.GoremeTwilight_ROW5000170185_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Info",
                "Title": "Göreme, Cappadocia, Türkiye",
                "Copyright": "© ONNAJA/Getty Images",
                "SocialGood": null,
                "MapLink": {
                    "Url": "",
                    "Link": ""
                },
                "QuickFact": {
                    "MainText": "",
                    "LinkUrl": "",
