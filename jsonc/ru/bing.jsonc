        "urlbase": "/th?id=OHR.PumpkinFarm_ROW0518823159",
        "copyright": "Pumpkin farm in North Carolina, United States (© Matthew H Irvin/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=pumpkin&form=hpcapt",
        "title": "Info",
