        "url": "/th?id=OHR.TuftedTitmouse_ROW4045050908_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.TuftedTitmouse_ROW4045050908",
        "copyright": "Tufted titmouse perched on pine boughs, Massachusetts, United States (© Tim Laman/NPL/Minden Pictures)",
        "copyrightlink": "https://www.bing.com/search?q=Tufted+Titmouse&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251214_TuftedTitmouse%22&FORM=HPQUIZ",
        "wp": true,
