        "copyright": "Swing carousel at Oktoberfest, Munich, Bavaria, Germany (© LOOK-foto/Alamy)",
        "copyrightlink": "https://www.bing.com/search?q=Oktoberfest&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250920_OktoberfestSwing%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "a8c4375349af2181e8298d0bf42ea0d2",
