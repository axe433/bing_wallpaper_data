        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Nestled within Rock River Canyon Wilderness, in Michigan, United States, Rock River Falls emerges amid a landscape shaped by glaciers, dense woods and layers of history. In the Upper Peninsula, humans have left their traces for millennia: Indigenous Algonquian-speaking peoples were followed by French and British explorers and waves of Finnish, Swedish and French-Canadian immigrants settled there during the 19th-century mining and logging booms. Today, this sparsely populated region hosts barely 3% of Michigan's residents, cradling its forests and waterfalls in near-natural serenity.",
                "Image": {
                    "Url": "/th?id=OHR.RockRiverFalls_ROW9398171921_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.RockRiverFalls_ROW9398171921_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
