        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "From 18th-century visitors to fire-carved trails, this rock city tells a story of survival. Hidden in Czechia's Hradec Králové Region, the Adršpach–Teplice Rocks form Central Europe's largest sandstone labyrinth. For centuries, the cliffs and passages lay cloaked in forest until a great fire stripped the land bare. Arches, towers and winding corridors emerged out of the ashes and the first hiking paths were carved into the rock. Soon after, explorers and poets left their marks with stone inscriptions that captured a destination both wild and enchanting.",
                "Image": {
                    "Url": "/th?id=OHR.TepliceRocks_ROW0717999002_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.TepliceRocks_ROW0717999002_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
