        "MediaContent": {
            "ImageContent": {
                "Description": "Nested between Cannes and Nice, the Cap d'Antibes is a peaceful peninsula at the heart of Antibes, France. Maritime pines perfume the salty air, the coves harbour solitude and the coastal paths are silent except for the waves.",
                "Image": {
                    "Url": "/th?id=OHR.CapAntibes_ROW9927091167_1920x1080.webp",
