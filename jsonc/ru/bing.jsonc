        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Tom McCall Waterfront Park, a 12.5-hectare urban oasis along the Willamette River in Portland, Oregon, is one of the city's most beloved green spaces. Each spring—typically from mid-March to early April—it transforms into a sea of soft pink and white as cherry blossoms bloom. These vibrant trees along scenic walking paths offer a peaceful escape in the heart of the city. The park also features notable landmarks like Salmon Street Springs, an interactive fountain with numerous water jets, and the Portland Saturday Market, a favourite local destination.",
                "Image": {
                    "Url": "/th?id=OHR.PortlandBlossoms_ROW4378783991_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.PortlandBlossoms_ROW4378783991_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
