        "urlbase": "/th?id=OHR.CoronaArch_ROW4754489590",
        "copyright": "A man rappels off Corona Arch near Moab, Utah, United States (© Grant Ordelheide/TANDEM Stills + Motion)",
        "copyrightlink": "https://www.bing.com/search?q=Natural+arch&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250813_CoronaArch%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "36c0e82d25eae189b72f5adf45fcb297",
