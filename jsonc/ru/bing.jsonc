        "urlbase": "/th?id=OHR.CastleBlossoms_ROW0945099429",
        "copyright": "Hirosaki Castle with cherry blossoms, Hirosaki, Japan (© Glenn Waters/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Hirosaki+Castle&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260406_CastleBlossoms%22&FORM=HPQUIZ",
        "wp": true,
