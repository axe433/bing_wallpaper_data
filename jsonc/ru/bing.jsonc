        "urlbase": "/th?id=OHR.MonurikiFiji_ROW9654134811",
        "copyright": "Coral reef surrounding the island of Monuriki, Mamanuca Islands, Fiji (© David Wall/SuperStock)",
        "copyrightlink": "https://www.bing.com/search?q=Monuriki&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251010_MonurikiFiji%22&FORM=HPQUIZ",
        "wp": true,
