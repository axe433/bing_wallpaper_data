        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "A red fox standing in the snowfall of Grand Teton National Park is more than a picturesque moment—it offers a glimpse into the resilience of one of North America's most adaptable predators. This small carnivore is instantly recognisable by its sharp gaze and thick, fiery coat that helps it thrive even in Wyoming's harsh winter conditions. Snow muffles sound, yet the animal's extraordinary hearing allows it to detect prey moving beneath the surface. You can almost imagine it pausing amid the drifting flakes, ears rotating, body perfectly still, waiting for the faintest rustle.",
                "Image": {
                    "Url": "/th?id=OHR.TetonFox_ROW1833044776_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.TetonFox_ROW1833044776_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
