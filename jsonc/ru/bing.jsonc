        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "The surface looks busy, but everything else is still. White bubbles stack under clear ice as if time stalled halfway through a reaction. Unusual? Yes. Mysterious? Only until you look closer. This is Abraham Lake, the largest reservoir in Alberta, Canada. It is located in the Kootenay Plains area of the Canadian Rockies' front range, where winter captures gas in mid-escape.",
                "Image": {
                    "Url": "/th?id=OHR.BubblesAbraham_ROW5591187969_1920x1080.webp",
