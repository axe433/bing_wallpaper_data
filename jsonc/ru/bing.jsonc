        "urlbase": "/th?id=OHR.Echasse_ROW7944797323",
        "copyright": "Black-winged stilts, France (© Antonio Sementa/500px/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Black-winged+stilt&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250915_Echasse%22&FORM=HPQUIZ",
