    {
        "startdate": "20260518",
        "fullstartdate": "202605180700",
        "enddate": "20260519",
        "url": "/th?id=OHR.NPFortnight2026_ROW9483729156_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.NPFortnight2026_ROW9483729156",
        "copyright": "Dolbadarn Castle, Llanberis, Wales (© Allan Hartley/Alamy)",
        "copyrightlink": "https://www.bing.com/search?q=Dolbadarn+Castle+Wales&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260518_NPFortnight2026%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "5a0c08b5cb585251be2d97174962dcd0",
        "hsh": "df3e6c5f17dc70f3795bfc9e748decf2",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Some people chase peaks, others follow lakes. In Wales, the Snowdonia (Eryri) National Park is one stop that quietly combines both—Dolbadarn Castle. Standing beside the serene waters of Llyn Padarn, this 13th-century fortress was built by Llywelyn the Great—Prince of Gwynedd from 1199 to 1240—to guard the route through Llanberis Pass. Built from purple and green slate, the castle was largely assembled using dry stone techniques without mortar, apart from the keep. Its distinctive round tower once stood watch over the valley. History here has its twists. Owain Goch ap Gruffudd, Llywelyn's nephew, is believed to have been imprisoned inside these walls after a family feud.",
                "Image": {
                    "Url": "/th?id=OHR.NPFortnight2026_ROW9483729156_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.NPFortnight2026_ROW9483729156_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Info",
                "Title": "Dolbadarn Castle, Llanberis, Wales",
                "Copyright": "© Allan Hartley/Alamy",
                "SocialGood": null,
                "MapLink": {
                    "Url": "",
                    "Link": ""
                },
                "QuickFact": {
                    "MainText": "",
                    "LinkUrl": "",
                    "LinkText": ""
                },
                "TriviaUrl": "/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260518_NPFortnight2026\"&FORM=HPQUIZ",
                "BackstageUrl": "/search?q=Dolbadarn+Castle+Wales&form=hpcapt&filters=HpDate:\"20260518_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"",
