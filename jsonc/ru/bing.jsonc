        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Tilting, a village on Fogo Island at Canada's eastern edge, was settled by Irish immigrants in the 18th century. It remains a unique example of an Irish outport community that has preserved its cultural identity. The bright fishing sheds and homes weren't painted just for aesthetics; the hues once made buildings easier to spot during heavy fog or snowfall. These vivid colours also reflect the practical, resourceful life of the people who settled here. It is also one of the few places in North America where traditional Irish communal land use practices—such as shared meadows and garden plots—have been preserved in both form and function.",
                "Image": {
                    "Url": "/th?id=OHR.CanadaDayFogo_ROW4542871312_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.CanadaDayFogo_ROW4542871312_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Info",
                "Title": "Fishing village of Tilting, Fogo Island, Newfoundland and Labrador, Canada",
                "Copyright": "© FedevPhoto/Getty Images",
                "SocialGood": null,
                "MapLink": {
                    "Url": "",
                    "Link": ""
                },
