        "copyright": "Spotted eagle rays, San Cristóbal Island, Galápagos Islands, Ecuador (© Tui De Roy/Minden Pictures)",
        "copyrightlink": "https://www.bing.com/search?q=Spotted+eagle+rays&form=hpcapt",
        "title": "Info",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250815_SpottedEagleRay%22&FORM=HPQUIZ",
        "wp": true,
