        "wp": true,
        "md5": "3eccd600064e8fe0a219e0d897b33b17",
        "hsh": "da3f23eb22695ebd9374a072572414f5",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "El zorro rojo es uno de los mamíferos más adaptables del planeta. Habita bosques, montañas y llanuras, y puede sobrevivir tanto en climas extremos como cerca de zonas humanas. Destaca por su oído fino, capaz de detectar presas bajo la nieve, y por su inteligencia, que le permite memorizar rutas y esconder alimento para más tarde. Su espesa cola le sirve de abrigo y de equilibrio cuando corre o salta, mientras que su pelaje varía con la estación y el entorno.",
                "Image": {
                    "Url": "/th?id=OHR.TetonFox_ES-ES3808150258_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.TetonFox_ES-ES3808150258_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Susurros de invierno",
                "Title": "Zorro rojo bajo la nieve, parque nacional de Grand Teton, Wyoming, EE. UU.",
                "Copyright": "© Radomir Jakubowski/naturepl.com",
