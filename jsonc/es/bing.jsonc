        "copyright": "Lince euroasiático, Siberia (© Mario Plechaty Photograph/Shutterstock)",
        "copyrightlink": "https://www.bing.com/search?q=Lince+euroasi%C3%A1tico&form=hpcapt&filters=HpDate%3a%2220251015_2200%22",
        "title": "El gato fantasma",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251015_SiberianLynx%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "c98b131f99b78567ee68021095cf7366",
