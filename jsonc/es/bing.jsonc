        "url": "/th?id=OHR.GrandSunset_ES-ES4658848615_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.GrandSunset_ES-ES4658848615",
        "copyright": "Gran Cañón y río Colorado, Arizona, EE. UU. (© Matt Anderson Photography/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Gran+Ca%C3%B1%C3%B3n&form=hpcapt&filters=HpDate%3a%2220260225_2300%22",
        "title": "Una vista majestuosa",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260225_GrandSunset%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "aa30350b7955b20865648a4852af95cc",
        "hsh": "4589383e3943c9fb6469581a2c50f8aa",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "El Gran Cañón se extiende como una escultura majestuosa en el norte de Arizona, Estados Unidos, resultado de millones de años de erosión paciente. Sus paredes revelan capas de roca que narran la historia geológica del continente, con colores cambiantes según la luz y la hora del día. La magnitud del paisaje desafía la escala humana y transmite una sensación de profundidad y silencio difíciles de olvidar, donde el viento y la piedra parecen dialogar sin prisa.",
                "Image": {
                    "Url": "/th?id=OHR.GrandSunset_ES-ES4658848615_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.GrandSunset_ES-ES4658848615_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Una vista majestuosa",
                "Title": "Gran Cañón y río Colorado, Arizona, EE. UU.",
                "Copyright": "© Matt Anderson Photography/Getty Images",
