        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "El puente Armbrug forma parte del entramado cotidiano de Ámsterdam, donde los canales marcan el ritmo de la ciudad. Se trata de un puente levadizo discreto, pensado más para la vida diaria que para el gesto monumental, pero esencial para permitir el paso de embarcaciones y peatones. Su nombre alude directamente a su mecanismo móvil, que se eleva como un brazo para abrir el canal. Integrado en el paisaje urbano, combina funcionalidad y sencillez, recordando la estrecha relación entre la ciudad y el agua.",
                "Image": {
                    "Url": "/th?id=OHR.ArmbrugBridge_ES-ES5113545309_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.ArmbrugBridge_ES-ES5113545309_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Acortando distancias",
                "Title": "Puente Armbrug, Ámsterdam, Países Bajos",
                "Copyright": "© Alexander Spatari/Getty Images",
                "SocialGood": null,
                "MapLink": {
                    "Url": "//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.375378,4.900051/9?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=es-ES&od=2&shading=flat&pp=52.375378,4.900051;S9;Puente Armbrug, Ámsterdam, Países Bajos&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro",
