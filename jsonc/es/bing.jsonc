        "copyright": "Guanaco, Punta Norte, Península Valdés, Argentina (© Sylvain Cordier/naturepl.com)",
        "copyrightlink": "https://www.bing.com/search?q=Guanaco&form=hpcapt&filters=HpDate%3a%2220251208_2300%22",
        "title": "¡Soy la llama que llama!",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251208_LlamaDay%22&FORM=HPQUIZ",
        "wp": true,
