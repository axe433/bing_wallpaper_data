        "MediaContent": {
            "ImageContent": {
                "Description": "El castillo de Hirosaki, en la ciudad japonesa del mismo nombre, es uno de los referentes de la arquitectura feudal del país. Construido a comienzos del siglo XVII por el clan Tsugaru, se alza rodeado por miles de cerezos que cada primavera transforman el foso y los jardines en un paisaje efímero.",
                "Image": {
                    "Url": "/th?id=OHR.CastleBlossoms_ES-ES5659720575_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.CastleBlossoms_ES-ES5659720575_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
