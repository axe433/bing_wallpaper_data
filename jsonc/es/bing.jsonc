        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "La naturaleza tiene sus trucos, y el lago Sørvágsvatn, en las Islas Feroe (territorio autónomo de Dinamarca), es uno de los más sorprendentes. También conocido como Leitisvatn, este lago parece flotar sobre el océano, pero en realidad está a menos de 30 metros sobre el nivel del mar. Es el lago más grande del archipiélago, con una superficie de más de 3,5 kilómetros cuadrados, y da origen a la cascada Bøsdalafossur, cuyas aguas caen directamente al mar desde un acantilado.",
                "Image": {
                    "Url": "/th?id=OHR.FaroeLake_ES-ES8719950614_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.FaroeLake_ES-ES8719950614_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Un lago sobre el océano",
                "Title": "Lago Sørvágsvatn, Isla de Vágar, Islas Feroe, Reino de Dinamarca",
                "Copyright": "© Anton Petrus/Getty Images",
                "SocialGood": null,
                "MapLink": {
