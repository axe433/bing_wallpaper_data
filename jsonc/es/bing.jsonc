    {
        "startdate": "20251121",
        "fullstartdate": "202511212300",
        "enddate": "20251122",
        "url": "/th?id=OHR.LeshanBuddha_ES-ES8164485271_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.LeshanBuddha_ES-ES8164485271",
        "copyright": "Gran Buda de Leshan, Sichuan, China (© www.anotherdayattheoffice.org/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Gran+Buda+de+Leshan+China&form=hpcapt&filters=HpDate%3a%2220251121_2300%22",
        "title": "El guardián de las aguas",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251121_LeshanBuddha%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "d45857502d6a8f388623f532cf5ecc8a",
        "hsh": "ba0513d9bd12836a3c1d37f364431e2e",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Hay grandes estatuas, y luego está el Buda Gigante de Leshan. Tallada en un acantilado junto a la confluencia de los ríos Min, Qingyi y Dadu, en Sichuan, China, esta obra es una maravilla antigua de la ingeniería. Su construcción comenzó en el año 713 d.C., bajo la dirección del monje Hai Tong, quien esperaba que la presencia del Buda calmara las peligrosas corrientes fluviales que amenazaban a los barcos.",
                "Image": {
                    "Url": "/th?id=OHR.LeshanBuddha_ES-ES8164485271_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.LeshanBuddha_ES-ES8164485271_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "El guardián de las aguas",
