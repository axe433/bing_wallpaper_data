        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "“Hacer heno mientras brilla el sol” no es solo un refrán: en el campo es una necesidad. Empacar heno consiste en cortar, secar y prensar pastos para alimentar al ganado en los meses fríos. El clima es clave: la hierba debe estar seca antes de empacarla, o podría enmohecerse. Por eso, cuando llega un periodo de sol, los agricultores trabajan contra reloj.",
                "Image": {
                    "Url": "/th?id=OHR.YorkshireHay_ES-ES7917729802_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.YorkshireHay_ES-ES7917729802_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Vamos a tejer la naturaleza",
                "Title": "Pacas de heno, Yorkshire del Norte, Inglaterra",
                "Copyright": "© Nick Brundle Photography/Getty Images",
                "SocialGood": null,
                "MapLink": {
                    "Url": "",
                    "Link": ""
                },
