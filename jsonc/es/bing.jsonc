        "copyright": "Cisnes cantores, estanque Kotoku, Japón (© Martin Bailey/Shutterstock)",
        "copyrightlink": "https://www.bing.com/search?q=Cisne+cantor&form=hpcapt&filters=HpDate%3a%2220251229_2300%22",
        "title": "Viaje sin fronteras",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251229_JapanSwans%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "10942e61584bf0102014485acc6b5568",
