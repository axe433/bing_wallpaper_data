        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "¿Sabías que estamos en temporada de hongos? Uno de los más llamativos es la laccaria de amatista, también llamada “engaño de amatista”. Su color púrpura brillante deslumbra cuando es joven, pero se desvanece con la edad y la intemperie, lo que hace que sea difícil de identificar. A pesar de su apariencia delicada, este hongo es comestible y cumple un papel esencial en el ecosistema.",
                "Image": {
                    "Url": "/th?id=OHR.AmethystLaccaria_ES-ES1228402064_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.AmethystLaccaria_ES-ES1228402064_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
