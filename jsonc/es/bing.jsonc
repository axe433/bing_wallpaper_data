        "copyright": "Zorro ártico durmiendo (© Chansak Joe/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Zorro+%C3%A1rtico&form=hpcapt&filters=HpDate%3a%2220251231_2300%22",
        "title": "Guardián del invierno",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251231_NewYearFox%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "ac9a61a239a813f4bc9179a2a1e49693",
