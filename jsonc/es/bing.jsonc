        "copyrightlink": "https://www.bing.com/search?q=D%C3%ADa+de+Canad%C3%A1&form=hpcapt&filters=HpDate%3a%2220250630_2200%22",
        "title": "Canadá cumple 158 años",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250630_CanadaDayFogo%22&FORM=HPQUIZ",
        "wp": true,
