        "copyright": "Edificio del Parlamento Húngaro, Budapest, Hungría (© Alexander Spatari/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Budapest&form=hpcapt&filters=HpDate%3a%2220251118_2300%22",
        "title": "Con vistas al Danubio",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251118_BudapestParliament%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "949cb09d9e8bc81309c8105a0202454e",
