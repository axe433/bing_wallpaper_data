        "copyright": "Entrada al castillo de Bran en Bran, Brașov, Rumania (© blue sky in my pocket/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=castillo+de+Bran&form=hpcapt&filters=HpDate%3a%2220251030_2300%22",
        "title": "Bajo el hechizo de Halloween",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251030_BranCastle%22&FORM=HPQUIZ",
        "wp": true,
