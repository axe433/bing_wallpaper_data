        "MediaContent": {
            "ImageContent": {
                "Description": "Noviembre no es solo tiempo de castañas, setas y platos calientes; también es el Mes de Concienciación sobre el Manatí, una ocasión ideal para descubrir a estos tranquilos gigantes del mar. Lejos del protagonismo de los delfines o los tiburones, los manatíes conquistan corazones con su calma y simpatía.",
                "Image": {
                    "Url": "/th?id=OHR.ManateeBaby_ES-ES4491348488_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.ManateeBaby_ES-ES4491348488_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Un baño relajante",
