        "urlbase": "/th?id=OHR.ArmbrugBridge_ES-ES5113545309",
        "copyright": "Puente Armbrug, Ámsterdam, Países Bajos (© Alexander Spatari/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Puente+Armbrug+%C3%81msterdam+Pa%C3%ADses+Bajos&form=hpcapt&filters=HpDate%3a%2220260402_2200%22",
        "title": "Acortando distancias",
