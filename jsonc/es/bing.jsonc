    {
        "startdate": "20250616",
        "fullstartdate": "202506162200",
        "enddate": "20250617",
        "url": "/th?id=OHR.CumberlandOaks_ES-ES0192371070_1920x1080.jpg&rf=LaDigue_1920x1080.jpg&pid=hp",
        "urlbase": "/th?id=OHR.CumberlandOaks_ES-ES0192371070",
        "copyright": "Bosque marítimo en la Costa Nacional de la Isla Cumberland, Georgia, EE. UU. (© Chris Moore/TANDEM Stills + Motion)",
        "copyrightlink": "https://www.bing.com/search?q=Costa+Nacional+de+la+Isla+Cumberland&form=hpcapt&filters=HpDate%3a%2220250616_2200%22",
        "title": "Un bosque encantado",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20250616_CumberlandOaks%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "81a4e46d39d0b1a0c420f4be008ac4a1",
        "hsh": "1fecab5e5de5b058b0e9bd3ecc2c099a",
        "drk": 1,
        "top": 1,
        "bot": 1,
        "hs": [],
        "MediaContent": {
            "ImageContent": {
                "Description": "Antes de llegar a la playa, lo oirás: el susurro de las hojas movidas por la brisa salada, el crujir de troncos retorcidos y el silencio de un mundo antiguo. Bienvenido al bosque marítimo de la Isla Cumberland, en la costa atlántica de Georgia, Estados Unidos, uno de los últimos de su tipo en el país. Los robles vivos se doblan con los vientos huracanados, pero no se rompen. A su sombra crecen palmitos enanos como si fueran guardianes verdes, y del ramaje cuelga musgo español, llamado así porque recuerda a las barbas de los conquistadores. Este detalle conecta, curiosamente, con la historia de España en América.",
                "Image": {
                    "Url": "/th?id=OHR.CumberlandOaks_ES-ES0192371070_1920x1080.webp",
                    "Wallpaper": "/th?id=OHR.CumberlandOaks_ES-ES0192371070_1920x1200.jpg&rf=LaDigue_1920x1200.jpg",
                    "Downloadable": true
                },
                "Headline": "Un bosque encantado",
                "Title": "Bosque marítimo en la Costa Nacional de la Isla Cumberland, Georgia, EE. UU.",
                "Copyright": "© Chris Moore/TANDEM Stills + Motion",
                "SocialGood": null,
                "MapLink": {
