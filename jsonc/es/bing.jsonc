        "copyright": "Bahía Esmeralda e isla Fannette, lago Tahoe, California, EE. UU. (© Bill Stevenson/Cavan Images)",
        "copyrightlink": "https://www.bing.com/search?q=Isla+Fannette&form=hpcapt&filters=HpDate%3a%2220260202_2300%22",
        "title": "Donde el tiempo se detiene",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260202_FanetteIsland%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "cd28269de13c8d65e4288614d55b72d7",
