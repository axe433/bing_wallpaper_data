        "copyrightlink": "https://www.bing.com/search?q=Hongos+laccaria+de+amatista&form=hpcapt&filters=HpDate%3a%2220251014_2200%22",
        "title": "Los sabrosos del bosque",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251014_AmethystLaccaria%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "baa5e18a85066ca55e1f14593675ca5e",
