        "copyright": "Iglesia de San Gregorio en las ruinas de Ani, Kars, Turquía (© Kenan Talas/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Ani+en+Kars+Turqu%C3%ADa&form=hpcapt&filters=HpDate%3a%2220251228_2300%22",
        "title": "Caminos de la historia",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251228_AniTurkey%22&FORM=HPQUIZ",
        "wp": true,
        "md5": "9d286e3de8d9ea60a6bd59483b760e17",
