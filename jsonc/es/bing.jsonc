        "copyright": "Flores de crocus púrpuras, Siete Lagos de Rila, Bulgaria (© Maya Karkalicheva/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Siete+Lagos+de+Rila+Bulgaria&form=hpcapt&filters=HpDate%3a%2220260303_2300%22",
        "title": "Los crocus en el punto de mira",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20260303_RilaCrocuses%22&FORM=HPQUIZ",
        "wp": true,
