        "copyright": "Puerta gótica en las rocas de Adršpach-Teplice, Bohemia, República Checa (© Kseniya_Milner/Getty Images)",
        "copyrightlink": "https://www.bing.com/search?q=Rocas+Adr%C5%A1pach+Teplice&form=hpcapt&filters=HpDate%3a%2220251027_2300%22",
        "title": "Entrada al paraíso rocoso",
        "quiz": "/search?q=Bing+homepage+quiz&filters=WQOskey:%22HPQuiz_20251027_TepliceRocks%22&FORM=HPQUIZ",
        "wp": true,
