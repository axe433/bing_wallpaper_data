{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-06T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"If your screen time has been winning lately, today is a good time to change that—we suggest hiking. National Trails Day was created in 1993 by the American Hiking Society. It is marked in the United Kingdom as well on the first Saturday in June, where organisations across England and Wales nudge people towards exploring trails.","Image":{"Url":"/th?id=OHR.HikingNatchez_EN-GB9388336824_1920x1080.webp","Wallpaper":"/th?id=OHR.HikingNatchez_EN-GB9388336824_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Wander often, wonder more","Title":"Natchez Trace Parkway, Tupelo, Mississippi, United States","Copyright":"© The best photo is earned/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/31.54333,-91.38306/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=31.54333,-91.38306;S9;Natchez Trace Parkway, Tupelo, Mississippi, United States&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260606_HikingNatchez\"&FORM=HPQUIZ","BackstageUrl":"/search?q=National+Trails+Day&form=hpcapt&filters=HpDate:\"20260605_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260606_HikingNatchez"},"Ssd":"20260606","Name":"HikingNatchez","Market":"EN-GB","Hash":"9388336824","FullDateString":"6 Jun 2026"},{"ImageContent":{"Description":"If nature had a 'do not disturb' sign, it would hang over Sarek National Park, often called 'the last European wilderness.' On World Environment Day, this remote corner of Swedish Lapland reminds us what the planet looks like when humans take a step back—and let the wild take the lead.","Image":{"Url":"/th?id=OHR.WedLapland_EN-GB9256196437_1920x1080.webp","Wallpaper":"/th?id=OHR.WedLapland_EN-GB9256196437_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The quiet power of an unclaimed world","Title":"View from Skierffe Mountain over the Rapadalen river delta, Sarek National Park, Laponia, Lapland, Sweden","Copyright":"© Robert Haasmann/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/67.28834,17.66914/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=67.28834,17.66914;S9;Sarek National Park, Laponia, Lapland, Sweden&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260605_WedLapland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=World+Environment+Day&form=hpcapt&filters=HpDate:\"20260604_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260605_WedLapland"},"Ssd":"20260605","Name":"WedLapland","Market":"EN-GB","Hash":"9256196437","FullDateString":"5 Jun 2026"},{"ImageContent":{"Description":"Poetic name, poetic appearance. Meet the snowy egret, whose all-white plumage and bright yellow 'slippers' on black legs give it a striking look. Once nearly wiped out by demand for its delicate breeding-season feathers—soft, lacy plumes prized for fashionable hats—conservation efforts saved its plumage.","Image":{"Url":"/th?id=OHR.PreeningEgret_EN-GB9120612883_1920x1080.webp","Wallpaper":"/th?id=OHR.PreeningEgret_EN-GB9120612883_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Fancy feathers","Title":"Snowy egret preening, central Florida, United States","Copyright":"© Donald M. Jones/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Snowy egrets often feed alongside herons, benefiting from the movement that stirs hidden prey into view.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260604_PreeningEgret\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Snowy+egret&form=hpcapt&filters=HpDate:\"20260603_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260604_PreeningEgret"},"Ssd":"20260604","Name":"PreeningEgret","Market":"EN-GB","Hash":"9120612883","FullDateString":"4 Jun 2026"},{"ImageContent":{"Description":"Your average route to work might not resemble the one in today's image, but it shouldn't stop you from pedalling. World Bicycle Day invites us to rethink what's possible on two wheels—whether the ride cuts through city streets or remote terrain. Observed every 3 June, the United Nations–backed day recognises cycling as a practical way to move, supporting health, lowering emissions and making mobility more accessible.","Image":{"Url":"/th?id=OHR.BardenasReales_EN-GB8956577575_1920x1080.webp","Wallpaper":"/th?id=OHR.BardenasReales_EN-GB8956577575_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Where the road stops, the ride begins","Title":"Cyclist in Bardenas Reales Natural Park and Biosphere Reserve, Navarra, Spain","Copyright":"© Artur Debat/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/42.210213,-1.515728/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=42.210213,-1.515728;S9;Las Bardenas Reales, Navarra, Spain&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260603_BardenasReales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=World+Bicycle+Day&form=hpcapt&filters=HpDate:\"20260602_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260603_BardenasReales"},"Ssd":"20260603","Name":"BardenasReales","Market":"EN-GB","Hash":"8956577575","FullDateString":"3 Jun 2026"},{"ImageContent":{"Description":"Cutting a surreal path through the high-altitude deserts of western China, Xitai Jinaier Lake (also known as West Taijinar Lake) is a striking salt lake in the remote Qaidam Basin. A stretch of National Highway 315 runs directly across its shallow waters, creating the illusion of a road floating between two worlds. On one side, the water often appears deep blue; on the other, a softer green hue, a contrast shaped by differing mineral concentrations in the brine.","Image":{"Url":"/th?id=OHR.Qinghai_EN-GB8807388585_1920x1080.webp","Wallpaper":"/th?id=OHR.Qinghai_EN-GB8807388585_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Between the blues","Title":"Highway through Xitai Jinaier Lake, Qinghai Province, China","Copyright":"© Kaicheng Xu/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.668594,96.043144/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=35.668594,96.043144;S9;Qinghai Province, China&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260602_Qinghai\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Qaidam+Basin+China&form=hpcapt&filters=HpDate:\"20260601_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260602_Qinghai"},"Ssd":"20260602","Name":"Qinghai","Market":"EN-GB","Hash":"8807388585","FullDateString":"2 Jun 2026"},{"ImageContent":{"Description":"Palermo, the capital of the island of Sicily in southern Italy, is a city where layers of history, art and culture meet in a vivid and sometimes chaotic harmony. Founded by the Phoenicians and later shaped by Romans, Arabs, Normans and Spaniards, it carries traces of many civilisations that passed through the Mediterranean. This rich past is visible in its architecture, from the Arab-Norman palaces and churches recognised by UNESCO to the Baroque facades that define its historic streets.","Image":{"Url":"/th?id=OHR.OlivaPalermo_EN-GB8668911302_1920x1080.webp","Wallpaper":"/th?id=OHR.OlivaPalermo_EN-GB8668911302_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Flavours of history","Title":"Palermo skyline, Sicily, Italy","Copyright":"© Sean Pavone/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.121254,13.359494/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=38.121254,13.359494;S9;Palermo, Sicily, Italy&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260601_OlivaPalermo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Palermo&form=hpcapt&filters=HpDate:\"20260531_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260601_OlivaPalermo"},"Ssd":"20260601","Name":"OlivaPalermo","Market":"EN-GB","Hash":"8668911302","FullDateString":"1 Jun 2026"},{"ImageContent":{"Description":"Wetlands don't shout for attention–they flow quietly, shaping entire landscapes. Few places prove their power like Everglades National Park in the United States. From above, Florida's famous 'River of Grass' unfolds as a vast patchwork of shallow water, sawgrass, mangroves and winding channels, shaped by freshwater slowly flowing south from Lake Okeechobee. It's also the only place on Earth where American alligators and American crocodiles share space, each sticking to their preferred waters.","Image":{"Url":"/th?id=OHR.EvergladesWetlands_EN-GB2174930094_1920x1080.webp","Wallpaper":"/th?id=OHR.EvergladesWetlands_EN-GB2174930094_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Follow the flow","Title":"Aerial view of Everglades National Park, Florida, United States","Copyright":"© Tetra Images/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.286623,-80.898659/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=25.286623,-80.898659;S9;Everglades National Park, Florida, United States&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260531_EvergladesWetlands\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Everglades+National+Park&form=hpcapt&filters=HpDate:\"20260530_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260531_EvergladesWetlands"},"Ssd":"20260531","Name":"EvergladesWetlands","Market":"EN-GB","Hash":"2174930094","FullDateString":"31 May 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Every June, London swaps its traffic noise for drumbeats, marching soldiers and horses trotting with clockwork precision. Trooping the Colour is the royal birthday parade where scarlet uniforms steal the spotlight and every polished boot seems to shine on cue.","Image":{"Url":"/th?id=OHR.TroopingTheColour2026_EN-GB9412651820_1920x1080.webp","Wallpaper":"/th?id=OHR.TroopingTheColour2026_EN-GB9412651820_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Marching to the royal beat","Title":"Members of the Household Cavalry Mounted Regiment at Hyde Park, London","Copyright":"© Leon Neal/Staff/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.507418,-0.164143/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=51.507418,-0.164143;S9;Hyde Park, London&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260613_TroopingTheColour2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Trooping+the+Colour&form=hpcapt&filters=HpDate:\"20260612_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260613_TroopingTheColour2026"},"Ssd":"20260613","Name":"TroopingTheColour2026","Market":"EN-GB","Hash":"9412651820","FullDateString":"13 Jun 2026"},{"ImageContent":{"Description":"A streak of colour glides past a blur of wildflowers as a European bee-eater cuts through the air. Turquoise, gold and chestnut shimmer across its wings as it hunts in flight, snatching insects mid-air with swift turns. Bees and wasps are among its favoured prey, and the bird often removes the stinger before feeding—a behaviour that reduces the risk of injury.","Image":{"Url":"/th?id=OHR.SpainBeeEater_EN-GB0400736039_1920x1080.webp","Wallpaper":"/th?id=OHR.SpainBeeEater_EN-GB0400736039_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"A flash in flight","Title":"European bee-eater in Sierra de Grazalema Natural Park, Cádiz, Spain","Copyright":"© Andres M. Dominguez/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/36.74794,-5.371703/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=36.74794,-5.371703;S9;Sierra de Grazalema Natural Park, Cádiz, Spain&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260612_SpainBeeEater\"&FORM=HPQUIZ","BackstageUrl":"/search?q=European+bee-eater&form=hpcapt&filters=HpDate:\"20260611_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260612_SpainBeeEater"},"Ssd":"20260612","Name":"SpainBeeEater","Market":"EN-GB","Hash":"0400736039","FullDateString":"12 Jun 2026"},{"ImageContent":{"Description":"Tucked away beneath steep cliffs near Cabo da Roca, the westernmost point of mainland Europe, Praia da Ursa feels like the edge of the continent. Reached by a narrow, rugged trail, this secluded beach along Portugal's Atlantic coast is shaped largely by wind, stone and powerful waves. When the tide recedes, the shoreline briefly widens. Smooth rocks emerge, and with them, small signs of life. Limpets cling tightly to the exposed stone, holding fast where the ocean usually breaks.","Image":{"Url":"/th?id=OHR.Limpets_EN-GB0252915957_1920x1080.webp","Wallpaper":"/th?id=OHR.Limpets_EN-GB0252915957_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Quiet strength","Title":"Limpets exposed at low tide on the coast of Praia da Ursa, Portugal","Copyright":"© Theo Bosboom/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.790765,-9.492425/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=38.790765,-9.492425;S9;Praia da Ursa, Sintra, Portugal&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260611_Limpets\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Praia+da+Ursa+Portugal&form=hpcapt&filters=HpDate:\"20260610_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260611_Limpets"},"Ssd":"20260611","Name":"Limpets","Market":"EN-GB","Hash":"0252915957","FullDateString":"11 Jun 2026"},{"ImageContent":{"Description":"From above, the lake's smooth surface contrasts sharply with the rugged ground surrounding it. Hnausapollur crater lake—also known as Bláhylur—lies in the heart of Fjallabak Nature Reserve, a remote area of Iceland's highlands shaped more by volcanic activity than by human settlement. The crater formed when magma met groundwater, triggering an explosion that carved out the circular basin visible today.","Image":{"Url":"/th?id=OHR.Hnausapollur_EN-GB0108881813_1920x1080.webp","Wallpaper":"/th?id=OHR.Hnausapollur_EN-GB0108881813_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"A splash of blue","Title":"Hnausapollur volcanic crater lake, Fjallabak Nature Reserve, Landmannalaugar, Iceland","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/64.055313,-19.031654/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=64.055313,-19.031654;S9;Hnausapollur, Iceland&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260610_Hnausapollur\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Hnausapollur+Iceland&form=hpcapt&filters=HpDate:\"20260609_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260610_Hnausapollur"},"Ssd":"20260610","Name":"Hnausapollur","Market":"EN-GB","Hash":"0108881813","FullDateString":"10 Jun 2026"},{"ImageContent":{"Description":"Vernazza is a small seaside town in Cinque Terre, in Italy's Liguria region. Built around the area's only natural harbour, it has long been tied to the sea. First recorded in 1080 as a fortified settlement and maritime base, it later became part of the Republic of Genoa's coastal defences. To this day, the village preserves its past in the ruins of Doria Castle and the watchtowers overlooking the bay. At the water's edge stands the Church of Santa Margherita d'Antiochia, first mentioned in 1318 and expanded in later centuries, with a bell tower overlooking the port. Above the houses and narrow lanes, steep terraces support vineyards and olive groves, shaped by generations of stonework in a landscape protected within Cinque Terre National Park, part of a UNESCO World Heritage Site. Picture an aperitivo here: a glass of local white wine, the harbour in view and Ligurian favourites like focaccia and basil pesto—basically a postcard you can taste.","Image":{"Url":"/th?id=OHR.CTNPVernazza_EN-GB9932633613_1920x1080.webp","Wallpaper":"/th?id=OHR.CTNPVernazza_EN-GB9932633613_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Taste the sunset","Title":"Vernazza, Cinque Terre, Liguria, Italy","Copyright":"© Kelly Cheng/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/44.135512,9.681952/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=44.135512,9.681952;S9;Vernazza, Liguria, Italy&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260609_CTNPVernazza\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Vernazza+Cinque+Terre+Liguria+Italy&form=hpcapt&filters=HpDate:\"20260608_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260609_CTNPVernazza"},"Ssd":"20260609","Name":"CTNPVernazza","Market":"EN-GB","Hash":"9932633613","FullDateString":"9 Jun 2026"},{"ImageContent":{"Description":"Today is World Oceans Day, so follow the lead of a creature that goes wherever the water takes it. Want to spot a lion's mane jellyfish? Look in cold northern seas. Its bell is split into eight lobes, and beneath it hang long tentacles and oral arms. As it drifts with the current, stinging cells snare plankton and small fish. For humans, the sting can be painful. Reactions vary, and even a washed-up tentacle can still hurt. The rule is simple: admire it, then leave it alone. Some lion's manes in Arctic waters have bells more than 1.8 metres across, but most sightings are smaller animals near shore after storms or strong currents.","Image":{"Url":"/th?id=OHR.Cyanea_EN-GB9769682227_1920x1080.webp","Wallpaper":"/th?id=OHR.Cyanea_EN-GB9769682227_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Drift with the current","Title":"Lion's mane jellyfish swimming in the ocean","Copyright":"© Alexander Semenov Images/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Though mostly water, the lion's mane jellyfish can reach more than 36 metres in length—surpassing even the blue whale.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260608_Cyanea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=World+Oceans+Day&form=hpcapt&filters=HpDate:\"20260607_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260608_Cyanea"},"Ssd":"20260608","Name":"Cyanea","Market":"EN-GB","Hash":"9769682227","FullDateString":"8 Jun 2026"},{"ImageContent":{"Description":"At Dunseverick Castle, history hangs on—literally. Wall fragments cling to a basalt stack above the Atlantic, proving that even ruins can hold their ground. Two thousand years ago, it marked the end of the Slige Midluachra, one of Ireland's five great roads, linking travellers to the royal seat at Hill of Tara. In the 5th century, Saint Patrick is said to have visited and baptised a local man, Olcán, here. Tradition holds that the Lia Fáil (Stone of Destiny), used for crowning Irish kings, was taken from this shore for Scotland.","Image":{"Url":"/th?id=OHR.DunseverickCastle2026_EN-GB9557094817_1920x1080.webp","Wallpaper":"/th?id=OHR.DunseverickCastle2026_EN-GB9557094817_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The last wall standing","Title":"Ruins of Dunseverick Castle, County Antrim, Northern Ireland","Copyright":"© Krzysztof Rogalski/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/55.238358,-6.448198/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-GB&od=2&shading=flat&pp=55.238358,-6.448198;S9;Dunseverick Castle, Northern Ireland&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260607_DunseverickCastle2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Dunseverick+Castle&form=hpcapt&filters=HpDate:\"20260606_2300\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260607_DunseverickCastle2026"},"Ssd":"20260607","Name":"DunseverickCastle2026","Market":"EN-GB","Hash":"9557094817","FullDateString":"7 Jun 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Image of the day","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Learn more","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donate now","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Quick fact:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Recent Homepage images","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage image for {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"On this day in history","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"On this day in {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Share today's Bing homepage","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Download this image. Use of this image is restricted to wallpaper only.","LOC_MUSCARD_DOWNLOAD_LINK":"Download this image","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"This image is not available to download as wallpaper.","LOC_HOMEPAGE_