{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-07T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Owls are full of contradictions. Silent wings, loud opinions. They are night hunters that somehow feel ancient. From myths to cartoons, they have always had a presence. Athena's owl symbolised wisdom, while pop culture gave us lines we still quote—remember Owl from 'Winnie-the-Pooh' always sounding sure of himself?","Image":{"Url":"/th?id=OHR.OwlonGuard_ROW4856156035_1920x1080.webp","Wallpaper":"/th?id=OHR.OwlonGuard_ROW4856156035_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Snowy owl near the Canadian Rockies, Canada","Copyright":"© www.harshadventure.com/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260307_OwlonGuard\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Snowy+owl&form=hpcapt&filters=HpDate:\"20260307_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260307_OwlonGuard"},"Ssd":"20260307","Name":"OwlonGuard","Market":"ROW","Hash":"4856156035","FullDateString":"7 Mar 2026"},{"ImageContent":{"Description":"Architecture blends art and technology, expressed through the built form. While many designs focus primarily on function, some buildings give equal weight to visual impact. A strong example is The Wave building complex in Vejle, Denmark, where sculptural design and practical housing come together seamlessly.","Image":{"Url":"/th?id=OHR.WaveDenmark_ROW5073761456_1920x1080.webp","Wallpaper":"/th?id=OHR.WaveDenmark_ROW5073761456_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"The Wave residential building, Vejle, Denmark","Copyright":"© Frank Bach/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260306_WaveDenmark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=The+Wave+building+Vejle+Denmark&form=hpcapt&filters=HpDate:\"20260306_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260306_WaveDenmark"},"Ssd":"20260306","Name":"WaveDenmark","Market":"ROW","Hash":"5073761456","FullDateString":"6 Mar 2026"},{"ImageContent":{"Description":"As evening settles over the town of Göreme in the heart of the Cappadocia region of Türkiye, dusk reveals a landscape forged by nature and centuries of human presence. This scene is part of Göreme National Park and the Rock Sites of Cappadocia, a UNESCO World Heritage Site inscribed in 1985 for its exceptional combination of early cultural history and geological formations. These formations, often called 'fairy chimneys' or hoodoos, began as layers of volcanic ash that hardened into soft stone following eruptions of ancient Anatolian volcanoes. Over time, wind and water carved the pillars, ridges and valleys that define the region today.","Image":{"Url":"/th?id=OHR.GoremeTwilight_ROW5000170185_1920x1080.webp","Wallpaper":"/th?id=OHR.GoremeTwilight_ROW5000170185_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Göreme, Cappadocia, Türkiye","Copyright":"© ONNAJA/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260305_GoremeTwilight\"&FORM=HPQUIZ","BackstageUrl":"/search?q=G%c3%b6reme+T%c3%bcrkiye&form=hpcapt&filters=HpDate:\"20260305_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260305_GoremeTwilight"},"Ssd":"20260305","Name":"GoremeTwilight","Market":"ROW","Hash":"5000170185","FullDateString":"5 Mar 2026"},{"ImageContent":{"Description":"As winter's grip on the Rila Mountains of southwestern Bulgaria begins to loosen, crocuses push through the thinning snow, signalling the arrival of spring in the country's highest mountain range. These early bloomers use stored nutrients to quickly grow in cold conditions, completing much of their life cycle before taller plants emerge. Their clustered blossoms unfurl over alpine meadows in sweeping purple ribbons, creating a striking contrast with bright snowfields and crisp morning light.","Image":{"Url":"/th?id=OHR.RilaCrocuses_ROW4635215657_1920x1080.webp","Wallpaper":"/th?id=OHR.RilaCrocuses_ROW4635215657_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Purple crocus flowers, Seven Rila Lakes, Bulgaria","Copyright":"© Maya Karkalicheva/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260304_RilaCrocuses\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Seven+Rila+Lakes+Bulgaria&form=hpcapt&filters=HpDate:\"20260304_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260304_RilaCrocuses"},"Ssd":"20260304","Name":"RilaCrocuses","Market":"ROW","Hash":"4635215657","FullDateString":"4 Mar 2026"},{"ImageContent":{"Description":"Our well-being is deeply connected to the natural world. Medicinal and aromatic plants (MAPs)—species used in traditional healing, modern medicine, cosmetics and food—play a vital role in daily life across the globe. An estimated 50,000 to 70,000 MAP species are harvested worldwide, with 70–95% of people in many developing countries relying on them for primary health care. Yet many of these plants face growing threats from habitat loss, overharvesting and illegal trade, making sustainable use essential for their future.","Image":{"Url":"/th?id=OHR.BabyElephant_ROW4423597871_1920x1080.webp","Wallpaper":"/th?id=OHR.BabyElephant_ROW4423597871_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"African elephant calf playing with its mother, Masai Mara National Reserve, Kenya","Copyright":"© Denis-Huot/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260303_BabyElephant\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Masai+Mara+National+Reserve&form=hpcapt&filters=HpDate:\"20260303_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260303_BabyElephant"},"Ssd":"20260303","Name":"BabyElephant","Market":"ROW","Hash":"4423597871","FullDateString":"3 Mar 2026"},{"ImageContent":{"Description":"Do not be fooled by how simple Ko Samui's longtail boats look from a distance; decades of local ingenuity have shaped their slender frames. These vessels, known in Thailand as 'ruea hang yao,' emerged in the early 20th century, when fishermen repurposed vehicle engines to navigate shallow waters that larger boats couldn't reach. Handcrafted plank by plank, each boat reflects generations of skill. Their hulls burst with bold, striking colours, while decorative cloth and flowers often crown the bows—Buddhist blessings meant to safeguard both the boat and its crew.","Image":{"Url":"/th?id=OHR.SamuiThailand_ROW4256574976_1920x1080.webp","Wallpaper":"/th?id=OHR.SamuiThailand_ROW4256574976_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Harbour and longtail boats at Ko Samui, Thailand","Copyright":"© Foto2rich/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260302_SamuiThailand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Ko+Samui+Thailand&form=hpcapt&filters=HpDate:\"20260302_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260302_SamuiThailand"},"Ssd":"20260302","Name":"SamuiThailand","Market":"ROW","Hash":"4256574976","FullDateString":"2 Mar 2026"},{"ImageContent":{"Description":"Today we celebrate the stunning Spanish islands of the Balearic archipelago. This diverse and deeply Mediterranean territory includes Mallorca, Menorca, Ibiza and Formentera, each shaped by centuries of history and a close relationship with the sea.","Image":{"Url":"/th?id=OHR.BalearesDay_ROW4071522082_1920x1080.webp","Wallpaper":"/th?id=OHR.BalearesDay_ROW4071522082_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Ibiza, Balearic Islands, Spain","Copyright":"© tokar/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260301_BalearesDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Ibiza+city&form=hpcapt&filters=HpDate:\"20260301_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260301_BalearesDay"},"Ssd":"20260301","Name":"BalearesDay","Market":"ROW","Hash":"4071522082","FullDateString":"1 Mar 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Time has altered the land around it, but Lanyon Quoit in Cornwall, England, still commands attention. Built in the Neolithic period, 'The Giant's Table' offers a rare chance to consider how early settlers marked their presence. Formed by upright stones holding a massive capstone of about 13,000 kilograms, the monument likely served as a communal burial chamber.","Image":{"Url":"/th?id=OHR.CornwallDolmen_ROW3459140266_1920x1080.webp","Wallpaper":"/th?id=OHR.CornwallDolmen_ROW3459140266_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Lanyon Quoit, a Neolithic dolmen in Cornwall, England","Copyright":"© Helen Hotson/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260314_CornwallDolmen\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Lanyon+Quoit&form=hpcapt&filters=HpDate:\"20260314_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260314_CornwallDolmen"},"Ssd":"20260314","Name":"CornwallDolmen","Market":"ROW","Hash":"3459140266","FullDateString":"14 Mar 2026"},{"ImageContent":{"Description":"Silence on the water often means something special is happening—have you noticed how swans seem to turn lakes into slow-moving classrooms? A mute swan glides across calm water with its cygnets in Hesse, Germany. This scene is common across European lakes and river landscapes, from Lake Constance and the Mecklenburg Lake District to restored river channels in many towns and cities. These waterways provide sheltered shorelines and abundant aquatic plants, the swan's primary food source.","Image":{"Url":"/th?id=OHR.SwanHesse_ROW3213322861_1920x1080.webp","Wallpaper":"/th?id=OHR.SwanHesse_ROW3213322861_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Mute swan with chicks, Hesse, Germany","Copyright":"© Wilfried Martin/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260313_SwanHesse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Mute+swan&form=hpcapt&filters=HpDate:\"20260313_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260313_SwanHesse"},"Ssd":"20260313","Name":"SwanHesse","Market":"ROW","Hash":"3213322861","FullDateString":"13 Mar 2026"},{"ImageContent":{"Description":"High in Ecuador's cloud forests, a young sunbittern spreads its wings in an early display, casting flashes of orange, black and white through the filtered green light. The sudden contrast cuts through the moss‑covered branches and leaf‑shadowed understorey, offering a snapshot of the species' dramatic wing patterns. Adult sunbitterns most often show these bold markings during defensive displays, briefly transforming an elusive bird into a striking spectacle.","Image":{"Url":"/th?id=OHR.SunbitternEcuador_ROW2999974301_1920x1080.webp","Wallpaper":"/th?id=OHR.SunbitternEcuador_ROW2999974301_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Juvenile sunbittern displaying at nest, Ecuador","Copyright":"© Andy Rouse/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260312_SunbitternEcuador\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sunbittern+bird&form=hpcapt&filters=HpDate:\"20260312_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260312_SunbitternEcuador"},"Ssd":"20260312","Name":"SunbitternEcuador","Market":"ROW","Hash":"2999974301","FullDateString":"12 Mar 2026"},{"ImageContent":{"Description":"Spring hits differently in Cieza. It doesn't gently unfold—it erupts with colour. Between February and March, this small city in Spain's Murcia region is the epicentre of 'La Floración,' the flowering of peach trees. In a matter of days, more than 4,850 hectares—Spain's largest municipal peach production—transform into a sea of colour we see in today's image.","Image":{"Url":"/th?id=OHR.PeachBloom_ROW2817467939_1920x1080.webp","Wallpaper":"/th?id=OHR.PeachBloom_ROW2817467939_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Peach trees in bloom, Cieza, Murcia, Spain","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260311_PeachBloom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Cieza+Spain&form=hpcapt&filters=HpDate:\"20260311_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260311_PeachBloom"},"Ssd":"20260311","Name":"PeachBloom","Market":"ROW","Hash":"2817467939","FullDateString":"11 Mar 2026"},{"ImageContent":{"Description":"Have you ever wondered what happens when fire, ice and time negotiate the same territory? Iceland's Hveravellir geothermal field has the answer. In this highland hotspot, energy from the Earth's interior meets the icy surface, triggering a volatile dialogue between pressure, temperature and stone. Fumaroles hiss, steam curls into the air and the ground paints itself with sulphur whites, rust reds and ochre yellows—not only artistry, but chemical reactions driven by extreme heat. In today's image, Bláhver, a natural hot spring, dazzles in electric blue. Its colour comes from mineral- and silica-rich waters that reflect light on the surface.","Image":{"Url":"/th?id=OHR.SpringIceland_ROW2538267892_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringIceland_ROW2538267892_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Geothermal blue pool Bláhver at Hveravellir, Iceland","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260310_SpringIceland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Blahver+pool+Iceland&form=hpcapt&filters=HpDate:\"20260310_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260310_SpringIceland"},"Ssd":"20260310","Name":"SpringIceland","Market":"ROW","Hash":"2538267892","FullDateString":"10 Mar 2026"},{"ImageContent":{"Description":"Not all wildlife moments are dramatic—some unfold in perfect stillness. The grey seal resting on the shores of the Orkney Islands, Scotland, is a perfect example. Grey seals are among the UK's largest native marine mammals, with the country supporting around 40% of the world's population. Despite their size, they are remarkably adaptable sleepers. Rather than settling into one long stretch, grey seals nap in short, flexible bursts shaped by their surroundings.","Image":{"Url":"/th?id=OHR.NappingSeal_ROW2198134616_1920x1080.webp","Wallpaper":"/th?id=OHR.NappingSeal_ROW2198134616_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Grey seal sleeping on the beach, Orkney Islands, Scotland","Copyright":"© Andrew Mason/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260309_NappingSeal\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Grey+seal&form=hpcapt&filters=HpDate:\"20260309_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260309_NappingSeal"},"Ssd":"20260309","Name":"NappingSeal","Market":"ROW","Hash":"2198134616","FullDateString":"9 Mar 2026"},{"ImageContent":{"Description":"Imagine reaching the Brocken in Harz National Park, Germany, as clouds slide across the ridge. With the sun behind you, mist ahead—then a giant, haloed shadow forms. Ever wondered why climbers once feared this sight? The phenomenon, called the Brocken spectre, is an eerie natural optical effect that occurs when sunlight projects a person's shadow onto cloud or fog. Rising about 1,141 metres, the Brocken is the highest peak in northern Germany and has long inspired folklore, including tales of witches gathering here during Walpurgis Night.","Image":{"Url":"/th?id=OHR.BrockenSunrise_ROW5181265545_1920x1080.webp","Wallpaper":"/th?id=OHR.BrockenSunrise_ROW5181265545_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Sunrise on the Brocken, Harz National Park, Germany","Copyright":"© imageBROKER/AVTG/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260308_BrockenSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Harz+National+Park&form=hpcapt&filters=HpDate:\"20260308_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260308_BrockenSunrise"},"Ssd":"20260308","Name":"BrockenSunrise","Market":"ROW","Hash":"5181265545","FullDateString":"8 Mar 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Image of the day","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Learn more","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donate now","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Quick fact:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Recent Homepage images","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage image for {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"On this day in history","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"On this day in {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Share today's Bing homepage","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Download this image. Use of this image is restricted to wallpaper only.","LOC_MUSCARD_DOWNLOAD_LINK":"Download this image","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"This image is not available to download as wallpaper.","LOC_HOMEPAGE_INFO_TEXT":"Info","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Get the Bing Wallpaper app","LOC_BING_APP_TEXT":"Get Bing Wallpaper on your devices","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adjust=nk9xri2_dzfz5n2","LOC_BING_APP_LINK_MOBILE":"https://app.adjust.com/d93ddtl_a75k0gg?deeplink=sapphire%3A%2F%2Fwallpaper","LOC_BING_APP_DOWNLOAD_TEXT":"Mobile App","LOC_BING_WP_APP_DOWNLOAD_TEXT":"Desktop App","LOC_BING_APP_TEXT_MOBILE":"Get daily photos with Bing App","LOC_BING_APP_DOWNLOAD_TEXT_MOBILE":"Get","LOC_HOMEPAGE_VERTICAL_SCROLL_TOB":"Trending on Bing","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB":"Trending on Bing","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_NEXT":"Next","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_Close":"Hide trending on Bing","LOC_HOMEPAGE_TOB_