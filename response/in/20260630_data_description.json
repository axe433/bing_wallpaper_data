{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-30T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"As the sun sinks low in the Masai Mara National Reserve, the silhouettes of Masai giraffes rise against a blazing sky and open plains. Another day comes to an end in the reserve, which stretches across about 1,500 square kilometres in southwestern Kenya, bordering Tanzania's Serengeti National Park. It is a vast expanse, one of the world's greatest wildlife arenas. Rolling grasslands, scattered acacia trees and the life-giving Mara River set the stage for unforgettable encounters.","Image":{"Url":"/th?id=OHR.MasaiGiraffe_EN-IN0088128873_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiGiraffe_EN-IN0088128873_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Where shadows stretch tall","Title":"Giraffes at sunset in the Masai Mara National Reserve, Kenya","Copyright":"© danm/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-1.529493,35.170876/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=-1.529493,35.170876;S9;Masai Mara National Reserve, Kenya&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260630_MasaiGiraffe\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Masai+Mara+National+Reserve&form=hpcapt&filters=HpDate:\"20260629_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260630_MasaiGiraffe"},"Ssd":"20260630","Name":"MasaiGiraffe","Market":"EN-IN","Hash":"0088128873","FullDateString":"30 Jun, 2026"},{"ImageContent":{"Description":"Observed each 29 June, the International Day of the Tropics spotlights a vast region stretching between the Tropics of Cancer and Capricorn, where warmth and rainfall shape daily life. This zone covers about 40% of Earth's surface area, yet supports around 80% of global biodiversity, making it central to planetary health and culture.","Image":{"Url":"/th?id=OHR.BoraBoraLagoon_EN-IN9424063973_1920x1080.webp","Wallpaper":"/th?id=OHR.BoraBoraLagoon_EN-IN9424063973_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Born on fire, held by water","Title":"Bora Bora and its lagoon, South Pacific, French Polynesia","Copyright":"© Frederick Millett/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-16.498926,-151.73819/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=-16.498926,-151.73819;S9;Bora Bora, French Polynesia&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260629_BoraBoraLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=International+Day+of+the+Tropics&form=hpcapt&filters=HpDate:\"20260628_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260629_BoraBoraLagoon"},"Ssd":"20260629","Name":"BoraBoraLagoon","Market":"EN-IN","Hash":"9424063973","FullDateString":"29 Jun, 2026"},{"ImageContent":{"Description":"'Stick around' takes on a new meaning in the Sonoran Desert, where the saguaro cactus has mastered survival. With trunks and arms raised in all directions, this giant has become the American Southwest's mascot.","Image":{"Url":"/th?id=OHR.SaguaroSun_EN-IN9141839272_1920x1080.webp","Wallpaper":"/th?id=OHR.SaguaroSun_EN-IN9141839272_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Looking sharp","Title":"Saguaro cacti near Windgate Pass, McDowell Range, Arizona, United States","Copyright":"© Eric Mischke/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/33.796104,-111.810696/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=33.796104,-111.810696;S9;Windgate Pass, McDowell Range, Arizona, United States&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260628_SaguaroSun\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Saguaro+cactus&form=hpcapt&filters=HpDate:\"20260627_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260628_SaguaroSun"},"Ssd":"20260628","Name":"SaguaroSun","Market":"EN-IN","Hash":"9141839272","FullDateString":"28 Jun, 2026"},{"ImageContent":{"Description":"At Boneyard Beach within Hunting Island State Park, South Carolina, United States, the first thing you notice is the trees. Then comes the question: why are bleached trunks and exposed roots scattered across the sand like a scene paused midway through collapse? Since the 1980s, Hunting Island has experienced major beach erosion, with some of the highest rates along the US East Coast—reaching up to 9 metres per year in certain areas.","Image":{"Url":"/th?id=OHR.BoneyardBeach_EN-IN2656634065_1920x1080.webp","Wallpaper":"/th?id=OHR.BoneyardBeach_EN-IN2656634065_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The trees that lost ground","Title":"Driftwood on Boneyard Beach, Hunting Island, South Carolina, United States","Copyright":"© Frances/Adobe Stock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/32.40758,-80.445631/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=32.40758,-80.445631;S9;Hunting Island State Park, South Carolina, United States&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260627_BoneyardBeach\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Hunting+Island&form=hpcapt&filters=HpDate:\"20260626_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260627_BoneyardBeach"},"Ssd":"20260627","Name":"BoneyardBeach","Market":"EN-IN","Hash":"2656634065","FullDateString":"27 Jun, 2026"},{"ImageContent":{"Description":"What does a parliament, a clock tower and a giant wheel have in common? They all stand beside the River Thames as if London had carefully staged its icons for dramatic effect.","Image":{"Url":"/th?id=OHR.ThamesSummer_EN-IN8289570374_1920x1080.webp","Wallpaper":"/th?id=OHR.ThamesSummer_EN-IN8289570374_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Current affairs","Title":"The River Thames, London, England","Copyright":"© Daniel Lange/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.50382,-0.121258/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=51.50382,-0.121258;S9;The River Thames, London, Greater London, England&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260626_ThamesSummer\"&FORM=HPQUIZ","BackstageUrl":"/search?q=River+Thames&form=hpcapt&filters=HpDate:\"20260625_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260626_ThamesSummer"},"Ssd":"20260626","Name":"ThamesSummer","Market":"EN-IN","Hash":"8289570374","FullDateString":"26 Jun, 2026"},{"ImageContent":{"Description":"Few squares in Belgium wear history as well as the Grand Place. The surrounding buildings, seen here, began as guild houses, each funded by a specific trade. Brewers, bakers, merchants and craftsmen treated architecture as language, translating work, status and rivalry into stone through reliefs, coats of arms and generous gold leaf. Styles meet without caution. Gothic verticals rise beside Baroque curves, while the Town Hall, older than its neighbours and unapologetically asymmetrical, holds the composition together.","Image":{"Url":"/th?id=OHR.GrandPlace_EN-IN3033098257_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandPlace_EN-IN3033098257_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Square up to history","Title":"Buildings on Grand-Place Square in Brussels, Belgium","Copyright":"© Vladislav Zolotov/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.846851,4.352454/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=50.846851,4.352454;S9;Grand-Place Square, Brussels, Belgium&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_GrandPlace\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Grand+Place+Brussels&form=hpcapt&filters=HpDate:\"20260624_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_GrandPlace"},"Ssd":"20260625","Name":"GrandPlace","Market":"EN-IN","Hash":"3033098257","FullDateString":"25 Jun, 2026"},{"ImageContent":{"Description":"Zoom in on the small transaction that keeps landscapes alive: a butterfly on a yellow flower, sipping nectar. While it feeds, pollen dusts its body and hitches a ride to the next bloom—one of the quiet ways flowering plants reproduce. Pollinators are not only bees. Butterflies, birds, bats, beetles and many others help move pollen, supporting wild plants and many of the fruits and vegetables we eat.","Image":{"Url":"/th?id=OHR.BFPollin_EN-IN2234226266_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_EN-IN2234226266_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Pollen meets wings","Title":"Butterfly pollinating on yellow flower","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Pollinators are responsible for about one out of three bites of food we eat.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Pollinator+Week&form=hpcapt&filters=HpDate:\"20260623_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"EN-IN","Hash":"2234226266","FullDateString":"24 Jun, 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"A bill like a multitool and plumage full of colour—the plate-billed mountain toucan is one of the Andes' most distinctive birds. It lives in the humid mountain forests of Ecuador and southwestern Colombia, perfectly adapted to life high in the canopy.","Image":{"Url":"/th?id=OHR.MountainToucanOrchids_EN-IN1662413935_1920x1080.webp","Wallpaper":"/th?id=OHR.MountainToucanOrchids_EN-IN1662413935_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Colour, craft and canopy life","Title":"Plate-billed mountain toucan with orchids, Ecuador","Copyright":"© Murray Cooper/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"The plate-billed mountain toucan's colourful bill features a pale yellow 'plate,' a rare trait that gives this species its name.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260707_MountainToucanOrchids\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Plate-billed+mountain+toucan&form=hpcapt&filters=HpDate:\"20260706_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260707_MountainToucanOrchids"},"Ssd":"20260707","Name":"MountainToucanOrchids","Market":"EN-IN","Hash":"1662413935","FullDateString":"7 Jul, 2026"},{"ImageContent":{"Description":"Founded by Greek settlers from Corinth around 734 BCE, the Italian city of Syracuse, on the island of Sicily, grew into one of the ancient Mediterranean's great powers and is now part of a UNESCO World Heritage Site, 'Syracuse and the Rocky Necropolis of Pantalica.' It is forever linked to Archimedes, whose genius still shapes its identity, and to Plato, who came to Syracuse hoping philosophy might shape political life. That layered past still feels tangible at Castello Maniace, a seafront fortress built for Holy Roman Emperor Frederick II in the 13th century, which can still be admired today.","Image":{"Url":"/th?id=OHR.SyracuseItaly_EN-IN1535239880_1920x1080.webp","Wallpaper":"/th?id=OHR.SyracuseItaly_EN-IN1535239880_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"A city written in centuries","Title":"Syracuse, Sicily, Italy","Copyright":"© Balate Dorin/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/37.067122,15.285311/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=37.067122,15.285311;S9;Syracuse, Sicily, Italy&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260706_SyracuseItaly\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Syracuse+Sicily&form=hpcapt&filters=HpDate:\"20260705_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260706_SyracuseItaly"},"Ssd":"20260706","Name":"SyracuseItaly","Market":"EN-IN","Hash":"1535239880","FullDateString":"6 Jul, 2026"},{"ImageContent":{"Description":"In southeastern France, on the Valensole Plateau, summer arrives in waves of purple and blue. Valensole—one of the largest plateaus in the region—lies in the Verdon Regional Natural Park between the Durance and Asse valleys, near the Gorges du Verdon and its lakes. From mid-June to early July, depending on altitude and weather, lavender and lavandin bloom and transform the landscape into one of Provence's most recognisable sights. The air carries a sharp, dry and unmistakably Mediterranean scent.","Image":{"Url":"/th?id=OHR.LavenderRows_EN-IN4483122586_1920x1080.webp","Wallpaper":"/th?id=OHR.LavenderRows_EN-IN4483122586_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Sea of purple","Title":"Lavender rows, Plateau de Valensole, Provence, France","Copyright":"© Robert Harding/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.857636,5.974437/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=43.857636,5.974437;S9;Plateau de Valensole, Provence, France&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260705_LavenderRows\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Lavandula&form=hpcapt&filters=HpDate:\"20260704_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260705_LavenderRows"},"Ssd":"20260705","Name":"LavenderRows","Market":"EN-IN","Hash":"4483122586","FullDateString":"5 Jul, 2026"},{"ImageContent":{"Description":"On July 4, the Tour de France begins—perfect timing to spotlight northeastern France and the Alsace village of Kaysersberg. Set along the Weiss River, about 12 kilometres northwest of Colmar, this historic town lies on the eastern slopes of the Vosges Mountains.","Image":{"Url":"/th?id=OHR.KaysersbergVillage_EN-IN4147544931_1920x1080.webp","Wallpaper":"/th?id=OHR.KaysersbergVillage_EN-IN4147544931_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"This is your detour","Title":"Kaysersberg, Alsace, France","Copyright":"© Federica Gentile/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.18747,7.215853/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=48.18747,7.215853;S9;Kaysersberg, France&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260704_KaysersbergVillage\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Kaysersberg+Alsace&form=hpcapt&filters=HpDate:\"20260703_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260704_KaysersbergVillage"},"Ssd":"20260704","Name":"KaysersbergVillage","Market":"EN-IN","Hash":"4147544931","FullDateString":"4 Jul, 2026"},{"ImageContent":{"Description":"In Okayama Prefecture, when humid air settles over a stream, hotaru—Japan's fireflies—begin signalling. On warm, windless evenings, they often start glowing about two hours after sunset under favourable conditions, inviting silence beside water.","Image":{"Url":"/th?id=OHR.FirefliesJapan_EN-IN4315418814_1920x1080.webp","Wallpaper":"/th?id=OHR.FirefliesJapan_EN-IN4315418814_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The poetry of vanishing light","Title":"Fireflies glowing above a stream, Okayama Prefecture, Japan","Copyright":"© tdub303/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/34.822845,133.813507/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=34.822845,133.813507;S9;Fireflies glowing above a stream, Okayama Prefecture, Japan&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260703_FirefliesJapan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Firefly+insect&form=hpcapt&filters=HpDate:\"20260702_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260703_FirefliesJapan"},"Ssd":"20260703","Name":"FirefliesJapan","Market":"EN-IN","Hash":"4315418814","FullDateString":"3 Jul, 2026"},{"ImageContent":{"Description":"At the Temple of Esna, south of Luxor, Egypt, visitors enter a vivid world devoted to Khnum, the ram-headed god believed to have moulded humanity from Nile clay. Built mainly during the Ptolemaic and Roman eras, the temple's surviving hall is supported by 24 towering columns, each carved with intricate reliefs and ritual texts honouring various deities.","Image":{"Url":"/th?id=OHR.TempleEsna_EN-IN3356286000_1920x1080.webp","Wallpaper":"/th?id=OHR.TempleEsna_EN-IN3356286000_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Inside Esna's sacred universe","Title":"Ceiling of the Temple of Esna, Egypt","Copyright":"© Nick Brundle Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.293581,32.556398/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=25.293581,32.556398;S9;Temple of Esna, Egypt&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260702_TempleEsna\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Temple+of+Esna+Egypt&form=hpcapt&filters=HpDate:\"20260701_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260702_TempleEsna"},"Ssd":"20260702","Name":"TempleEsna","Market":"EN-IN","Hash":"3356286000","FullDateString":"2 Jul, 2026"},{"ImageContent":{"Description":"Most rivers spend their lives flowing around obstacles. The Sharavathi River reaches the edge of a cliff and simply jumps. At Jog Falls in Karnataka, the river plunges 253 metres, making it the third-highest waterfall in India.","Image":{"Url":"/th?id=OHR.JogFalls2026_EN-IN2533705121_1920x1080.webp","Wallpaper":"/th?id=OHR.JogFalls2026_EN-IN2533705121_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The art of taking the plunge","Title":"Jog Falls on the Sharavathi River, Shivamogga district, Karnataka","Copyright":"© Amith Nag Photography/Moment/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/14.228129,74.810677/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-IN&od=2&shading=flat&pp=14.228129,74.810677;S9;Jog Falls, Karnataka&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260701_JogFalls2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Jog+Falls&form=hpcapt&filters=HpDate:\"20260630_1830\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260701_JogFalls2026"},"Ssd":"20260701","Name":"JogFalls2026","Market":"EN-IN","Hash":"2533705121","FullDateString":"1 Jul, 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"दिन की छवि","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"अधिक जानें","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"अभी दान दें","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"त्वरित तथ्य:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"हाल ही की मुख पृष्ठ छवियाँ","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} की मुख्य पृष्ठ छवि","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"इतिहास में आज के दिन","LOC_HOMEPAGE_ON_THI