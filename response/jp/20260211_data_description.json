{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-02-11T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"オリンダは、ブラジル北東部ペルナンブコ州にある美しい都市です。16 世紀に築かれた植民都市を基盤に発展し、その後ポルトガル建築やアフリカ系ブラジル文化など、長い年月をかけて育まれた芸術表現が重なり合う歴史都市として知られています。1982 年には「オリンダ歴史地区」としてユネスコ世界遺産に登録されました…","Image":{"Url":"/th?id=OHR.Olinda_JA-JP1273177244_1920x1080.webp","Wallpaper":"/th?id=OHR.Olinda_JA-JP1273177244_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"鮮やかな色で飾られた家","Title":"オリンダ歴史地区, ブラジル","Copyright":"© Robert Pekar/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-7.99186,-34.858752/13?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-7.99186,-34.858752;S9;オリンダ, ブラジル&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=30&q=Olinda-Pernambuco%2C%20Brazil&satid=id.sid%3Ad3586bda-6215-399b-7e39-9d6f2fbb85e3&vdpid=6493001879356702721&mb=-7.954672~-34.96038~-8.050891~-34.783257&cardbg=%23F98745&tt=Olinda%2C%20Pernambuco%2C%20Brazil&tsts0=%2526ty%253D30%2526q%253DOlinda-Pernambuco%25252C%252520Brazil%2526satid%253Did.sid%25253Ad3586bda-6215-399b-7e39-9d6f2fbb85e3%2526vdpid%253D6493001879356702721%2526mb%253D-7.954672~-34.96038~-8.050891~-34.783257%2526cardbg%253D%252523F98745&tstt0=Olinda%2C%20Pernambuco%2C%20Brazil&cp=-8.002807~-34.895024&lvl=13.876247&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260212_Olinda\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%aa%e3%83%aa%e3%83%b3%e3%83%80%e6%ad%b4%e5%8f%b2%e5%9c%b0%e5%8c%ba&form=hpcapt&filters=HpDate:\"20260211_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260212_Olinda"},"Ssd":"20260212","Name":"Olinda","Market":"JA-JP","Hash":"1273177244","FullDateString":"2026 年 2月 月 12 日"},{"ImageContent":{"Description":"金沢の兼六園、岡山の後楽園とともに日本三名園のひとつに数えられている水戸の偕楽園。水戸藩第 9 代藩主、徳川斉昭によって作られました。「偕楽」の名は、「古の人は民と偕（とも）に楽しむ、故に能く楽しむなり」という中国の古典「孟子」の一節から名づけられており、藩士だけではなく、領民への開放も目的としていました…","Image":{"Url":"/th?id=OHR.MitoPlumFestival2026_JA-JP1087345056_1920x1080.webp","Wallpaper":"/th?id=OHR.MitoPlumFestival2026_JA-JP1087345056_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日から水戸の梅まつり","Title":"白梅の花","Copyright":"© EarthScapeImageGraphy/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"梅は中国から日本に伝わり、当初は食用として栽培されていました。その後、花の美しさが評価され、貴族文化や宗教儀式の中で重要視されるようになりました。","LinkUrl":"/search?q=%e6%a2%85%e3%81%8c%e6%97%a5%e6%9c%ac%e3%81%ab%e4%bc%9d%e3%82%8f%e3%81%a3%e3%81%9f%e3%81%ae%e3%81%af%e3%81%84%e3%81%a4%ef%bc%9f&form=hpvsfa","LinkText":"梅が日本に伝わったのはいつ？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260211_MitoPlumFestival2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%99%bd%e6%a2%85%e3%81%ae%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260210_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260211_MitoPlumFestival2026"},"Ssd":"20260211","Name":"MitoPlumFestival2026","Market":"JA-JP","Hash":"1087345056","FullDateString":"2026 年 2月 月 11 日"},{"ImageContent":{"Description":"エス・ヴェドラはスペインのイビサ島南西に位置する無人島です。高さ約 400m の険しい崖のような島には、固有種のイビサカベカナヘビをはじめ、海鳥、岩場に適応した無脊椎動物、希少な植物など、多様な生物が生息しています。その独特な生態系を保全するため、島への上陸は禁じられています…","Image":{"Url":"/th?id=OHR.IbizaIslets_JA-JP0828320693_1920x1080.webp","Wallpaper":"/th?id=OHR.IbizaIslets_JA-JP0828320693_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"穏やかな海に佇む神秘的な島","Title":"エス・ヴェドラ島, スペイン","Copyright":"© L. Apolli/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.867802,1.198694/4?key=AsSOKo7OOz5VAtfAj0rj