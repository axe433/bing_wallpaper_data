{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-04-24T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"今日 4 月 25 日は、世界ペンギンの日。毎年この時期に、アデリーペンギンが米国の南極基地に現れることを祝い、制定されました。そして画像は、エクアドルのガラパゴス諸島で泳ぐガラパゴスペンギン。ペンギンの中で最も低緯度となる赤道直下に生息する希少種で、気候変動や海洋汚染、漁業による混獲などの影響により個体数が減少し、絶滅危惧種に指定されています。","Image":{"Url":"/th?id=OHR.GalapagosPenguins_JA-JP8635536385_1920x1080.webp","Wallpaper":"/th?id=OHR.GalapagosPenguins_JA-JP8635536385_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界ペンギンの日","Title":"ガラパゴスペンギン, エクアドル","Copyright":"© Henley Spiers/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-0.858834,-91.215952/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-0.858834,-91.215952;S9;ガラパゴス諸島, エクアドル&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260425_GalapagosPenguins%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260425_GalapagosPenguins\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e3%83%9a%e3%83%b3%e3%82%ae%e3%83%b3%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260424_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260425_GalapagosPenguins"},"Ssd":"20260425","Name":"GalapagosPenguins","Market":"JA-JP","Hash":"8635536385","FullDateString":"2026 年 4月 月 25 日"},{"ImageContent":{"Description":"今日 4 月 24 日は米国のアーバーデイ（植樹祭）。1872 年に始まり、毎年 4 月の最終金曜日に祝われています。最初の開催日には、およそ 100 万本の木が植えられたといわれています。そして画像は、米国フロリダ州にあるエバーグレーズ国立公園。ユネスコの世界遺産に登録されており、オークやマツなどの木々や様々な野草といった豊かな植生を誇る世界最大級の湿地帯の一つです。","Image":{"Url":"/th?id=OHR.SlashPine_JA-JP0980166238_1920x1080.webp","Wallpaper":"/th?id=OHR.SlashPine_JA-JP0980166238_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はアーバーデイ","Title":"エバーグレーズ国立公園, 米国 フロリダ州","Copyright":"© Mary Liz Austin/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.286996,-80.898707/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=25.286996,-80.898707;S9;エバーグレーズ国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260424_SlashPine%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260424_SlashPine\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%83%bc%e3%83%90%e3%83%bc%e3%83%87%e3%82%a4&form=hpcapt&filters=HpDate:\"20260423_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260424_SlashPine"},"Ssd":"20260424","Name":"SlashPine","Market":"JA-JP","Hash":"0980166238","FullDateString":"2026 年 4月 月 24 日"},{"ImageContent":{"Description":"今日 4 月 23 日は「世界本の日」であり、イギリスを代表する劇作家ウィリアム・シェイクスピアの命日でもあります。そして、画像はイングランド・ウォリックシャー州ショッタリー村にある「アン・ハサウェイのコテージ」です。シェイクスピアの妻アン・ハサウェイが幼少期を過ごしたとされる家屋で、現在は博物館として一般公開されています。","Image":{"Url":"/th?id=OHR.HathawayCottage_JA-JP0891184783_1920x1080.webp","Wallpaper":"/th?id=OHR.HathawayCottage_JA-JP0891184783_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"今日はシェイクスピアの命日","Title":"アン・ハサウェイのコテージ, イングランド","Copyright":"© David Steele/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.191271,-1.732166/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=52.191271,-1.732166;S9;アン・ハサウェイのコテージ, イングランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260423_HathawayCottage%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260423_HathawayCottage\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b7%e3%82%a7%e3%82%a4%e3%82%af%e3%82%b9%e3%83%94%e3%82%a2%e3%81%ae%e5%91%bd%e6%97%a5&form=hpcapt&filters=HpDate:\"20260422_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260423_HathawayCottage"},"Ssd":"20260423","Name":"HathawayCottage","Market":"JA-JP","Hash":"0891184783","FullDateString":"2026 年 4月 月 23 日"},{"ImageContent":{"Description":"今日 4 月 22 日は地球の日（アースデイ）。地球環境について考える日であり、毎年世界各地でイベントが行われています。2026 年のテーマは、「Our Power, Our Planet™」で、再生可能エネルギーへの転換を加速するとともに、持続可能な未来を創り出す「力」について確認することを目的としています。そして、この「力」を象徴するのが今日の画像、エストニア最大の自然保護区・アラムペジャ自然保護区です。余計な手を加えず自然そのものが持つ「力」のみで循環させることで、ヨーロッパ最大級の湿地帯を守り続けています。","Image":{"Url":"/th?id=OHR.TartuEstonia_JA-JP0849293902_1920x1080.webp","Wallpaper":"/th?id=OHR.TartuEstonia_JA-JP0849293902_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は地球の日","Title":"アラムペジャ自然保護区, エストニア","Copyright":"© Sven Zacek/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/58.466962,26.199996/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=58.466962,26.199996;S9;アラムペジャ自然保護区, エストニア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260422_TartumaaEstonia%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260422_TartuEstonia\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%b0%e7%90%83%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260421_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260422_TartuEstonia"},"Ssd":"20260422","Name":"TartuEstonia","Market":"JA-JP","Hash":"0849293902","FullDateString":"2026 年 4月 月 22 日"},{"ImageContent":{"Description":"今日の写真は、フランスで撮影されたハリネズミです。文字通り体に針のようなトゲを持つこの動物は、視力が弱く、嗅覚と聴覚を頼りに、ミミズや昆虫、カエル、種子などを探して食べます。単独行動を好み、他のハリネズミと行動するのは繁殖・子育ての時のみです。「ネズミ」と名前についているものの、モグラに近い動物であり、土を掘り巣穴をつくる種も存在します。","Image":{"Url":"/th?id=OHR.SpringHedgehog_JA-JP0798616014_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringHedgehog_JA-JP0798616014_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"緑の中にたたずむ小動物","Title":"ハリネズミ, フランス","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/46.624809,2.458377/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=46.624809,2.458377;S9;フランス&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260421_SpringHedgehog%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260421_SpringHedgehog\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%8f%e3%83%aa%e3%83%8d%e3%82%ba%e3%83%9f&form=hpcapt&filters=HpDate:\"20260420_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260421_SpringHedgehog"},"Ssd":"20260421","Name":"SpringHedgehog","Market":"JA-JP","Hash":"0798616014","FullDateString":"2026 年 4月 月 21 日"},{"ImageContent":{"Description":"4 月 18 日から 26 日まで、米国では「国立公園週間」が開催されます。期間中、全米各地の国立公園では、国立公園の魅力を広く伝えるため、レンジャーによるガイドツアーや教育ワークショップなどが行われます。そして、画像は米国ユタ州に位置するキャニオンランズ国立公園。面積は 1,366km² を誇り、コロラド川とグリーン川が削り出した峡谷や岩の尖塔、自然によって造られたアーチといった壮大な景観が広がっています。","Image":{"Url":"/th?id=OHR.SunsetKiva_JA-JP0609102045_1920x1080.webp","Wallpaper":"/th?id=OHR.SunsetKiva_JA-JP0609102045_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今週は米国の国立公園週間","Title":"キャニオンランズ国立公園, 米国 ユタ州","Copyright":"© Jason Hatfield/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.214046,-109.902539/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.214046,-109.902539;S9;キャニオンランズ国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260420_SunsetKiva%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260420_SunsetKiva\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92%e9%80%b1%e9%96%93&form=hpcapt&filters=HpDate:\"20260419_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260420_SunsetKiva"},"Ssd":"20260420","Name":"SunsetKiva","Market":"JA-JP","Hash":"0609102045","FullDateString":"2026 年 4月 月 20 日"},{"ImageContent":{"Description":"今日の画像は、ポルトガルの首都・リスボンのテージョ川沿いに建つ「ベレンの塔」です。川を出入りする船を監視する要塞として、1500 年代初頭にマヌエル 1 世の命によって建設されました。建築様式はマヌエル様式と呼ばれるもので、ゴシック建築に海藻やロープ、貝などの海をモチーフにした装飾が施されている点が特徴です。同じくリスボンにある「ジェロニモス修道院」とともに「リスボンのジェロニモス修道院とベレンの塔」として世界遺産に登録されています。","Image":{"Url":"/th?id=OHR.BelemTowerBank_JA-JP0304685153_1920x1080.webp","Wallpaper":"/th?id=OHR.BelemTowerBank_JA-JP0304685153_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水辺にたたずむ歴史的な塔","Title":"ベレンの塔, ポルトガル","Copyright":"© f9photos/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.691989,-9.215991/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.691989,-9.215991;S9;ベレンの塔, ポルトガル&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260419_BelemTower%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260419_BelemTowerBank\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%99%e3%83%ac%e3%83%b3%e3%81%ae%e5%a1%94&form=hpcapt&filters=HpDate:\"20260418_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260419_BelemTowerBank"},"Ssd":"20260419","Name":"BelemTowerBank","Market":"JA-JP","Hash":"0304685153","FullDateString":"2026 年 4月 月 19 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今日 5 月 2 日は八十八夜。立春から数えて 88 日目で、春から夏へ移る節目の日です。新茶を摘む時期でもあり、八十八夜に摘んだ茶葉は上等で、これを飲むと長生きするともいわれています。そして画像は、京都府和束町に位置する「和束の茶畑」です。京都府における宇治茶の生産量の約 4 割を占め、「茶源郷」とも呼ばれています。茶畑の畝が、急傾斜の山肌に覆い尽くすように張り巡らされているのが特徴です。鎌倉時代から受け継がれてきたこの景観は、京都府景観資産の登録第 1 号となったほか、2015 年には「日本茶 800 年の歴史散歩」として日本遺産にも登録されました。","Image":{"Url":"/th?id=OHR.HachijyuHachiya2026_JA-JP2065177671_1920x1080.webp","Wallpaper":"/th?id=OHR.HachijyuHachiya2026_JA-JP2065177671_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は八十八夜","Title":"和束の茶畑, 京都府 和束町","Copyright":"© Tuul and Bruno Morandi/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/34.802149,135.900084/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=34.802149,135.900084;S9;和束町, 京都府和束町&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260502_HachijyuHachiya2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260502_HachijyuHachiya2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%85%ab%e5%8d%81%e5%85%ab%e5%a4%9c&form=hpcapt&filters=HpDate:\"20260501_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260502_HachijyuHachiya2026"},"Ssd":"20260502","Name":"HachijyuHachiya2026","Market":"JA-JP","Hash":"2065177671","FullDateString":"2026 年 5月 月 2 日"},{"ImageContent":{"Description":"ここはカナダのアルバータ州にあるジャスパー国立公園。総面積は約 11,000km² を誇り、世界遺産に登録されています。コロンビア氷原から流れ出す氷河や高山草原、マツの森など、多様な自然景観が広がるほか、ヘラジカやハイイログマ、オオカミ、トナカイなど、多くの野生動物が生息しています。季節を問わず、トレイルや景観道路、湖や星空など多彩な自然を楽しめる人気の観光地です。","Image":{"Url":"/th?id=OHR.GreenJasper_JA-JP1765702331_1920x1080.webp","Wallpaper":"/th?id=OHR.GreenJasper_JA-JP1765702331_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"自然が描く湖畔の景色","Title":"ジャスパー国立公園, カナダ","Copyright":"© Don White/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.873404,-117.954307/20?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=52.873404,-117.954307;S9;ジャスパー国立公園, カナダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260501_GreenJasper%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260501_GreenJasper\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b8%e3%83%a3%e3%82%b9%e3%83%91%e3%83%bc%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260430_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260501_GreenJasper"},"Ssd":"20260501","Name":"GreenJasper","Market":"JA-JP","Hash":"1765702331","FullDateString":"2026 年 5月 月 1 日"},{"ImageContent":{"Description":"ここはオランダのリッセにあるキューケンホフ公園。ヨーロッパの公園とも呼ばれている「花の公園」であり、毎年約 700 万球の花が植えられる世界最大級の庭園として知られています。春を迎えると、テーマ別の庭園に 800 種以上のチューリップが咲き誇り、園内は鮮やかな色彩に包まれます。限られた季節のみ一般公開される春の名所であるため、この時期は世界中から多くの人々が春の風景を楽しみに訪れます。","Image":{"Url":"/th?id=OHR.DutchTulips_JA-JP3809671349_1920x1080.webp","Wallpaper":"/th?id=OHR.DutchTulips_JA-JP3809671349_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"色とりどりに咲き誇る花畑","Title":"チューリップ, オランダ","Copyright":"© Martin Ruegner/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.26889,4.547222/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=52.26889,4.547222;S9;キューケンホフ公園, オランダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260430_DutchTulips%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260430_DutchTulips\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%81%e3%83%a5%e3%83%bc%e3%83%aa%e3%83%83%e3%83%97&form=hpcapt&filters=HpDate:\"20260429_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260430_DutchTulips"},"Ssd":"20260430","Name":"DutchTulips","Market":"JA-JP","Hash":"3809671349","FullDateString":"2026 年 4月 月 30 日"},{"ImageContent":{"Description":"今日 4 月 29 日は「昭和の日」。昭和天皇の誕生日であり、日本が歩んできた昭和の時代を振り返り、国の将来に思いを巡らせる日とするため、2007 年に「みどりの日」から変更されました。そして、画像は、国会議事堂の内部。現在の議事堂は、昭和 11 年（ 1936 年）に新議事堂として設立されたもので、昭和から令和へ、日本の発展の歴史と軌跡を伝える象徴的な存在です。観光名所でもあるため、毎年多くの修学旅行生や団体客が訪れています。","Image":{"Url":"/th?id=OHR.ShowaEraDay2026_JA-JP3778600248_1920x1080.webp","Wallpaper":"/th?id=OHR.ShowaEraDay2026_JA-JP3778600248_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は昭和の日","Title":"国会議事堂, 東京都","Copyright":"© Hiroshi Watanabe/Getty images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.676022,139.744835/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.676022,139.744835;S9;国会議事堂&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260429_ShowaEraDay2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260429_ShowaEraDay2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%98%ad%e5%92%8c%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260428_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260429_ShowaEraDay2026"},"Ssd":"20260429","Name":"ShowaEraDay2026","Market":"JA-JP","Hash":"3778600248","FullDateString":"2026 年 4月 月 29 日"},{"ImageContent":{"Description":"メガネグマは、南米のアンデス山脈に分布するクマ科の動物で、クマ科では南米に生息する唯一の種です。目の周囲にある淡い模様が眼鏡のように見えることから、この名前が付けられました。非常に木登りが得意で、樹上に巣を作ることもあります。主に果実を食べますが、時には昆虫や小型の哺乳類なども捕食します。生息地の減少や狩猟、人間活動の影響により、国際自然保護連合（IUCN）では、「危急種（Vulnerable）」に分類されているため、その保護が重要視されています。","Image":{"Url":"/th?id=OHR.AndeanBear_JA-JP1349028050_1920x1080.webp","Wallpaper":"/th?id=OHR.AndeanBear_JA-JP1349028050_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"木の上でくつろぐ野生動物","Title":"メガネグマ, エクアドル","Copyright":"© Andy Rouse/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-1.339767,-79.366699/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-1.339767,-79.366699;S9;エクアドル&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260428_AndeanBear%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260428_AndeanBear\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a1%e3%82%ac%e3%83%8d%e3%82%b0%e3%83%9e&form=hpcapt&filters=HpDate:\"20260427_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260428_AndeanBear"},"Ssd":"20260428","Name":"AndeanBear","Market":"JA-JP","Hash":"1349028050","FullDateString":"2026 年 4月 月 28 日"},{"ImageContent":{"Description":"ここはイタリア・ミラノにある「ヴィットーリオ・エマヌエーレ 2 世のガッレリア」です。イタリア最古かつ世界で最も美しいともいわれるショッピングアーケードで、建築家ジュゼッペ・メンゴーニによって設計され、1877 年に完成しました。ガラスと鉄の屋根、優雅な八角形の構造が特徴で、高級ブティックや歴史あるカフェ、名高いレストランが軒を連ねています。また、東京ディズニーランドのワールドバザールのモデルでもあります。","Image":{"Url":"/th?id=OHR.MilanGalleria_JA-JP1271955440_1920x1080.webp","Wallpaper":"/th?id=OHR.MilanGalleria_JA-JP1271955440_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"壮麗なガラスドーム","Title":"ヴィットーリオ・エマヌエーレ 2 世のガッレリア, イタリア","Copyright":"© PhillipMinnis/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/45.466133,9.189982/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=45.466133,9.189982;S9;ヴィットーリオ・エマヌエーレ 2 世のガッレリア, イタリア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,