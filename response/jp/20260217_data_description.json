%e3%83%b3%e3%83%80%e6%ad%b4%e5%8f%b2%e5%9c%b0%e5%8c%ba&form=hpcapt&filters=HpDate:\"20260211_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260212_Olinda"},"Ssd":"20260212","Name":"Olinda","Market":"JA-JP","Hash":"1273177244","FullDateString":"2026 年 2月 月 12 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"ここは、米国アラスカ州の州都ジュノー近郊にあるメンデンホール氷河の氷の洞窟。氷河が溶けることで生まれた洞窟の中には、息をのむほど美しい世界が広がっています。太陽の光の波長を厚い氷が一部吸収することで、洞窟内は神秘的な青色に包まれ、丸みを帯びた滑らかな氷の壁が独特の造形を生み出しています。洞窟は今も刻々と変化し続けており、その大きさや色合いも常に異なっています。","Image":{"Url":"/th?id=OHR.MendenhallCave_JA-JP8678792509_1920x1080.webp","Wallpaper":"/th?id=OHR.MendenhallCave_JA-JP8678792509_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"泡のような天井が広がるアイスケーブ","Title":"メンデンホール氷河の氷の洞窟, 米国 アラスカ州","Copyright":"© Designpics/Adobe Stock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/58.41721,-134.545792/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=58.41721,-134.545792;S9;メンデンホール氷河&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260225_MendenhallCave%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260225_MendenhallCave\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a1%e3%83%b3%e3%83%87%e3%83%b3%e3%83%9b%e3%83%bc%e3%83%ab%e6%b0%b7%e6%b2%b3%e3%81%ae%e6%b0%b7%e3%81%ae%e6%b4%9e%e7%aa%9f&form=hpcapt&filters=HpDate:\"20260224_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260225_MendenhallCave"},"Ssd":"20260225","Name":"MendenhallCave","Market":"JA-JP","Hash":"8678792509","FullDateString":"2026 年 2月 月 25 日"},{"ImageContent":{"Description":"ここはメキシコ・トゥルムにあるグラン・セノーテ。セノーテとは、陥没穴に地下水が溜まってできたもので、澄んだ水が広がる神秘的な泉です。水面にはスイレンが浮かび、その下で魚や亀がゆったりと動き回ります。また、鍾乳石が連なる洞窟内にはトンボなどの昆虫が飛んでおり、何万年もの時をかけて形づくられた穏やかで豊かな自然の風景が広がっています。","Image":{"Url":"/th?id=OHR.TulumLilies_JA-JP8645849779_1920x1080.webp","Wallpaper":"/th?id=OHR.TulumLilies_JA-JP8645849779_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"自然の鏡に映る色とりどりの葉","Title":"スイレン, メキシコ","Copyright":"© Christian Vizl/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/20.246545,-87.464165/14?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=20.246545,-87.464165;S9;グラン・セノーテ, メキシコ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260224_TulumLilies%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260224_TulumLilies\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b9%e3%82%a4%e3%83%ac%e3%83%b3&form=hpcapt&filters=HpDate:\"20260223_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260224_TulumLilies"},"Ssd":"20260224","Name":"TulumLilies","Market":"JA-JP","Hash":"8645849779","FullDateString":"2026 年 2月 月 24 日"},{"ImageContent":{"Description":"今日 2 月 23 日は天皇誕生日であり、「富士山 (223) 」の語呂合わせで、静岡県と山梨県が制定した「富士山の日」でもあります。この日を祝して、静岡県の景勝地、日本平から望む富士山と清水港の夕景をお届けします。清水港は、長崎港と神戸港と並び「日本三大美港」に数えられており、クルーズ客船の寄港も多く、近年は貿易港としてだけではなく、観光港としても整備されています。","Image":{"Url":"/th?id=OHR.MountFuji2026_JA-JP8594170652_1920x1080.webp","Wallpaper":"/th?id=OHR.MountFuji2026_JA-JP8594170652_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は「富士山の日」","Title":"富士山, 静岡県","Copyright":"© Cravetiger/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.363282,138.730883/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.363282,138.730883;S9;富士山&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260223_MountFuji2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260223_MountFuji2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%af%8c%e5%a3%ab%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260222_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260223_MountFuji2026"},"Ssd":"20260223","Name":"MountFuji2026","Market":"JA-JP","Hash":"8594170652","FullDateString":"2026 年 2月 月 23 日"},{"ImageContent":{"Description":"マム・トーは、イングランド・ダービーシャー州のピーク・ディストリクト国立公園内にある標高 517m の丘です。「母なる丘」を意味し、東斜面で繰り返される地滑りによって麓に無数の「小さな丘」が生まれたことが名前の由来となっています。また、丘の周囲には四つの洞窟もあり、雄大な景観と歩きやすい尾根道が楽しめることから、この地を代表する散策スポットとして親しまれています。","Image":{"Url":"/th?id=OHR.MamTorSunrise_JA-JP8500587140_1920x1080.webp","Wallpaper":"/th?id=OHR.MamTorSunrise_JA-JP8500587140_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"雪原に広がるなだらかな丘陵","Title":"マム・トーの丘, イングランド","Copyright":"© john finney photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/53.387242,-1.819306/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=53.387242,-1.819306;S9;マム・トー丘, イングランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260222_MamTorSunrise%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260222_MamTorSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%9e%e3%83%a0%e3%83%bb%e3%83%88%e3%83%bc%e3%81%ae%e4%b8%98&form=hpcapt&filters=HpDate:\"20260221_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260222_MamTorSunrise"},"Ssd":"20260222","Name":"MamTorSunrise","Market":"JA-JP","Hash":"8500587140","FullDateString":"2026 年 2月 月 22 日"},{"ImageContent":{"Description":"今日の画像は、米国ワイオミング州のグランド・ティトン国立公園に生息するアカギツネ。音を吸収する雪の中でも鋭い聴覚で獲物の気配を感じ取り、静かに待ち構えるハンターです。イヌ科ではあるものの、体の特徴やその行動は猫に似ているとされています。炎のように赤い冬毛は白銀の風景に鮮やかに映え、厳しい冬を生き抜く野生動物の力強さを感じさせてくれます。","Image":{"Url":"/th?id=OHR.TetonFox_JA-JP8453720368_1920x1080.webp","Wallpaper":"/th?id=OHR.TetonFox_JA-JP8453720368_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"降り積もる雪の中に生きる凛とした気配","Title":"アカギツネ, 米国 ワイオミング州","Copyright":"© Radomir Jakubowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.790948,-110.681668/15?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=43.790948,-110.681668;S9;グランド・ティトン国立公園, 米国 ワイオミング州&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260221_TetonFox%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260221_TetonFox\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%82%ab%e3%82%ae%e3%83%84%e3%83%8d&form=hpcapt&filters=HpDate:\"20260220_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260221_TetonFox"},"Ssd":"20260221","Name":"TetonFox","Market":"JA-JP","Hash":"8453720368","FullDateString":"2026 年 2月 月 21 日"},{"ImageContent":{"Description":"今日の画像は、ホーステール滝のファイアフォール。ホーステール滝は、米国カリフォルニア州にあるヨセミテ国立公園の名所です。ファイアフォールとは、太陽の光が滝に当たり、水が溶岩のように赤く輝く自然現象で、その名称は、近隣の展望地、グレイシャー・ポイントでかつて行われていた赤熱した石炭を崖から落とす行事に由来しています。2 月中旬から下旬の夕暮れ時に、気象条件が揃うと見ることができる珍しい現象のため、多くの写真家や旅行者を魅了しています。","Image":{"Url":"/th?id=OHR.AdamsFirefall_JA-JP8340862281_1920x1080.webp","Wallpaper":"/th?id=OHR.AdamsFirefall_JA-JP8340862281_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"炎の滝が一瞬だけ現れる夕刻","Title":"ホーステール滝, 米国 カリフォルニア州","Copyright":"© Jorge Villalba/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/37.729141,-119.628471/15?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=37.729141,-119.628471;S9;ホーステール滝, 米国 カリフォルニア州&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260220_AdamsFirefall%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260220_AdamsFirefall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%9b%e3%83%bc%e3%82%b9%e3%83%86%e3%83%bc%e3%83%ab%e6%bb%9d&form=hpcapt&filters=HpDate:\"20260219_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260220_AdamsFirefall"},"Ssd":"20260220","Name":"AdamsFirefall","Market":"JA-JP","Hash":"8340862281","FullDateString":"2026 年 2月 月 20 日"},{"ImageContent":{"Description":"ノルウェー・ロフォーテン諸島にあるウッタクレイヴは、わずか 22 人の住民が暮らす小さな集落です。険しい山々とターコイズブルーの海に囲まれ、白砂のビーチとごつごつした岩場が織りなす風景が特徴であり、さらに、冬はオーロラ観測の名所としても知られています…","Image":{"Url":"/th?id=OHR.DragonsEyeRock_JA-JP3484187300_1920x1080.webp","Wallpaper":"/th?id=OHR.DragonsEyeRock_JA-JP3484187300_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"H