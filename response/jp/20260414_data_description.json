{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-04-14T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"4 月 11 日から 5 月 24 日まで、山梨県の富士本栖湖リゾートで「富士芝桜まつり」が開催されます。富士山の麓に広がる広大な敷地には、ピンクや白など色とりどりの芝桜が約 50 万株も咲き誇り、春の富士山との美しいコラボレーションを披露してくれます。毎年全国から多くの観光客が訪れており、今年のテーマは「春の特等席。」です。","Image":{"Url":"/th?id=OHR.Shibazakura2026_JA-JP4532713069_1920x1080.webp","Wallpaper":"/th?id=OHR.Shibazakura2026_JA-JP4532713069_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"富士芝桜まつりが開催中","Title":"芝桜, 山梨県","Copyright":"© DoctorEgg/Getty images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.443361,138.604036/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.443361,138.604036;S9;富士本栖湖リゾート&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260415_Shibazakura2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260415_Shibazakura2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8a%9d%e6%a1%9c&form=hpcapt&filters=HpDate:\"20260414_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260415_Shibazakura2026"},"Ssd":"20260415","Name":"Shibazakura2026","Market":"JA-JP","Hash":"4532713069","FullDateString":"2026 年 4月 月 15 日"},{"ImageContent":{"Description":"イソギンチャクは、植物のようにも見えますが、実際はクラゲやサンゴに近い動物です。岩などに付着して生息し、毒針のついた糸が入ったカプセル状の「刺胞」をもつ触手で獲物を捕らえます。そして、画像はそんなイソギンチャクと共生するクマノミ。インドネシアのラジャ・アンパット諸島で撮影されたものです。クマノミは、刺胞から身を守る特殊な粘液によって、イソギンチャクの触手を安全な住処としており、そのお返しに、捕食者を追い払ったりイソギンチャクに食べ残しを与えたりしています。","Image":{"Url":"/th?id=OHR.OcellarisClownfish_JA-JP4425106127_1920x1080.webp","Wallpaper":"/th?id=OHR.OcellarisClownfish_JA-JP4425106127_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"イソギンチャクの中で身を寄せる小魚","Title":"クマノミ, インドネシア","Copyright":"© Magnus Lundgren/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-0.233312,130.507889/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-0.233312,130.507889;S9;アンパット諸島, インドネシア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260414_OcellarisClownfish%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260414_OcellarisClownfish\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%af%e3%83%9e%e3%83%8e%e3%83%9f&form=hpcapt&filters=HpDate:\"20260413_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260414_OcellarisClownfish"},"Ssd":"20260414","Name":"OcellarisClownfish","Market":"JA-JP","Hash":"4425106127","FullDateString":"2026 年 4月 月 14 日"},{"ImageContent":{"Description":"今日 4 月 13 日から 20 日は「国際ダークスカイ・ウィーク」です。美しい星空を見つめ直し、光害について認識を深めることを目的に、ダークスカイ・インターナショナルが開催しているキャンペーンです。そして、今日の画像は、アンザ・ボレゴ砂漠州立公園の上空に広がる天の川。公園は、米国カリフォルニア州最大級の州立公園で、晴れた夜には惑星や星団を観察できることから、国際ダークスカイ公園に指定されています。","Image":{"Url":"/th?id=OHR.BorregoStars_JA-JP7872026496_1920x1080.webp","Wallpaper":"/th?id=OHR.BorregoStars_JA-JP7872026496_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日から国際ダークスカイ・ウィーク","Title":"アンザ・ボレゴ砂漠州立公園, 米国 カリフォルニア州","Copyright":"© Kevin Key/Slworking","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/33.100494,-116.301331/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=33.100494,-116.301331;S9;アンザ・ボレゴ砂漠州立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260413_BorregoStars%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260413_BorregoStars\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%9a%9b%e3%83%80%e3%83%bc%e3%82%af%e3%82%b9%e3%82%ab%e3%82%a4%e3%83%bb%e3%82%a6%e3%82%a3%e3%83%bc%e3%82%af&form=hpcapt&filters=HpDate:\"20260412_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260413_BorregoStars"},"Ssd":"20260413","Name":"BorregoStars","Market":"JA-JP","Hash":"7872026496","FullDateString":"2026 年 4月 月 13 日"},{"ImageContent":{"Description":"今日 4 月 12 日は世界宇宙飛行の日。1961 年、ロシアの宇宙飛行士ユーリイ・ガガーリンが、史上初の有人宇宙飛行に成功した日です。彼の宇宙探求の精神は、現在、地上から約 400km 上空に建設された巨大な有人実験施設である国際宇宙ステーション (ISS) に受け継がれています。2000 年から継続的に有人運用されている ISS では、宇宙飛行士たちが日々、地球を観測しながら医学や気候化学などの研究を行い、人類が地球外で生活し働く可能性を探っています。","Image":{"Url":"/th?id=OHR.SpaceTrails_JA-JP7486143829_1920x1080.webp","Wallpaper":"/th?id=OHR.SpaceTrails_JA-JP7486143829_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界宇宙飛行の日","Title":"光の筋となる都市の夜景, 国際宇宙ステーション","Copyright":"© NASA","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"無重力環境では筋肉や骨が弱くなるため、宇宙飛行士はその低下を防ぐ目的で、筋力トレーニングなどの運動を毎日約 2 時間行っています。","LinkUrl":"/search?q=%e5%9b%bd%e9%9a%9b%e5%ae%87%e5%ae%99%e3%82%b9%e3%83%86%e3%83%bc%e3%82%b7%e3%83%a7%e3%83%b3%e5%86%85%e9%83%a8%e3%81%ae%e9%87%8d%e5%8a%9b%e3%81%af%e3%81%a9%e3%81%86%e3%81%aa%e3%81%a3%e3%81%a6%e3%81%84%e3%82%8b%ef%bc%9f&form=hpvsfa","LinkText":"国際宇宙ステーション内部の重力はどうなっている？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260412_SpaceTrails\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e5%ae%87%e5%ae%99%e9%a3%9b%e8%a1%8c%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260411_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260412_SpaceTrails"},"Ssd":"20260412","Name":"SpaceTrails","Market":"JA-JP","Hash":"7486143829","FullDateString":"2026 年 4月 月 12 日"},{"ImageContent":{"Description":"ここは、パパガヨビーチ。スペインのカナリア諸島に属するランサローテ島南部に位置します。ランサローテ島は長い火山活動の歴史を持ち、特に 18 世紀の噴火が現在の地形形成に大きく影響しました。そしてパパガヨビーチは、火山岩の断崖に囲まれており、それが防波堤になることで、波が和らげられ、ビーチには穏やかで透明度の高い海が広がります。黄金色の砂浜は、砕けた貝殻と火山岩が混ざり合ってできたもので、この島の成り立ちを感じさせます。","Image":{"Url":"/th?id=OHR.PlayaPapagayo_JA-JP3931450183_1920x1080.webp","Wallpaper":"/th?id=OHR.PlayaPapagayo_JA-JP3931450183_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"乾いた大地に囲まれた青い海","Title":"パパガヨビーチ, スペイン","Copyright":"© Gavin Hellier/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/28.84295,-13.78824/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=28.84295,-13.78824;S9;パパガヨビーチ, スペイン&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260411_PlayaPapagayo%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260411_PlayaPapagayo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%91%e3%83%91%e3%82%ac%e3%83%a8%e3%83%93%e3%83%bc%e3%83%81&form=hpcapt&filters=HpDate:\"20260410_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260411_PlayaPapagayo"},"Ssd":"20260411","Name":"PlayaPapagayo","Market":"JA-JP","Hash":"3931450183","FullDateString":"2026 年 4月 月 11 日"},{"ImageContent":{"Description":"今日 4 月 10 日は「兄弟姉妹の日」。ニューヨーク在住のクラウディア・エヴァート氏が、幼い頃に亡くなった兄弟姉妹の記憶をたたえるために考案した記念日です。日本では、NPO 法人「しぶたね」が「きょうだいの日」を制定し、この記念日の普及活動を行っています。そして、画像はエストニアのカルラ国立公園で撮影されたアカギツネの兄妹。子ギツネたちは追いかけっこやじゃれ合いを通して狩りの技術を学び、互いに支え合いながら成長していきます。","Image":{"Url":"/th?id=OHR.FoxSiblings_JA-JP3895166955_1920x1080.webp","Wallpaper":"/th?id=OHR.FoxSiblings_JA-JP3895166955_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はきょうだいの日","Title":"アカギツネ, エストニア","Copyright":"© Sven Zacek/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/57.714678,26.486612/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=57.714678,26.486612;S9;カルラ国立公園, エストニア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260410_FoxSiblings%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260410_FoxSiblings\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%82%ab%e3%82%ae%e3%83%84%e3%83%8d&form=hpcapt&filters=HpDate:\"20260409_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260410_FoxSiblings"},"Ssd":"20260410","Name":"FoxSiblings","Market":"JA-JP","Hash":"3895166955","FullDateString":"2026 年 4月 月 10 日"},{"ImageContent":{"Description":"ここは、南ウェールズで最も特徴的な滝の一つであるスグド・イル・エイル滝。バンナイ・ブラヘイニョグ国立公園内に位置しています。ウェールズ語で「雪の滝」を意味しており、水が淡く流れ落ちる姿が特徴的です。滝の裏側へと続く細い小道が設けられており、水を通る光や滝が流れ落ちる音、そして滝そのものの動きを間近で感じるという体験が楽しめます。","Image":{"Url":"/th?id=OHR.WalesWaterfall_JA-JP5848698751_1920x1080.webp","Wallpaper":"/th?id=OHR.WalesWaterfall_JA-JP5848698751_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"森の中に流れ落ちる滝","Title":"スグド・イル・エイル滝, ウェールズ","Copyright":"© Guy Edwardes/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.78174,-3.554824/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=51.78174,-3.554824;S9;スグド・イル・エイル滝, ウェールズ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260409_WalesWaterfall%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260409_WalesWaterfall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b9%e3%82%b0%e3%83%89%e3%83%bb%e3%82%a4%e3%83%ab%e3%83%bb%e3%82%a8%e3%82%a4%e3%83%ab%e6%bb%9d&form=hpcapt&filters=HpDate:\"20260408_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260409_WalesWaterfall"},"Ssd":"20260409","Name":"WalesWaterfall","Market":"JA-JP","Hash":"5848698751","FullDateString":"2026 年 4月 月 9 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今日 4 月 22 日は地球の日（アースデイ）。地球環境について考える日であり、毎年世界各地でイベントが行われています。2026 年のテーマは、「Our Power, Our Planet™」で、再生可能エネルギーへの転換を加速するとともに、持続可能な未来を創り出す「力」について確認することを目的としています。そして、この「力」を象徴するのが今日の画像、エストニア最大の自然保護区・アラムペジャ自然保護区です。余計な手を加えず自然そのものが持つ「力」のみで循環させることで、ヨーロッパ最大級の湿地帯を守り続けています。","Image":{"Url":"/th?id=OHR.TartuEstonia_JA-JP0849293902_1920x1080.webp","Wallpaper":"/th?id=OHR.TartuEstonia_JA-JP0849293902_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は地球の日","Title":"アラムペジャ自然保護区, エストニア","Copyright":"© Sven Zacek/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/58.466962,26.199996/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=58.466962,26.199996;S9;アラムペジャ自然保護区, エストニア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260422_TartumaaEstonia%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260422_TartuEstonia\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%b0%e7%90%83%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260421_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260422_TartuEstonia"},"Ssd":"20260422","Name":"TartuEstonia","Market":"JA-JP","Hash":"0849293902","FullDateString":"2026 年 4月 月 22 日"},{"ImageContent":{"Description":"今日の写真は、フランスで撮影されたハリネズミです。文字通り体に針のようなトゲを持つこの動物は、視力が弱く、嗅覚と聴覚を頼りに、ミミズや昆虫、カエル、種子などを探して食べます。単独行動を好み、他のハリネズミと行動するのは繁殖・子育ての時のみです。「ネズミ」と名前についているものの、モグラに近い動物であり、土を掘り巣穴をつくる種も存在します。","Image":{"Url":"/th?id=OHR.SpringHedgehog_JA-JP0798616014_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringHedgehog_JA-JP0798616014_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"緑の中にたたずむ小動物","Title":"ハリネズミ, フランス","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/46.624809,2.458377/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=46.624809,2.458377;S9;フランス&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260421_SpringHedgehog%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260421_SpringHedgehog\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%8f%e3%83%aa%e3%83%8d%e3%82%ba%e3%83%9f&form=hpcapt&filters=HpDate:\"20260420_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260421_SpringHedgehog"},"Ssd":"20260421","Name":"SpringHedgehog","Market":"JA-JP","Hash":"0798616014","FullDateString":"2026 年 4月 月 21 日"},{"ImageContent":{"Description":"4 月 18 日から 26 日まで、米国では「国立公園週間」が開催されます。期間中、全米各地の国立公園では、国立公園の魅力を広く伝えるため、レンジャーによるガイドツアーや教育ワークショップなどが行われます。そして、画像は米国ユタ州に位置するキャニオンランズ国立公園。面積は 1,366km² を誇り、コロラド川とグリーン川が削り出した峡谷や岩の尖塔、自然によって造られたアーチといった壮大な景観が広がっています。","Image":{"Url":"/th?id=OHR.SunsetKiva_JA-JP0609102045_1920x1080.webp","Wallpaper":"/th?id=OHR.SunsetKiva_JA-JP0609102045_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今週は米国の国立公園週間","Title":"キャニオンランズ国立公園, 米国 ユタ州","Copyright":"© Jason Hatfield/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.214046,-109.902539/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.214046,-109.902539;S9;キャニオンランズ国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260420_SunsetKiva%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260420_SunsetKiva\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92%e9%80%b1%e9%96%93&form=hpcapt&filters=HpDate:\"20260419_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260420_SunsetKiva"},"Ssd":"20260420","Name":"SunsetKiva","Market":"JA-JP","Hash":"0609102045","FullDateString":"2026 年 4月 月 20 日"},{"ImageContent":{"Description":"今日の画像は、ポルトガルの首都・リスボンのテージョ川沿いに建つ「ベレンの塔」です。川を出入りする船を監視する要塞として、1500 年代初頭にマヌエル 1 世の命によって建設されました。建築様式はマヌエル様式と呼ばれるもので、ゴシック建築に海藻やロープ、貝などの海をモチーフにした装飾が施されている点が特徴です。同じくリスボンにある「ジェロニモス修道院」とともに「リスボンのジェロニモス修道院とベレンの塔」として世界遺産に登録されています。","Image":{"Url":"/th?id=OHR.BelemTowerBank_JA-JP0304685153_1920x1080.webp","Wallpaper":"/th?id=OHR.BelemTowerBank_JA-JP0304685153_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水辺にたたずむ歴史的な塔","Title":"ベレンの塔, ポルトガル","Copyright":"© f9photos/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.691989,-9.215991/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.691989,-9.215991;S9;ベレンの塔, ポルトガル&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260419_BelemTower%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260419_BelemTowerBank\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%99%e3%83%ac%e3%83%b3%e3%81%ae%e5%a1%94&form=hpcapt&filters=HpDate:\"20260418_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260419_BelemTowerBank"},"Ssd":"20260419","Name":"BelemTowerBank","Market":"JA-JP","Hash":"0304685153","FullDateString":"2026 年 4月 月 19 日"},{"ImageContent":{"Description":"今日 4 月 18 日は「世界遺産の日」。歴史的な文化財や自然遺産の保護と保存の重要性を再認識する日です。そして画像は、チリにある世界遺産、ラパ・ヌイ国立公園（イースター島）のモアイ像です。13 世紀から 16 世紀にかけて、ラパ・ヌイの先住民であるポリネシア系の人々によって造られたもので、現在、島内には 900 体以上のモアイ像が残されており、それぞれが異なる表情や特徴を持っています。","Image":{"Url":"/th?id=OHR.MaoiStatues_JA-JP0155278246_1920x1080.webp","Wallpaper":"/th?id=OHR.MaoiStatues_JA-JP0155278246_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"今日は世界遺産の日","Title":"モアイ像, チリ","Copyright":"© Gavin Hellier/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-27.14951,-109.385875/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-27.14951,-109.385875;S9;ラパ・ヌイ国立公園, チリ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260418_MaoiStatues%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260418_MaoiStatues\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e9%81%ba%e7%94%a3%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260417_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260418_MaoiStatues"},"Ssd":"20260418","Name":"MaoiStatues","Market":"JA-JP","Hash":"0155278246","FullDateString":"2026 年 4月 月 18 日"},{"ImageContent":{"Description":"今日、4 月 17 日は「国際コウモリ感謝の日」です。日本ではあまりなじみがない記念日ですが、果物や昆虫を食べて生態系を支えているコウモリへの理解を深め、保全への意識を高めることを目的としています。そして画像は、オーストラリアで撮影された、赤ちゃんを抱えるハイイロオオコウモリ。オーストラリア最大級のコウモリで、翼は広げると 1m 以上にもなります。また、コウモリが使うことで知られる反響定位（エコーロケーション）は使用しない種であり、鋭い視覚と嗅覚を使って飛びます。","Image":{"Url":"/th?id=OHR.FlyingFoxMom_JA-JP9261315523_1920x1080.webp","Wallpaper":"/th?id=OHR.FlyingFoxMom_JA-JP9261315523_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は国際コウモリ感謝の日","Title":"ハイイロオオコウモリ, オーストラリア","Copyright":"© Doug Gimesy/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-37.79762,145.012239/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-37.79762,145.012239;S9;ヤラ・ベンド公園, オーストラリア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&