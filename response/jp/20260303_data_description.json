{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-03T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"ブルガリア最高峰のリラ山脈では、雪の下からクロッカスが咲き始め、春の訪れを告げます。今日の画像は、ブルガリア南西部のリラ国立公園に広がるクロッカスの花です。リラ国立公園は、1992 年に設立されたブルガリア国最大の保護区であり、名高い「リラの七湖」を含む氷河湖群を有しています。また、園内の一部はユネスコの生物圏保護区にも指定されています。","Image":{"Url":"/th?id=OHR.RilaCrocuses_JA-JP8929761168_1920x1080.webp","Wallpaper":"/th?id=OHR.RilaCrocuses_JA-JP8929761168_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"残雪の山に咲く紫の小さな花","Title":"紫クロッカス, ブルガリア","Copyright":"© Maya Karkalicheva/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/42.204161,23.312577/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=42.204161,23.312577;S9;リラの七湖, ブルガリア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260304_RilaCrocuses%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260304_RilaCrocuses\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%b4%ab%e3%82%af%e3%83%ad%e3%83%83%e3%82%ab%e3%82%b9&form=hpcapt&filters=HpDate:\"20260303_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260304_RilaCrocuses"},"Ssd":"20260304","Name":"RilaCrocuses","Market":"JA-JP","Hash":"8929761168","FullDateString":"2026 年 3月 月 4 日"},{"ImageContent":{"Description":"今日 3 月 3 日はひな祭り。竹筒の中に入った可愛らしいひな人形をお届けします。ひな祭りの歴史は古く、諸説ありますが、平安時代に上巳の節句として行われていた、紙で作ったひな人形を川に流す「流しびな」の行事が起源ともいわれています。室町時代になると、現在のひな人形の原型ともいえる「立雛」が登場し、江戸時代になるとひな人形は次第に豪華さを増していきました。現代のような様式となったのは明治以降になります。","Image":{"Url":"/th?id=OHR.HinaMatsuri2026_JA-JP1524445029_1920x1080.webp","Wallpaper":"/th?id=OHR.HinaMatsuri2026_JA-JP1524445029_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はひな祭り","Title":"竹筒から顔をのぞかせる可愛いひな人形","Copyright":"© Bong Grit/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"ひな祭りは､もともと｢上巳｣として中国から伝わった節句で､桃の花が咲く時期であることから、｢桃の節句｣と言われてきました。","LinkUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e3%81%a7%e3%81%af%e6%a1%83%e3%81%ae%e6%9c%a8+%e6%84%8f%e5%91%b3&form=hpvsfa","LinkText":"中国では、桃の木にはどのような意味がある？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260303_HinaMatsuri2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%81%b2%e3%81%aa%e7%a5%ad%e3%82%8a&form=hpcapt&filters=HpDate:\"20260302_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260303_HinaMatsuri2026"},"Ssd":"20260303","Name":"HinaMatsuri2026","Market":"JA-JP","Hash":"1524445029","FullDateString":"2026 年 3月 月 3 日"},{"ImageContent":{"Description":"今日の画像は、タイ南部・サムイ島の港に浮かぶロングテールボート。タイ語で「ルア・ハン・ヤオ」と呼ばれるこの船は、20 世紀初頭に誕生した伝統的な木造船です。エンジンを備え、浅瀬や狭い水路でも高い機動性を発揮します。船首に飾られた鮮やかな色の布や花の装飾は、単なる美化のためではなく、航海の安全と繁栄を願う深い宗教的・信仰的な意味が込められています。","Image":{"Url":"/th?id=OHR.SamuiThailand_JA-JP8871404355_1920x1080.webp","Wallpaper":"/th?id=OHR.SamuiThailand_JA-JP8871404355_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"港に浮かぶロングテールボート","Title":"サムイ島, タイ","Copyright":"© Foto2rich/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/9.566348,100.007721/11?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=9.566348,100.007721;S9;サムイ島&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260302_SamuiThailand%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260302_SamuiThailand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b5%e3%83%a0%e3%82%a4%e5%b3%b6&form=hpcapt&filters=HpDate:\"20260301_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260302_SamuiThailand"},"Ssd":"20260302","Name":"SamuiThailand","Market":"JA-JP","Hash":"8871404355","FullDateString":"2026 年 3月 月 2 日"},{"ImageContent":{"Description":"地中海に浮かぶイビサ島。スペイン・バレアレス諸島に属するこの島は、世界的に有名なリゾート地です。透き通るような青い海と白い砂浜が広がり、白壁の家々が島の各地に点在しています。特に夏には、世界中から観光客や音楽ファンが集まり、クラブやビーチで世界的に有名な DJ によるパーティーが開かれることで知られています。","Image":{"Url":"/th?id=OHR.BalearesDay_JA-JP8835307227_1920x1080.webp","Wallpaper":"/th?id=OHR.BalearesDay_JA-JP8835307227_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"ダンスミュージックの聖地","Title":"イビサ島, スペイン","Copyright":"© tokar/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.964145,1.418331/9?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.964145,1.418331;S9;イビサ島, スペイン&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260301_BalearesDay%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260301_BalearesDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a4%e3%83%93%e3%82%b5%e5%b3%b6&form=hpcapt&filters=HpDate:\"20260228_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260301_BalearesDay"},"Ssd":"20260301","Name":"BalearesDay","Market":"JA-JP","Hash":"8835307227","FullDateString":"2026 年 3月 月 1 日"},{"ImageContent":{"Description":"ハワイ諸島の中でも、手つかずの自然が色濃く残るモロカイ島。約 670km² の面積を誇り、険しい尾根と深い谷が連なるこの島は、100 万年以上前の火山活動によって形成されました。そして画像は、島の北海岸に位置するオロウペナ滝。米国で最も高く、世界でも四番目の高さを誇るこの滝は、落差約 900m に達します。緑の断崖絶壁から流れ落ちるその姿は、荘厳でありながら繊細な美しさを感じさせます。","Image":{"Url":"/th?id=OHR.OloupenaFalls_JA-JP0587758979_1920x1080.webp","Wallpaper":"/th?id=OHR.OloupenaFalls_JA-JP0587758979_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"緑の断崖絶壁から流れ落ちる白糸","Title":"オロウペナ滝, 米国 ハワイ州","Copyright":"© Andrew Aylett/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/21.160559,-156.856293/9?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=21.160559,-156.856293;S9;オロウペナ滝, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260228_Olo’upenaFalls%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260228_OloupenaFalls\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%aa%e3%83%ad%e3%82%a6%e3%83%9a%e3%83%8a%e6%bb%9d&form=hpcapt&filters=HpDate:\"20260227_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260228_OloupenaFalls"},"Ssd":"20260228","Name":"OloupenaFalls","Market":"JA-JP","Hash":"0587758979","FullDateString":"2026 年 2月 月 28 日"},{"ImageContent":{"Description":"今日2月27日は国際ホッキョクグマの日。氷の世界に生きる世界最大の陸上肉食動物ホッキョクグマの保護を目的とした記念日です。気候変動による海氷の減少が進み、ホッキョクグマのライフサイクルは深刻な影響を受けています。二酸化炭素排出量の削減や保護活動への取り組みは、ホッキョクグマが生息する北極圏の自然環境を守るために欠かせません。","Image":{"Url":"/th?id=OHR.ArcitcCub_JA-JP8771161198_1920x1080.webp","Wallpaper":"/th?id=OHR.ArcitcCub_JA-JP8771161198_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は国際ホッキョクグマの日","Title":"ホッキョクグマの子, 米国 アラスカ州","Copyright":"© Steven Kazlowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/68.75,-143.5/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=68.75,-143.5;S9;北極圏の自然環境, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260227_ArcitcCub%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260227_ArcitcCub\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%9b%e3%83%83%e3%82%ad%e3%83%a7%e3%82%af%e3%82%b0%e3%83%9e%e3%81%ae%e5%ad%90&form=hpcapt&filters=HpDate:\"20260226_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260227_ArcitcCub"},"Ssd":"20260227","Name":"ArcitcCub","Market":"JA-JP","Hash":"8771161198","FullDateString":"2026 年 2月 月 27 日"},{"ImageContent":{"Description":"米国アリゾナ州に位置するグランドキャニオン国立公園は、1919 年の今日、2 月 26 日に国立公園に指定されました。この公園は、コロラド川が数百万年にわたって削り出した壮大な峡谷で形成されており、299 種以上の野鳥や 74 種の哺乳動物など、多種多様な動物が多く生息しています。また、世界で最も多くの化石が発見された場所でもあり、1979 年には世界遺産に登録されました。","Image":{"Url":"/th?id=OHR.GrandSunset_JA-JP8711394757_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandSunset_JA-JP8711394757_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は米国グランドキャニオン国立公園の記念日","Title":"グランドキャニオン国立公園, 米国 アリゾナ州","Copyright":"© Matt Anderson Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/36.05159,-112.106194/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=36.05159,-112.106194;S9;グランドキャニオン国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260226_GrandSunset%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260226_GrandSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b0%e3%83%a9%e3%83%b3%e3%83%89%e3%82%ad%e3%83%a3%e3%83%8b%e3%82%aa%e3%83%b3%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260225_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260226_GrandSunset"},"Ssd":"20260226","Name":"GrandSunset","Market":"JA-JP","Hash":"8711394757","FullDateString":"2026 年 2月 月 26 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"東日本大震災から今日で 15 年。画像は、2016 年に宮城県名取市で行われた追悼イベントにおいて、市役所の周りに飾られた犠牲者への追悼と復興を願う灯籠です。震災当時、名取市のおよそ 27% が津波によって浸水し、特に沿岸部に位置する閖上地区は壊滅的な被害を受けました。それから 15 年、地元の人々の努力によって、かわまちてらす閖上の建設をはじめ、復興へと歩み続けています。","Image":{"Url":"/th?id=OHR.TohokuEarthquakeMemorial2026_JA-JP5225999611_1920x1080.webp","Wallpaper":"/th?id=OHR.TohokuEarthquakeMemorial2026_JA-JP5225999611_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"東日本大震災から15年","Title":"復興の願いが書かれた灯籠, 宮城県 名取市","Copyright":"© NurPhoto/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.196004,140.881161/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.196004,140.881161;S9;名取市&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260311_TohokuEarthquakeMemorial2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260311_TohokuEarthquakeMemorial2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%9d%b1%e6%97%a5%e6%9c%ac%e5%a4%a7%e9%9c%87%e7%81%bd%e3%81%8b%e3%82%8915%e5%b9%b4&form=hpcapt&filters=HpDate:\"20260310_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260311_TohokuEarthquakeMemorial2026"},"Ssd":"20260311","Name":"TohokuEarthquakeMemorial2026","Market":"JA-JP","Hash":"5225999611","FullDateString":"2026 年 3月 月 11 日"},{"ImageContent":{"Description":"ここは、アイスランドのクヴェラヴェトリル地熱地帯。地中深くの熱が氷に覆われた大地と出会い、噴気孔から湯気が立ち上るという、まるで異なる惑星のような光景が広がります。特に、水中に浮遊するシリカなどのミネラル粒子が光を散乱させることでブルーに輝く温泉「ブラゥクヴェル」がひときわ目を引きます。かつては、高地を行き交う旅人の休息地として利用されていたもので、今もその独特で神秘的な姿を保ち続けています。","Image":{"Url":"/th?id=OHR.SpringIceland_JA-JP4910368485_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringIceland_JA-JP4910368485_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"神秘的な青を湛える地熱のプール","Title":"クヴェラヴェトリル地熱地帯の地熱プール, アイスランド","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/64.865398,-19.559103/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=64.865398,-19.559103;S9;フヴェリル地熱地帯, アイスランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260310_SpringIceland%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260310_SpringIceland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%af%e3%83%b4%e3%82%a7%e3%83%a9%e3%83%b4%e3%82%a7%e3%83%88%e3%83%aa%e3%83%ab%e5%9c%b0%e7%86%b1%e5%9c%b0%e5%b8%af%e3%81%ae%e5%9c%b0%e7%86%b1%e3%83%97%e3%83%bc%e3%83%ab&form=hpcapt&filters=HpDate:\"20260309_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260310_SpringIceland"},"Ssd":"20260310","Name":"SpringIceland","Market":"JA-JP","Hash":"4910368485","FullDateString":"2026 年 3月 月 10 日"},{"ImageContent":{"Description":"米国では夏時間が始まった直後に「全国昼寝の日」が訪れます。時計が 1 時間進むことで睡眠不足になりやすく、乱れた体内リズムを整えるため短い休息をとることを促しています。画像はスコットランド沿岸で休むアザラシ。水中では浮上して呼吸するために浅く短く眠り、海岸では深く休息します。人も動物も、適切な休息が環境の変化に順応する助けとなります。","Image":{"Url":"/th?id=OHR.NappingSeal_JA-JP4638317955_1920x1080.webp","Wallpaper":"/th?id=OHR.NappingSeal_JA-JP4638317955_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は米国の全国昼寝の日","Title":"アザラシ, スコットランド","Copyright":"© Andrew Mason/Minden Pictures","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/59,-3/9?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=59,-3;S9;オークニー諸島, スコットランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260309_NappingSeal%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260309_NappingSeal\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%82%b6%e3%83%a9%e3%82%b7&form=hpcapt&filters=HpDate:\"20260308_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260309_NappingSeal"},"Ssd":"20260309","Name":"NappingSeal","Market":"JA-JP","Hash":"4638317955","FullDateString":"2026 年 3月 月 9 日"},{"ImageContent":{"Description":"今日から米国の多くの地域で夏時間が始まります。時計を 1 時間進めることで日が暮れるまでの時間を増やす、というこの制度は、第一次世界大戦中の省エネルギー対策として導入されました。そして、今日の画像は、16 世紀に設置されたドイツ・ウルム市庁舎の天文時計です。法廷時刻ではなく、太陽や月の周期を計測して時を示すものであり、日の光が人の手による時刻表ではなく、天文学によって支配されていることを静かに物語っています。","Image":{"Url":"/th?id=OHR.UlmClock_JA-JP3640087811_1920x1080.webp","Wallpaper":"/th?id=OHR.UlmClock_JA-JP3640087811_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"米国は今日から夏時間","Title":"ウルム市庁舎の天文時計, ドイツ","Copyright":"© Tomekbudujedomek/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.397026,9.993355/12?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=48.397026,9.993355;S9;ウルム市庁舎の天文時計, ドイツ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260308_UlmClock%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260308_UlmClock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a6%e3%83%ab%e3%83%a0%e5%b8%82%e5%ba%81%e8%88%8e%e3%81%ae%e5%a4%a9%e6%96%87%e6%99%82%e8%a8%88&form=hpcapt&filters=HpDate:\"20260307_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260308_UlmClock"},"Ssd":"20260308","Name":"UlmClock","Market":"JA-JP","Hash":"3640087811","FullDateString":"2026 年 3月 月 8 日"},{"ImageContent":{"Description":"エル・カズネ（宝物殿）は、ヨルダンにある古代都市ペトラを代表する建造物の一つです。1 世紀にナバテア人が砂岩の岩肌を彫って造ったもので、ファサードと呼ばれる正面部分は、高さ約 40m を誇ります。現在も驚くほど良好な保存状態を保っており、岩から生まれた都市ペトラの壮大さを伝えています。","Image":{"Url":"/th?id=OHR.PetraTomb_JA-JP3426866239_1920x1080.webp","Wallpaper":"/th?id=OHR.PetraTomb_JA-JP3426866239_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"峡谷の静寂に佇む古代の石遺構","Title":"エル・カズネ, ヨルダン","Copyright":"© Frédéric Soltan/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/30.32206,35.45145/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=30.32206,35.45145;S9;アル・カズネ, ヨルダン&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260307_PetraTomb%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260307_PetraTomb\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a8%e3%83%ab%e3%83%bb%e3%82%ab%e3%82%ba%e3%83%8d&form=hpcapt&filters=HpDate:\"20260306_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260307_PetraTomb"},"Ssd":"20260307","Name":"PetraTomb","Market":"JA-JP","Hash":"3426866239","FullDateString":"2026 年 3月 月 7 日"},{"ImageContent":{"Description":"今日の画像は、デンマーク南部の港町ヴァイレにある「ザ・ウェイブ」。波形が特徴的なこの建物は、9 階建ての集合住宅であり、各棟には 20 戸の住戸が設けられています。デンマークを代表する建築家、ヘニング・ラーセンが設計したもので、2018 年に完成しました。住宅として機能しながら、自然環境と調和する造形が高く評価され、現代デンマーク建築を代表するランドマークとなっています。","Image":{"Url":"/th?id=OHR.WaveDenmark_JA-JP3181035967_1920x1080.webp","Wallpaper":"/th?id=OHR.WaveDenmark_JA-JP3181035967_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水辺に波打つ集合住宅","Title":"集合住宅「ザ・ウェイブ」, デンマーク","Copyright":"© Frank Bach/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/55.709099,9.5561/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=55.709099,9.5561;S9;ザ・ウェイブ, デンマーク&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260306_WaveDenmark%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260306_WaveDenmark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9b%86%e5%90%88%e4%bd%8f%e5%ae%85%e3%80%8c%e3%82%b6%e3%83%bb%e3%82%a6%e3%82%a7%e3%82%a4%e3%83%96%e3%80%8d&form=hpcapt&filters=HpDate:\"20260305_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260306_WaveDenmark"},"Ssd":"20260306","Name":"WaveDenmark","Market":"JA-JP","Hash":"3181035967","FullDateString":"2026 年 3月 月 6 日"},{"ImageContent":{"Description":"ここは、トルコ・カッパドキア地方の中心に位置するギョレメ国立公園。火山活動によって生まれた地形を風や水が何千年もかけて削った「妖精の煙突」と呼ばれる奇岩群で知られています。また、岩を掘って造られた住居や教会が点在します。そして教会内部には 11 世紀頃に完成したフレスコ画が多数残されており、「ギョレメ国立公園とカッパドキアの岩窟群」として世界遺産に登録されています。地質と文化、現代の暮らしが交差するカッパドキア観光の玄関口です。","Image":{"Url":"/th?id=OHR.GoremeTwilight_JA-JP8961447363_1920x1080.webp","Wallpaper":"/th?id=OHR.GoremeTwilight_JA-JP8961447363_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"奇岩の谷に広がる幻想的な夜景","Title":"ギョレメ国立公園, トルコ","Copyright":"© ONNAJA/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.64296,34.828777/13?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.64296,34.828777;S9;ギョレメ国立公園, トルコ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260305_GoremeTwilight%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260305_GoremeTwilight\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ae%e3%83%a7%e3%83%ac%e3%83%a1%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260304_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260305_GoremeTwilight"},"Ssd":"20260305","Name":"GoremeTwilight","Market":"JA-JP","Hash":"8961447363","FullDateString":"2026 年 3月 月 5 日"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"今日の画像","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"詳細情報","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"今すぐ寄付","LOC_HOMEPAGE_VERTICAL_SCRO