{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-05-26T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"春が訪れると、米国・北カリフォルニアの風景は、青や紫、白に彩られたルピナスの花々によって鮮やかに一変します。ルピナスは、世界に 200 種以上が分布し、海岸沿いから山地の草原まで、多様な環境に生息しています。ただ美しく咲くだけではなく、ミツバチやチョウ、カブトムシなどにとって重要な食糧源となるほか、土壌を豊かにし、栄養分の乏しい環境でも周囲の植物の生育を助けるという役割を果たしています。","Image":{"Url":"/th?id=OHR.LupineBloom_JA-JP9737515603_1920x1080.webp","Wallpaper":"/th?id=OHR.LupineBloom_JA-JP9737515603_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一面に咲き広がる青いルピナス","Title":"ルピナスの花, 米国 カリフォルニア州","Copyright":"© Jeffrey Lewis/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/37.254669,-119.617271/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=37.254669,-119.617271;S9;米国 カリフォルニア州&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260526_LupineBloom%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260526_LupineBloom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%ab%e3%83%94%e3%83%8a%e3%82%b9%e3%81%ae%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260525_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260526_LupineBloom"},"Ssd":"20260526","Name":"LupineBloom","Market":"JA-JP","Hash":"9737515603","FullDateString":"2026 年 5月 月 26 日"},{"ImageContent":{"Description":"今日の画像は、トゥール・マウル（大塔）灯台です。1845 年、ウェールズのイニス・ランドゥイン島南西端に建設された高さ 10m の塔で、円錐形の構造が特徴です。かつてはメナイ海峡の航行の目印として使われていましたが、1975 年に近くのトゥール・バック（小塔）灯台へ役割が引き継がれました。現在はイギリスにおける特別な建造物「イギリス指定建造物」として保存されています。","Image":{"Url":"/th?id=OHR.TwrMawrLighthouse2026_JA-JP9539215085_1920x1080.webp","Wallpaper":"/th?id=OHR.TwrMawrLighthouse2026_JA-JP9539215085_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"小道の先に佇む灯台","Title":"トゥール・マウル灯台, ウェールズ","Copyright":"© Lukas Bischoff/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/53.13707,-4.412761/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=53.13707,-4.412761;S9;トゥール・マウル灯台, ウェールズ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260525_TwrMawrLighthouse2026 %22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260525_TwrMawrLighthouse2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%88%e3%82%a5%e3%83%bc%e3%83%ab%e3%83%bb%e3%83%9e%e3%82%a6%e3%83%ab%e7%81%af%e5%8f%b0&form=hpcapt&filters=HpDate:\"20260524_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260525_TwrMawrLighthouse2026"},"Ssd":"20260525","Name":"TwrMawrLighthouse2026","Market":"JA-JP","Hash":"9539215085","FullDateString":"2026 年 5月 月 25 日"},{"ImageContent":{"Description":"今日 5 月 24 日は「ヨーロッパ公園の日」。1909 年にスウェーデンでヨーロッパ初の国立公園が設立されたことを記念する日であり、自然保護の重要性や持続可能な地域づくりへの意識を高める日でもあります。そして画像は、イタリアのドロミーティに広がるトレ・チーメ自然公園です。1981 年に設立されたこの公園は、アルプスを代表する景観の一つである岩山群「トレ・チーメ・ディ・ラヴァレード」で知られています。","Image":{"Url":"/th?id=OHR.DolomitesPark_JA-JP9299187350_1920x1080.webp","Wallpaper":"/th?id=OHR.DolomitesPark_JA-JP9299187350_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はヨーロッパの公園の日","Title":"トレ・チーメ自然公園, イタリア","Copyright":"© Adisorn Fineday Chutikunakorn/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/46.643931,12.343052/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=46.643931,12.343052;S9;トレ・チーメ自然公園, イタリア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260524_DolomitesPark%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260524_DolomitesPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=European+Day+of+Parks&form=hpcapt&filters=HpDate:\"20260523_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260524_DolomitesPark"},"Ssd":"20260524","Name":"DolomitesPark","Market":"JA-JP","Hash":"9299187350","FullDateString":"2026 年 5月 月 24 日"},{"ImageContent":{"Description":"今日 5 月 23 日は世界カメの日。カメは、約 2 億年前に出現したと考えられていますが、現在は、生息地の汚染や喪失、乱獲などの影響を受け、一部の種は絶滅が危惧されています。カメは、ペットとしても人気ですが、ウミガメが藻場やサンゴ礁を健全な状態に保つのに貢献したり、淡水や陸のカメが生態系のバランスを支えていたりするなど、生物多様性の保全にも欠かせません。今日は、そんな彼らに対する知識を深め、その保護の重要性を認識する日です。","Image":{"Url":"/th?id=OHR.ThreeTurtlesButterflies_JA-JP9111323268_1920x1080.webp","Wallpaper":"/th?id=OHR.ThreeTurtlesButterflies_JA-JP9111323268_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界カメの日","Title":"カメと蝶","Copyright":"© Patrick Gallet/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"アマゾンでは、蝶がカメの涙を吸ってミネラルをとります。これを「吸水行動」と呼びます。","LinkUrl":"/search?q=%e3%82%ab%e3%83%a1%e3%81%8c%e6%b6%99%e3%82%92%e6%b5%81%e3%81%99%e7%90%86%e7%94%b1%e3%81%af%ef%bc%9f&form=hpvsfa","LinkText":"カメが涙を流す理由は？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260523_ThreeTurtlesButterflies\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e3%82%ab%e3%83%a1%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260522_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260523_ThreeTurtlesButterflies"},"Ssd":"20260523","Name":"ThreeTurtlesButterflies","Market":"JA-JP","Hash":"9111323268","FullDateString":"2026 年 5月 月 23 日"},{"ImageContent":{"Description":"今日、5 月 22 日は東京スカイツリーの開業記念日です。タワーとしては世界第 1 位となる高さ 634m を誇り、電波塔という本来の役割を超え、東京を象徴するランドマークとして、国内外から多くの来訪者を集めています。館内は 7 月 6 日まで、14 周年記念の装飾が施されており、開業記念日当日には、公式キャラクターによるグリーティングや特別ライティングの点灯も行われます。","Image":{"Url":"/th?id=OHR.TokyoSkyTreeDay2026_JA-JP8960437090_1920x1080.webp","Wallpaper":"/th?id=OHR.TokyoSkyTreeDay2026_JA-JP8960437090_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"スカイツリー開業から 14 年","Title":"東京スカイツリー, 東京","Copyright":"© GoranQ/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.710404,139.810706/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.710404,139.810706;S9;東京スカイツリー&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260522_TokyoSkyTreeDay2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260522_TokyoSkyTreeDay2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%9d%b1%e4%ba%ac%e3%82%b9%e3%82%ab%e3%82%a4%e3%83%84%e3%83%aa%e3%83%bc%e9%96%8b%e6%a5%ad%e8%a8%98%e5%bf%b5%e6%97%a5&form=hpcapt&filters=HpDate:\"20260521_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260522_TokyoSkyTreeDay2026"},"Ssd":"20260522","Name":"TokyoSkyTreeDay2026","Market":"JA-JP","Hash":"8960437090","FullDateString":"2026 年 5月 月 22 日"},{"ImageContent":{"Description":"今日 5 月 21 日は国際連合が定める「国際お茶の日」。そして画像は、中国・四川省の段々畑の茶畑です。この地域は茶文化の発祥地の一つとされており、何世紀にもわたってお茶が栽培されてきました。また、近隣の蒙山は約 2000 年前、西漢の時代に甘露寺の普慧禅師（呉理真）が茶樹を植えて、世界で初めて体系的な茶の栽培を行った地ともいわれています。","Image":{"Url":"/th?id=OHR.SichuanTea_JA-JP8777846900_1920x1080.webp","Wallpaper":"/th?id=OHR.SichuanTea_JA-JP8777846900_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は国際お茶の日","Title":"四川省の茶畑, 中国","Copyright":"© lzf/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/30,103/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=30,103;S9;四川省, 中国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260521_SichuanTea%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260521_SichuanTea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%9a%9b%e3%81%8a%e8%8c%b6%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260520_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260521_SichuanTea"},"Ssd":"20260521","Name":"SichuanTea","Market":"JA-JP","Hash":"8777846900","FullDateString":"2026 年 5月 月 21 日"},{"ImageContent":{"Description":"今日 5 月 20 日は「世界ミツバチの日」。2017 年 12 月に国連総会で制定されました。そして、今日の画像はマルハナバチ。飛行筋を震わせて花粉を落とす「振動受粉（バズ・ポリネーション）」という独特の方法で植物を受粉させます。こうした花粉を媒介する動物は花粉媒介者と呼ばれており、世界の主要な食用作物の 75% 以上に関与し、収量や品質の向上に貢献しています。近年は、生息地の喪失や気候変動などによって減少が進んでいるため、生物多様性と食料の安定供給のためにも、この小さな働き者を保護することが重要となっています。","Image":{"Url":"/th?id=OHR.BumbleBee_JA-JP8551190250_1920x1080.webp","Wallpaper":"/th?id=OHR.BumbleBee_JA-JP8551190250_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界ミツバチの日","Title":"受粉しているマルハナバチ, イングランド","Copyright":"© SimonEastwood87/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.192932,-2.221088/10?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=52.192932,-2.221088;S9;ウスター市, イングランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260520_BumbleBee%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260520_BumbleBee\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e3%83%9f%e3%83%84%e3%83%90%e3%83%81%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260519_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260520_BumbleBee"},"Ssd":"20260520","Name":"BumbleBee","Market":"JA-JP","Hash":"8551190250","FullDateString":"2026 年 5月 月 20 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今日 6 月 2 日は横浜開港記念日。かつて、200 年以上に渡り鎖国していた日本は、1854 年に米国と日米和親条約を結んで開国しました。そして、1858 年に締結された安政の五カ国条約に基づき、1859 年 7 月 1 日（安政 6 年 6 月 2 日）に横浜港が開港しました。毎年この日に合わせて、横浜港では「横浜開港祭」が行われます。そして、今日の画像は、そんな横浜港を取り囲む計画都市、みなとみらい 21 地区です。1989 年の横浜博覧会を契機に本格的な開発が行われた地区であり、現在では横浜都心に指定され、観光・ビジネス・文化の拠点へと成長しています。","Image":{"Url":"/th?id=OHR.YokohamaPort2026_JA-JP8907488905_1920x1080.webp","Wallpaper":"/th?id=OHR.YokohamaPort2026_JA-JP8907488905_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は横浜開港記念日","Title":"みなとみらい 21 地区, 神奈川県 横浜市","Copyright":"© simpletun/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.462246,139.63147/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.462246,139.63147;S9;みなとみらい 21 地区&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260602_YokohamaPort2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260602_YokohamaPort2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%a8%aa%e6%b5%9c%e9%96%8b%e6%b8%af%e8%a8%98%e5%bf%b5%e6%97%a5&form=hpcapt&filters=HpDate:\"20260601_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260602_YokohamaPort2026"},"Ssd":"20260602","Name":"YokohamaPort2026","Market":"JA-JP","Hash":"8907488905","FullDateString":"2026 年 6月 月 2 日"},{"ImageContent":{"Description":"今日の画像は、中国青海省の柴達木盆地に広がる西タイジナール湖（西台吉乃爾湖）。国道 315 号線によって分断され、同じ塩湖でありながら片方は濃い青色、もう片方は淡い緑色という幻想的な湖です。標高約 2700m の乾燥地帯に位置しており、土地の堆積物に含まれているミネラル濃度の違いによって、この独特の色合いが生み出されています。荒涼とした大地に広がる美しいこの湖は人気の観光地であり、中国屈指の絶景として知られています。","Image":{"Url":"/th?id=OHR.Qinghai_JA-JP8687946851_1920x1080.webp","Wallpaper":"/th?id=OHR.Qinghai_JA-JP8687946851_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"二つの世界をつなぐ一本道","Title":"西タイジナール湖, 中国","Copyright":"© Kaicheng Xu/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.668594,96.043144/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.668594,96.043144;S9;青海省, 中国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260601_Qinghai %22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260601_Qinghai\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Xitai+Jinaier+Lake&form=hpcapt&filters=HpDate:\"20260531_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260601_Qinghai"},"Ssd":"20260601","Name":"Qinghai","Market":"JA-JP","Hash":"8687946851","FullDateString":"2026 年 6月 月 1 日"},{"ImageContent":{"Description":"今日 5 月 31 日は、「米国の湿地月間」の最終日です。湿地の重要性を啓蒙するため 1991 年に創設されました。そして画像は、米国フロリダ州のエバーグレーズ国立公園。約 6100km² の面積を誇る米国最大の亜熱帯地域として知られており、園内には広大な湿地が存在します。この湿地が、炭素の蓄積や水質浄化を行うことで、絶滅危惧種のマナティーやフロリダパンサーなど、多様な生物の生息に重要な役割を果たしています。","Image":{"Url":"/th?id=OHR.EvergladesWetlands_JA-JP7977535602_1920x1080.webp","Wallpaper":"/th?id=OHR.EvergladesWetlands_JA-JP7977535602_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は米国の湿地月間の最終日","Title":"エバーグレーズ国立公園, 米国 フロリダ州","Copyright":"© Tetra Images/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.286623,-80.898659/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=25.286623,-80.898659;S9;エバーグレーズ国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260531_EvergladesWetlands%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260531_EvergladesWetlands\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%b1%b3%e5%9b%bd%e3%81%ae%e6%b9%bf%e5%9c%b0%e6%9c%88%e9%96%93&form=hpcapt&filters=HpDate:\"20260530_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260531_EvergladesWetlands"},"Ssd":"20260531","Name":"EvergladesWetlands","Market":"JA-JP","Hash":"7977535602","FullDateString":"2026 年 5月 月 31 日"},{"ImageContent":{"Description":"今日の画像は、ナミビアのエトーシャ国立公園で撮影されたサバンナシマウマの子ども。大自然に生きるシマウマは、常にライオンやチーター、ヒョウといった捕食者に狙われています。そんな環境で少しでも生存率を上げるため、シマウマの子どもは生まれて数分で立ち上がり、数時間後には自分の足で歩き始めます。彼らの特徴的な黒と白の縞模様については諸説ありますが、近年では吸血性のハエなどの虫を避ける効果が最も有力な説とされています。一方で、捕食者の視覚をかく乱する可能性も指摘されています。","Image":{"Url":"/th?id=OHR.EquusQuagga_JA-JP7756090544_1920x1080.webp","Wallpaper":"/th?id=OHR.EquusQuagga_JA-JP7756090544_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けに佇む若いシマウマ","Title":"サバンナシマウマの子馬, ナミビア","Copyright":"© Sharon Heald/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-18.98073,15.762634/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-18.98073,15.762634;S9;エトーシャ国立公園, ナミビア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260530_EquusQuagga%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260530_EquusQuagga\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b5%e3%83%90%e3%83%b3%e3%83%8a%e3%82%b7%e3%83%9e%e3%82%a6%e3%83%9e%e3%81%ae%e5%ad%90%e9%a6%ac&form=hpcapt&filters=HpDate:\"20260529_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260530_EquusQuagga"},"Ssd":"20260530","Name":"EquusQuagga","Market":"JA-JP","Hash":"7756090544","FullDateString":"2026 年 5月 月 30 日"},{"ImageContent":{"Description":"今日の画像はエベレスト。ネパールと中国の国境にまたがる世界最高峰の山です。そして、今日 5 月 29 日は、そんなエベレストの登頂に人類が初めて成功した日です。1953 年、ニュージーランド出身の登山家エドモンド・ヒラリーと、ネパール出身のテンジン・ノルゲイによって達成されました。初登頂以降も、様々な国の登山家たちが登頂に挑み、1970 年に、松浦輝夫と植村直己の二人が日本人初の登頂に成功しました。また、2013 年に登頂に成功した日本人登山家・三浦雄一郎は、世界最高齢の登頂成功者として記録されています。","Image":{"Url":"/th?id=OHR.SummitEverest_JA-JP1474604254_1920x1080.webp","Wallpaper":"/th?id=OHR.SummitEverest_JA-JP1474604254_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はエベレスト登頂記念日","Title":"エベレスト, ネパール","Copyright":"© fotoVoyager/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/27.980471,86.880623/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=27.980471,86.880623;S9;エベレスト, ネパール&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260529_SummitEverest%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260529_SummitEverest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a8%e3%83%99%e3%83%ac%e3%82%b9%e3%83%88%e5%88%9d%e7%99%bb%e9%a0%82&form=hpcapt&filters=HpDate:\"20260528_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260529_SummitEverest"},"Ssd":"20260529","Name":"SummitEverest","Market":"JA-JP","Hash":"1474604254","FullDateString":"2026 年 5月 月 29 日"},{"ImageContent":{"Description":"今日の画像は、韓国・水原市にある水原華城の城壁です。朝鮮王朝の 22 代国王・正祖によって 1794 年から 1796 年にかけて造られました。効率的な統治を目指す正祖の理念を体現した城であり、東洋と西洋の技術が融合した当時最先端の建築物でした。地形に沿って築かれた城壁や、防御と通信を兼ねた設計は今も良好な状態で残っており、1997 年に世界遺産に登録されました。","Image":{"Url":"/th?id=OHR.HwaesongFortress_JA-JP0157517591_1920x1080.webp","Wallpaper":"/th?id=OHR.HwaesongFortress_JA-JP0157517591_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕空に溶け込む城壁","Title":"スウォンファソン, 韓国 水原市","Copyright":"© aomam/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/37.289031,127.014114/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=37.289031,127.014114;S9;スウォンファソン, 韓国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260528_HwaseongFortress%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260528_HwaesongFortress\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b9%e3%82%a6%e3%82%a9%e3%83%b3%e3%83%95%e3%82%a1%e3%82%bd%e3%83%b3&form=hpcapt&filters=HpDate:\"20260527_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260528_HwaesongFortress"},"Ssd":"20260528","Name":"HwaesongFortress","Market":"JA-JP","Hash":"0157517591","FullDateString":"2026 年 5月 月 28 日"},{"ImageContent":{"Description":"今日 5 月 27 日は世界カワウソの日。カワウソの保護を呼びかけるために設けられた記念日で、毎年 5 月の最終水曜日に祝われます。そして画像は、米国・アラスカ州カチェマック湾を泳ぐラッコ。ラッコは「海のカワウソ」とも呼ばれるカワウソの仲間であり、同じイタチ科の動物です。ウニを捕食することでコンブ林（海藻林）のバランスを保ち、海の生態系と生物多様性を支えています。しかし、生息地の破壊や水質汚染により多くの種が絶滅の危機にあります。","Image":{"Url":"/th?id=OHR.OtterDay_JA-JP9963461992_1920x1080.webp","Wallpaper":"/th?id=OHR.OtterDay_JA-JP9963461992_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界カワウソの日","Title":"ラッコ, 米国 アラスカ州","Copyright":"© roclwyr/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/59.725746,-151.141037/10?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=59.725746,-151.141037;S9;カチェマック湾, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260527_OtterDay%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260527_OtterDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e3%82%ab%e3%83%af%e3%82%a6%e3%82%bd%e3%81%ae%e6%97%a5&form=