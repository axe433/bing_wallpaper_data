{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-31T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"ここは米国カリフォルニア州のセントラル・バレー。現在は約 5 万 km² の面積を誇る世界有数の農業地帯ですが、かつては原生の野花に覆われた草原でした。今でも春になると、カリフォルニアポピーをはじめ、さまざまな野花が芽吹き、色とりどりの花が咲き乱れます。数週間だけ、現代の農地と、かつて野花に覆われていた草原の風景が重なって現れます。","Image":{"Url":"/th?id=OHR.WildflowerValley_JA-JP7238318324_1920x1080.webp","Wallpaper":"/th?id=OHR.WildflowerValley_JA-JP7238318324_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"丘陵を染める一面の野生花","Title":"セントラル・バレー, 米国 カリフォルニア州","Copyright":"© Jeff Lewis/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/40.522843,-122.240585/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=40.522843,-122.240585;S9;セントラル・バレー, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260401_WildflowerValley%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260401_WildflowerValley\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%bb%e3%83%b3%e3%83%88%e3%83%a9%e3%83%ab%e3%83%bb%e3%83%90%e3%83%ac%e3%83%bc&form=hpcapt&filters=HpDate:\"20260331_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260401_WildflowerValley"},"Ssd":"20260401","Name":"WildflowerValley","Market":"JA-JP","Hash":"7238318324","FullDateString":"2026 年 4月 月 1 日"},{"ImageContent":{"Description":"ここはベトナム中部のフォンニャ・ケバン国立公園の奥深くに広がる洞窟、「天国の洞」です。全長は 30km を超え、アジア最長級の乾燥洞窟のひとつとして知られています。長い年月をかけて形成された高い天井や広大な洞室、複雑で美しい石灰岩の造形が続き、照明に照らされた石柱や鍾乳石が幻想的な景観を演出しています。公開されているのは全体のごく一部に過ぎませんが、洞窟の大半は手つかずのまま保護されています。","Image":{"Url":"/th?id=OHR.ParadiseCave_JA-JP9838102190_1920x1080.webp","Wallpaper":"/th?id=OHR.ParadiseCave_JA-JP9838102190_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"光に照らされた幻想的な洞","Title":"天国の洞, ベトナム","Copyright":"© Pakawat Thongcharoen/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/17.519514,106.222969/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=17.519514,106.222969;S9;天国の洞, ベトナム&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260331_ParadiseCave%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260331_ParadiseCave\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a9%e5%9b%bd%e3%81%ae%e6%b4%9e&form=hpcapt&filters=HpDate:\"20260330_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260331_ParadiseCave"},"Ssd":"20260331","Name":"ParadiseCave","Market":"JA-JP","Hash":"9838102190","FullDateString":"2026 年 3月 月 31 日"},{"ImageContent":{"Description":"アネハヅルは、ツル科の中で比較的小さな鳥です。カザフスタンやモンゴル、中国北部の温帯域で繁殖し、インドや北東アフリカ、中東などの温暖な地域へ渡って越冬します。ほっそりとした体つきと美しい羽色、息の合った精巧な求愛ダンスで知られており、草原や湿地など幅広い環境に適応して暮らしています。日本にも稀に迷鳥として渡来することがあり、江戸時代には将軍へ献上されたという記録と絵図が残されています。","Image":{"Url":"/th?id=OHR.IndiaCranes_JA-JP0130275400_1920x1080.webp","Wallpaper":"/th?id=OHR.IndiaCranes_JA-JP0130275400_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"求愛ダンスが得意な鳥","Title":"アネハヅル, インド","Copyright":"© Axel Gomille/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/22.352491,79.363708/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=22.352491,79.363708;S9;インド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260330_IndiaCranes%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260330_IndiaCranes\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%83%8d%e3%83%8f%e3%83%85%e3%83%ab&form=hpcapt&filters=HpDate:\"20260329_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260330_IndiaCranes"},"Ssd":"20260330","Name":"IndiaCranes","Market":"JA-JP","Hash":"0130275400","FullDateString":"2026 年 3月 月 30 日"},{"ImageContent":{"Description":"ペギーズ・コーブは、カナダ東部・ノバスコシア州の荒々しい海岸線に佇む小さな村です。そして、画像は村の象徴的な存在であるペギーズ・ポイント灯台。1868 年に建築された当初は、木造の小屋でしたが、1914 年に現在の姿に建て替えられ、海を見守り続けてきました。この灯台のほか、村にはカラフルな家々が並び、観光地としても知られています。アートギャラリーやクラフトショップが点在し、観光客は活気のあるローカルアートに触れることができるほか、近隣のレストランでは、名物のロブスターが味わえます。","Image":{"Url":"/th?id=OHR.PeggysLighthouse_JA-JP4636734313_1920x1080.webp","Wallpaper":"/th?id=OHR.PeggysLighthouse_JA-JP4636734313_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けの空と海に佇む灯台","Title":"ペギーズ・ポイント灯台, カナダ","Copyright":"© Prashanth Bala/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/44.492264,-63.918158/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=44.492264,-63.918158;S9;ペギーズ・ポイント灯台, カナダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260329_PeggysLighthouse%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260329_PeggysLighthouse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%9a%e3%82%ae%e3%83%bc%e3%82%ba%e3%83%bb%e3%83%9d%e3%82%a4%e3%83%b3%e3%83%88%e7%81%af%e5%8f%b0&form=hpcapt&filters=HpDate:\"20260328_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260329_PeggysLighthouse"},"Ssd":"20260329","Name":"PeggysLighthouse","Market":"JA-JP","Hash":"4636734313","FullDateString":"2026 年 3月 月 29 日"},{"ImageContent":{"Description":"アフリカスイギュウは、タンザニアのサバンナや湿地帯に生息しており、巨大な体と湾曲した角が特徴的な草食動物として知られています。そして、今日の画像はユネスコ世界遺産にも登録されているンゴロンゴロ保全地域で撮影されたアフリカスイギュウ。古代の火山活動によって形成された広大なンゴロンゴロ・クレーターで、彼らは大規模な群れをつくりながら暮らしています。","Image":{"Url":"/th?id=OHR.CapeBuffalo_JA-JP4477954927_1920x1080.webp","Wallpaper":"/th?id=OHR.CapeBuffalo_JA-JP4477954927_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"口ひげのように見える角を持つ動物","Title":"アフリカスイギュウ, タンザニア","Copyright":"© jesuss8/500px/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-3.064646,35.381698/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-3.064646,35.381698;S9;ンゴロンゴロ・クレーター&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260328_CapeBuffalo %22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260328_CapeBuffalo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%83%95%e3%83%aa%e3%82%ab%e3%82%b9%e3%82%a4%e3%82%ae%e3%83%a5%e3%82%a6&form=hpcapt&filters=HpDate:\"20260327_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260328_CapeBuffalo"},"Ssd":"20260328","Name":"CapeBuffalo","Market":"JA-JP","Hash":"4477954927","FullDateString":"2026 年 3月 月 28 日"},{"ImageContent":{"Description":"今日 3 月 27 日は「さくらの日」。日本さくらの会が 1992 年に制定した桜の記念日で、七十二候の「桜始開」の頃にもあたり、暦の上では桜が咲き始める時期とされています。そして、画像の桜並木は、早咲きの桜として知られるカンヒザクラが咲く沖縄で撮影されました。沖縄では、本州とは逆に桜前線が北から南へと南下するのが特徴で、本島北部では、1 月から 2 月上旬にかけて見頃を迎えます。","Image":{"Url":"/th?id=OHR.SakuraDay2026_JA-JP6970025028_1920x1080.webp","Wallpaper":"/th?id=OHR.SakuraDay2026_JA-JP6970025028_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はさくらの日","Title":"日本一早い桜、沖縄","Copyright":"© @hapidayss/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/26.496021,127.961555/12?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=26.496021,127.961555;S9;沖縄&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260327_SakuraDay2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260327_SakuraDay2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%97%a5%e6%9c%ac%e4%b8%80%e6%97%a9%e3%81%84%e6%a1%9c&form=hpcapt&filters=HpDate:\"20260326_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260327_SakuraDay2026"},"Ssd":"20260327","Name":"SakuraDay2026","Market":"JA-JP","Hash":"6970025028","FullDateString":"2026 年 3月 月 27 日"},{"ImageContent":{"Description":"ウエストコースト・トレイルは、カナダ・ブリティッシュコロンビア州バンクーバー島西岸に位置する、全長約 75km に及ぶハイキングコースです。この地域の沿岸は、かつて「太平洋の墓場」と呼ばれるほど難破船事故が多発しており、トレイルは、事故発生時の救助活動に迅速に対応するため、1907 年に整備されました。現在では、世界中のハイカーが憧れる「聖地」の一つとなっています。そして画像は、このトレイルの途中に架かるローガン・クリーク吊り橋です。","Image":{"Url":"/th?id=OHR.LoganCreek_JA-JP4033681513_1920x1080.webp","Wallpaper":"/th?id=OHR.LoganCreek_JA-JP4033681513_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"森に溶け込む吊り橋","Title":"ローガン・クリーク吊り橋, カナダ","Copyright":"© Tandem Stock/Adobe Stock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.742102,-125.618767/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=50.742102,-125.618767;S9;バンクーバー島, カナダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260326_LoganCreek%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260326_LoganCreek\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Logan+Creek+Suspension+Bridge%2c+West+Coast+Trail&form=hpcapt&filters=HpDate:\"20260325_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260326_LoganCreek"},"Ssd":"20260326","Name":"LoganCreek","Market":"JA-JP","Hash":"4033681513","FullDateString":"2026 年 3月 月 26 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"ここは、米国ワシントン州北西部に位置するシアトル。市名は、この地に先住していたネイティブ・アメリカン、スクアミシュ族のシアトル酋長の名前に由来します。古くから貿易港として栄え、グローバルに展開する企業の誕生した地としても知られています。また、緑豊かな森林と自然に囲まれているため、「エメラルド・シティ」の愛称でも親しまれています。","Image":{"Url":"/th?id=OHR.SeattleSunrise_JA-JP6952248899_1920x1080.webp","Wallpaper":"/th?id=OHR.SeattleSunrise_JA-JP6952248899_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けに染まる港と街の景色","Title":"シアトル市のウォーターフロント, 米国 ワシントン州","Copyright":"© Jim Patterson/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/47.60323,-122.330276/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=47.60323,-122.330276;S9;シアトル, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260408_SeattleSunrise%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260408_SeattleSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b7%e3%82%a2%e3%83%88%e3%83%ab%e5%b8%82%e3%81%ae%e3%82%a6%e3%82%a9%e3%83%bc%e3%82%bf%e3%83%bc%e3%83%95%e3%83%ad%e3%83%b3%e3%83%88&form=hpcapt&filters=HpDate:\"20260407_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260408_SeattleSunrise"},"Ssd":"20260408","Name":"SeattleSunrise","Market":"JA-JP","Hash":"6952248899","FullDateString":"2026 年 4月 月 8 日"},{"ImageContent":{"Description":"今日 4 月 7 日は「国際ビーバーデー」です。「森の建築家」などとも呼ばれるビーバーは、丈夫な前歯で木をかじり倒し、それを材料にダムや巣を作って自らの生活環境を整えます。そして、その結果生まれる湿地は、ビーバーのみならず、多くの生きものにとって貴重な生息地となります。今日の画像は、ドイツに生息するヨーロッパビーバー。体重は約 20kg で、特徴的な尾を除いた体長は約 90cm に達し、げっ歯類として最大級の大きさを誇ります。","Image":{"Url":"/th?id=OHR.BeaverPortrait_JA-JP3724788571_1920x1080.webp","Wallpaper":"/th?id=OHR.BeaverPortrait_JA-JP3724788571_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は国際ビーバーデー","Title":"ビーバー, ドイツ","Copyright":"© Andyworks/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.091988,10.380808/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=51.091988,10.380808;S9;ドイツ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260407_BeaverPortrait%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260407_BeaverPortrait\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%93%e3%83%bc%e3%83%90%e3%83%bc&form=hpcapt&filters=HpDate:\"20260406_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260407_BeaverPortrait"},"Ssd":"20260407","Name":"BeaverPortrait","Market":"JA-JP","Hash":"3724788571","FullDateString":"2026 年 4月 月 7 日"},{"ImageContent":{"Description":"今日 4 月 6 日は、「城の日」。1974 年に、4 （し）と 6 （ろ）の語呂合わせから、日本城郭協会が制定した記念日です。そして、今日の画像は青森県の弘前公園の中にある弘前城です。江戸時代初期の 1611 年に築かれた城で、鷹岡城（高岡城）という別名で呼ばれることもあります。当時の天守や櫓などが現存しており、国の重要文化財に指定されています。","Image":{"Url":"/th?id=OHR.CastleBlossoms_JA-JP3550257541_1920x1080.webp","Wallpaper":"/th?id=OHR.CastleBlossoms_JA-JP3550257541_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は城の日","Title":"弘前城, 青森県 弘前市","Copyright":"© Glenn Waters/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/40.607736,140.463899/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=40.607736,140.463899;S9;弘前城&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260406_CastleBlossoms%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260406_CastleBlossoms\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%bc%98%e5%89%8d%e5%9f%8e&form=hpcapt&filters=HpDate:\"20260405_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260406_CastleBlossoms"},"Ssd":"20260406","Name":"CastleBlossoms","Market":"JA-JP","Hash":"3550257541","FullDateString":"2026 年 4月 月 6 日"},{"ImageContent":{"Description":"今日 4 月 5 日は復活祭。イースターなどとも呼ばれており、処刑されたイエス・キリストが復活したことを祝うお祭りです。そして画像は、リトアニアのアーティストが制作した美しい木製の「イースターエッグ」。新たな生命を生み出す卵は、古くから豊作や再生の象徴とされており、復活祭には仲間や家族と卵料理を楽しんだり、カラフルに彩った卵を飾ったりします。","Image":{"Url":"/th?id=OHR.LithuaniaEggs_JA-JP3508325746_1920x1080.webp","Wallpaper":"/th?id=OHR.LithuaniaEggs_JA-JP3508325746_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は復活祭","Title":"カラフルな木製イースターエッグ, リトアニア","Copyright":"© maximkabb/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/54.797957,25.297483/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=54.797957,25.297483;S9;ヴィリニュス&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260405_LithuanianEggs%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260405_LithuaniaEggs\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ab%e3%83%a9%e3%83%95%e3%83%ab%e3%81%aa%e6%9c%a8%e8%a3%bd%e3%82%a4%e3%83%bc%e3%82%b9%e3%82%bf%e3%83%bc%e3%82%a8%e3%83%83%e3%82%b0&form=hpcapt&filters=HpDate:\"20260404_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260405_LithuaniaEggs"},"Ssd":"20260405","Name":"LithuaniaEggs","Market":"JA-JP","Hash":"3508325746","FullDateString":"2026 年 4月 月 5 日"},{"ImageContent":{"Description":"今日 4 月 4 日は二十四節気の「清明」。沖縄では、先祖の供養をしつつ、親戚同士の親睦を深める行事である清明祭（シーミー）が行われます。そして画像は、沖縄のシンボル、首里城の歓会門。城郭内へ入る第一の正門で、1477 ～ 1500 年頃に創建されました。門の名称である「歓会」には「歓迎する」という意味があり、中国皇帝から派遣された使者を丁重にもてなした場所であったことに由来します。","Image":{"Url":"/th?id=OHR.QingmingFestival2026_JA-JP3473610824_1920x1080.webp","Wallpaper":"/th?id=OHR.QingmingFestival2026_JA-JP3473610824_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は清明","Ti