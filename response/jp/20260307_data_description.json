{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-07T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"今日から米国の多くの地域で夏時間が始まります。時計を 1 時間進めることで日が暮れるまでの時間を増やす、というこの制度は、第一次世界大戦中の省エネルギー対策として導入されました。そして、今日の画像は、16 世紀に設置されたドイツ・ウルム市庁舎の天文時計です。法廷時刻ではなく、太陽や月の周期を計測して時を示すものであり、日の光が人の手による時刻表ではなく、天文学によって支配されていることを静かに物語っています。","Image":{"Url":"/th?id=OHR.UlmClock_JA-JP3640087811_1920x1080.webp","Wallpaper":"/th?id=OHR.UlmClock_JA-JP3640087811_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"米国は今日から夏時間","Title":"ウルム市庁舎の天文時計, ドイツ","Copyright":"© Tomekbudujedomek/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.397026,9.993355/12?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=48.397026,9.993355;S9;ウルム市庁舎の天文時計, ドイツ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260308_UlmClock%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260308_UlmClock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a6%e3%83%ab%e3%83%a0%e5%b8%82%e5%ba%81%e8%88%8e%e3%81%ae%e5%a4%a9%e6%96%87%e6%99%82%e8%a8%88&form=hpcapt&filters=HpDate:\"20260307_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260308_UlmClock"},"Ssd":"20260308","Name":"UlmClock","Market":"JA-JP","Hash":"3640087811","FullDateString":"2026 年 3月 月 8 日"},{"ImageContent":{"Description":"ここはドイツのハルツ国立公園にあるブロッケン山。標高 1,141m を誇り、太陽光を背にした登山者の影が霧や雲に映る「ブロッケン現象」で知られています。冷戦期には東ドイツとソ連の監視拠点として利用されていましたが、再統一後に一般開放されました。現在は、約 247km² に広がる森や湿原、清流などの貴重な自然環境が保護されています。また、歴史ある蒸気機関車が今も山腹を走り、国内外から多くの人々を魅了し続けています。","Image":{"Url":"/th?id=OHR.BrockenSunrise_JA-JP0540053898_1920x1080.webp","Wallpaper":"/th?id=OHR.BrockenSunrise_JA-JP0540053898_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"日の出の霧に包まれる岩場","Title":"ブロッケン山, ドイツ","Copyright":"© imageBROKER/AVTG/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.779861,10.523202/10?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=51.779861,10.523202;S9;ハルツ国立公園, ドイツ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260307_BrockenSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%96%e3%83%ad%e3%83%83%e3%82%b1%e3%83%b3%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260306_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260307_BrockenSunrise"},"Ssd":"20260307","Name":"BrockenSunrise","Market":"JA-JP","Hash":"0540053898","FullDateString":"2026 年 3月 月 7 日"},{"ImageContent":{"Description":"今日の画像は、デンマーク南部の港町ヴァイレにある「ザ・ウェイブ」。波形が特徴的なこの建物は、9 階建ての集合住宅であり、各棟には 20 戸の住戸が設けられています。デンマークを代表する建築家、ヘニング・ラーセンが設計したもので、2018 年に完成しました。住宅として機能しながら、自然環境と調和する造形が高く評価され、現代デンマーク建築を代表するランドマークとなっています。","Image":{"Url":"/th?id=OHR.WaveDenmark_JA-JP3181035967_1920x1080.webp","Wallpaper":"/th?id=OHR.WaveDenmark_JA-JP3181035967_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水辺に波打つ集合住宅","Title":"集合住宅「ザ・ウェイブ」, デンマーク","Copyright":"© Frank Bach/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/55.709099,9.5561/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=55.709099,9.5561;S9;ザ・ウェイブ, デンマーク&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260306_WaveDenmark%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260306_WaveDenmark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9b%86%e5%90%88%e4%bd%8f%e5%ae%85%e3%80%8c%e3%82%b6%e3%83%bb%e3%82%a6%e3%82%a7%e3%82%a4%e3%83%96%e3%80%8d&form=hpcapt&filters=HpDate:\"20260305_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260306_WaveDenmark"},"Ssd":"20260306","Name":"WaveDenmark","Market":"JA-JP","Hash":"3181035967","FullDateString":"2026 年 3月 月 6 日"},{"ImageContent":{"Description":"ここは、トルコ・カッパドキア地方の中心に位置するギョレメ国立公園。火山活動によって生まれた地形を風や水が何千年もかけて削った「妖精の煙突」と呼ばれる奇岩群で知られています。また、岩を掘って造られた住居や教会が点在します。そして教会内部には 11 世紀頃に完成したフレスコ画が多数残されており、「ギョレメ国立公園とカッパドキアの岩窟群」として世界遺産に登録されています。地質と文化、現代の暮らしが交差するカッパドキア観光の玄関口です。","Image":{"Url":"/th?id=OHR.GoremeTwilight_JA-JP8961447363_1920x1080.webp","Wallpaper":"/th?id=OHR.GoremeTwilight_JA-JP8961447363_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"奇岩の谷に広がる幻想的な夜景","Title":"ギョレメ国立公園, トルコ","Copyright":"© ONNAJA/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.64296,34.828777/13?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.64296,34.828777;S9;ギョレメ国立公園, トルコ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260305_GoremeTwilight%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260305_GoremeTwilight\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ae%e3%83%a7%e3%83%ac%e3%83%a1%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260304_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260305_GoremeTwilight"},"Ssd":"20260305","Name":"GoremeTwilight","Market":"JA-JP","Hash":"8961447363","FullDateString":"2026 年 3月 月 5 日"},{"ImageContent":{"Description":"ブルガリア最高峰のリラ山脈では、雪の下からクロッカスが咲き始め、春の訪れを告げます。今日の画像は、ブルガリア南西部のリラ国立公園に広がるクロッカスの花です。リラ国立公園は、1992 年に設立されたブルガリア国最大の保護区であり、名高い「リラの七湖」を含む氷河湖群を有しています。また、園内の一部はユネスコの生物圏保護区にも指定されています。","Image":{"Url":"/th?id=OHR.RilaCrocuses_JA-JP8929761168_1920x1080.webp","Wallpaper":"/th?id=OHR.RilaCrocuses_JA-JP8929761168_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"残雪の山に咲く紫の小さな花","Title":"紫クロッカス, ブルガリア","Copyright":"© Maya Karkalicheva/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/42.204161,23.312577/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=42.204161,23.312577;S9;リラの七湖, ブルガリア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260304_RilaCrocuses%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260304_RilaCrocuses\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%b4%ab%e3%82%af%e3%83%ad%e3%83%83%e3%82%ab%e3%82%b9&form=hpcapt&filters=HpDate:\"20260303_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260304_RilaCrocuses"},"Ssd":"20260304","Name":"RilaCrocuses","Market":"JA-JP","Hash":"8929761168","FullDateString":"2026 年 3月 月 4 日"},{"ImageContent":{"Description":"今日 3 月 3 日はひな祭り。竹筒の中に入った可愛らしいひな人形をお届けします。ひな祭りの歴史は古く、諸説ありますが、平安時代に上巳の節句として行われていた、紙で作ったひな人形を川に流す「流しびな」の行事が起源ともいわれています。室町時代になると、現在のひな人形の原型ともいえる「立雛」が登場し、江戸時代になるとひな人形は次第に豪華さを増していきました。現代のような様式となったのは明治以降になります。","Image":{"Url":"/th?id=OHR.HinaMatsuri2026_JA-JP1524445029_1920x1080.webp","Wallpaper":"/th?id=OHR.HinaMatsuri2026_JA-JP1524445029_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はひな祭り","Title":"竹筒から顔をのぞかせる可愛いひな人形","Copyright":"© Bong Grit/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"ひな祭りは､もともと｢上巳｣として中国から伝わった節句で､桃の花が咲く時期であることから、｢桃の節句｣と言われてきました。","LinkUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e3%81%a7%e3%81%af%e6%a1%83%e3%81%ae%e6%9c%a8+%e6%84%8f%e5%91%b3&form=hpvsfa","LinkText":"中国では、桃の木にはどのような意味がある？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260303_HinaMatsuri2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%81%b2%e3%81%aa%e7%a5%ad%e3%82%8a&form=hpcapt&filters=HpDate:\"20260302_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260303_HinaMatsuri2026"},"Ssd":"20260303","Name":"HinaMatsuri2026","Market":"JA-JP","Hash":"1524445029","FullDateString":"2026 年 3月 月 3 日"},{"ImageContent":{"Description":"今日の画像は、タイ南部・サムイ島の港に浮かぶロングテールボート。タイ語で「ルア・ハン・ヤオ」と呼ばれるこの船は、20 世紀初頭に誕生した伝統的な木造船です。エンジンを備え、浅瀬や狭い水路でも高い機動性を発揮します。船首に飾られた鮮やかな色の布や花の装飾は、単なる美化のためではなく、航海の安全と繁栄を願う深い宗教的・信仰的な意味が込められています。","Image":{"Url":"/th?id=OHR.SamuiThailand_JA-JP8871404355_1920x1080.webp","Wallpaper":"/th?id=OHR.SamuiThailand_JA-JP8871404355_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"港に浮かぶロングテールボート","Title":"サムイ島, タイ","Copyright":"© Foto2rich/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/9.566348,100.007721/11?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=9.566348,100.007721;S9;サムイ島&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260302_SamuiThailand%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260302_SamuiThailand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b5%e3%83%a0%e3%82%a4%e5%b3%b6&form=hpcapt&filters=HpDate:\"20260301_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260302_SamuiThailand"},"Ssd":"20260302","Name":"SamuiThailand","Market":"JA-JP","Hash":"8871404355","FullDateString":"2026 年 3月 月 2 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今日の画像は、ホエールウォッチングの名所として知られるカナダ・バンクーバー島にあるパシフィック・リム国立公園です。そして、島の西海岸に位置する町、ユークルエットでは、3 月 14 日から 21 日までパシフィック・リム・ホエール・フェスティバルが開催されます。カリフォルニアの繁殖地から北へ長い旅を続けるコククジラが、島の西海岸近くを通過する春の回遊を祝う催しです。期間中は、海洋教育や野生生物を敬意をもって観察することに重点が置かれます。","Image":{"Url":"/th?id=OHR.PacificRimNP_JA-JP9772026876_1920x1080.webp","Wallpaper":"/th?id=OHR.PacificRimNP_JA-JP9772026876_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"パシフィック・リム・ホエール・フェスティバルが開催中","Title":"パシフィック・リム国立公園, カナダ","Copyright":"© EmilyNorton/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/49.068329,-125.753273/21?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=49.068329,-125.753273;S9;パシフィック・リム国立公園, カナダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260315_PacificRimNP%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260315_PacificRimNP\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%91%e3%82%b7%e3%83%95%e3%82%a3%e3%83%83%e3%82%af%e3%83%bb%e3%83%aa%e3%83%a0%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260314_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260315_PacificRimNP"},"Ssd":"20260315","Name":"PacificRimNP","Market":"JA-JP","Hash":"9772026876","FullDateString":"2026 年 3月 月 15 日"},{"ImageContent":{"Description":"今日 3 月 14 日は円周率の日。円周率の「 3.14 」にちなんだ記念日です。また、天才物理学者アルベルト・アインシュタインの誕生日でもあるため、日本では、「数学の日」にも制定されています。そして今日の画像は、イギリス・コーンウォール地方にある円周率「 π 」を象ったような巨石、「ラニョン・クォイト」。新石器時代に作られたとされる古代遺跡で、文字による数学が生まれる以前から、古代の建築者たちが均衡や測定のために概念的に数学を活用していたことを示しています。","Image":{"Url":"/th?id=OHR.CornwallDolmen_JA-JP6001769606_1920x1080.webp","Wallpaper":"/th?id=OHR.CornwallDolmen_JA-JP6001769606_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は円周率の日","Title":"ラニョン・クォイト, イングランド","Copyright":"© Helen Hotson/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.147726,-5.599093/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=50.147726,-5.599093;S9;ラニョン・クォイト, イングランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260314_CornwallDolmen%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260314_CornwallDolmen\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a9%e3%83%8b%e3%83%a7%e3%83%b3%e3%83%bb%e3%82%af%e3%82%a9%e3%82%a4%e3%83%88&form=hpcapt&filters=HpDate:\"20260313_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260314_CornwallDolmen"},"Ssd":"20260314","Name":"CornwallDolmen","Market":"JA-JP","Hash":"6001769606","FullDateString":"2026 年 3月 月 14 日"},{"ImageContent":{"Description":"今日の画像は、フランス西部の海辺の町レ・サーブル＝ドロンヌにあるノートルダム・ド・ボン＝ポルト教会の天井です。1646 年に造られたもので、町が漁港として発展するにつれて、大洋横断を控えた船乗りたちが祈りを捧げるために立ち寄る場所となりました。ゴシック様式のアーチとルネサンス様式の細部が調和した建築が、建築と信仰、そして海とともに生きてきた人々の暮らしが深く結びついていた時代を現代に伝えています。","Image":{"Url":"/th?id=OHR.VendeeVaults_JA-JP5730260896_1920x1080.webp","Wallpaper":"/th?id=OHR.VendeeVaults_JA-JP5730260896_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"歴史ある聖堂のアーチ","Title":"ノートルダム・ド・ボン＝ポルト教会, フランス","Copyright":"© Helmut Meyer zur Capellen/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/46.496203,-1.786035/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=46.496203,-1.786035;S9;ノートルダム・ド・ボン＝ポルト教会, フランス&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260313_VendeeVaults%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260313_VendeeVaults\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%8e%e3%83%bc%e3%83%88%e3%83%ab%e3%83%80%e3%83%a0%e3%83%bb%e3%83%89%e3%83%bb%e3%83%9c%e3%83%b3%ef%bc%9d%e3%83%9d%e3%83%ab%e3%83%88%e6%95%99%e4%bc%9a&form=hpcapt&filters=HpDate:\"20260312_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260313_VendeeVaults"},"Ssd":"20260313","Name":"VendeeVaults","Market":"JA-JP","Hash":"5730260896","FullDateString":"2026 年 3月 月 13 日"},{"ImageContent":{"Description":"3 月 1 日から 14 日まで、奈良県の東大寺二月堂では、修二会が行われています。修二会とは、毎年 2 月に仏教寺院で行われる法会であり、人々の幸福を願う行事として始まりました。また、今日 3 月 12 日の深夜には、二月堂前の若狭井という井戸から「お香水」を汲み上げ、観音さまにお供えする「お水取り」が行われます。この儀式があるため、東大寺二月堂の修二会は「お水取り」とも呼ばれています。","Image":{"Url":"/th?id=OHR.TodaijiTempleOmizutori2026_JA-JP4273263363_1920x1080.webp","Wallpaper":"/th?id=OHR.TodaijiTempleOmizutori2026_JA-JP4273263363_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は東大寺のお水取り","Title":"東大寺, 奈良県 奈良市","Copyright":"© Sean Pavone/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/34.686792,135.841077/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=34.686792,135.841077;S9;東大寺&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260312_TodaijiTempleOmizutori2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260312_TodaijiTempleOmizutori2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%9d%b1%e5%a4%a7%e5%af%ba%e3%81%ae%e3%81%8a%e6%b0%b4%e5%8f%96%e3%82%8a&form=hpcapt&filters=HpDate:\"20260311_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260312_TodaijiTempleOmizutori2026"},"Ssd":"20260312","Name":"TodaijiTempleOmizutori2026","Market":"JA-JP","Hash":"4273263363","FullDateString":"2026 年 3月 月 12 日"},{"ImageContent":{"Description":"東日本大震災から今日で 15 年。画像は、2016 年に宮城県名取市で行われた追悼イベントにおいて、市役所の周りに飾られた犠牲者への追悼と復興を願う灯籠です。震災当時、名取市のおよそ 27% が津波によって浸水し、特に沿岸部に位置する閖上地区は壊滅的な被害を受けました。それから 15 年、地元の人々の努力によって、かわまちてらす閖上の建設をはじめ、復興へと歩み続けています。","Image":{"Url":"/th?id=OHR.TohokuEarthquakeMemorial2026_JA-JP5225999611_1920x1080.webp","Wallpaper":"/th?id=OHR.TohokuEarthquakeMemorial2026_JA-JP5225999611_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"東日本大震災から15年","Title":"復興の願いが書かれた灯籠, 宮城県 名取市","Copyright":"© NurPhoto/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.196004,140.881161/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=38.196004,140.881161;S9;名取市&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260311_TohokuEarthquakeMemorial2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260311_TohokuEarthquakeMemorial2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%9d%b1%e6%97%a5%e6%9c%ac%e5%a4%a7%e9%9c%87%e7%81%bd%e3%81%8b%e3%82%8915%e5%b9%b4&form=hpcapt&filters=HpDate:\"20260310_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260311_TohokuEarthquakeMemorial2026"},"Ssd":"20260311","Name":"TohokuEarthquakeMemorial2026","Market":"JA-JP","Hash":"5225999611","FullDateString":"2026 年 3月 月 11 日"},{"ImageContent":{"Description":"ここは、アイスランドのクヴェラヴェトリル地熱地帯。地中深くの熱が氷に覆われた大地と出会い、噴気孔から湯気が立ち上るという、まるで異なる惑星のような光景が広がります。特に、水中に浮遊するシリカなどのミネラル粒子が光を散乱させることでブルーに輝く温泉「ブラゥクヴェル」がひときわ目を引きます。かつては、高地を行き交う旅人の休息地として利用されていたもので、今もその独特で神秘的な姿を保ち続けています。","Image":{"Url":"/th?id=OHR.SpringIceland_JA-JP4910368485_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringIceland_JA-JP4910368485_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"神秘的な青を湛える地熱のプール","Title":"クヴェラヴェトリル地熱地帯の地熱プール, アイスランド","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/64.865398,-19.559103/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=64.865398,-19.559103;S9;フヴェリル地熱地帯, アイスランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260310_SpringIc