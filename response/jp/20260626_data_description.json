{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-26T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"イングランド南部を流れるテムズ川は、古代から交通・交易・軍事などの要所とされていました。全長は 346km で、川沿いにはローマ時代や中世の名残が見られます。ロンドン市街を流れる区間には、タワーブリッジや、世界遺産のウェストミンスター宮殿といった建築物が立ち並んでおり、ロンドンの観光名所として知られています。","Image":{"Url":"/th?id=OHR.ThamesSummer_JA-JP5302199333_1920x1080.webp","Wallpaper":"/th?id=OHR.ThamesSummer_JA-JP5302199333_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"活気あふれる川沿いの街並み","Title":"テムズ川, イングランド ロンドン","Copyright":"© Daniel Lange/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.50382,-0.121258/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=51.50382,-0.121258;S9;テムズ川, イングランド&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260626_ThamesSummer%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260626_ThamesSummer\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%86%e3%83%a0%e3%82%ba%e5%b7%9d&form=hpcapt&filters=HpDate:\"20260625_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260626_ThamesSummer"},"Ssd":"20260626","Name":"ThamesSummer","Market":"JA-JP","Hash":"5302199333","FullDateString":"2026 年 6月 月 26 日"},{"ImageContent":{"Description":"今日の画像は、初夏の日差しを浴びる北海道・中富良野のラベンダー畑。富良野のラベンダーは、例年 6 月下旬から 7 月中旬ごろにかけて見頃を迎えます。ラベンダーらしいさわやかな香りと一面に広がる鮮やかな紫色が、季節の移ろいと自然の豊かさを感じさせてくれます。また、紫のラベンダー以外にも、ひまわりやマリーゴールド、サルビアなどの花も咲き誇り、訪れた人々に安らぎを与えてくれます。","Image":{"Url":"/th?id=OHR.LavenderSeason2026_JA-JP7050134160_1920x1080.webp","Wallpaper":"/th?id=OHR.LavenderSeason2026_JA-JP7050134160_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"初夏に揺れる紫の花畑","Title":"ラベンダー畑, 北海道 中富良野町","Copyright":"© Weiheng Pan/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.388721,142.348068/14?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=43.388721,142.348068;S9;北海道 中富良野町&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260625_LavenderSeason2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_LavenderSeason2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a9%e3%83%99%e3%83%b3%e3%83%80%e3%83%bc%e3%82%b7%e3%83%bc%e3%82%ba%e3%83%b3&form=hpcapt&filters=HpDate:\"20260624_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_LavenderSeason2026"},"Ssd":"20260625","Name":"LavenderSeason2026","Market":"JA-JP","Hash":"7050134160","FullDateString":"2026 年 6月 月 25 日"},{"ImageContent":{"Description":"今週は全米花粉媒介者週間。ミツバチをはじめ、蝶や鳥、コウモリ、甲虫といった花粉媒介者の存在に気づき、守ることを呼びかける期間です。画像のように、蝶が蜜を吸う際に、体に花粉が付着します。この花粉をつけた蝶が次の花へ移動することで、植物は受粉し、繁殖します。花粉媒介者は植物の繁殖や農作物の安定した供給に欠かせない存在です。生態系の保全や私たちの豊かな食生活を維持するためにも、彼らの保護は重要です。","Image":{"Url":"/th?id=OHR.BFPollin_JA-JP2026844024_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_JA-JP2026844024_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今週は全米花粉媒介者週間","Title":"花の蜜を味わう蝶","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"昼間に活動するミツバチや蝶とは異なり、夜に花粉を運ぶ生き物も多く存在します。","LinkUrl":"/search?q=%e4%bb%a3%e8%a1%a8%e7%9a%84%e3%81%aa%e5%a4%9c%e8%a1%8c%e6%80%a7%e3%81%ae%e8%8a%b1%e7%b2%89%e5%aa%92%e4%bb%8b%e8%80%85%e3%81%af%ef%bc%9f&form=hpvsfa","LinkText":"代表的な夜行性の花粉媒介者は？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8a%b1%e3%81%ae%e8%9c%9c%e3%82%92%e5%90%b8%e3%81%86%e8%9d%b6&form=hpcapt&filters=HpDate:\"20260623_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"JA-JP","Hash":"2026844024","FullDateString":"2026 年 6月 月 24 日"},{"ImageContent":{"Description":"ここは、米国ワシントン州のオリンピック国立公園南西部に位置するキノート・レイン・フォレスト。年間降水量は 5,200mm にも達する温帯雨林です。湿ったコケやシダに覆われたオオバカエデやマウンテンヘムロックなどの樹木が見られ、林床には菌類や昆虫、両生類が生息しています。また、この森の中では、オリンピック国立公園内で最大の陸生哺乳類であるルーズベルトエルクの姿を見ることもできます。","Image":{"Url":"/th?id=OHR.QuinaultFerns_JA-JP6908853562_1920x1080.webp","Wallpaper":"/th?id=OHR.QuinaultFerns_JA-JP6908853562_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"陽光が貫く密林","Title":"キノート・レイン・フォレスト, 米国 ワシントン州","Copyright":"© Chris Moore/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/47.505886,-123.820313/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=47.505886,-123.820313;S9;キノート・レイン・フォレスト, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260623_QuinaultFerns%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260623_QuinaultFerns\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ad%e3%83%8e%e3%83%bc%e3%83%88%e3%83%bb%e3%83%ac%e3%82%a4%e3%83%b3%e3%83%bb%e3%83%95%e3%82%a9%e3%83%ac%e3%82%b9%e3%83%88&form=hpcapt&filters=HpDate:\"20260622_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260623_QuinaultFerns"},"Ssd":"20260623","Name":"QuinaultFerns","Market":"JA-JP","Hash":"6908853562","FullDateString":"2026 年 6月 月 23 日"},{"ImageContent":{"Description":"今日 6 月 22 日は、富士山が世界文化遺産に登録された日です。古くから日本では霊峰とされてきた富士山ですが、1992 年の日本最初の世界遺産暫定一覧表には選ばれないなど、世界遺産登録までには長い年月を要しました。1994 年の 100 万人署名運動や、1998 年の富士山憲章制定など、20 年以上に渡る世界遺産登録運動を経て、2007 年に世界遺産暫定一覧表に登録。そして、2013 年 6 月 22 日、カンボジアで開催されたユネスコ世界遺産委員会において、「富士山―信仰の対象と芸術の源泉」として世界文化遺産に登録されました。この登録は、景観の美しさに加え、人々の信仰や芸術に与えてきた文化的価値が認められたものです。","Image":{"Url":"/th?id=OHR.Fujisan_JA-JP1483326201_1920x1080.webp","Wallpaper":"/th?id=OHR.Fujisan_JA-JP1483326201_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は富士山が世界文化遺産に登録された日","Title":"富士山","Copyright":"© phutthiseth thongtae/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.362812,138.730911/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.362812,138.730911;S9;富士山&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260622_Fujisan%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260622_Fujisan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%af%8c%e5%a3%ab%e5%b1%b1%e3%81%8c%e4%b8%96%e7%95%8c%e6%96%87%e5%8c%96%e9%81%ba%e7%94%a3%e3%81%ab%e7%99%bb%e9%8c%b2%e3%81%95%e3%82%8c%e3%81%9f%e6%97%a5&form=hpcapt&filters=HpDate:\"20260621_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260622_Fujisan"},"Ssd":"20260622","Name":"Fujisan","Market":"JA-JP","Hash":"1483326201","FullDateString":"2026 年 6月 月 22 日"},{"ImageContent":{"Description":"今日 6 月 21 日は父の日。米国発祥の記念日であり、1909 年にワシントン州のソノラ・スマート・ドッドという女性が、父親を讃えるため教会に礼拝をしてもらったことが始まりとされており、1972 年に米国の正式な記念日となりました。日本や米国は 6 月の第 3 日曜日に祝いますが、国によっては日付が異なります。そして画像は、卵を守るオウサマペンギンの父親。卵を後肢の上に乗せ、「抱卵嚢」と呼ばれる腹部の皮膚で温めています。巣を持たないペンギンのため、父と母は交代しながら托卵しており、片方が海に餌を捕りに行っている間、片方はほとんど動かず、時に絶食しながら卵を守り続けます。","Image":{"Url":"/th?id=OHR.EggDad_JA-JP1066785458_1920x1080.webp","Wallpaper":"/th?id=OHR.EggDad_JA-JP1066785458_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は父の日","Title":"オウサマペンギンの父親","Copyright":"© McDonald Wildlife Photography Inc./Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"オウサマペンギンは複数の層からなる羽毛で寒さを防ぎます。特にヒナはふわふわの綿羽に覆われており、親より大きく見えることもあります。","LinkUrl":"/search?q=%e3%82%aa%e3%82%a6%e3%82%b5%e3%83%9e%e3%83%9a%e3%83%b3%e3%82%ae%e3%83%b3%e3%81%ae%e7%be%bd%e6%af%9b%e3%81%af%e4%bd%95%e5%b1%a4%ef%bc%9f&form=hpvsfa","LinkText":"オウサマペンギンの羽毛は何層？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260621_EggDad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%88%b6%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260620_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260621_EggDad"},"Ssd":"20260621","Name":"EggDad","Market":"JA-JP","Hash":"1066785458","FullDateString":"2026 年 6月 月 21 日"},{"ImageContent":{"Description":"氷山は、南極に降り積もった雪が氷となり、海へ移動して割れることで形成されます。南極海で主に見られるのは、上面が平らな卓状氷山ですが、画像のように、浸食によって不規則な形に形成された氷山なども存在します。一見するとただの氷の塊の氷山ですが、実際には生態系を支える重要な存在です。海中部分には藻類が付着しており、オキアミなどのプランクトンが餌としています。そして、そのプランクトンは、魚やアザラシ、クジラなどの食料となります。また、氷が溶けるとその栄養分が周囲の海へと放出され、周辺海域の生態系を豊かにしています。このように氷山は、「移動する生態系」ともいえる役割を果たしています。","Image":{"Url":"/th?id=OHR.ArchedIceberg_JA-JP0865478817_1920x1080.webp","Wallpaper":"/th?id=OHR.ArchedIceberg_JA-JP0865478817_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"氷山に穿たれた天然のアーチ","Title":"アーチ状の氷山, 南極半島西部","Copyright":"© Steven Kazlowski/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-69.5,-65/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-69.5,-65;S9;南極半島&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260620_ ArchedIceberg%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260620_ArchedIceberg\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%83%bc%e3%83%81%e7%8a%b6%e3%81%ae%e6%b0%b7%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260619_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260620_ArchedIceberg"},"Ssd":"20260620","Name":"ArchedIceberg","Market":"JA-JP","Hash":"0865478817","FullDateString":"2026 年 6月 月 20 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"ここは、米国サウスカロライナ州のハンティング島州立公園南端に広がるボニーヤード・ビーチです。かつては木々が生い茂っていたものの、1980 年以降、潮汐や嵐の影響によって海岸侵食が進み、次第に海へと削り取られていきました。その結果、砂浜には立ち枯れた木々や流木が残る風景が広がっています。一方で動物は多数生息しており、公園内には数百種の鳥類が確認されているほか、沖合ではバンドウイルカが見られることもあります。さらに、周辺の砂浜はアカウミガメの産卵地としても知られています。","Image":{"Url":"/th?id=OHR.BoneyardBeach_JA-JP3339035555_1920x1080.webp","Wallpaper":"/th?id=OHR.BoneyardBeach_JA-JP3339035555_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けに染まる水辺と枯れ木","Title":"ボニーヤード・ビーチ, 米国 サウスカロライナ州","Copyright":"© Frances/Adobe Stock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/32.40758,-80.445631/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=32.40758,-80.445631;S9;ハンティング島州立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260703_BoneyardBeach%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260703_BoneyardBeach\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%8f%e3%83%b3%e3%83%86%e3%82%a3%e3%83%b3%e3%82%b0%e5%b3%b6%e5%b7%9e%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260702_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260703_BoneyardBeach"},"Ssd":"20260703","Name":"BoneyardBeach","Market":"JA-JP","Hash":"3339035555","FullDateString":"2026 年 7月 月 3 日"},{"ImageContent":{"Description":"今日の画像は、古代エジプトにあるエスナ神殿（クヌム神殿）の天井です。エスナ神殿は、エジプト南部のナイル川西岸に位置し、主にプトレマイオス朝からローマ時代にかけて建設されました。現在残っている柱廊ホールは、24本の巨大な柱に支えられ、その柱や壁面には宗教的な文様が刻まれています。また、天井には黄道十二宮（星座）や天体図、神々などの天文学的装飾が描かれています。それらの装飾は儀礼や宇宙の循環などを象徴し、参拝者を神聖な世界へと導く役割を果たしていたと考えられています。","Image":{"Url":"/th?id=OHR.TempleEsna_JA-JP0629204284_1920x1080.webp","Wallpaper":"/th?id=OHR.TempleEsna_JA-JP0629204284_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"古代神殿の壮麗な内部空間","Title":"クヌム神に捧げられたエスナ神殿の天井, エジプト","Copyright":"© Nick Brundle Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.293581,32.556398/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=25.293581,32.556398;S9;エスナ神殿, エジプト&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260702_TempleEsna%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260702_TempleEsna\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a8%e3%82%b9%e3%83%8a%e7%a5%9e%e6%ae%bf&form=hpcapt&filters=HpDate:\"20260701_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260702_TempleEsna"},"Ssd":"20260702","Name":"TempleEsna","Market":"JA-JP","Hash":"0629204284","FullDateString":"2026 年 7月 月 2 日"},{"ImageContent":{"Description":"今日 7 月 1 日はカナダの日。1867 年 7 月 1 日に制定された英領北米法によって、カナダ連邦が誕生したことを記念する日です。そして画像は、カナダのニューファンドランド・ラブラドール州の険しい海岸沿いに位置するダンジョン州立公園。大西洋の波によって 2 つの開口部を持つ海食洞が削られ、天井が崩落したことで、現在の独特な地形が形成されました。荒々しい海と切り立った断崖が織りなすこの景観は、今なおカナダの大地が持つ自然の力を物語っています。","Image":{"Url":"/th?id=OHR.DungeonPark_JA-JP3903067497_1920x1080.webp","Wallpaper":"/th?id=OHR.DungeonPark_JA-JP3903067497_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はカナダの日","Title":"ダンジョン州立公園, カナダ","Copyright":"© Kaitlyn McLachlan/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.666842,-53.084148/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=48.666842,-53.084148;S9;ダンジョン州立公園, カナダ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260701_DungeonPark%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260701_DungeonPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ab%e3%83%8a%e3%83%80%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260630_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260701_DungeonPark"},"Ssd":"20260701","Name":"DungeonPark","Market":"JA-JP","Hash":"3903067497","FullDateString":"2026 年 7月 月 1 日"},{"ImageContent":{"Description":"今日の画像は、ケニアのマサイマラ国立保護区で撮影されたマサイキリンです。マサイキリンは、他のキリン同様体に模様があり、ギザギザとした葉のような形をしているのが特徴です。この模様は、人間の指紋のように、個体ごとに異なります。彼らは、一日の大半を食事に充てており、長い舌を器用に使って鋭い棘の間から葉を摘み取って食べています。普段は穏やかで優雅に過ごしていますが、捕食者から逃げる際などは時速約 55km に達する速さで走れます。","Image":{"Url":"/th?id=OHR.MasaiGiraffe_JA-JP6554855892_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiGiraffe_JA-JP6554855892_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けに浮かぶキリンの影","Title":"マサイキリン, ケニヤ","Copyright":"© danm/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-1.529493,35.170876/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-1.529493,35.170876;S9;マサイマラ国立保護区, ケニヤ&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260630_MasaiGiraffe%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260630_MasaiGiraffe\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%9e%e3%82%b5%e3%82%a4%e3%82%ad%e3%83%aa%e3%83%b3&form=hpcapt&filters=HpDate:\"20260629_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260630_MasaiGiraffe"},"Ssd":"20260630","Name":"MasaiGiraffe","Market":"JA-JP","Hash":"6554855892","FullDateString":"2026 年 6月 月 30 日"},{"ImageContent":{"Description":"今日 6 月 29 日は国際熱帯デー。熱帯とは、赤道を中心に南北回帰線に挟まれた年中温暖な地域を指します。世界人口の約 40% が暮らし、地球上の生物種の約 80% が生息する重要な場所です。そして、画像は赤道近くに位置するフランス領ポリネシアにあるボラボラ島。島の中央にはオテマヌ山とパヒア山といった玄武岩の峰々がそびえています。周囲を取り囲むサンゴ礁の内側には穏やかなターコイズ色のラグーンが広がり、その美しさから「太平洋の真珠」とも称されています。","Image":{"Url":"/th?id=OHR.BoraBoraLagoon_JA-JP3981162879_1920x1080.webp","Wallpaper":"/th?id=OHR.BoraBoraLagoon_JA-JP3981162879_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は国際熱帯デー","Title":"ボラボラ島, フランス領ポリネシア","Copyright":"© Frederick Millett/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-16.498926,-151.73819/11?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-16.498926,-151.73819;S9;ボラボラ島, フランス領ポリネシア&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260629_BoraBora%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260629_BoraBoraLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%9a%9b%e7%86%b1%e5%b8%af%e3%83%87%e3%83%bc&form=hpcapt&filters=HpDate:\"20260628_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260629_BoraBoraLagoon"},"Ssd":"20260629","Name":"BoraBoraLagoon","Market":"JA-JP","Hash":"3981162879","FullDateString":"2026 年 6月 月 29 日"},{"ImageContent":{"Description":"ベンケイチュウは、米国とメキシコにかけて広がるソノラ砂漠固有のサボテンです。高さは 12m 以上、重さは最大で約 6 トンに達し、世界最大級のサボテンといわれています。過酷な乾燥環境に適応した植物で、根は約 30m にわたって浅く広く伸び、わずかな雨水も効率よく吸収するほか、ひだ状の幹に水分を蓄え、雨の後には膨らみ、干ばつ時には縮むという特徴もあります。寿命は長く、最大で 200 年ほど生きることもあります。","Image":{"Url":"/th?id=OHR.SaguaroSun_JA-JP5856249761_1920x1080.webp","Wallpaper":"/th?id=OHR.SaguaroSun_JA-JP5856249761_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕日を浴びるベンケイチュウ","Title":"ウィンドゲートパス, 米国 アリゾナ州","Copyright":"© Eric Mischke/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/33.796104,-111.810696/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=33.796104,-111.810696;S9;ウィンドゲート峠, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260628_SaguaroSun%22+WQI