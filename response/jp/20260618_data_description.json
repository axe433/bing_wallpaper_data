{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-18T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"今日の画像は、インカの遺跡「サクサイワマン」です。ペルー南東部、インカ帝国の古都クスコの高台に位置し、かつてはインカ帝国の聖都の一部でした。15 世紀に築かれた広大な複合施設であり、段状のテラスや広場、塔の遺構が今もなお整然と並んでいます。巨大な石塊の城壁には高さ約 8m を超える石も見られ、モルタルを使わず精密に組まれた構造は、幾度もの地震に耐えてきました。その圧倒的な精度と規模からなる石造技術は、今もなお注目を集めています。","Image":{"Url":"/th?id=OHR.Saqsaywaman_JA-JP0282514779_1920x1080.webp","Wallpaper":"/th?id=OHR.Saqsaywaman_JA-JP0282514779_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"上空から望む古代遺跡の構造美","Title":"サクサイワマン, ペルー","Copyright":"© Creative-Family/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-13.50778,-71.98222/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-13.50778,-71.98222;S9;サクサイワマン, ペルー&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260618_Saqsaywaman %22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260618_Saqsaywaman\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b5%e3%82%af%e3%82%b5%e3%82%a4%e3%83%af%e3%83%9e%e3%83%b3&form=hpcapt&filters=HpDate:\"20260617_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260618_Saqsaywaman"},"Ssd":"20260618","Name":"Saqsaywaman","Market":"JA-JP","Hash":"0282514779","FullDateString":"2026 年 6月 月 18 日"},{"ImageContent":{"Description":"今日の画像は、スイスで最も長い歴史的な道路建造物ともいわれる旧街道「トレモラ道路」です。麓の街アイロロからゴッタルド峠へと続いています。特に象徴的な石畳区間では、高低差 300m を約 4km にわたって 24 ものカーブで登ります。曲がりくねった道の形状が、独特の景観を生み出しています。1800 年代に建設され、1951 年の再建工事によって現在の姿となりました。道路の幅は約 6m で、両側には擁壁が設けられています。山々と渓谷が織りなす壮大な景観を望むことができる道路であり、サイクリングやドライブを目的に多くの人が訪れています。","Image":{"Url":"/th?id=OHR.TremolaRoad_JA-JP0031183332_1920x1080.webp","Wallpaper":"/th?id=OHR.TremolaRoad_JA-JP0031183332_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"山肌に輝く曲がりくねった道路","Title":"トレモラ道路, スイス","Copyright":"© Sandro Bisaro/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/46.557487,8.562773/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=46.557487,8.562773;S9;サン・ゴッタルド峠, スイス&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260617_TremolaRoad %22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260617_TremolaRoad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%88%e3%83%ac%e3%83%a2%e3%83%a9%e9%81%93%e8%b7%af&form=hpcapt&filters=HpDate:\"20260616_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260617_TremolaRoad"},"Ssd":"20260617","Name":"TremolaRoad","Market":"JA-JP","Hash":"0031183332","FullDateString":"2026 年 6月 月 17 日"},{"ImageContent":{"Description":"今日 6 月 16 日は「世界ウミガメの日」。ウミガメの存在やその保護の大切さについて、改めて考える日です。世界に生息している 7 種のウミガメのうち、日本の砂浜で産卵が確認されているのは、アカウミガメ、アオウミガメ、そして画像のタイマイの 3 種です。タイマイは、模様のある甲羅と、タカのくちばしのように先のとがった口元が特徴です。沿岸の浅い海域を好み、主に海綿動物を食べることで、サンゴ礁のバランスを保つ役割を果たしています。現在、絶滅の危機に瀕しており、ウミガメの中でも特に希少な種のひとつです。","Image":{"Url":"/th?id=OHR.SevenMileTurtle_JA-JP9577560353_1920x1080.webp","Wallpaper":"/th?id=OHR.SevenMileTurtle_JA-JP9577560353_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は世界ウミガメの日","Title":"優雅に泳ぐタイマイ, ケイマン諸島","Copyright":"© Alex Mustard/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/19.321451,-81.229248/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=19.321451,-81.229248;S9;ケイマン諸島&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260616_ SevenMileTurtle%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260616_SevenMileTurtle\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e3%82%a6%e3%83%9f%e3%82%ac%e3%83%a1%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260615_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260616_SevenMileTurtle"},"Ssd":"20260616","Name":"SevenMileTurtle","Market":"JA-JP","Hash":"9577560353","FullDateString":"2026 年 6月 月 16 日"},{"ImageContent":{"Description":"1934 年 6 月 15 日、グレート・スモーキー山脈国立公園は米国議会により設立されました。この公園はテネシー州とノースカロライナ州の州境に位置し、約 2,100km² の面積を誇る米国東部で最も広い保護地域の一つです。公園の標高は約 250m から 2,000m で、最高地点であるクウォヒ（標高 2,025m ）の展望台は、壮大な景観を一望できる人気のスポットとなっています。標高差や豊富な降水量、広大な原生林によって、多様な生態系が育まれており、クロクマやヘラジカ、200 種以上の鳥類、数千種の植物が生息しています。また、約 30 種のサンショウウオが生息しており、「サンショウウオの世界の首都」とも呼ばれています。","Image":{"Url":"/th?id=OHR.ParkEstd_JA-JP9205724491_1920x1080.webp","Wallpaper":"/th?id=OHR.ParkEstd_JA-JP9205724491_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日はグレート・スモーキー山脈国立公園の記念日","Title":"グレート・スモーキー山脈国立公園, 米国 テネシー州","Copyright":"© Mint Images/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.613045,-83.553131/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.613045,-83.553131;S9;グレート・スモーキー山脈国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260615_ ParkEstd%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260615_ParkEstd\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%b0%e3%83%ac%e3%83%bc%e3%83%88%e3%83%bb%e3%82%b9%e3%83%a2%e3%83%bc%e3%82%ad%e3%83%bc%e5%b1%b1%e8%84%88%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92%e3%81%ae%e8%a8%98%e5%bf%b5%e6%97%a5&form=hpcapt&filters=HpDate:\"20260614_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260615_ParkEstd"},"Ssd":"20260615","Name":"ParkEstd","Market":"JA-JP","Hash":"9205724491","FullDateString":"2026 年 6月 月 15 日"},{"ImageContent":{"Description":"ここは、米国サウスダコタ州に位置するバッドランズ国立公園。面積約 980km² の広大な敷地には、水と風の浸食によって長い年月をかけて形成された崖や峡谷、そそり立つ尖峰など、独特の地形が広がっています。化石の宝庫としても知られており、荒涼とした地表の下には、3400 万年前から 2500 万年前に生きていた哺乳類の化石が多く確認されています。また、公園の周囲に広がる草原には、バイソン、ビッグホーン、プレーリードッグなどの野生動物が多数生息しています。","Image":{"Url":"/th?id=OHR.BadSunset_JA-JP5960860484_1920x1080.webp","Wallpaper":"/th?id=OHR.BadSunset_JA-JP5960860484_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"夕焼けに染まる層をなす岩の景観","Title":"バッドランズ国立公園, 米国 サウスダコタ州","Copyright":"© Troy Harrison/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.85538,-102.339666/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=43.85538,-102.339666;S9;バッドランズ国立公園, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260614_BadSunset%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260614_BadSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%90%e3%83%83%e3%83%89%e3%83%a9%e3%83%b3%e3%82%ba%e5%9b%bd%e7%ab%8b%e5%85%ac%e5%9c%92&form=hpcapt&filters=HpDate:\"20260613_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260614_BadSunset"},"Ssd":"20260614","Name":"BadSunset","Market":"JA-JP","Hash":"5960860484","FullDateString":"2026 年 6月 月 14 日"},{"ImageContent":{"Description":"今日、6 月 13 日は「はやぶさの日」。「はやぶさ」は、2003 年に宇宙航空研究開発機構 (JAXA) によって打ち上げられた小惑星探査機です。交信途絶などの様々なトラブルを乗り越えて、2010 年 6 月 13 日に地球へ帰還したことで大きな注目を集めました。「はやぶさの日」は、そんな「はやぶさ」とそのプロジェクトに関わった人々を称え、2012 年に認定された記念日です。2014 年には後継機「はやぶさ 2 」が打ち上げられ、2019 年に小惑星リュウグウへのタッチダウンに成功しました。今日の画像は、2020 年 12 月 6 日に、「はやぶさ 2 」からサンプルの入ったカプセルが地球へ向けて分離され、落下する様子です。本体は現在も稼働しており、拡張ミッションを継続中です。","Image":{"Url":"/th?id=OHR.HayabusaDay2026_JA-JP6590656546_1920x1080.webp","Wallpaper":"/th?id=OHR.HayabusaDay2026_JA-JP6590656546_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日ははやぶさの日","Title":"はやぶさ 2 から切り離されたカプセル","Copyright":"© MORGAN SETTE/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"はやぶさカプセルは、超高速かつ高温の状態で地球の大気圏に突入するため、流れ星のように見えます。","LinkUrl":"/search?q=%e3%81%af%e3%82%84%e3%81%b6%e3%81%95%e3%82%ab%e3%83%97%e3%82%bb%e3%83%ab%e3%81%8c%e5%a4%a7%e6%b0%97%e5%9c%8f%e3%81%ab%e7%aa%81%e5%85%a5%e3%81%99%e3%82%8b%e3%81%a8%e3%81%8d%e3%81%ae%e9%80%9f%e5%ba%a6%e3%81%a8%e6%b8%a9%e5%ba%a6%e3%81%af%ef%bc%9f&form=hpvsfa","LinkText":"はやぶさカプセルが大気圏に突入するときの速度と温度は？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260613_HayabusaDay2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%81%af%e3%82%84%e3%81%b6%e3%81%95+%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260612_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260613_HayabusaDay2026"},"Ssd":"20260613","Name":"HayabusaDay2026","Market":"JA-JP","Hash":"6590656546","FullDateString":"2026 年 6月 月 13 日"},{"ImageContent":{"Description":"今日の画像は、茶、黄、青、緑とカラフルな羽色が目を引くヨーロッパハチクイ。その名の通りハチ類を主に食べる鳥です。飛行中のハチを空中で巧みに捕らえ、地面などに打ちつけて毒針を抜いて食べており、1 日に約 250 匹のミツバチを捕食することもあります。渡り鳥であり、南ヨーロッパや北アフリカ・西アジアの一部で繁殖し、冬はアフリカの熱帯地域で過ごします。","Image":{"Url":"/th?id=OHR.SpainBeeEater_JA-JP8800920985_1920x1080.webp","Wallpaper":"/th?id=OHR.SpainBeeEater_JA-JP8800920985_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"野の花をかすめる色鮮やかな鳥","Title":"ヨーロッパハチクイ, スペイン","Copyright":"© Andres M. Dominguez/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/36.74794,-5.371703/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=36.74794,-5.371703;S9;グラサレマ山脈自然公園&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260612_ SpainBeeEater%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260612_SpainBeeEater\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a8%e3%83%bc%e3%83%ad%e3%83%83%e3%83%91%e3%83%8f%e3%83%81%e3%82%af%e3%82%a4&form=hpcapt&filters=HpDate:\"20260611_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260612_SpainBeeEater"},"Ssd":"20260612","Name":"SpainBeeEater","Market":"JA-JP","Hash":"8800920985","FullDateString":"2026 年 6月 月 12 日"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今日の画像は、初夏の日差しを浴びる北海道・中富良野のラベンダー畑。富良野のラベンダーは、例年 6 月下旬から 7 月中旬ごろにかけて見頃を迎えます。ラベンダーらしいさわやかな香りと一面に広がる鮮やかな紫色が、季節の移ろいと自然の豊かさを感じさせてくれます。また、紫のラベンダー以外にも、ひまわりやマリーゴールド、サルビアなどの花も咲き誇り、訪れた人々に安らぎを与えてくれます。","Image":{"Url":"/th?id=OHR.LavenderSeason2026_JA-JP7050134160_1920x1080.webp","Wallpaper":"/th?id=OHR.LavenderSeason2026_JA-JP7050134160_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"初夏に揺れる紫の花畑","Title":"ラベンダー畑, 北海道 中富良野町","Copyright":"© Weiheng Pan/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.388721,142.348068/14?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=43.388721,142.348068;S9;北海道 中富良野町&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260625_LavenderSeason2026%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_LavenderSeason2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%83%a9%e3%83%99%e3%83%b3%e3%83%80%e3%83%bc%e3%82%b7%e3%83%bc%e3%82%ba%e3%83%b3&form=hpcapt&filters=HpDate:\"20260624_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_LavenderSeason2026"},"Ssd":"20260625","Name":"LavenderSeason2026","Market":"JA-JP","Hash":"7050134160","FullDateString":"2026 年 6月 月 25 日"},{"ImageContent":{"Description":"今週は全米花粉媒介者週間。ミツバチをはじめ、蝶や鳥、コウモリ、甲虫といった花粉媒介者の存在に気づき、守ることを呼びかける期間です。画像のように、蝶が蜜を吸う際に、体に花粉が付着します。この花粉をつけた蝶が次の花へ移動することで、植物は受粉し、繁殖します。花粉媒介者は植物の繁殖や農作物の安定した供給に欠かせない存在です。生態系の保全や私たちの豊かな食生活を維持するためにも、彼らの保護は重要です。","Image":{"Url":"/th?id=OHR.BFPollin_JA-JP2026844024_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_JA-JP2026844024_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今週は全米花粉媒介者週間","Title":"花の蜜を味わう蝶","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"昼間に活動するミツバチや蝶とは異なり、夜に花粉を運ぶ生き物も多く存在します。","LinkUrl":"/search?q=%e4%bb%a3%e8%a1%a8%e7%9a%84%e3%81%aa%e5%a4%9c%e8%a1%8c%e6%80%a7%e3%81%ae%e8%8a%b1%e7%b2%89%e5%aa%92%e4%bb%8b%e8%80%85%e3%81%af%ef%bc%9f&form=hpvsfa","LinkText":"代表的な夜行性の花粉媒介者は？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8a%b1%e3%81%ae%e8%9c%9c%e3%82%92%e5%90%b8%e3%81%86%e8%9d%b6&form=hpcapt&filters=HpDate:\"20260623_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"JA-JP","Hash":"2026844024","FullDateString":"2026 年 6月 月 24 日"},{"ImageContent":{"Description":"ここは、米国ワシントン州のオリンピック国立公園南西部に位置するキノート・レイン・フォレスト。年間降水量は 5,200mm にも達する温帯雨林です。湿ったコケやシダに覆われたオオバカエデやマウンテンヘムロックなどの樹木が見られ、林床には菌類や昆虫、両生類が生息しています。また、この森の中では、オリンピック国立公園内で最大の陸生哺乳類であるルーズベルトエルクの姿を見ることもできます。","Image":{"Url":"/th?id=OHR.QuinaultFerns_JA-JP6908853562_1920x1080.webp","Wallpaper":"/th?id=OHR.QuinaultFerns_JA-JP6908853562_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"陽光が貫く密林","Title":"キノート・レイン・フォレスト, 米国 ワシントン州","Copyright":"© Chris Moore/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/47.505886,-123.820313/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=47.505886,-123.820313;S9;キノート・レイン・フォレスト, 米国&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260623_QuinaultFerns%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260623_QuinaultFerns\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%ad%e3%83%8e%e3%83%bc%e3%83%88%e3%83%bb%e3%83%ac%e3%82%a4%e3%83%b3%e3%83%bb%e3%83%95%e3%82%a9%e3%83%ac%e3%82%b9%e3%83%88&form=hpcapt&filters=HpDate:\"20260622_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260623_QuinaultFerns"},"Ssd":"20260623","Name":"QuinaultFerns","Market":"JA-JP","Hash":"6908853562","FullDateString":"2026 年 6月 月 23 日"},{"ImageContent":{"Description":"今日 6 月 22 日は、富士山が世界文化遺産に登録された日です。古くから日本では霊峰とされてきた富士山ですが、1992 年の日本最初の世界遺産暫定一覧表には選ばれないなど、世界遺産登録までには長い年月を要しました。1994 年の 100 万人署名運動や、1998 年の富士山憲章制定など、20 年以上に渡る世界遺産登録運動を経て、2007 年に世界遺産暫定一覧表に登録。そして、2013 年 6 月 22 日、カンボジアで開催されたユネスコ世界遺産委員会において、「富士山―信仰の対象と芸術の源泉」として世界文化遺産に登録されました。この登録は、景観の美しさに加え、人々の信仰や芸術に与えてきた文化的価値が認められたものです。","Image":{"Url":"/th?id=OHR.Fujisan_JA-JP1483326201_1920x1080.webp","Wallpaper":"/th?id=OHR.Fujisan_JA-JP1483326201_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は富士山が世界文化遺産に登録された日","Title":"富士山","Copyright":"© phutthiseth thongtae/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.362812,138.730911/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=35.362812,138.730911;S9;富士山&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260622_Fujisan%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260622_Fujisan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%af%8c%e5%a3%ab%e5%b1%b1%e3%81%8c%e4%b8%96%e7%95%8c%e6%96%87%e5%8c%96%e9%81%ba%e7%94%a3%e3%81%ab%e7%99%bb%e9%8c%b2%e3%81%95%e3%82%8c%e3%81%9f%e6%97%a5&form=hpcapt&filters=HpDate:\"20260621_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260622_Fujisan"},"Ssd":"20260622","Name":"Fujisan","Market":"JA-JP","Hash":"1483326201","FullDateString":"2026 年 6月 月 22 日"},{"ImageContent":{"Description":"今日 6 月 21 日は父の日。米国発祥の記念日であり、1909 年にワシントン州のソノラ・スマート・ドッドという女性が、父親を讃えるため教会に礼拝をしてもらったことが始まりとされており、1972 年に米国の正式な記念日となりました。日本や米国は 6 月の第 3 日曜日に祝いますが、国によっては日付が異なります。そして画像は、卵を守るオウサマペンギンの父親。卵を後肢の上に乗せ、「抱卵嚢」と呼ばれる腹部の皮膚で温めています。巣を持たないペンギンのため、父と母は交代しながら托卵しており、片方が海に餌を捕りに行っている間、片方はほとんど動かず、時に絶食しながら卵を守り続けます。","Image":{"Url":"/th?id=OHR.EggDad_JA-JP1066785458_1920x1080.webp","Wallpaper":"/th?id=OHR.EggDad_JA-JP1066785458_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"今日は父の日","Title":"オウサマペンギンの父親","Copyright":"© McDonald Wildlife Photography Inc./Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"オウサマペンギンは複数の層からなる羽毛で寒さを防ぎます。特にヒナはふわふわの綿羽に覆われており、親より大きく見えることもあります。","LinkUrl":"/search?q=%e3%82%aa%e3%82%a6%e3%82%b5%e3%83%9e%e3%83%9a%e3%83%b3%e3%82%ae%e3%83%b3%e3%81%ae%e7%be%bd%e6%af%9b%e3%81%af%e4%bd%95%e5%b1%a4%ef%bc%9f&form=hpvsfa","LinkText":"オウサマペンギンの羽毛は何層？"},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260621_EggDad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%88%b6%e3%81%ae%e6%97%a5&form=hpcapt&filters=HpDate:\"20260620_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260621_EggDad"},"Ssd":"20260621","Name":"EggDad","Market":"JA-JP","Hash":"1066785458","FullDateString":"2026 年 6月 月 21 日"},{"ImageContent":{"Description":"氷山は、南極に降り積もった雪が氷となり、海へ移動して割れることで形成されます。南極海で主に見られるのは、上面が平らな卓状氷山ですが、画像のように、浸食によって不規則な形に形成された氷山なども存在します。一見するとただの氷の塊の氷山ですが、実際には生態系を支える重要な存在です。海中部分には藻類が付着しており、オキアミなどのプランクトンが餌としています。そして、そのプランクトンは、魚やアザラシ、クジラなどの食料となります。また、氷が溶けるとその栄養分が周囲の海へと放出され、周辺海域の生態系を豊かにしています。このように氷山は、「移動する生態系」ともいえる役割を果たしています。","Image":{"Url":"/th?id=OHR.ArchedIceberg_JA-JP0865478817_1920x1080.webp","Wallpaper":"/th?id=OHR.ArchedIceberg_JA-JP0865478817_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"氷山に穿たれた天然のアーチ","Title":"アーチ状の氷山, 南極半島西部","Copyright":"© Steven Kazlowski/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-69.5,-65/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=-69.5,-65;S9;南極半島&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260620_ ArchedIceberg%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260620_ArchedIceberg\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e3%82%a2%e3%83%bc%e3%83%81%e7%8a%b6%e3%81%ae%e6%b0%b7%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260619_1500\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260620_ArchedIceberg"},"Ssd":"20260620","Name":"ArchedIceberg","Market":"JA-JP","Hash":"0865478817","FullDateString":"2026 年 6月 月 20 日"},{"ImageContent":{"Description":"今日の画像は「グラン＝プラス」。ベルギーの首都、ブリュッセルの中心地にある大広場です。世界で最も美しい広場のひとつとも称され、ユネスコの世界遺産にも登録されています。かつてこの広場を囲む建物の多くは木造でしたが、大同盟戦争中の 1695 年に、フランスの砲撃によって大半が破壊されました。その後、様々な職業別組合（ギルド）によって、現在のような石造りの建物に再建されました。建物の壁に飾られた樽や手押し車などの紋章は、それぞれの職業を象徴しています。","Image":{"Url":"/th?id=OHR.GrandPlace_JA-JP0571812680_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandPlace_JA-JP0571812680_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"装飾美が際立つ歴史的街並み","Title":"グラン＝プラス, ベルギー","Copyright":"© Vladislav Zolotov/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.84685,4.352454/16?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=ja-JP&od=2&shading=flat&pp=50.84685,4.352454;S9;グラン＝プラス, ベルギー&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/search?q=Bing+%e3%83%88%e3%83%aa%e3%83%93%e3%82%a2%e3%82%af%e3%82%a4%e3%82%ba&setmkt=JA-JP&filters=IsConversation%3a%22True%22+WQOskey:%22HPQuiz_20260619_GrandPlace%22+WQId:%221%22&form=hpbal1"},"QuickFact":{"Mai