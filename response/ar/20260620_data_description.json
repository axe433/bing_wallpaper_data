{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-20T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Perched at the far edge of Piazza Bovio in Piombino, Tuscany, Italy, is the Piombino Lighthouse. Locally, it is known as 'Faro di Piombino' or 'La Rocchetta Lighthouse.' It overlooks the point where the Tuscan coast faces the island of Elba.","Image":{"Url":"/th?id=OHR.IsolaElba_ROW4135146629_1920x1080.webp","Wallpaper":"/th?id=OHR.IsolaElba_ROW4135146629_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"La Rocchetta Lighthouse, Piombino, Tuscany, Italy","Copyright":"© StevanZZ/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260619_IsolaElba\"&FORM=HPQUIZ","BackstageUrl":"/search?q=La+Rocchetta+Lighthouse&form=hpcapt&filters=HpDate:\"20260619_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260619_IsolaElba"},"Ssd":"20260619","Name":"IsolaElba","Market":"ROW","Hash":"4135146629","FullDateString":"19 de jun de 2026"},{"ImageContent":{"Description":"Set high above Cusco in Peru, Sacsayhuamán reveals the ambition of the Inca Empire in stone. Built in the 15th century, this vast complex once formed part of the sacred capital of the Incas. From above, the layout becomes clear: terraces, open plazas and the remains of towers forming a carefully planned citadel. The largest walls, built from enormous blocks, still stand strong today. Some stones rise more than 8.2 metres tall and were fitted together so precisely—without mortar—that the structure has endured centuries of earthquakes.","Image":{"Url":"/th?id=OHR.Saqsaywaman_ROW9340385062_1920x1080.webp","Wallpaper":"/th?id=OHR.Saqsaywaman_ROW9340385062_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Aerial view of the ruins of Sacsayhuamán, Cusco, Peru","Copyright":"© Creative-Family/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260618_Saqsaywaman\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sacsayhuaman+Cusco+Peru&form=hpcapt&filters=HpDate:\"20260618_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260618_Saqsaywaman"},"Ssd":"20260618","Name":"Saqsaywaman","Market":"ROW","Hash":"9340385062","FullDateString":"18 de jun de 2026"},{"ImageContent":{"Description":"Follow the glowing ribbon of switchbacks and you'll find one of Switzerland's most legendary drives: Tremola Road, the historic southern approach to the Saint Gotthard Pass, above Airolo. Built in the early 1800s and largely shaped by a 1951 reconstruction, this route is celebrated as Switzerland's longest monument to historic road construction. Its showstopper stretch climbs about 299 metres in just 4 kilometres, curling through 24 named hairpin bends on granite cobblestones, with sturdy retaining walls edging the way. Overall, it runs about 11 kilometres and features 37 bends in total. Take it slow—every curve feels like a step back in time, trading speed for sweeping mountain scenery and big views toward the upper Leventina Valley. Whether you're driving, cycling or pulling over for photos, look for the Grand Tour of Switzerland photo spot framing those iconic zigzags.","Image":{"Url":"/th?id=OHR.TremolaRoad_ROW9264574129_1920x1080.webp","Wallpaper":"/th?id=OHR.TremolaRoad_ROW9264574129_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Tremola Road on the Saint Gotthard Pass in Airolo, Switzerland","Copyright":"© Sandro Bisaro/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260617_TremolaRoad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Tremola+Road&form=hpcapt&filters=HpDate:\"20260617_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260617_TremolaRoad"},"Ssd":"20260617","Name":"TremolaRoad","Market":"ROW","Hash":"9264574129","FullDateString":"17 de jun de 2026"},{"ImageContent":{"Description":"Sea turtles have been navigating Earth's oceans for more than 100 million years. Imagine crossing vast stretches of open water and returning to the same beach decades later. Long migrations between feeding and nesting grounds are central to their lives, with some travelling thousands of kilometres across the oceans. They also play an important role in marine ecosystems by maintaining seagrass beds and helping to keep coral reefs healthy. Despite their resilience, all sea turtle species face threats including habitat loss, plastic pollution, climate change and accidental capture in fishing gear.","Image":{"Url":"/th?id=OHR.SevenMileTurtle_ROW9119311274_1920x1080.webp","Wallpaper":"/th?id=OHR.SevenMileTurtle_ROW9119311274_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Hawksbill sea turtle pair near Seven Mile Beach, Grand Cayman, Cayman Islands","Copyright":"© Alex Mustard/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260616_SevenMileTurtle\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Hawksbill+sea+turtle&form=hpcapt&filters=HpDate:\"20260616_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260616_SevenMileTurtle"},"Ssd":"20260616","Name":"SevenMileTurtle","Market":"ROW","Hash":"9119311274","FullDateString":"16 de jun de 2026"},{"ImageContent":{"Description":"These mountains were shaped over time—and June 15, 1934, helped protect them. That's when the Great Smoky Mountains National Park was established in Tennessee and North Carolina. Covering over 2,112 square kilometres, the park takes its name from the natural smoky haze drifting over its ridgelines. Part of the Appalachian Mountains, these peaks are over 300 million years old.","Image":{"Url":"/th?id=OHR.ParkEstd_ROW8995340148_1920x1080.webp","Wallpaper":"/th?id=OHR.ParkEstd_ROW8995340148_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Great Smoky Mountains National Park, Tennessee, United States","Copyright":"© Mint Images/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260615_ParkEstd\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Great+Smoky+Mountains+National+Park&form=hpcapt&filters=HpDate:\"20260615_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260615_ParkEstd"},"Ssd":"20260615","Name":"ParkEstd","Market":"ROW","Hash":"8995340148","FullDateString":"15 de jun de 2026"},{"ImageContent":{"Description":"At daybreak, the mallard glides over the still water like a brush across a canvas. Its shimmering plumage—emerald-green head in the male, speckled brown coat in the female—catches the first light. It can be seen from the marshes of the Camargue to the urban canals of Amsterdam, a faithful companion of Europe's aquatic landscapes.","Image":{"Url":"/th?id=OHR.DuckPond_ROW8945252603_1920x1080.webp","Wallpaper":"/th?id=OHR.DuckPond_ROW8945252603_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Mallard duck","Copyright":"© Philippe Paternolli/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260614_DuckPond\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Mallard+duck&form=hpcapt&filters=HpDate:\"20260614_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260614_DuckPond"},"Ssd":"20260614","Name":"DuckPond","Market":"ROW","Hash":"8945252603","FullDateString":"14 de jun de 2026"},{"ImageContent":{"Description":"Layered ridges stretch across Badlands National Park in South Dakota. Their bands of pink, grey and gold shift with the light as eroded peaks and valleys come into view. Wind and water continue to shape this terrain, steadily wearing away soft sedimentary rock and exposing millions of years of Earth's history in layers formed by ancient rivers, volcanic ash and periods when shallow seas covered the region.","Image":{"Url":"/th?id=OHR.BadSunset_ROW3111301246_1920x1080.webp","Wallpaper":"/th?id=OHR.BadSunset_ROW3111301246_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Sunset in Badlands National Park, South Dakota, United States","Copyright":"© Troy Harrison/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260613_BadSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Badlands+National+Park&form=hpcapt&filters=HpDate:\"20260613_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260613_BadSunset"},"Ssd":"20260613","Name":"BadSunset","Market":"ROW","Hash":"3111301246","FullDateString":"13 de jun de 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"What does a parliament, a clock tower and a giant wheel have in common? They all stand beside the River Thames as if London had carefully staged its icons for dramatic effect.","Image":{"Url":"/th?id=OHR.ThamesSummer_ROW5725205310_1920x1080.webp","Wallpaper":"/th?id=OHR.ThamesSummer_ROW5725205310_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"The River Thames, London, England","Copyright":"© Daniel Lange/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260626_ThamesSummer\"&FORM=HPQUIZ","BackstageUrl":"/search?q=River+Thames&form=hpcapt&filters=HpDate:\"20260626_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260626_ThamesSummer"},"Ssd":"20260626","Name":"ThamesSummer","Market":"ROW","Hash":"5725205310","FullDateString":"26 de jun de 2026"},{"ImageContent":{"Description":"Few squares in Belgium wear history as well as the Grand Place. The surrounding buildings, seen here, began as guild houses, each funded by a specific trade. Brewers, bakers, merchants and craftsmen treated architecture as language, translating work, status and rivalry into stone through reliefs, coats of arms and generous gold leaf. Styles meet without caution. Gothic verticals rise beside Baroque curves, while the Town Hall, older than its neighbours and unapologetically asymmetrical, holds the composition together.","Image":{"Url":"/th?id=OHR.GrandPlace_ROW9942052634_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandPlace_ROW9942052634_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Buildings on Grand-Place Square in Brussels, Belgium","Copyright":"© Vladislav Zolotov/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_GrandPlace\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Grand+Place+Brussels&form=hpcapt&filters=HpDate:\"20260625_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_GrandPlace"},"Ssd":"20260625","Name":"GrandPlace","Market":"ROW","Hash":"9942052634","FullDateString":"25 de jun de 2026"},{"ImageContent":{"Description":"Zoom in on the small interaction that helps keep landscapes alive: a butterfly on a yellow flower, pausing for nectar. While it feeds, pollen dusts its body and hitches a ride to the next bloom—one of the quiet ways flowering plants reproduce. Pollinators are not only bees. Butterflies, birds, bats, beetles and many other animals help move pollen, supporting wild plants and many of the fruits and vegetables people eat.","Image":{"Url":"/th?id=OHR.BFPollin_ROW9877719219_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_ROW9877719219_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Butterfly pollinating on yellow flower","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Butterfly&form=hpcapt&filters=HpDate:\"20260624_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"ROW","Hash":"9877719219","FullDateString":"24 de jun de 2026"},{"ImageContent":{"Description":"Mount Fuji, Japan's highest mountain, rises to 3,776 metres on Honshu Island, about 97 kilometres southwest of Tokyo. Its near-perfect cone is a volcano—dormant since its last eruption in December 1707 yet still classed as active. That last major event is known as the Hōei eruption. It blasted ash and other tephra across eastern Japan, reaching Edo (today's Tokyo). Beyond geology, Fuji has long been treated as a sacred landscape and a destination for pilgrimage climbs, reflecting how nature, religion and daily life overlap in Japan. That enduring cultural appeal is one reason it was designated a UNESCO World Heritage Site in 2013 as 'a sacred place and source of artistic inspiration.' Fuji is famously visible from far away on clear days but never guaranteed—clouds can hide it in minutes. Whether you hike it or just catch a glimpse from a train window, it still feels like Japan's signature on the horizon.","Image":{"Url":"/th?id=OHR.Fujisan_ROW9816660784_1920x1080.webp","Wallpaper":"/th?id=OHR.Fujisan_ROW9816660784_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Mount Fuji on Honshu Island, Japan","Copyright":"© phutthiseth thongtae/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260623_Fujisan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Mount+Fuji&form=hpcapt&filters=HpDate:\"20260623_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260623_Fujisan"},"Ssd":"20260623","Name":"Fujisan","Market":"ROW","Hash":"9816660784","FullDateString":"23 de jun de 2026"},{"ImageContent":{"Description":"Rainforests aren't just dots on the map. They thrive across the tropics and beyond, yet cover only about 6% of Earth's surface. Quinault, in Olympic National Park in Washington state, is a primeval temperate rainforest on the Olympic Peninsula, where Pacific moisture creates ideal conditions for dense growth. Rain and drifting fog keep the forest thriving, turning branches, trunks and even fallen logs into living surfaces.","Image":{"Url":"/th?id=OHR.QuinaultFerns_ROW9752257605_1920x1080.webp","Wallpaper":"/th?id=OHR.QuinaultFerns_ROW9752257605_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Quinault rainforest, Olympic National Park, Washington state, United States","Copyright":"© Chris Moore/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260622_QuinaultFerns\"&FORM=HPQUIZ","BackstageUrl":"/search?q=World+Rainforest+Day&form=hpcapt&filters=HpDate:\"20260622_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260622_QuinaultFerns"},"Ssd":"20260622","Name":"QuinaultFerns","Market":"ROW","Hash":"9752257605","FullDateString":"22 de jun de 2026"},{"ImageContent":{"Description":"Above the Tarn Valley, the Millau Viaduct seems to brush the sky. At 343 metres, its highest pylons rise taller than the Eiffel Tower. At dawn, light mist often drifts between the hills of the Larzac plateau and Aveyron, wrapping steel and concrete in an almost unreal softness. From some viewpoints, the bridge can appear to float above the clouds rather than standing upon them.","Image":{"Url":"/th?id=OHR.MillauViaductFrance_ROW0201721820_1920x1080.webp","Wallpaper":"/th?id=OHR.MillauViaductFrance_ROW0201721820_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Millau Viaduct, France","Copyright":"© Sergi Reboredo/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260621_MillauViaductFrance\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Millau+Viaduct&form=hpcapt&filters=HpDate:\"20260621_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260621_MillauViaductFrance"},"Ssd":"20260621","Name":"MillauViaductFrance","Market":"ROW","Hash":"0201721820","FullDateString":"21 de jun de 2026"},{"ImageContent":{"Description":"A sculpted arch of ice rises from the Southern Ocean along the Antarctic Peninsula, one of the fastest-warming regions on Earth. This formation began as compacted snow that turned into glacial ice over thousands of years. Eventually, part of a glacier or floating ice shelf fractured and broke free—a process known as calving—creating a drifting iceberg.","Image":{"Url":"/th?id=OHR.ArchedIceberg_ROW4666187976_1920x1080.webp","Wallpaper":"/th?id=OHR.ArchedIceberg_ROW4666187976_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Arched iceberg floating off the western Antarctic Peninsula, Southern Ocean","Copyright":"© Steven Kazlowski/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260620_ArchedIceberg\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Iceberg&form=hpcapt&filters=HpDate:\"20260620_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260620_ArchedIceberg"},"Ssd":"20260620","Name":"ArchedIceberg","Market":"ROW","Hash":"4666187976","FullDateString":"20 de jun de 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Imagen del día","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Más información","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donar ahora","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Sabías que:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Imágenes recientes de la página principal","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Imagen de la página principal del {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"En este día en la historia","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"Este día en {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Compartir la página principal de Bing de hoy","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Descarga la imagen. Solo se puede usar como papel tapiz.","LOC_MUSCARD_DOWNLOAD_LINK":"Descarga esta imagen","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"Esta imagen no está disponible para su descarga como fondo de pantalla.","LOC_HOMEPAGE_INFO_TEXT":"Información","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Obtén la aplicación Fondo de pantalla de Bing","LOC_BING_APP_TEXT":"Obtén la aplicación de Bing Wallpaper en tus dispositivos","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adjust=nk9xri2_dzfz5n2","LOC_BING_APP_LINK_MOBILE":"https://app.adjust.com/d93ddtl_a75k0gg?deeplink=sapphire%3A%2F%2Fwallpaper","LOC_BING_APP_DOWNLOAD_TEXT":"Aplicación móvil","LOC_BING_WP_APP_DOWNLOAD_TEXT":"Aplicació