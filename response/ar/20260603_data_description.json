{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-03T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Cutting a surreal path through the high-altitude deserts of western China, Xitai Jinaier Lake (also known as West Taijinar Lake) is a striking salt lake in the remote Qaidam Basin. A stretch of National Highway 315 runs directly across its shallow waters, creating the illusion of a road floating between two worlds. On one side, the water often appears deep blue; on the other, a softer green hue, a contrast shaped by differing mineral concentrations in the brine.","Image":{"Url":"/th?id=OHR.Qinghai_ROW4654938866_1920x1080.webp","Wallpaper":"/th?id=OHR.Qinghai_ROW4654938866_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Highway through Xitai Jinaier Lake, Qinghai Province, China","Copyright":"© Kaicheng Xu/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260602_Qinghai\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Qaidam+Basin+China&form=hpcapt&filters=HpDate:\"20260602_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260602_Qinghai"},"Ssd":"20260602","Name":"Qinghai","Market":"ROW","Hash":"4654938866","FullDateString":"2 de jun de 2026"},{"ImageContent":{"Description":"Palermo, the capital of the island of Sicily in southern Italy, is a city where layers of history, art and culture meet in a vivid and sometimes chaotic harmony. Founded by the Phoenicians and later shaped by Romans, Arabs, Normans and Spaniards, it carries traces of many civilisations that passed through the Mediterranean. This rich past is visible in its architecture, from the Arab-Norman palaces and churches recognised by UNESCO to the Baroque facades that define its historic streets.","Image":{"Url":"/th?id=OHR.OlivaPalermo_ROW4355319130_1920x1080.webp","Wallpaper":"/th?id=OHR.OlivaPalermo_ROW4355319130_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Palermo skyline at dusk, Sicily, Italy","Copyright":"© Sean Pavone/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260601_OlivaPalermo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Palermo&form=hpcapt&filters=HpDate:\"20260601_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260601_OlivaPalermo"},"Ssd":"20260601","Name":"OlivaPalermo","Market":"ROW","Hash":"4355319130","FullDateString":"1 de jun de 2026"},{"ImageContent":{"Description":"Few places show their power quite like Everglades National Park in Florida, United States. From above, Florida's iconic wetlands unfold as a vast patchwork of shallow water, sawgrass, mangroves and winding channels, shaped by freshwater flowing slowly south from Lake Okeechobee.","Image":{"Url":"/th?id=OHR.EvergladesWetlands_ROW3871146559_1920x1080.webp","Wallpaper":"/th?id=OHR.EvergladesWetlands_ROW3871146559_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Aerial view of Everglades National Park, Florida, United States","Copyright":"© Tetra Images/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260531_EvergladesWetlands\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Everglades+National+Park&form=hpcapt&filters=HpDate:\"20260531_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260531_EvergladesWetlands"},"Ssd":"20260531","Name":"EvergladesWetlands","Market":"ROW","Hash":"3871146559","FullDateString":"31 de may de 2026"},{"ImageContent":{"Description":"Etosha National Park, Namibia, is not a place for soft starts, and the plains zebra foal in this image seems to get the memo. In a land this vast—nearly 22,300 square kilometres of salt pans and grassland—timing is everything, and hesitation is expensive. Lions, spotted hyenas, wild dogs, cheetahs and leopards constantly pressure the herd—especially the youngest—so zebras are born ready. Minutes after arrival, they're upright. Hours later, they're moving.","Image":{"Url":"/th?id=OHR.EquusQuagga_ROW3735095884_1920x1080.webp","Wallpaper":"/th?id=OHR.EquusQuagga_ROW3735095884_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Plains zebra foal in Etosha National Park, Namibia","Copyright":"© Sharon Heald/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260530_EquusQuagga\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Plains+zebras&form=hpcapt&filters=HpDate:\"20260530_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260530_EquusQuagga"},"Ssd":"20260530","Name":"EquusQuagga","Market":"ROW","Hash":"3735095884","FullDateString":"30 de may de 2026"},{"ImageContent":{"Description":"In Sagarmatha National Park, Nepal, Mount Everest rises into view, calm and unmoved as evening settles in. That stillness was broken in 1953. After years of planning and weeks of climbing, New Zealander Edmund Hillary and Sherpa mountaineer Tenzing Norgay reached the summit. At just under 8,850 metres above sea level, they became the first people known to have stood at Earth's highest point.","Image":{"Url":"/th?id=OHR.SummitEverest_ROW0124036396_1920x1080.webp","Wallpaper":"/th?id=OHR.SummitEverest_ROW0124036396_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Mount Everest summit, Sagarmatha National Park, Nepal","Copyright":"© fotoVoyager/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260529_SummitEverest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Mount+Everest&form=hpcapt&filters=HpDate:\"20260529_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260529_SummitEverest"},"Ssd":"20260529","Name":"SummitEverest","Market":"ROW","Hash":"0124036396","FullDateString":"29 de may de 2026"},{"ImageContent":{"Description":"As night settles over Suwon, South Korea, the old city wall pictured here shows that function doesn't necessarily cancel out beauty—it can create it. Built between 1794 and 1796 under King Jeongjo of the Joseon Dynasty, Hwaseong Fortress was more than a barrier. It was policy in stone: a reform-minded push for a leaner, better-run state, driven by practicality and a deeply personal motive. Jeongjo ordered its construction to honour his father while strengthening a kingdom that wanted smarter systems, not just thicker walls.","Image":{"Url":"/th?id=OHR.HwaesongFortress_ROW5120424335_1920x1080.webp","Wallpaper":"/th?id=OHR.HwaesongFortress_ROW5120424335_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Old city wall of Hwaseong Fortress, Suwon, South Korea","Copyright":"© aomam/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260528_HwaesongFortress\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Hwaseong+Fortress+Suwon&form=hpcapt&filters=HpDate:\"20260528_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260528_HwaesongFortress"},"Ssd":"20260528","Name":"HwaesongFortress","Market":"ROW","Hash":"5120424335","FullDateString":"28 de may de 2026"},{"ImageContent":{"Description":"Just look at this cutie swimming in the waters of Kachemak Bay in Alaska! Otters are captivating creatures that play an essential role in maintaining healthy ecosystems. Known for their playful behaviour and remarkable intelligence, otters are key indicators of waterway health. Sadly, they face growing challenges from habitat loss and pollution.","Image":{"Url":"/th?id=OHR.OtterDay_ROW8950256578_1920x1080.webp","Wallpaper":"/th?id=OHR.OtterDay_ROW8950256578_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Sea otter, Kachemak Bay, Homer, Alaska, United States","Copyright":"© roclwyr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260527_OtterDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sea+Otter&form=hpcapt&filters=HpDate:\"20260527_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260527_OtterDay"},"Ssd":"20260527","Name":"OtterDay","Market":"ROW","Hash":"8950256578","FullDateString":"27 de may de 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Vernazza is a small seaside town in Cinque Terre, in Italy's Liguria region. Built around the area's only natural harbour, it has long been tied to the sea. First recorded in 1080 as a fortified settlement and maritime base, it later became part of the Republic of Genoa's coastal defences. To this day, the village preserves its past in the ruins of Doria Castle and the watchtowers overlooking the bay. At the water's edge stands the Church of Santa Margherita d'Antiochia, first mentioned in 1318 and expanded in later centuries, with a bell tower overlooking the port. Above the houses and narrow lanes, steep terraces support vineyards and olive groves, shaped by generations of stonework in a landscape protected within Cinque Terre National Park, part of a UNESCO World Heritage Site. Picture an aperitivo here: a glass of local white wine, the harbour in view and Ligurian favourites like focaccia and basil pesto—basically a postcard you can taste.","Image":{"Url":"/th?id=OHR.CTNPVernazza_ROW6038252808_1920x1080.webp","Wallpaper":"/th?id=OHR.CTNPVernazza_ROW6038252808_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Vernazza, Cinque Terre, Liguria, Italy","Copyright":"© Kelly Cheng/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260609_CTNPVernazza\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Vernazza+Cinque+Terre+Liguria+Italy&form=hpcapt&filters=HpDate:\"20260609_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260609_CTNPVernazza"},"Ssd":"20260609","Name":"CTNPVernazza","Market":"ROW","Hash":"6038252808","FullDateString":"9 de jun de 2026"},{"ImageContent":{"Description":"Today, let's follow the lead of a creature that goes wherever the water takes it. Want to spot a lion's mane jellyfish? Look in cold northern seas. Its bell is divided into eight lobes, and beneath it trail long tentacles and oral arms that can capture plankton, fish and even other jellyfish. Well, a single animal may carry thousands of stinging cells on each tentacle. For humans, the sting can be painful, and even detached tentacles washed ashore may still react on contact. The rule is simple: admire it, then leave it alone.","Image":{"Url":"/th?id=OHR.Cyanea_ROW5915372220_1920x1080.webp","Wallpaper":"/th?id=OHR.Cyanea_ROW5915372220_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Lion's mane jellyfish swimming in the ocean","Copyright":"© Alexander Semenov Images/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260608_Cyanea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Lions+mane+jellyfish&form=hpcapt&filters=HpDate:\"20260608_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260608_Cyanea"},"Ssd":"20260608","Name":"Cyanea","Market":"ROW","Hash":"5915372220","FullDateString":"8 de jun de 2026"},{"ImageContent":{"Description":"At Dunseverick Castle in Northern Ireland, history hangs on—literally. Wall fragments cling to a basalt stack above the Atlantic, proving that even ruins can hold their ground. Two thousand years ago, it marked the end of the Slige Midluachra, one of Ireland's five great roads, linking travellers to the royal seat at Hill of Tara. In the 5th century, Saint Patrick is said to have visited and baptised a local man, Olcán, here. Tradition holds that the Lia Fáil (Stone of Destiny), used for crowning Irish kings, was taken from this shore for Scotland.","Image":{"Url":"/th?id=OHR.DunseverickCastle2026_ROW5774172338_1920x1080.webp","Wallpaper":"/th?id=OHR.DunseverickCastle2026_ROW5774172338_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Ruins of Dunseverick Castle, County Antrim, Northern Ireland","Copyright":"© Krzysztof Rogalski/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260607_DunseverickCastle2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Dunseverick+Castle&form=hpcapt&filters=HpDate:\"20260607_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260607_DunseverickCastle2026"},"Ssd":"20260607","Name":"DunseverickCastle2026","Market":"ROW","Hash":"5774172338","FullDateString":"7 de jun de 2026"},{"ImageContent":{"Description":"Near Tupelo, Mississippi, the Natchez Trace Parkway follows one of North America's oldest travel corridors. Long before paved roads and motorways, Native American communities used this route for trade, hunting and communication across the Southeast. Curious how deeply history can shape a landscape? Some preserved sections of the original trail still sit noticeably below ground level, worn down by centuries of footsteps, horses and wagon wheels. Later, European and American traders, soldiers and explorers relied on the path during the late 18th and early 19th centuries.","Image":{"Url":"/th?id=OHR.HikingNatchez_ROW5481453055_1920x1080.webp","Wallpaper":"/th?id=OHR.HikingNatchez_ROW5481453055_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Natchez Trace Parkway, Tupelo, Mississippi, United States","Copyright":"© The best photo is earned/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260606_HikingNatchez\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Natchez+Trace+Parkway&form=hpcapt&filters=HpDate:\"20260606_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260606_HikingNatchez"},"Ssd":"20260606","Name":"HikingNatchez","Market":"ROW","Hash":"5481453055","FullDateString":"6 de jun de 2026"},{"ImageContent":{"Description":"If nature had a 'do not disturb' sign, it would hang over Sarek National Park, often called 'the last European wilderness.' This remote corner of Swedish Lapland reminds us what the planet looks like when humans take a step back—and let the wild take the lead.","Image":{"Url":"/th?id=OHR.WedLapland_ROW5306546113_1920x1080.webp","Wallpaper":"/th?id=OHR.WedLapland_ROW5306546113_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"View from Skierffe Mountain over the Rapadalen river delta, Sarek National Park, Laponia, Lapland, Sweden","Copyright":"© Robert Haasmann/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260605_WedLapland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sarek+National+Park&form=hpcapt&filters=HpDate:\"20260605_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260605_WedLapland"},"Ssd":"20260605","Name":"WedLapland","Market":"ROW","Hash":"5306546113","FullDateString":"5 de jun de 2026"},{"ImageContent":{"Description":"Poetic name, poetic appearance. Meet the snowy egret, whose all-white plumage and bright yellow 'slippers' on black legs give it a striking look. Once nearly wiped out by demand for its delicate breeding-season feathers—soft, lacy plumes prized for fashionable hats—conservation efforts saved its plumage.","Image":{"Url":"/th?id=OHR.PreeningEgret_ROW4946670098_1920x1080.webp","Wallpaper":"/th?id=OHR.PreeningEgret_ROW4946670098_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Snowy egret preening, central Florida, United States","Copyright":"© Donald M. Jones/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260604_PreeningEgret\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Snowy+egret&form=hpcapt&filters=HpDate:\"20260604_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260604_PreeningEgret"},"Ssd":"20260604","Name":"PreeningEgret","Market":"ROW","Hash":"4946670098","FullDateString":"4 de jun de 2026"},{"ImageContent":{"Description":"An adventurer shown here cycles through Bardenas Reales Natural Park and Biosphere Reserve in Navarra, Spain, a stark landscape shaped by wind and water over millions of years. Its maze of eroded cliffs, plateaus and dry channels feels closer to another planet than northern Spain. Ever wondered why filmmakers use it as a stand-in for deserts and distant worlds? The reserve covers more than 400 square kilometres and supports hardy plants adapted to heat, drought and poor soils. Griffon vultures circle above ravines, while foxes, wildcats and migratory birds move across the semi-arid terrain.","Image":{"Url":"/th?id=OHR.BardenasReales_ROW4809412441_1920x1080.webp","Wallpaper":"/th?id=OHR.BardenasReales_ROW4809412441_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Cyclist in Bardenas Reales Natural Park and Biosphere Reserve, Navarra, Spain","Copyright":"© Artur Debat/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260603_BardenasReales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Bardenas+Reales+Natural+Park+and+Biosphere+Reserve&form=hpcapt&filters=HpDate:\"20260603_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260603_BardenasReales"},"Ssd":"20260603","Name":"BardenasReales","Market":"ROW","Hash":"4809412441","FullDateString":"3 de jun de 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Imagen del día","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Más información","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donar ahora","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Sabías que:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Imágenes recientes de la página principal","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Imagen de la página principal del {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"En este día en la historia","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"Este día en {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Compartir la página principal de Bing de hoy","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Descarga la imagen. Solo se puede usar como papel tapiz.","LOC_MUSCARD_DOWNLOAD_LINK":"Descarga esta imagen","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"Esta imagen no está disponible para su descarga como fondo de pantalla.","LOC_HOMEPAGE_INFO_TEXT":"Información","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Obtén la aplicac