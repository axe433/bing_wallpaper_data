{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-05-08T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Few animals have matched humanity's quiet resilience quite like the donkey. Donkeys have worked alongside people for thousands of years, prized for their endurance, sharp memory and sure-footed confidence on rugged ground.","Image":{"Url":"/th?id=OHR.SardinianDonkey_ROW1501196122_1920x1080.webp","Wallpaper":"/th?id=OHR.SardinianDonkey_ROW1501196122_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Sardinian donkey mare and foal, France","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260508_SardinianDonkey\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sardinian+donkey&form=hpcapt&filters=HpDate:\"20260508_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260508_SardinianDonkey"},"Ssd":"20260508","Name":"SardinianDonkey","Market":"ROW","Hash":"1501196122","FullDateString":"8 maj 2026"},{"ImageContent":{"Description":"Stretching across the Sonoran Desert in southwestern Arizona, Kofa National Wildlife Refuge is a land of sharp peaks, wide skies and surprising life. The refuge was established in 1939 to protect desert bighorn sheep, whose sure-footed silhouettes still define the rugged landscape.","Image":{"Url":"/th?id=OHR.Kofa_ROW0914409827_1920x1080.webp","Wallpaper":"/th?id=OHR.Kofa_ROW0914409827_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Kofa National Wildlife Refuge, Arizona, United States","Copyright":"© Denis Tangney Jr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260507_Kofa\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Kofa+National+Wildlife+Refuge&form=hpcapt&filters=HpDate:\"20260507_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260507_Kofa"},"Ssd":"20260507","Name":"Kofa","Market":"ROW","Hash":"0914409827","FullDateString":"7 maj 2026"},{"ImageContent":{"Description":"Located on the eastern Balkan Peninsula, Bulgaria sits at the crossroads of Europe and Asia, where ancient cultures, fertile landscapes and shifting climates converge.","Image":{"Url":"/th?id=OHR.BulgariaPlains_ROW5132279610_1920x1080.webp","Wallpaper":"/th?id=OHR.BulgariaPlains_ROW5132279610_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Thunderstorm above the plains, Bulgaria","Copyright":"© Revolu7ion93/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260506_BulgariaPlains\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Bulgaria&form=hpcapt&filters=HpDate:\"20260506_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260506_BulgariaPlains"},"Ssd":"20260506","Name":"BulgariaPlains","Market":"ROW","Hash":"5132279610","FullDateString":"6 maj 2026"},{"ImageContent":{"Description":"In the highlands of Jalisco, Mexico, rows of blue agave stretch across the landscape, their spiky leaves catching the light like a field of sculpted stars. This region, centred around the town of Tequila, is the birthplace of tequila, a spirit deeply tied to both land and tradition.","Image":{"Url":"/th?id=OHR.MayoAgave_ROW0279228757_1920x1080.webp","Wallpaper":"/th?id=OHR.MayoAgave_ROW0279228757_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Field of blue agave near Tequila, Jalisco, Mexico","Copyright":"© Brian Overcast/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260505_MayoAgave\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Tequila+Jalisco+Mexico&form=hpcapt&filters=HpDate:\"20260505_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260505_MayoAgave"},"Ssd":"20260505","Name":"MayoAgave","Market":"ROW","Hash":"0279228757","FullDateString":"5 maj 2026"},{"ImageContent":{"Description":"Today's image takes us to Ksar Ouled Soltane in Tunisia's Tataouine district, where stacked clay granaries rise like sand-coloured fortresses. Dating back to the 15th century, this storehouse complex was built by Berber communities to protect harvests from heat, theft and time. Function first. Beauty as a side effect.","Image":{"Url":"/th?id=OHR.KsarOuledSoltane_ROW9968378030_1920x1080.webp","Wallpaper":"/th?id=OHR.KsarOuledSoltane_ROW9968378030_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Ksar Ouled Soltane, Tataouine district in southern Tunisia","Copyright":"© Dark_Eni/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260504_KsarOuledSoltane\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Ksar+Ouled+Soltane+Tataouine+district&form=hpcapt&filters=HpDate:\"20260504_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260504_KsarOuledSoltane"},"Ssd":"20260504","Name":"KsarOuledSoltane","Market":"ROW","Hash":"9968378030","FullDateString":"4 maj 2026"},{"ImageContent":{"Description":"High above the savannah in Kenya's Masai Mara National Reserve, a leopard curls up on a tree branch, napping as the grasslands glow at sunset. Today, let's throw light on one of the world's most adaptable big cats. Leopards roam across Africa and parts of Asia, thriving in habitats that range from forests and mountains to open savannas. Their spotted coats are unique to each individual, like fingerprints, and their powerful climbing skills allow them to stash prey high in trees, out of reach of scavengers.","Image":{"Url":"/th?id=OHR.MasaiLeopard_ROW2641665263_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiLeopard_ROW2641665263_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Leopard sleeping in a tree in the savannah, Masai Mara National Reserve, Kenya","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260503_MasaiLeopard\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Masai+Mara+National+Reserve&form=hpcapt&filters=HpDate:\"20260503_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260503_MasaiLeopard"},"Ssd":"20260503","Name":"MasaiLeopard","Market":"ROW","Hash":"2641665263","FullDateString":"3 maj 2026"},{"ImageContent":{"Description":"Can you picture 11,000 square kilometres of protected wilderness? That's Jasper National Park in Alberta. Established in 1907 as part of a growing network of protected landscapes in the Canadian Rockies, it was designated a national park in 1930. The park reflects both conservation efforts and much older Indigenous connections, including those of the Nakoda and Secwépemc peoples. Its terrain ranges from glacier-fed rivers and alpine meadows to dense conifer forests dominated by spruce and pine.","Image":{"Url":"/th?id=OHR.GreenJasper_ROW9272973075_1920x1080.webp","Wallpaper":"/th?id=OHR.GreenJasper_ROW9272973075_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Small lake and marsh in Jasper National Park in Alberta, Canada","Copyright":"© Don White/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260502_GreenJasper\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Jasper+National+Park+Alberta&form=hpcapt&filters=HpDate:\"20260502_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260502_GreenJasper"},"Ssd":"20260502","Name":"GreenJasper","Market":"ROW","Hash":"9272973075","FullDateString":"2 maj 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Brains, brawn and a serious case of going deep—the sperm whale isn't here for surface-level living. Today, we meet a giant that thinks big and dives deeper.","Image":{"Url":"/th?id=OHR.EndangeredWhales_ROW6081633589_1920x1080.webp","Wallpaper":"/th?id=OHR.EndangeredWhales_ROW6081633589_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"A family of sperm whales, Indian Ocean","Copyright":"© Tony Wu/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260515_EndangeredWhales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Sperm+whales&form=hpcapt&filters=HpDate:\"20260515_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260515_EndangeredWhales"},"Ssd":"20260515","Name":"EndangeredWhales","Market":"ROW","Hash":"6081633589","FullDateString":"15 maj 2026"},{"ImageContent":{"Description":"Perched on a tufa ridge in southern Tuscany, Italy, Pitigliano is a small town with a big personality. Its roots stretch back to Etruscan times, and the winding streets still echo the past, from medieval fortifications to Renaissance palaces. Walking through its narrow alleys, you can feel centuries of life carved into the stone, while small piazzas invite pauses for coffee or gelato. This enduring treasure is often called 'Little Jerusalem' for its historic Jewish quarter, where a synagogue and historic cemetery tell stories of a once-thriving community.","Image":{"Url":"/th?id=OHR.Pitigliano_ROW4097720054_1920x1080.webp","Wallpaper":"/th?id=OHR.Pitigliano_ROW4097720054_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Medieval town of Pitigliano, Tuscany, Italy","Copyright":"© bluejayphoto/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260514_Pitigliano\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Pitigliano+Tuscany&form=hpcapt&filters=HpDate:\"20260514_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260514_Pitigliano"},"Ssd":"20260514","Name":"Pitigliano","Market":"ROW","Hash":"4097720054","FullDateString":"14 maj 2026"},{"ImageContent":{"Description":"In today's image, the granite arches of the Alabama Hills frame the Milky Way over a rugged landscape in California's eastern Sierra Nevada, United States. Famous for its rounded boulders and weathered rock formations, this area formed when molten rock cooled deep underground around 100 million years ago. Water and wind gradually shaped the stone into the smooth shapes seen today. Visitors can explore the natural arches, hike among the rocks, capture photographs of the unique landscape, ride horses or mountain bikes and enjoy seasonal displays of wildflowers.","Image":{"Url":"/th?id=OHR.AlabamaHills_ROW6449052938_1920x1080.webp","Wallpaper":"/th?id=OHR.AlabamaHills_ROW6449052938_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Arch and Milky Way, Alabama Hills, Sierra Nevada, California, United States","Copyright":"© Tim Fitzharris/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260513_AlabamaHills\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Alabama+Hills&form=hpcapt&filters=HpDate:\"20260513_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260513_AlabamaHills"},"Ssd":"20260513","Name":"AlabamaHills","Market":"ROW","Hash":"6449052938","FullDateString":"13 maj 2026"},{"ImageContent":{"Description":"Along the rocky coasts of the North Atlantic, Atlantic puffins make their homes in burrows and cliffside crevices. These seabirds, with their black‑and‑white plumage and colourful beaks, are classified by the IUCN as vulnerable, as overfishing and changing ocean conditions reduce the availability of their prey. Each spring, they return to breed, laying a single egg in carefully dug burrows. Remarkable swimmers, they use their wings to 'fly' underwater when hunting small fish such as herring and sand eels.","Image":{"Url":"/th?id=OHR.Fratercula_ROW2531275403_1920x1080.webp","Wallpaper":"/th?id=OHR.Fratercula_ROW2531275403_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Atlantic puffins, Wales","Copyright":"© FLPA/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260512_Fratercula\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Atlantic+puffin&form=hpcapt&filters=HpDate:\"20260512_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260512_Fratercula"},"Ssd":"20260512","Name":"Fratercula","Market":"ROW","Hash":"2531275403","FullDateString":"12 maj 2026"},{"ImageContent":{"Description":"One of the world's greatest natural wonders stretches through the turquoise waters of the Coral Sea off Australia's northeast shoreline. The Great Barrier Reef, running along the coast of Queensland, is the world's largest coral reef system. It is made up of nearly 3,000 individual reefs and hundreds of islands, spanning more than 2,253 kilometres.","Image":{"Url":"/th?id=OHR.QueenslandReef_ROW2249526975_1920x1080.webp","Wallpaper":"/th?id=OHR.QueenslandReef_ROW2249526975_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Great Barrier Reef from above, Queensland, Australia","Copyright":"© Francesco Riccardo Iacomino/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260511_QueenslandReef\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Great+Barrier+Reef+Australia&form=hpcapt&filters=HpDate:\"20260511_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260511_QueenslandReef"},"Ssd":"20260511","Name":"QueenslandReef","Market":"ROW","Hash":"2249526975","FullDateString":"11 maj 2026"},{"ImageContent":{"Description":"Captured in Wapusk National Park in northern Manitoba, Canada, today's image shows a polar bear mother and her cubs sharing a playful moment on the Arctic tundra. For polar bears, motherhood is a long and demanding commitment. Females give birth in winter, sheltering their newborn cubs in snow dens that provide vital insulation. Cubs are born tiny and rely entirely on their mother's rich, fat-heavy milk for warmth and rapid growth.","Image":{"Url":"/th?id=OHR.MotherCub_ROW1931444463_1920x1080.webp","Wallpaper":"/th?id=OHR.MotherCub_ROW1931444463_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Polar bear mother and cubs playing in Wapusk National Park, Manitoba, Canada","Copyright":"© Hao Jiang/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260510_MotherCub\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Polar+bear&form=hpcapt&filters=HpDate:\"20260510_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260510_MotherCub"},"Ssd":"20260510","Name":"MotherCub","Market":"ROW","Hash":"1931444463","FullDateString":"10 maj 2026"},{"ImageContent":{"Description":"Water is the architect of Krka National Park in Croatia, shaping emerald pools and layered waterfalls along the Krka River. Today's image highlights Skradinski Buk, the park's most famous waterfall system, where multiple streams spill over travertine terraces in a dense forest near the village of Lozovac.","Image":{"Url":"/th?id=OHR.SkradinskiBuk_ROW1678535800_1920x1080.webp","Wallpaper":"/th?id=OHR.SkradinskiBuk_ROW1678535800_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Info","Title":"Skradinski Buk Waterfall in Krka National Park, Croatia","Copyright":"© Amazing Aerial Agency/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260509_SkradinskiBuk\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Krka+National+Park+Croatia&form=hpcapt&filters=HpDate:\"20260509_0700\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260509_SkradinskiBuk"},"Ssd":"20260509","Name":"SkradinskiBuk","Market":"ROW","Hash":"1678535800","FullDateString":"9 maj 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Obraz dnia","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Więcej informacji","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Przekaż darowiznę","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Ciekawostka:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Ostatnie obrazy na stronie głównej","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Obraz na stronie głównej na {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"Wydarzenia historyczne z tego dnia","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"W tym dniu w {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Udostępnij dzisiejszą stronę główną usługi Bing","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Pobierz ten obraz. Ten obraz może być używany tylko jako tapeta.","LOC_MUSCARD_DOWNLOAD_LINK":"Pobierz ten obraz","LOC_HOMEPAGE_WA