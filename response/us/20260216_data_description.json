{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-02-16T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Presidents' Day is observed on the third Monday of February and is officially recognized at the federal level as Washington's Birthday. The holiday was originally celebrated on February 22, George Washington's birthday, before being rescheduled under the Uniform Monday Holiday Act. Passed in 1968 and implemented in 1971, the Act shifted several federal holidays to Mondays, creating standardized long weekends. Washington's Birthday was among those affected, which moved the observance away from Washington's actual birthday and allowed its meaning to broaden over time.","Image":{"Url":"/th?id=OHR.PresidentsDay_EN-US6598155144_1920x1080.webp","Wallpaper":"/th?id=OHR.PresidentsDay_EN-US6598155144_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Legacies in view","Title":"Lincoln Memorial, Washington, DC","Copyright":"© Westend61/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.889286,-77.050179/12?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=38.889286,-77.050179;S9;Lincoln%20Memorial%2C%20Washington%2C%20DC&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=18&q=Lincoln%20Memorial%2C%20Washington%2C%20District%20of%20Columbia%2C%20United%20States&ss=ypid.YNB07BE067C65046BA&mb=38.895809~-77.060208~38.882748~-77.040167&description=2%20Lincoln%20Memorial%20Cir%20NW%2C%20Washington%2C%20DC%2020037&cardbg=%233AABCF&dt=1766449800000&tt=Lincoln%20Memorial&tsts0=%2526ty%253D18%2526q%253DLincoln%252520Memorial%25252C%252520Washington%25252C%252520District%252520of%252520Columbia%25252C%252520United%252520States%2526ss%253Dypid.YNB07BE067C65046BA%2526mb%253D38.895809~-77.060208~38.882748~-77.040167%2526description%253D2%252520Lincoln%252520Memorial%252520Cir%252520NW%25252C%252520Washington%25252C%252520DC%25252020037%2526cardbg%253D%2525233AABCF%2526dt%253D1766449800000&tstt0=Lincoln%20Memorial&cp=38.690058~-77.995526&lvl=8.167124&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260216_PresidentsDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Presidents+Day&form=hpcapt&filters=HpDate:\"20260216_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260216_PresidentsDay"},"Ssd":"20260216","Name":"PresidentsDay","Market":"EN-US","Hash":"6598155144","FullDateString":"Feb 16, 2026"},{"ImageContent":{"Description":"World Whale Day, observed on the third Sunday of February, began in the 1980s in Hawaii, where communities celebrated the seasonal return of migrating humpback whales. The day gained wider recognition after the International Whaling Commission's 1986 moratorium on commercial whaling, which marked a major milestone in international whale conservation.","Image":{"Url":"/th?id=OHR.MontereyHumpbacks_EN-US6328970690_1920x1080.webp","Wallpaper":"/th?id=OHR.MontereyHumpbacks_EN-US6328970690_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Songs beneath the waves","Title":"Humpback whales in Monterey Bay, California","Copyright":"© Kiliii Fish/Cavan Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/36.8,-121.9/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=36.8,-121.9;S9;Monterey Bay, California&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=30&q=Monterey%20Bay%2C%20California%2C%20United%20States&satid=id.sid%3A7a521404-94a6-1178-e22e-a4785d548927&vdpid=5058067213018202113&mb=36.998808~-122.349881~36.600414~-121.450241&cardbg=%23FFFFFF&dt=1766431800000&tt=Monterey%20Bay%2C%20California%2C%20United%20States&tsts0=%2526ty%253D30%2526q%253DMonterey%252520Bay%25252C%252520California%25252C%252520United%252520States%2526satid%253Did.sid%25253A7a521404-94a6-1178-e22e-a4785d548927%2526vdpid%253D5058067213018202113%2526mb%253D36.998808~-122.349881~36.600414~-121.450241%2526cardbg%253D%252523FFFFFF%2526dt%253D1766431800000&tstt0=Monterey%20Bay%2C%20California%2C%20United%20States&cp=36.371447~-125.661252&lvl=6.232266&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260215_MontereyHumpbacks\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Whale&form=hpcapt&filters=HpDate:\"20260215_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260215_MontereyHumpbacks"},"Ssd":"20260215","Name":"MontereyHumpbacks","Market":"EN-US","Hash":"6328970690","FullDateString":"Feb 15, 2026"},{"ImageContent":{"Description":"Valentine's Day celebrates the heart in all its forms—love that is bold or tender, hopeful or quietly vulnerable. Few symbols capture this emotion as naturally as the bleeding heart flower, pictured here. With its unmistakable heart-shaped blooms, the plant emerges each spring, growing up to 2 feet tall and spreading nearly 30 inches wide, creating a graceful, almost poetic display.","Image":{"Url":"/th?id=OHR.ValentineHearts_EN-US6208359150_1920x1080.webp","Wallpaper":"/th?id=OHR.ValentineHearts_EN-US6208359150_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Love in bloom","Title":"Bleeding hearts","Copyright":"© Dorene Hookey/Cavan Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"It is widely believed that Valentine's Day has pagan roots, specifically in the Roman festival of Lupercalia, which celebrated fertility and the onset of spring.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260214_ValentineHearts\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Valentines+day&form=hpcapt&filters=HpDate:\"20260214_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260214_ValentineHearts"},"Ssd":"20260214","Name":"ValentineHearts","Market":"EN-US","Hash":"6208359150","FullDateString":"Feb 14, 2026"},{"ImageContent":{"Description":"Before bridges, rivers set the pace of travel. Now, with bridges, people do. That shift explains why cross-border links like the Third Thai-Lao Friendship Bridge connecting Laos and Thailand matter. Bridges come in many forms, each built to meet a specific challenge. Arch bridges manage compression, suspension bridges span long distances, and concrete box-girder bridges prioritize stability and load efficiency. This bridge uses the box-girder design, making it a practical choice for crossing the wide, fast-moving Mekong River.","Image":{"Url":"/th?id=OHR.FriendshipBridge_EN-US6136231298_1920x1080.webp","Wallpaper":"/th?id=OHR.FriendshipBridge_EN-US6136231298_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Built to bring closer","Title":"Third Thai-Lao Friendship Bridge connecting Laos and Thailand","Copyright":"© chaiyut samsuk/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/16.600522,104.740271/12?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=16.600522,104.740271;S9;Third%20Thai-Lao%20Friendship%20Bridge%2C%20Thailand&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=18&q=Third%20Thai-Lao%20Friendship%20Bridge%2C%20Thailand&mb=16.604383~104.732212~16.596668~104.748336&cardbg=%23F98745&dt=1766734200000&tt=Thai%20-%20Lao%20Friendship%20Bridge%202%20Bang%20Sai%20Yai%2C%20Mueang%20Mukdahan%20%E0%B8%88%E0%B8%B1%E0%B8%87%E0%B8%AB%E0%B8%A7%E0%B8%B1%E0%B8%94%E0%B8%A1%E0%B8%B8%E0%B8%81%E0%B8%94%E0%B8%B2%E0%B8%AB%E0%B8%B2%E0%B8%A3%2C%2049000%2C%20%E0%B8%9B%E0%B8%A3%E0%B8%B0%E0%B9%80%E0%B8%97%E0%B8%A8%E0%B9%84%E0%B8%97%E0%B8%A2&tsts0=%2526ty%253D18%2526q%253DThird%252520Thai-Lao%252520Friendship%252520Bridge%25252C%252520Thailand%2526mb%253D16.604383~104.732212~16.596668~104.748336%2526cardbg%253D%252523F98745%2526dt%253D1766734200000&tstt0=Thai%20-%20Lao%20Friendship%20Bridge%202%20Bang%20Sai%20Yai%2C%20Mueang%20Mukdahan%20%E0%B8%88%E0%B8%B1%E0%B8%87%E0%B8%AB%E0%B8%A7%E0%B8%B1%E0%B8%94%E0%B8%A1%E0%B8%B8%E0%B8%81%E0%B8%94%E0%B8%B2%E0%B8%AB%E0%B8%B2%E0%B8%A3%2C%2049000%2C%20%E0%B8%9B%E0%B8%A3%E0%B8%B0%E0%B9%80%E0%B8%97%E0%B8%A8%E0%B9%84%E0%B8%97%E0%B8%A2&cp=16.595857~104.728025&lvl=14.717764&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260213_FriendshipBridge\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Third+Thai+Lao+Friendship+Bridge&form=hpcapt&filters=HpDate:\"20260213_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260213_FriendshipBridge"},"Ssd":"20260213","Name":"FriendshipBridge","Market":"EN-US","Hash":"6136231298","FullDateString":"Feb 13, 2026"},{"ImageContent":{"Description":"Darwin Day marks more than a birthday—it marks a shift in thinking. Charles Darwin's observations connected variation, the survival of individuals best suited to their environment, and inheritance in ways science still builds on. His legacy rests on years of studying variation—finches, fossils, barnacles—and recognizing patterns others had overlooked. When 'On the Origin of Species' was published in 1859, it offered a framework explaining how species evolve through natural selection.","Image":{"Url":"/th?id=OHR.DarwinBooby_EN-US4839738451_1920x1080.webp","Wallpaper":"/th?id=OHR.DarwinBooby_EN-US4839738451_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Evolution in focus","Title":"Blue-footed booby, Galápagos Islands, Ecuador","Copyright":"© Karine Aigner/TANDEM Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/0.901976,-91.166857/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=0.901976,-91.166857;S9;Galápagos Islands, Ecuador&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=30&q=Galapagos%20Islands%2C%20Gal%C3%A1pagos%2C%20Ecuador&satid=id.sid%3A24cf1790-4625-0fe7-80d2-f47d11da8555&vdpid=5956767920922034177&mb=0.883547~-93.655189~-2.218152~-87.441813&cardbg=%23219AB6&dt=1766734200000&tt=Galapagos%20Islands%2C%20Gal%C3%A1pagos%2C%20Ecuador&tsts0=%2526ty%253D30%2526q%253DGalapagos%252520Islands%25252C%252520Gal%2525C3%2525A1pagos%25252C%252520Ecuador%2526satid%253Did.sid%25253A24cf1790-4625-0fe7-80d2-f47d11da8555%2526vdpid%253D5956767920922034177%2526mb%253D0.883547~-93.655189~-2.218152~-87.441813%2526cardbg%253D%252523219AB6%2526dt%253D1766734200000&tstt0=Galapagos%20Islands%2C%20Gal%C3%A1pagos%2C%20Ecuador&cp=-0.882881~-94.925051&lvl=4.7402945&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260212_DarwinBooby\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Darwin+Day&form=hpcapt&filters=HpDate:\"20260212_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260212_DarwinBooby"},"Ssd":"20260212","Name":"DarwinBooby","Market":"EN-US","Hash":"4839738451","FullDateString":"Feb 12, 2026"},{"ImageContent":{"Description":"Death Valley National Park challenges first impressions. Spanning more than 3.4 million acres across California and Nevada, it is the largest national park in the contiguous United States. Across this vast expanse, salt flats, volcanic hills, sweeping sand dunes, and distant snowcapped peaks create a landscape shaped by time and extremes. From the soaring heights of Telescope Peak, which rises over 11,000 feet above the desert floor, to the depths of Badwater Basin, 282 feet below sea level, the park is a study in contrasts.","Image":{"Url":"/th?id=OHR.BadwaterFlats_EN-US4770719796_1920x1080.webp","Wallpaper":"/th?id=OHR.BadwaterFlats_EN-US4770719796_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The valley of contrasts","Title":"Salt flats in Badwater Basin, Death Valley National Park, California","Copyright":"© Jim Patterson/TANDEM Stills + Motion","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/36.25028,-116.8258/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=36.25028,-116.8258;S9;Badwater%20Basin%2C%20Inyo%20County%2C%20California%2C%20United%20States&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=30&q=Badwater%20Basin%2C%20Inyo%20County%2C%20California%2C%20United%20States&satid=id.sid%3Aba81208e-a37a-bab3-e035-442f54b6d6aa&vdpid=5060972230431735809&mb=36.254569~-116.835641~36.245986~-116.815964&cardbg=%23F98745&dt=1767004200000&tt=Badwater%20Basin%2C%20CA&tsts0=%2526ty%253D30%2526q%253DBadwater%252520Basin%25252C%252520Inyo%252520County%25252C%252520California%25252C%252520United%252520States%2526satid%253Did.sid%25253Aba81208e-a37a-bab3-e035-442f54b6d6aa%2526vdpid%253D5060972230431735809%2526mb%253D36.254569~-116.835641~36.245986~-116.815964%2526cardbg%253D%252523F98745%2526dt%253D1767004200000&tstt0=Badwater%20Basin%2C%20CA&cp=36.244273~-127.705078&lvl=5&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260211_BadwaterFlats\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Death+Valley+National+Park&form=hpcapt&filters=HpDate:\"20260211_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260211_BadwaterFlats"},"Ssd":"20260211","Name":"BadwaterFlats","Market":"EN-US","Hash":"4770719796","FullDateString":"Feb 11, 2026"},{"ImageContent":{"Description":"Just southwest of Ibiza, Spain, lie the uninhabited islets of Es Vedrà and Es Vedranell. Part of a protected nature reserve, these dramatic rock formations are admired for their ecological value and visual impact. Es Vedrà rises around 1,300 feet straight from the sea, its sheer limestone cliffs resembling a mountain range. Nearby, the jagged outline of Es Vedranell has earned it the nickname 'sleeping dragon,' appearing to guard its larger sibling.","Image":{"Url":"/th?id=OHR.IbizaIslets_EN-US4713963434_1920x1080.webp","Wallpaper":"/th?id=OHR.IbizaIslets_EN-US4713963434_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Where the Sirens sing","Title":"Islets of Es Vedrà and Es Vedranell, Ibiza, Spain","Copyright":"© L. Apolli/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/38.867802,1.198694/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=38.867802,1.198694;S9;Es%20Vedra&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=18&q=Es%20Vedra&ss=ypid.6306x4017281747423923045&mb=38.871089~1.194752~38.862802~1.204129&description=07830%2C%20Ibiza%20Town%20%28Islas%20Baleares%29&cardbg=%233DB838&dt=1766745000000&tt=Es%20Vedra&tsts1=%2526ty%253D18%2526q%253DEs%252520Vedra%2526ss%253Dypid.6306x4017281747423923045%2526mb%253D38.871089~1.194752~38.862802~1.204129%2526description%253D07830%25252C%252520Ibiza%252520Town%252520%252528Islas%252520Baleares%252529%2526cardbg%253D%2525233DB838%2526dt%253D1766745000000&tstt1=Es%20Vedra&cp=38.394937~-12.177118&lvl=4.437564&pi=0&ftst=1&ftics=True&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260210_IbizaIslets\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Es+Vedra+Ibiza&form=hpcapt&filters=HpDate:\"20260210_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260210_IbizaIslets"},"Ssd":"20260210","Name":"IbizaIslets","Market":"EN-US","Hash":"4713963434","FullDateString":"Feb 10, 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"The great egret is a striking large heron, easily recognizable by its pure white plumage, long neck, and sharp yellow bill. Known for its cosmopolitan distribution, it occupies habitats around the world and adapts well to many aquatic environments. Adults measure about 37 to 41 inches in body length, with a wingspan of 4.3 to 4.8 feet, and weigh about 2.2 pounds, giving them a tall, elegant silhouette—roughly chest‑high when compared to a 6‑foot-tall person. As carnivores, they feed primarily on fish but also take amphibians, insects, small mammals, and occasionally reptiles. Their patient hunting style, standing motionless before striking with sudden precision, is one of their most distinctive traits.","Image":{"Url":"/th?id=OHR.BavariaEgret_EN-US2697995103_1920x1080.webp","Wallpaper":"/th?id=OHR.BavariaEgret_EN-US2697995103_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Snowfield monarch","Title":"Great white egret, Upper Bavaria, Germany","Copyright":"© Konrad Wothe/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Once nearly wiped out, the great egret became the Audubon Society's emblem of conservation.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260223_BavariaEgret\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Great+white+egret&form=hpcapt&filters=HpDate:\"20260223_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260223_BavariaEgret"},"Ssd":"20260223","Name":"BavariaEgret","Market":"EN-US","Hash":"2697995103","FullDateString":"Feb 23, 2026"},{"ImageContent":{"Description":"'Shivering Mountain' is a dramatic nickname, but Mam Tor has earned it over hundreds of years. Rising above Castleton in England's Peak District, it lies within the United Kingdom's first national park, which spans 555 square miles. This landmark takes its name from Old English, 'mam' meaning 'mother,' a nod to the smaller hills it appears to cradle. Yet this 'mother mountain' is famously unstable. Its layers of shale and sandstone have caused landslips for centuries, including a collapse that permanently closed the A625 road in 1979.","Image":{"Url":"/th?id=OHR.MamTorSunrise_EN-US2655534073_1920x1080.webp","Wallpaper":"/th?id=OHR.MamTorSunrise_EN-US2655534073_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"The mother of hills","Title":"The hill of Mam Tor, Derbyshire, England","Copyright":"© john finney photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/53.387242,-1.819306/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=53.387242,-1.819306;S9;Mam Tor, Castleton, Derbyshire, England&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260222_MamTorSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Mam+Tor+hill&form=hpcapt&filters=HpDate:\"20260222_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260222_MamTorSunrise"},"Ssd":"20260222","Name":"MamTorSunrise","Market":"EN-US","Hash":"2655534073","FullDateString":"Feb 22, 2026"},{"ImageContent":{"Description":"A red fox standing in the snowfall of Grand Teton National Park is more than a picturesque moment—it offers a glimpse into the resilience of one of North America's most adaptable predators. This small carnivore is instantly recognizable by its sharp gaze and thick, fiery coat that helps it thrive even in Wyoming's harsh winter conditions. Snow muffles sound, yet the animal's extraordinary hearing allows it to detect prey moving beneath the surface. You can almost imagine it pausing amid the drifting flakes, ears rotating, body perfectly still, waiting for the faintest rustle.","Image":{"Url":"/th?id=OHR.TetonFox_EN-US2616700325_1920x1080.webp","Wallpaper":"/th?id=OHR.TetonFox_EN-US2616700325_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Whispers of winter","Title":"Red fox standing in snowfall, Grand Teton National Park, Wyoming","Copyright":"© Radomir Jakubowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/43.790948,-110.681668/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=43.790948,-110.681668;S9;Grand Teton National Park, Wyoming&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260221_TetonFox\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Red+fox&form=hpcapt&filters=HpDate:\"20260221_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260221_TetonFox"},"Ssd":"20260221","Name":"TetonFox","Market":"EN-US","Hash":"2616700325","FullDateString":"Feb 21, 2026"},{"ImageContent":{"Description":"Today we celebrate the birthday of Ansel Adams, a photographer whose vision helped shape the world's perception of Yosemite National Park. Yosemite is renowned for its granite walls, dramatic waterfalls, and striking light, all of which have inspired generations of artists. One of its most intriguing sights is the Firefall, a term that refers to two distinct events in the park's history. For decades, visitors gathered at Glacier Point to watch an artificial Firefall, in which embers were pushed off the cliff in a glowing stream of fire.","Image":{"Url":"/th?id=OHR.AdamsFirefall_EN-US2580399078_1920x1080.webp","Wallpaper":"/th?id=OHR.AdamsFirefall_EN-US2580399078_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Where light falls","Title":"Horsetail Fall in Yosemite National Park, California","Copyright":"© Jorge Villalba/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/37.729841,-119.628648/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=37.729841,-119.628648;S9;Horsetail Fall, Yosemite National Park, California&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260220_AdamsFirefall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Horsetail+Fall+Yosemite+National+Park&form=hpcapt&filters=HpDate:\"20260220_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260220_AdamsFirefall"},"Ssd":"20260220","Name":"AdamsFirefall","Market":"EN-US","Hash":"2580399078","FullDateString":"Feb 20, 2026"},{"ImageContent":{"Description":"Dragon's Eye sounds like something pulled from legend, and standing on Norway's Uttakleiv Beach in the Lofoten Islands, it's easy to see why. The formation, carved into ancient rock and framed by sand and sea, looks uncannily alive, as though the land itself is watching you. Shaped over thousands of years by ice and water, it has become one of the region's most captivating sights.","Image":{"Url":"/th?id=OHR.DragonsEyeRock_EN-US6826796617_1920x1080.webp","Wallpaper":"/th?id=OHR.DragonsEyeRock_EN-US6826796617_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Where the land stares back","Title":"The Dragon's Eye rock formation at Uttakleiv Beach, Norway","Copyright":"© reisegraf/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/68.209267,13.506241/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=en-US&od=2&shading=flat&pp=68.209267,13.506241;S9;Dragon's Eye, Uttakleiv Beach, Norway&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":"/maps?ty=18&q=Dragon%27s%20Eye%2C%20Uttakleivveien%2C%20Next%20to%20Uttakleiv%20beach%20and%20dragon%27s%20head%2C%20Leknes%2C%20Norway&ss=ypid.YN7996x13941137382204971750&mb=68.211238~13.496393~68.207287~13.51607&description=Uttakleivveien%2C%20Next%20to%20Uttakleiv%20beach%20and%20dragon%27s%20head%20Leknes%C2%B7Attraksjoner%20og%20aktiviteter&cardbg=%23219AB6&dt=1767097800000&tt=Dragon%27s%20Eye&tsts0=%2526ty%253D18%2526q%253DDragon%252527s%252520Eye%25252C%252520Uttakleivveien%25252C%252520Next%252520to%252520Uttakleiv%252520beach%252520and%252520dragon%252527s%252520head%25252C%252520Leknes%25252C%252520Norway%2526ss%253Dypid.YN7996x13941137382204971750%2526mb%253D68.211238~13.496393~68.207287~13.51607%2526description%253DUttakleivveien%25252C%252520Next%252520to%252520Uttakleiv%252520beach%252520and%252520dragon%252527s%252520head%252520Leknes%2525C2%2525B7Attraksjoner%252520og%252520aktiviteter%2526cardbg%253D%252523219AB6%2526dt%253D1767097800000&tstt0=Dragon%27s%20Eye&cp=67.940138~-20.61369&lvl=3.4375641&pi=0&ftst=0&ftics=False&v=2&sV=2&form=hpbal1"},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260219_DragonsEyeRock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Uttakleiv+Beach+Norway&form=hpcapt&filters=HpDate:\"20260219_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260219_DragonsEyeRock"},"Ssd":"20260219","Name":"DragonsEyeRock","Market":"EN-US","Hash":"6826796617","FullDateString":"Feb 19, 2026"},{"ImageContent":{"Description":"This species missed the domestication memo and kept going on its own terms. Say hello to Przewalski's horse, considered the last truly wild horse on Earth. Once widespread across Central Asia, it disappeared from the wild in the 1960s after decades of hunting, habitat loss, and competition with livestock. Its survival depended on an unlikely lifeline: a small number of individuals captured by early 20th‑century collectors, which became the foundation of all modern Przewalski's horses.","Image":{"Url":"/th?id=OHR.PrzewalskisHorse_EN-US6767229079_1920x1080.webp","Wallpaper":"/th?id=OHR.PrzewalskisHorse_EN-US6767229079_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Born to stay wild","Title":"Przewalski's horses","Copyright":"© Nemyrivskyi Viacheslav/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Przewalski's-type wild horses appear in European cave art dating as far back as 20,000 years ago.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260218_PrzewalskisHorse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Przewalskis+horse&form=hpcapt&filters=HpDate:\"20260218_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260218_PrzewalskisHorse"},"Ssd":"20260218","Name":"PrzewalskisHorse","Market":"EN-US","Hash":"6767229079","FullDateString":"Feb 18, 2026"},{"ImageContent":{"Description":"Chinese New Year, also known as the Spring Festival, marks the beginning of a new year on the traditional Chinese lunisolar calendar. This calendar follows the phases of the moon and the rhythms of the seasons. Red lanterns—like the ones shown in today's image—are widely associated with the celebration. The holiday falls on the new moon between January 21 and February 20 and has been observed for more than 2,000 years. In 2024, UNESCO added the Spring Festival to its Intangible Cultural Heritage of Humanity list, recognizing its cultural and historical importance.","Image":{"Url":"/th?id=OHR.NewYearLantern_EN-US6665128229_1920x1080.webp","Wallpaper":"/th?id=OHR.NewYearLantern_EN-US6665128229_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Fifteen days of light","Title":"Red lanterns celebrating Chinese New Year","Copyright":"© Gins Wang/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Chinese New Year can begin as late as February 20, making it one of the latest-starting major New Year celebrations in the world.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260217_NewYearLantern\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Chinese+New+Year&form=hpcapt&filters=HpDate:\"20260217_0800\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260217_NewYearLantern"},"Ssd":"20260217","Name":"NewYearLantern","Market":"EN-US","Hash":"6665128229","FullDateString":"Feb 17, 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Image of the day","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Learn more","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donate now","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Quick fact:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Recent Homepage images","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage image for {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"On this day in history","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"On this day in {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Share today's Bing homepage","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Download this image. Use of this image is restricted to wallpaper only.","LOC_MUSCARD_DOWNLOAD_LINK":"Download this image","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"This image is not available to download as wallpaper.","LOC_HOMEPAGE_INFO_TEXT":"Info","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Get the new Bing Wallpaper app"