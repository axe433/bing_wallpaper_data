{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-27T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Mitten in den Salzwiesen von Westerheversand erhebt sich ein Leuchtturm mit markanten rot-weißen Streifen über die weitläufige Küstenlandschaft. Seit mehr als hundert Jahren prägt das Bauwerk die Halbinsel Eiderstedt und dient bis heute als wichtiger Orientierungspunkt für die Schifffahrt. Der zwischen 1906 und 1908 errichtete Leuchtturm zählt zu den bekanntesten Wahrzeichen der nordfriesischen Küste. Das Highlight ist die Aussichtsplattform des rund 41 Meter hohen Turms, die über 157 Stufen erreicht werden kann.","Image":{"Url":"/th?id=OHR.Westerheversand_DE-DE9270031466_1920x1080.webp","Wallpaper":"/th?id=OHR.Westerheversand_DE-DE9270031466_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Rot‑weiß am Horizont","Title":"Leuchtturm Westerheversand, Nordsee, Schleswig-Holstein","Copyright":"© bluejayphoto/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/54.373402,8.6399/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=54.373402,8.6399;S9;Leuchtturm Westerheversand, Schleswig-Holstein&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260627_Westerheversand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Leuchtturm+Westerheversand&form=hpcapt&filters=HpDate:\"20260626_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260627_Westerheversand"},"Ssd":"20260627","Name":"Westerheversand","Market":"DE-DE","Hash":"9270031466","FullDateString":"27. Juni. 2026"},{"ImageContent":{"Description":"Entlang der Themse in London entfaltet sich eine der bekanntesten Stadtsilhouetten Europas, geprägt von Geschichte, Bewegung und einem stetigen Rhythmus. Boote gleiten ruhig vorbei, während Brücken das Bild strukturieren und verschiedene Viertel miteinander verbinden. Tagsüber spiegelt das Wasser graue Wolken und gläserne Fassaden, nachts tauchen Lichter alles in ein warmes Leuchten. Besucher und Einheimische folgen oft ihrem Verlauf, entdecken historische Gebäude und genießen die besondere Atmosphäre zwischen Tradition und Moderne. Big Ben und das London Eye prägen diese Ansicht.","Image":{"Url":"/th?id=OHR.ThamesSummer_DE-DE5848189110_1920x1080.webp","Wallpaper":"/th?id=OHR.ThamesSummer_DE-DE5848189110_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Die Stadt im Fluss der Zeit","Title":"Themse, London, England","Copyright":"© Daniel Lange/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/51.50382,-0.121258/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=51.50382,-0.121258;S9;Themse, London, England&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260626_ThamesSummer\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Themse&form=hpcapt&filters=HpDate:\"20260625_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260626_ThamesSummer"},"Ssd":"20260626","Name":"ThamesSummer","Market":"DE-DE","Hash":"5848189110","FullDateString":"26. Juni. 2026"},{"ImageContent":{"Description":"Rund um den Grand-Place in Brüssel, Belgien, entfaltet sich lebendige Geschichte. Prächtige Zunfthäuser säumen den Platz – einst von Brauern, Bäckern und Kaufleuten errichtet, die ihren Wohlstand in Stein, Reliefs und vergoldeten Details sichtbar machten. Gotische Höhen treffen auf barocke Fassaden, während das alte, leicht asymmetrische Rathaus das Ensemble zusammenhält.","Image":{"Url":"/th?id=OHR.GrandPlace_DE-DE1914769137_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandPlace_DE-DE1914769137_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Glanz trifft Geschichte","Title":"Gebäude am Grand-Place in Brüssel, Belgien","Copyright":"© Vladislav Zolotov/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.846851,4.352454/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=50.846851,4.352454;S9;Grand-Place, Brüssel, Belgien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_GrandPlace\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Grand-Place+Br%c3%bcssel&form=hpcapt&filters=HpDate:\"20260624_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_GrandPlace"},"Ssd":"20260625","Name":"GrandPlace","Market":"DE-DE","Hash":"1914769137","FullDateString":"25. Juni. 2026"},{"ImageContent":{"Description":"Ein Schmetterling flattert von Blüte zu Blüte und setzt dabei einen unscheinbaren Kreislauf in Bewegung: Beim Nektarsammeln bleibt Blütenstaub an ihm haften und wird weitergetragen. So können viele Pflanzen überhaupt Samen und Früchte bilden. Besonders tagaktive Schmetterlinge bestäuben oft farbenreiche Wildblumen und tragen so zur Artenvielfalt vieler Wiesen bei.","Image":{"Url":"/th?id=OHR.BFPollin_DE-DE1648202484_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_DE-DE1648202484_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Kleine Flügel, große Wirkung","Title":"Schmetterling beim Bestäuben einer gelben Blüte","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Etwa jeder dritte Bissen Nahrung hängt von Bestäubern ab.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Best%c3%a4uber+Insekten+&form=hpcapt&filters=HpDate:\"20260623_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"DE-DE","Hash":"1648202484","FullDateString":"24. Juni. 2026"},{"ImageContent":{"Description":"Der Fuji erhebt sich über Japan als nahezu perfekter Kegel, ist oft schneebedeckt und schon aus großer Entfernung sichtbar. Mit einer Höhe von 3.776 Metern ist er der höchste Berg des Landes. Er liegt etwa 100 Kilometer südwestlich von Tokio auf der Insel Honshū. Zum Vergleich: Die Zugspitze, Deutschlands höchster Gipfel, ist mit 2.962 Metern rund 800 Meter niedriger. Seine symmetrische Form verdankt der Fuji seiner vulkanischen Herkunft. Der Stratovulkan gilt als aktiv, auch wenn er seit der Hōei-Eruption im Jahr 1707 ruht. Damals trieb der Wind große Mengen Asche bis nach Edo, dem heutigen Tokio.","Image":{"Url":"/th?id=OHR.Fujisan_DE-DE4332870275_1920x1080.webp","Wallpaper":"/th?id=OHR.Fujisan_DE-DE4332870275_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Ikone am Horizont","Title":"Berg Fuji auf der Insel Honshū, Japan","Copyright":"© phutthiseth thongtae/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.365403,138.730373/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=35.365403,138.730373;S9;Fuji, Honshū, Japan&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260623_Fujisan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Fuji+Berg&form=hpcapt&filters=HpDate:\"20260622_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260623_Fujisan"},"Ssd":"20260623","Name":"Fujisan","Market":"DE-DE","Hash":"4332870275","FullDateString":"23. Juni. 2026"},{"ImageContent":{"Description":"Am 22. Juni rückt der Welttag des Regenwaldes die letzten Regenwälder der Erde in den Fokus. Diese komplexen Ökosysteme bedecken nur rund sechs Prozent der Erdoberfläche. Sie liegen vor allem in tropischen Regionen wie dem Amazonasbecken, dem Kongobecken und in Südostasien und spielen eine zentrale Rolle für Klima, Wasserhaushalt und Artenvielfalt weltweit. Sie speichern große Mengen Kohlenstoff und beeinflussen regionale wie globale Wetter- und Klimasysteme.","Image":{"Url":"/th?id=OHR.QuinaultFerns_DE-DE3985266590_1920x1080.webp","Wallpaper":"/th?id=OHR.QuinaultFerns_DE-DE3985266590_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Regenwälder voller Leben","Title":"Quinault‑Regenwald im Olympic‑Nationalpark, Washington, USA","Copyright":"© Chris Moore/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Obwohl sie nur rund 6 % der Erdoberfläche bedecken, beherbergen Regenwälder mehr als die Hälfte der weltweiten Artenvielfalt.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260622_QuinaultFerns\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Welttag+des+Regenwaldes&form=hpcapt&filters=HpDate:\"20260621_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260622_QuinaultFerns"},"Ssd":"20260622","Name":"QuinaultFerns","Market":"DE-DE","Hash":"3985266590","FullDateString":"22. Juni. 2026"},{"ImageContent":{"Description":"Inmitten einer dicht gedrängten Kolonie hebt sich ein einzelnes Männchen der Königspinguine kaum vom Gewimmel ab. Mit gesenktem Kopf hält es ein Ei sicher auf seinen Füßen, das unter einer warmen, gut durchbluteten Hautfalte verborgen ist. Ein Nest gibt es nicht – alles hängt davon ab, die empfindliche Last vor dem eisigen Wind zu schützen und konstant warmzuhalten.","Image":{"Url":"/th?id=OHR.EggDad_DE-DE1185821144_1920x1080.webp","Wallpaper":"/th?id=OHR.EggDad_DE-DE1185821144_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Wächter im Eis","Title":"Ein Königspinguin-Männchen schaut nach seinem Ei","Copyright":"© McDonald Wildlife Photography Inc./Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Weltweit gibt es 18 Pinguinarten – der Königspinguin ist nach dem Kaiserpinguin die zweitgrößte.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260621_EggDad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=K%c3%b6nigspinguin&form=hpcapt&filters=HpDate:\"20260620_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260621_EggDad"},"Ssd":"20260621","Name":"EggDad","Market":"DE-DE","Hash":"1185821144","FullDateString":"21. Juni. 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Fachwerkhäuser säumen die Ufer der Weiss im elsässischen Kaysersberg in Frankreich. Entlang des schmalen Flusslaufs drängen sich Giebel und Fensterläden dicht aneinander, während sich darüber die bewaldeten Hänge der Vogesen erheben. Das Dorf liegt rund zwölf Kilometer nordwestlich von Colmar und zählt zu den charakteristischen Weinorten der Region.","Image":{"Url":"/th?id=OHR.KaysersbergVillage_DE-DE1031882295_1920x1080.webp","Wallpaper":"/th?id=OHR.KaysersbergVillage_DE-DE1031882295_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Im Herzen des Elsass","Title":"Kaysersberg, Elsass, Frankreich","Copyright":"© Federica Gentile/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.18747,7.215853/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=48.18747,7.215853;S9;Kaysersberg, Frankreich&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260704_KaysersbergVillage\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Kaysersberg&form=hpcapt&filters=HpDate:\"20260703_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260704_KaysersbergVillage"},"Ssd":"20260704","Name":"KaysersbergVillage","Market":"DE-DE","Hash":"1031882295","FullDateString":"4. Juli. 2026"},{"ImageContent":{"Description":"Wenn sich in der Präfektur Okayama feuchtwarme Abendluft über einem Bach sammelt, beginnen Glühwürmchen – in Japan „hotaru“ genannt – mit ihren Leuchtsignalen und durchziehen die Dunkelheit mit kleinen, schwebenden Lichtpunkten. An windstillen Sommerabenden werden sie oft erst einige Zeit nach Sonnenuntergang aktiv. Ihr Licht entsteht durch eine chemische Reaktion im Hinterleib und dient vor allem der Partnersuche sowie der Verständigung zwischen den Tieren.","Image":{"Url":"/th?id=OHR.FirefliesJapan_DE-DE4398668270_1920x1080.webp","Wallpaper":"/th?id=OHR.FirefliesJapan_DE-DE4398668270_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Die Poesie des schwindenden Lichts","Title":"Leuchtende Glühwürmchen über einem Bach, Präfektur Okayama, Japan","Copyright":"© tdub303/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/34.822845,133.813507/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=34.822845,133.813507;S9;Präfektur Okayama, Japan&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260703_FirefliesJapan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Gl%c3%bchw%c3%bcrmchen&form=hpcapt&filters=HpDate:\"20260702_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260703_FirefliesJapan"},"Ssd":"20260703","Name":"FirefliesJapan","Market":"DE-DE","Hash":"4398668270","FullDateString":"3. Juli. 2026"},{"ImageContent":{"Description":"Die Decke des Tempels von Esna in Ägypten gehört zu den beeindruckendsten Zeugnissen der spätantiken ägyptischen Baukunst und fasziniert durch ihre außergewöhnlich gut erhaltenen Reliefs und Farben. Nach umfassenden Restaurierungsarbeiten treten heute wieder lebendige Darstellungen von Sternbildern, Göttern und rituellen Symbolen hervor, die lange unter Ruß und Schmutz verborgen waren. Besonders auffällig sind die sorgfältig ausgearbeiteten Tierkreiszeichen, die einen wichtigen Hinweis auf das damalige Weltverständnis und die Verbindung von Religion und Astronomie liefern.","Image":{"Url":"/th?id=OHR.TempleEsna_DE-DE2277338406_1920x1080.webp","Wallpaper":"/th?id=OHR.TempleEsna_DE-DE2277338406_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Ein Blick in Esnas Universum","Title":"Decke des Tempels von Esna, Ägypten","Copyright":"© Nick Brundle Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.293581,32.556398/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=25.293581,32.556398;S9;Tempel von Esna, Ägypten&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260702_TempleEsna\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Tempel+von+Esna&form=hpcapt&filters=HpDate:\"20260701_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260702_TempleEsna"},"Ssd":"20260702","Name":"TempleEsna","Market":"DE-DE","Hash":"2277338406","FullDateString":"2. Juli. 2026"},{"ImageContent":{"Description":"Oberhalb des Neckars bei Stuttgart ziehen sich terrassierte Weinberge die Hänge hinauf und prägen eine der charakteristischsten Kulturlandschaften des Neckartals. Beim Blick über den Fluss zeichnen sich die markanten Linien der Rebreihen und Trockenmauern ab. Sie schmiegen sich harmonisch an die Hänge und werden vielerorts noch in aufwendiger Handarbeit von den sogenannten Wengertern gepflegt. Das milde Klima begünstigt traditionelle Rebsorten wie Trollinger und Riesling, die bis heute eng mit der Weinbaugeschichte Württembergs verbunden sind.","Image":{"Url":"/th?id=OHR.NeckarVineyards_DE-DE0300601892_1920x1080.webp","Wallpaper":"/th?id=OHR.NeckarVineyards_DE-DE0300601892_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Rebhänge im Abendlicht","Title":"Sonnenuntergang über den Weinbergen von Steinhaldenfeld im Neckartal bei Stuttgart, Baden-Württemberg","Copyright":"© Cyril Gosselin/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.828049,9.232/10?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=48.828049,9.232;S9;Steinhaldenfeld, Stuttgart, Baden-Württemberg&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260701_NeckarVineyards\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Stuttgart+Neckar&form=hpcapt&filters=HpDate:\"20260630_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260701_NeckarVineyards"},"Ssd":"20260701","Name":"NeckarVineyards","Market":"DE-DE","Hash":"0300601892","FullDateString":"1. Juli. 2026"},{"ImageContent":{"Description":"Das Masai-Mara-Nationalreservat im Südwesten Kenias umfasst etwa 1500 Quadratkilometer und grenzt direkt an die Serengeti in Tansania. Es zählt zu den bedeutendsten Schutzgebieten für Wildtiere weltweit. Die Landschaft besteht aus offenen Grasflächen, locker verteilten Akazien und dem Mara-Fluss als zentraler Wasserquelle. Diese Bedingungen ermöglichen eine hohe Artenvielfalt und prägen das ökologische Gleichgewicht. In den Abendstunden, wenn die Sonne sinkt, verbessern sich die Sichtverhältnisse und viele Tiere werden in der weiten Savanne deutlich erkennbar.","Image":{"Url":"/th?id=OHR.MasaiGiraffe_DE-DE5053384610_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiGiraffe_DE-DE5053384610_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Wo sich die Schatten in die Länge ziehen","Title":"Giraffen bei Sonnenuntergang im Masai-Mara-Nationalreservat, Kenia","Copyright":"© danm/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-1.529493,35.170876/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-1.529493,35.170876;S9;Masai-Mara-Nationalreservat, Kenia&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260630_MasaiGiraffe\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Masai+Mara+Nationalreservat&form=hpcapt&filters=HpDate:\"20260629_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260630_MasaiGiraffe"},"Ssd":"20260630","Name":"MasaiGiraffe","Market":"DE-DE","Hash":"5053384610","FullDateString":"30. Juni. 2026"},{"ImageContent":{"Description":"Bora Bora im Südpazifik in Französisch-Polynesien gehört zu den eindrucksvollsten Landschaften der Erde. Die Insel entstand aus einem erloschenen Vulkan, dessen dunkle Gipfel sich steil über das Meer erheben. Ringförmig umgeben von einem Korallenriff liegt eine ruhige Lagune mit schimmernden Blautönen, die sich je nach Licht und Tiefe verändern. Palmen, weiße Strände und kristallklares Wasser prägen das Bild und verleihen dem Ort eine fast unwirkliche Schönheit. Besonders bei Sonnenaufgang und Sonnenuntergang entfaltet die Lagune eine beeindruckende Farbvielfalt, die Besucher immer wieder aufs Neue fasziniert.","Image":{"Url":"/th?id=OHR.BoraBoraLagoon_DE-DE4940738686_1920x1080.webp","Wallpaper":"/th?id=OHR.BoraBoraLagoon_DE-DE4940738686_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Aus Feuer geboren, vom Wasser gehalten","Title":"Bora Bora und ihre Lagune, Südpazifik, Französisch-Polynesien","Copyright":"© Frederick Millett/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-16.498926,-151.73819/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-16.498926,-151.73819;S9;Bora Bora, Französisch-Polynesien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260629_BoraBoraLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Bora+Bora&form=hpcapt&filters=HpDate:\"20260628_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260629_BoraBoraLagoon"},"Ssd":"20260629","Name":"BoraBoraLagoon","Market":"DE-DE","Hash":"4940738686","FullDateString":"29. Juni. 2026"},{"ImageContent":{"Description":"Nahe dem Windgate Pass in der McDowell Range ragen Saguaro-Kakteen wie stille Wächter in den Himmel der Sonora-Wüste. Ihre mächtigen Stämme und ausladenden Arme zeichnen markante Silhouetten im warmen Licht Arizonas, USA. Bei Sonnenaufgang färbt sich die Landschaft in goldene und rötliche Töne, die ihre Formen noch eindrucksvoller wirken lassen. Trotz der scheinbaren Starre steckt in ihnen ein erstaunliches Leben, das sich perfekt an Hitze, Trockenheit und seltene Regenfälle angepasst hat.","Image":{"Url":"/th?id=OHR.SaguaroSun_DE-DE9702644922_1920x1080.webp","Wallpaper":"/th?id=OHR.SaguaroSun_DE-DE9702644922_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Stille Riesen der Wüste","Title":"Saguaro-Kakteen nahe dem Windgate Pass, McDowell Range, Arizona, USA","Copyright":"© Eric Mischke/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/33.796104,-111.810696/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=33.796104,-111.810696;S9;Windgate Pass, McDowell Range, Arizona, USA&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260628_SaguaroSun\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Saguaro-Kaktus&form=hpcapt&filters=HpDate:\"20260627_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260628_SaguaroSun"},"Ssd":"20260628","Name":"SaguaroSun","Market":"DE-DE","Hash":"9702644922","FullDateString":"28. Juni. 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Bild des Tages","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Weitere Informationen","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Jetzt spenden","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Kurzinfo:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Letzte Bilder der Homepage","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage-Bild am {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"An diesem Tag in der Geschichte","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"An diesem Tag in {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Heutige Bing-Startseite teilen","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Dieses Bild herunterladen. Dieses Bild darf nur als Hintergrundbild verwendet werden.","LOC_MUSCARD_DOWNLOAD_LINK":"Dieses Bild herunterladen","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"Dieses Bild ste