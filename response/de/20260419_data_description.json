{"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-04-19T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"Saarbrücken ist eine Stadt zwischen Kulturen. Ihre Lage nahe der französischen Grenze hat Architektur, Stadtbild und Alltag über Jahrhunderte hinweg geprägt. Entlang der Saar treffen historische Einflüsse und städtisches Leben aufeinander und schaffen so ein vielschichtiges urbanes Umfeld.","Image":{"Url":"/th?id=OHR.SaarbrueckenRathaus_DE-DE1197352085_1920x1080.webp","Wallpaper":"/th?id=OHR.SaarbrueckenRathaus_DE-DE1197352085_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Ein Rathaus mit Geschichte","Title":"Rathaus St. Johann, Saarbrücken, Saarland","Copyright":"© frantic00/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/49.23518,6.996482/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=49.23518,6.996482;S9;Rathaus St. Johann, Saarbrücken, Saarland&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260420_SaarbrueckenRathaus\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Saarbr%c3%bccken+Rathaus+St+Johann&form=hpcapt&filters=HpDate:\"20260419_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260420_SaarbrueckenRathaus"},"Ssd":"20260420","Name":"SaarbrueckenRathaus","Market":"DE-DE","Hash":"1197352085","FullDateString":"20. Apr.. 2026"},{"ImageContent":{"Description":"Schon aus der Vogelperspektive wirkt die Praia do Espelho wie ein Gemälde aus Licht und Wasser. Helle Steilklippen, vorgelagerte Riffe und natürliche Gezeitenpools prägen diesen besonderen Ort. Bei Ebbe spiegeln die flachen Wasserflächen Himmel und Wolken so klar, dass der Beiname „Spiegelstrand“ treffend erscheint.","Image":{"Url":"/th?id=OHR.TranBA_DE-DE2926110774_1920x1080.webp","Wallpaper":"/th?id=OHR.TranBA_DE-DE2926110774_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Die Handschrift der Gezeiten","Title":"Praia do Espelho, Porto Seguro, Bahia, Brasilien","Copyright":"© Marcelo Nacinovic/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-16.729899,-39.126587/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-16.729899,-39.126587;S9;Praia do Espelho, Porto Seguro, Bahia, Brasilien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260419_TranBA\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Bahia+Brasilien&form=hpcapt&filters=HpDate:\"20260418_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260419_TranBA"},"Ssd":"20260419","Name":"TranBA","Market":"DE-DE","Hash":"2926110774","FullDateString":"19. Apr.. 2026"},{"ImageContent":{"Description":"Der Internationale Denkmaltag am 18. April lenkt den Blick auf historische Bauwerke und Stätten von herausragender Bedeutung. Sie bewahren kulturelles Wissen, spiegeln handwerkliche Traditionen wider und zeigen, wie Architektur, Glauben und Technik das kulturelle Erbe über Jahrhunderte geprägt haben. Das heutige Bild zeigt ein Detail des Eingangsportals des Kölner Doms, einer der bedeutendsten gotischen Kathedralen Europas und seit 1996 UNESCO‑Welterbe. Der Bau begann 1248, ruhte über Jahrhunderte und wurde erst 1880 vollendet. Reich verzierte Türflächen, plastische Reliefs und fein ausgearbeitete Ornamente verdeutlichen den hohen Anspruch mittelalterlicher Baukunst.","Image":{"Url":"/th?id=OHR.CathedralCologne_DE-DE0399722778_1920x1080.webp","Wallpaper":"/th?id=OHR.CathedralCologne_DE-DE0399722778_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Ein Tor zur Geschichte","Title":"Eingangsbereich des Kölner Doms, Nordrhein‑Westfalen","Copyright":"© ALFSnaiper/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/50.941534,6.958319/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=50.941534,6.958319;S9;Kölner Dom, Nordrhein‑Westfalen&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260418_CathedralCologne\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Internationaler+Denkmaltag&form=hpcapt&filters=HpDate:\"20260417_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260418_CathedralCologne"},"Ssd":"20260418","Name":"CathedralCologne","Market":"DE-DE","Hash":"0399722778","FullDateString":"18. Apr.. 2026"},{"ImageContent":{"Description":"Hoch oben in den Baumwipfeln klammert sich ein Jungtier fest an den Bauch seiner Mutter. Der Graukopf‑Flughund gehört zu den größten Vertretern der Fledertiere und ist in Australien heimisch. Obwohl er mit Fledermäusen verwandt ist, unterscheidet er sich deutlich von ihnen. Flughunde zählen zu einer eigenen Gruppe innerhalb der Fledertiere und nutzen in der Regel keine Echoortung. Stattdessen orientieren sie sich mithilfe ihres ausgeprägten Seh‑ und Geruchssinns, was eine Anpassung an ihre überwiegend pflanzliche Ernährung darstellt.","Image":{"Url":"/th?id=OHR.FlyingFoxMom_DE-DE9791519824_1920x1080.webp","Wallpaper":"/th?id=OHR.FlyingFoxMom_DE-DE9791519824_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Fest an Mamas Seite","Title":"Graukopf‑Flughund mit Jungtier, Yarra Bend Park, Melbourne, Australien","Copyright":"© Doug Gimesy/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-37.798065,145.012222/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-37.798065,145.012222;S9;Yarra Bend Park, Melbourne, Australien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260417_FlyingFoxMom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Flughunde&form=hpcapt&filters=HpDate:\"20260416_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260417_FlyingFoxMom"},"Ssd":"20260417","Name":"FlyingFoxMom","Market":"DE-DE","Hash":"9791519824","FullDateString":"17. Apr.. 2026"},{"ImageContent":{"Description":"Es gibt Landschaften, die sofort gute Laune machen – und Tulpenfelder gehören ganz sicher dazu. Im Skagit Valley im US‑Bundesstaat Washington ziehen sich bunte Streifen über weite Felder, als hätte jemand den Frühling großzügig über die Landschaft ausgegossen. Die Felder wirken nahezu endlos und laden dazu ein, kurz innezuhalten und die Farben auf sich wirken zu lassen. In der Region gibt es zwar auch ein bekanntes Tulpenfestival, doch die eigentliche Magie entsteht direkt auf den Feldern: in den klaren Linien, der Weite und dem ständigen Wechselspiel von Licht und Farbe.","Image":{"Url":"/th?id=OHR.SkagitTulips_DE-DE0725960684_1920x1080.webp","Wallpaper":"/th?id=OHR.SkagitTulips_DE-DE0725960684_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Ein Meer aus Tulpen","Title":"Tulpenfelder im Skagit Valley, Washington, USA","Copyright":"© Alan Majchrowicz/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/48.5,-122.033/4?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=48.5,-122.033;S9;Skagit Valley, Washington, USA&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260416_SkagitTulips\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Skagit+Valley+Washington+USA&form=hpcapt&filters=HpDate:\"20260415_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260416_SkagitTulips"},"Ssd":"20260416","Name":"SkagitTulips","Market":"DE-DE","Hash":"0725960684","FullDateString":"16. Apr.. 2026"},{"ImageContent":{"Description":"Kunst begleitet uns überall – in Bildern, Räumen und Ideen, die unsere Wahrnehmung herausfordern. Der Weltkunsttag am 15. April erinnert daran, wie sehr Kreativität unsere Kultur prägt und ständig neue Ausdrucksformen findet. Ein eindrucksvolles Beispiel dafür ist die immersive Van‑Gogh‑Inszenierung in den Carrières des Lumières im südfranzösischen Les Baux‑de‑Provence, wo seine Werke 2019–2020 über monumentale Steinwände projiziert wurden und Besuchern das Gefühl gaben, mitten in den Bildern zu stehen und förmlich durch die Pinselstriche zu wandeln.","Image":{"Url":"/th?id=OHR.VanGoghFields_DE-DE5579767701_1920x1080.webp","Wallpaper":"/th?id=OHR.VanGoghFields_DE-DE5579767701_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"Eintauchen in eine lebendige Leinwand","Title":"Van-Gogh-Ausstellung in den Carrières des Lumières, Les Baux‑de‑Provence, Frankreich","Copyright":"© Patrick Aventurier/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Der Weltkunsttag wird am 15. April, dem Geburtstag von Leonardo da Vinci, gefeiert. Damit wird sein nachhaltiger Einfluss auf die Kunst und die menschliche Kreativität gewürdigt.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260415_VanGoghFields\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Weltkunsttag&form=hpcapt&filters=HpDate:\"20260414_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260415_VanGoghFields"},"Ssd":"20260415","Name":"VanGoghFields","Market":"DE-DE","Hash":"5579767701","FullDateString":"15. Apr.. 2026"},{"ImageContent":{"Description":"Manchmal entfalten sich die faszinierendsten Naturbeziehungen in Momenten, die man leicht übersehen könnte. Seeanemonen wirken wie filigrane Unterwasserblumen, doch sie sind Tiere und eng mit Quallen und Korallen verwandt. Fest verankert auf Felsen oder Riffen nutzen sie ihre Tentakel mit winzigen Nesselzellen, um Beute zu fangen, was für die meisten Fische gefährlich wird. Auf dem Bild lugt ein Gewöhnlicher Clownfisch aus seiner Wirtsanemone in den Raja‑Ampat‑Inseln Indonesiens hervor, einem abgelegenen Archipel im westlichen Pazifik und Teil des Korallendreiecks. Eine spezielle Schleimschicht schützt den Fisch vor den Nesselzellen und macht die Anemone zu einem sicheren Zufluchtsort. Im Gegenzug profitiert sie von Schutz und Futterresten. Solche Partnerschaften zeigen, wie fein abgestimmt das Zusammenleben im Korallenriff ist.","Image":{"Url":"/th?id=OHR.OcellarisClownfish_DE-DE4824723739_1920x1080.webp","Wallpaper":"/th?id=OHR.OcellarisClownfish_DE-DE4824723739_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Nachbarn im Riff","Title":"Gewöhnlicher Clownfisch in einer Seeanemone, Raja-Ampat-Inseln, Indonesien","Copyright":"© Magnus Lundgren/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-0.233312,130.507889/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-0.233312,130.507889;S9;Raja-Ampat-Inseln, Indonesien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260414_OcellarisClownfish\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Seeanemone&form=hpcapt&filters=HpDate:\"20260413_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260414_OcellarisClownfish"},"Ssd":"20260414","Name":"OcellarisClownfish","Market":"DE-DE","Hash":"4824723739","FullDateString":"14. Apr.. 2026"}],"PreloadMediaContents":[{"ImageContent":{"Description":"Die Galleria Vittorio Emanuele II ist weit mehr als eine Einkaufspassage. Entworfen vom Architekten Giuseppe Mengoni und im Jahr 1877 fertiggestellt, setzte sie neue Maßstäbe für die Architektur und das Stadtleben Mailands. Mit ihrer gläsernen Kuppel verbindet sie bis heute zwei der wichtigsten Plätze der Stadt: die Piazza del Duomo und die Piazza della Scala.","Image":{"Url":"/th?id=OHR.MilanGalleria_DE-DE5963996541_1920x1080.webp","Wallpaper":"/th?id=OHR.MilanGalleria_DE-DE5963996541_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Eleganz unter Glas","Title":"Glaskuppel der Galleria Vittorio Emanuele II, Mailand, Italien","Copyright":"© PhillipMinnis/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/45.466179,9.18992/7?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=45.466179,9.18992;S9;Galleria Vittorio Emanuele II, Mailand, Italien&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260427_MilanGalleria\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Galleria+Vittorio+Emanuele+II+Mailand&form=hpcapt&filters=HpDate:\"20260426_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260427_MilanGalleria"},"Ssd":"20260427","Name":"MilanGalleria","Market":"DE-DE","Hash":"5963996541","FullDateString":"27. Apr.. 2026"},{"ImageContent":{"Description":"An der Zentralküste Kaliforniens kündigt die Apfelblüte den Frühling an. Zartrosa Blüten öffnen sich an den Zweigen der Apfelbäume und setzen helle Akzente vor dem Blau des Himmels und der offenen Küstenlandschaft des US‑Bundesstaats. Das vom Pazifik geprägte Klima mit gleichmäßigen Temperaturen und hohem Sonnenscheinanteil begünstigt eine frühe Blütezeit. In der Region rund um Avila Beach ziehen sich Apfelhaine durch nahegelegene Täler und sanfte Hügel, während kühle Meeresbrisen für ein frisches Klima sorgen und das Landschaftsbild prägen. Für Bienen und andere Insekten sind die Blüten eine wichtige Nahrungsquelle – zugleich bilden sie die Grundlage für die spätere Apfelernte.","Image":{"Url":"/th?id=OHR.AppleBlossoms_DE-DE5754939117_1920x1080.webp","Wallpaper":"/th?id=OHR.AppleBlossoms_DE-DE5754939117_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"In voller Blüte","Title":"Rosafarbene Apfelblüten, Avila Beach, Kalifornien, USA","Copyright":"© Mimi Ditchie Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/35.177404,-120.733528/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=35.177404,-120.733528;S9;Avila Beach, Kalifornien, USA&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260426_AppleBlossoms\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%c3%84pfel&form=hpcapt&filters=HpDate:\"20260425_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260426_AppleBlossoms"},"Ssd":"20260426","Name":"AppleBlossoms","Market":"DE-DE","Hash":"5754939117","FullDateString":"26. Apr.. 2026"},{"ImageContent":{"Description":"Bäume prägen Landschaften und sichern die ökologische Vielfalt. Am Tag des Baumes rücken sie auch in Deutschland besonders in den Mittelpunkt. Seit vielen Jahren nutzen Initiativen diesen Aktionstag, um mit Pflanzaktionen und Informationsveranstaltungen auf den Wert von Bäumen und Wäldern aufmerksam zu machen. Sie regulieren das Klima, verbessern die Luftqualität und bieten Lebensraum für zahlreiche Tier‑ und Pflanzenarten.","Image":{"Url":"/th?id=OHR.SlashPine_DE-DE2654946647_1920x1080.webp","Wallpaper":"/th?id=OHR.SlashPine_DE-DE2654946647_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Eine Hommage an die Bäume","Title":"Waldinsel mit Sumpfkiefern und Sägepalmen, Everglades-Nationalpark, Florida, USA","Copyright":"© Mary Liz Austin/Alamy","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/25.400611,-80.658833/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=25.400611,-80.658833;S9;Everglades-Nationalpark, Florida, USA&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260425_SlashPine\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Tag+des+Baumes&form=hpcapt&filters=HpDate:\"20260424_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260425_SlashPine"},"Ssd":"20260425","Name":"SlashPine","Market":"DE-DE","Hash":"2654946647","FullDateString":"25. Apr.. 2026"},{"ImageContent":{"Description":"Pinguine werden meist mit eisigen Regionen in Verbindung gebracht, doch die Galápagos‑Pinguine bilden eine bemerkenswerte Ausnahme. Als einzige Pinguinart reicht ihr natürliches Verbreitungsgebiet bis nördlich des Äquators. Beheimatet sind sie ausschließlich auf den Galapagosinseln, einem vulkanischen Archipel, das rund 1.000 Kilometer vor der Küste Ecuadors liegt.","Image":{"Url":"/th?id=OHR.GalapagosPenguins_DE-DE2195733852_1920x1080.webp","Wallpaper":"/th?id=OHR.GalapagosPenguins_DE-DE2195733852_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Wenn Pinguine aus der Reihe tanzen","Title":"Galápagos‑Pinguine beim Schwimmen, Galapagosinseln, Ecuador","Copyright":"© Henley Spiers/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/-0.859397,-91.215904/3?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=-0.859397,-91.215904;S9;Galapagosinseln, Ecuador&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260424_GalapagosPenguins\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Gal%c3%a1pagos-Pinguin&form=hpcapt&filters=HpDate:\"20260423_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260424_GalapagosPenguins"},"Ssd":"20260424","Name":"GalapagosPenguins","Market":"DE-DE","Hash":"2195733852","FullDateString":"24. Apr.. 2026"},{"ImageContent":{"Description":"Der heutige Tag steht im Zeichen von William Shakespeare, einem der einflussreichsten Dramatiker der Literaturgeschichte. Der Shakespeare-Tag fällt auf dieses Datum, da Shakespeare am 23. April 1616 starb und dieser Tag zugleich als sein traditionell angenommenes Geburtsdatum im Jahr 1564 gilt. Seine Werke – von „Hamlet” bis „Romeo und Julia” – gehören bis heute zum festen Repertoire von Bühnen weltweit und prägen Theater, Unterricht und Sprache weit über den englischsprachigen Raum hinaus. Viele seiner Wendungen sind bis heute im alltäglichen Sprachgebrauch präsent und zeugen von der anhaltenden Wirkung seines Schaffens.","Image":{"Url":"/th?id=OHR.HathawayCottage_DE-DE1846813831_1920x1080.webp","Wallpaper":"/th?id=OHR.HathawayCottage_DE-DE1846813831_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"Ein Cottage voller Geschichten","Title":"Anne Hathaway’s Cottage, Stratford‑upon‑Avon, England","Copyright":"© David Steele/Shutterstock","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/52.190984,-1.732059/6?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=52.190984,-1.732059;S9;Anne Hathaway’s Cottage, Stratford‑upon‑Avon, England&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260423_HathawayCottage\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Shakespeare%e2%80%91Tag&form=hpcapt&filters=HpDate:\"20260422_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260423_HathawayCottage"},"Ssd":"20260423","Name":"HathawayCottage","Market":"DE-DE","Hash":"1846813831","FullDateString":"23. Apr.. 2026"},{"ImageContent":{"Description":"Der Tag der Erde erinnert daran, dass Umweltbewusstsein aus konkreten Sorgen entstanden ist. Im Jahr 1970 machten Proteste auf verschmutzte Flüsse, belastete Luft und zerstörte Landschaften aufmerksam und setzten damit politische Veränderungen in Gang. Heute wird der 22. April weltweit begangen, um Bilanz zu ziehen und neue Ziele zu formulieren. Das Motto „Our Power, Our Planet“ für das Jahr 2026 richtet dabei den Blick nach vorn: Bis 2030 soll die globale Kapazität erneuerbarer Energien deutlich ausgebaut werden.","Image":{"Url":"/th?id=OHR.TartuEstonia_DE-DE1682620724_1920x1080.webp","Wallpaper":"/th?id=OHR.TartuEstonia_DE-DE1682620724_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Die Stimme der Erde","Title":"Naturschutzgebiet Alam‑Pedja, Landkreis Tartu, Estland","Copyright":"© Sven Zacek/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"//platform.bing.com/geo/REST/v1/Imagery/Map/RoadVibrant/58.466962,26.199884/5?key=AsSOKo7OOz5VAtfAj0rjgaXlhCrCZI6PGbLj7GCH8IW2HUalyg4BVhqA0z77PRCj&c=de-DE&od=2&shading=flat&pp=58.466962,26.199884;S9;Naturschutzgebiet Alam‑Pedja, Landkreis Tartu, Estland&st=pp|v:false;lv:false_trs|v:false;lv:false&ml=Basemap,Landmarks&logo=no&mapSize=386,434&da=ro","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260422_TartuEstonia\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Tag+der+Erde&form=hpcapt&filters=HpDate:\"20260421_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260422_TartuEstonia"},"Ssd":"20260422","Name":"TartuEstonia","Market":"DE-DE","Hash":"1682620724","FullDateString":"22. Apr.. 2026"},{"ImageContent":{"Description":"Mit dem Frühling zeigt sich ein vertrauter Bewohner unserer Landschaften. Der Europäische Igel, der hier in Frankreich zu sehen ist, ist ein überwiegend nachtaktives Tier, das meist allein lebt. Mit seiner feinen Nase und seinem guten Gehör durchstreift er Wiesen, Gärten und Waldränder auf der Suche nach Insekten, Würmern oder Schnecken. Droht Gefahr, zieht er sich zusammen und formt eine schützende Stachelkugel – eine einfache, aber wirkungsvolle Strategie. Nach dem Winterschlaf kehren Igel in vielen Teilen Europas in ihre Reviere zurück. Ihr Stoffwechsel fährt nun wieder hoch und sie müssen rasch neue Energiereserven aufbauen.","Image":{"Url":"/th?id=OHR.SpringHedgehog_DE-DE1345910488_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringHedgehog_DE-DE1345910488_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Stachelige Frühlingspatrouille","Title":"Europäischer Igel, Frankreich","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"Seine 5.000 bis 7.000 Stacheln sind keine echten Stacheln wie beim Stachelschwein, sondern feste, hohle Haare aus Keratin.","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260421_SpringHedgehog\"&FORM=HPQUIZ","BackstageUrl":"/search?q=Europ%c3%a4ischer+Igel&form=hpcapt&filters=HpDate:\"20260420_2200\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260421_SpringHedgehog"},"Ssd":"20260421","Name":"SpringHedgehog","Market":"DE-DE","Hash":"1345910488","FullDateString":"21. Apr.. 2026"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Bild des Tages","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Weitere Informationen","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Jetzt spenden","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Kurzinfo:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Letzte Bilder der Homepage","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage-Bild am {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"An diesem Tag in der Geschichte","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"An diesem Tag in {0}, {1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"Heutige Bing-Startseite teilen","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Dieses Bild herunterladen. Dieses Bild darf nur als Hintergrundbild verwendet werden.","LOC_MUSCARD_DOWNLOAD_LINK":"Dieses Bild herunterladen","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"Dieses Bild steht nicht zum Download als Hintergrundbild zur Verfügung.","LOC_HOMEPAGE_INFO_TEXT":"Info","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Herunterladen der Bing-Hintergrundbild-App","LOC_BING_APP_TEXT":"Abrufen eines Bing-Hintergrundbilds auf Ihrem Gerät","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adjust=nk9xri2_dzfz5n2","LOC_BING_APP_LINK_MOBILE":"https://app.adjust.com/d93ddtl_a75k0gg?deeplink=sapphire%3A%2F%2Fwallpaper","LOC_BING_APP_DOWNLOAD_TEXT":"Mobile App","LOC_BING_WP_APP_DOWNLOAD_TEXT":"Desktop-App","LOC_BING_APP_TEXT_MOBILE":"Täglich Fotos mit der Bing-App abrufen","LOC_BING_APP_DOWNLOAD_TEXT_MOBILE":"Herunterladen","LOC_HOMEPAGE_VERTICAL_SCROLL_TOB":"Trendthemen auf Bing","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB":"Trendth