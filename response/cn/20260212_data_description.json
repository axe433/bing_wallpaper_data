{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/2CWuZ7v7vDiJbFNiEuQGUziv1K4.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/7JXE81b_6A-kAbuSCjXI3FtZ4vo.css?bu=CMsBzgH-AYsCgQKBAoECyAI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7A/cir3,cc,nc/Utok7ck07gu22lmsIydejgWEtLY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/3wC_ht4ipmmpqzz_nMCVPQvHB-A.css?bu=CIsDgQKBAsICnAKBAoECgQI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/5B/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/gfxk7HQathU-S3ZTgg0a2mpD9Dg.css?bu=AtUC-wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/5B/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":false,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":true,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-02-12T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"在没有桥梁的年代，河流决定人们能走多远；而随着桥梁的建立，节奏掌握开始在人的手中。这种转变正是跨境基础设施的重要意义所在，比如连接老挝与泰国的第三座大桥泰老友谊大桥。桥梁结构多样，各有针对性：拱桥应对压力，悬索桥跨越长距离，混凝土箱梁桥则追求稳定与高效承载。这座桥选择箱梁设计，正是为应对湄公河宽阔水面与快速水流的现实需求。","Image":{"Url":"/th?id=OHR.FriendshipBridge_ZH-CN5199165736_1920x1080.webp","Wallpaper":"/th?id=OHR.FriendshipBridge_ZH-CN5199165736_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"为拉近距离而建","Title":"连接老挝和泰国的第三座泰老友谊大桥","Copyright":"© chaiyut samsuk/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"泰国与老挝之间的第五座泰老友谊大桥于2025年12月25日正式通车，连接泰国汶干府与老挝博里坎赛省，这座桥不仅缩短了距离，也串联起两国更频繁的往来与合作。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260213_FriendshipBridge\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%ac%ac%e4%b8%89%e5%ba%a7%e6%b3%b0%e8%80%81%e5%8f%8b%e8%b0%8a%e5%a4%a7%e6%a1%a5&form=hpcapt&filters=HpDate:\"20260212_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260213_FriendshipBridge"},"Ssd":"20260213","Name":"FriendshipBridge","Market":"ZH-CN","Hash":"5199165736","FullDateString":"2026 2月 13"},{"ImageContent":{"Description":"达尔文日纪念的不只是一位科学家的诞生，更是一场人类思维方式的转变。查尔斯·达尔文以敏锐的目光观察世界，从个体差异、生存优势到性状遗传，逐步建立起全新的科学认知。多年研究雀鸟、化石和藤壶后，他逐渐识别出其中隐藏的规律，并在1859年出版《物种起源》，首次系统提出物种通过自然选择不断演化的理论框架。","Image":{"Url":"/th?id=OHR.DarwinBooby_ZH-CN4925779873_1920x1080.webp","Wallpaper":"/th?id=OHR.DarwinBooby_ZH-CN4925779873_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"聚焦进化","Title":"蓝脚鲣鸟，加拉帕戈斯群岛, 厄瓜多尔","Copyright":"© Karine Aigner/TANDEM Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在求偶时，雄性蓝脚鲣鸟会把那双醒目的蓝色脚掌当作“王牌”，配合夸张的舞步来博得雌鸟青睐。它先把脚高高抬起，在雌鸟面前昂首阔步地走动，展开一场精心设计的表演。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260212_DarwinBooby\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%93%9d%e8%84%9a%e9%b2%a3%e9%b8%9f&form=hpcapt&filters=HpDate:\"20260211_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260212_DarwinBooby"},"Ssd":"20260212","Name":"DarwinBooby","Market":"ZH-CN","Hash":"4925779873","FullDateString":"2026 2月 12"},{"ImageContent":{"Description":"死亡谷国家公园颠覆人们对沙漠的想象，横跨加利福尼亚州与内华达州，总面积约340万英亩，是美国面积最大的国家公园。盐沼、火山丘陵、流动沙丘与覆雪山峰交错分布，构成极端而多变的地貌。从海拔11000英尺的望远镜峰，到低于海平面282英尺的恶水盆地，这里呈现出鲜明且震撼的对比。","Image":{"Url":"/th?id=OHR.BadwaterFlats_ZH-CN4713617982_1920x1080.webp","Wallpaper":"/th?id=OHR.BadwaterFlats_ZH-CN4713617982_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"对比之谷","Title":"死亡谷国家公园恶水盆地的盐滩, 加利福尼亚州, 美国","Copyright":"© Jim Patterson/TANDEM Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"除了震撼人心的自然景观与拓荒年代的故事，死亡谷曾长期作为一处兴盛的采矿中心。黄金白银铜钨铅锌锑和硼砂在谷地中被大量开采，留下深刻的工业印记。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260211_BadwaterFlats\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%ad%bb%e8%b0%b7%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260210_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260211_BadwaterFlats"},"Ssd":"20260211","Name":"BadwaterFlats","Market":"ZH-CN","Hash":"4713617982","FullDateString":"2026 2月 11"},{"ImageContent":{"Description":"在西班牙伊维萨岛西南海域，矗立着两座无人居住的小岛——埃斯韦德拉和埃斯韦德拉内尔。它们属于受保护的自然保留区，以独特的生态价值和震撼的视觉效果闻名。埃斯韦德拉几乎垂直从海中升起，高约1300英尺，陡峭的石灰岩峭壁宛如一座孤立的山脉。不远处的埃斯韦德拉内尔轮廓锋利，因形似伏卧的巨龙而被称为“沉睡的巨龙”，与主岛的高峻挺拔相互映衬。","Image":{"Url":"/th?id=OHR.IbizaIslets_ZH-CN4580106286_1920x1080.webp","Wallpaper":"/th?id=OHR.IbizaIslets_ZH-CN4580106286_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"海妖歌唱之处","Title":"埃斯韦德拉岛和埃斯韦德拉内尔岛，伊维萨岛，西班牙","Copyright":"© L. Apolli/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"埃斯韦德拉曾启发无数艺术家。1958年的美国电影《南太平洋》从中汲取灵感，1969年法国导演巴贝特·施罗德也曾在此取景拍摄电影。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260210_IbizaIslets\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bc%8a%e7%bb%b4%e8%90%a8%e5%b2%9b%e5%9f%83%e6%96%af%e7%bb%b4%e5%be%b7%e6%8b%89&form=hpcapt&filters=HpDate:\"20260209_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260210_IbizaIslets"},"Ssd":"20260210","Name":"IbizaIslets","Market":"ZH-CN","Hash":"4580106286","FullDateString":"2026 2月 10"},{"ImageContent":{"Description":"豹猫是一种体型较小的野生猫科动物，广泛分布于南亚、东南亚和东亚地区。它们体型与家猫相近，但四肢更修长、身形更为纤细，体长通常在15至30英寸之间，尾巴约7至12英寸。不同地区的成年豹猫体重差异较大，大致在1至16磅之间。外观变化也十分明显：南方种群多呈现温暖的金黄色皮毛，而分布在高纬度地区的豹猫则常拥有浅灰色皮毛，冬季时毛发会明显加厚。","Image":{"Url":"/th?id=OHR.LeopardCat_ZH-CN4431427444_1920x1080.webp","Wallpaper":"/th?id=OHR.LeopardCat_ZH-CN4431427444_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"斑纹流转","Title":"阿穆尔豹猫，俄罗斯","Copyright":"© Valeriy Maleev/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"豹猫会游泳，但极少下水。它们的叫声与家猫相近。无论雌雄，都会通过喷洒尿液、在显眼处排便、蹭头和抓挠等方式标记领地。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260209_LeopardCat\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%b1%b9%e7%8c%ab&form=hpcapt&filters=HpDate:\"20260208_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260209_LeopardCat"},"Ssd":"20260209","Name":"LeopardCat","Market":"ZH-CN","Hash":"4431427444","FullDateString":"2026 2月 9"},{"ImageContent":{"Description":"夜幕降临，希腊科孚岛展现出一种安静却耐人寻味的气息。温暖的路灯洒在石质立面上，古老的堡垒在夜色中勾勒出清晰的轮廓，狭窄的街巷层层延展，像一座仍在呼吸的迷宫老城。这里不仅保存着悠久的历史，也承载着真实的生活气息——多元文化在岁月流转中交叠，夜晚的节奏变得缓慢而从容，岛屿的生活气息，也在暗色中悄然浮现。","Image":{"Url":"/th?id=OHR.CorfuGreece_ZH-CN4305970968_1920x1080.webp","Wallpaper":"/th?id=OHR.CorfuGreece_ZH-CN4305970968_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"从宁静的夜晚到充满冒险的白天","Title":"科孚岛的夜晚, 希腊","Copyright":"© whitewizzard/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"科孚岛属于大陆型岛屿，其动物群与对岸大陆十分相似，物种丰富，涵盖哺乳动物、鸟类、爬行动物以及多样的海洋生物。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260208_CorfuGreece\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b8%8c%e8%85%8a%e7%a7%91%e5%ad%9a%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260207_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260208_CorfuGreece"},"Ssd":"20260208","Name":"CorfuGreece","Market":"ZH-CN","Hash":"4305970968","FullDateString":"2026 2月 8"},{"ImageContent":{"Description":"玻利维亚的乌尤尼盐沼并不会循序渐进地展开视野，它仿佛一道由光线构成的地平线，瞬间闯入眼帘。这里是世界上最大的盐沼，面积约4000平方英里，海拔接近12000英尺。景观会随季节剧烈变化：雨季来临时，地面被薄薄的积水覆盖，化作一面巨大的天然镜子，天空与大地在倒影中融为一片耀眼的光面。","Image":{"Url":"/th?id=OHR.SalarUyuni_ZH-CN4163237089_1920x1080.webp","Wallpaper":"/th?id=OHR.SalarUyuni_ZH-CN4163237089_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"在盐沼与天空之间，万物静谧","Title":"玻利维亚乌尤尼盐湖","Copyright":"© Abstract Aerial Art/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这片盐沼几乎看不到野生动物和植被，唯一显眼的生命，是成片生长的巨型仙人掌。它们每年仅生长约1厘 米，最高可达12米。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260207_SalarUyuni\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%8e%bb%e5%88%a9%e7%bb%b4%e4%ba%9a%e4%b9%8c%e5%b0%a4%e5%b0%bc%e7%9b%90%e6%b2%bc&form=hpcapt&filters=HpDate:\"20260206_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260207_SalarUyuni"},"Ssd":"20260207","Name":"SalarUyuni","Market":"ZH-CN","Hash":"4163237089","FullDateString":"2026 2月 7"}],"PreloadMediaContents":[{"ImageContent":{"Description":"今天，是安塞尔·亚当斯的诞辰。正是他的镜头，塑造了世人心中优胜美地的形象。这座国家公园以雄伟的花岗岩岩壁、壮观的瀑布和变幻莫测的光线闻名，持续激发着一代又一代艺术家的创作灵感。而其中最令人着迷的景象，是被称作“火瀑”的奇观。这一名称，其实源自优胜美地历史中的两种不同景象。在过去，人们曾聚集在冰川点，观看一种人工制造的奇观：炽热的余烬被推下悬崖，在夜幕中倾泻而下，宛如一条燃烧的火流。","Image":{"Url":"/th?id=OHR.AdamsFirefall_ZH-CN9409143565_1920x1080.webp","Wallpaper":"/th?id=OHR.AdamsFirefall_ZH-CN9409143565_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"光照之处","Title":"约塞米蒂国家公园里的火瀑布，加利福尼亚州，美国","Copyright":"© Jorge Villalba/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"唯有水量充沛、天空澄明，且阳光以恰当的角度洒落，火焰般的水幕才会显现。而这样的奇遇，并不会每年发生。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260220_AdamsFirefall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%ba%a6%e5%a1%9e%e7%b1%b3%e8%92%82%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad%e9%87%8c%e7%9a%84%e7%81%ab%e7%80%91%e5%b8%83&form=hpcapt&filters=HpDate:\"20260219_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260220_AdamsFirefall"},"Ssd":"20260220","Name":"AdamsFirefall","Market":"ZH-CN","Hash":"9409143565","FullDateString":"2026 2月 20"},{"ImageContent":{"Description":"“龙之眼”这个名字听起来像是出自传说，而当你站在挪威罗弗敦群岛的乌塔克莱夫海滩上时，你很容易就能明白为什么它会得此美名。这处地貌由古老的岩石雕琢而成，四周环绕着沙滩和大海，看起来栩栩如生，仿佛大地本身正在注视着你。它历经数千年的冰雪和海水的侵蚀塑造而成，如今已成为该地区最迷人的景点之一。","Image":{"Url":"/th?id=OHR.DragonsEyeRock_ZH-CN6164478776_1920x1080.webp","Wallpaper":"/th?id=OHR.DragonsEyeRock_ZH-CN6164478776_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"大地凝视着我们","Title":"乌塔克莱夫海滩的“龙之眼”岩层，挪威","Copyright":"© reisegraf/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"乌塔克莱夫是一个小社区，只有22名常住居民。除了“龙眼”岩层之外，该地区还以在沙丘上自由漫步和吃草的绵羊而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260219_DragonsEyeRock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b9%8c%e5%a1%94%e5%85%8b%e8%8e%b1%e5%a4%ab%e6%b5%b7%e6%bb%a9&form=hpcapt&filters=HpDate:\"20260218_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260219_DragonsEyeRock"},"Ssd":"20260219","Name":"DragonsEyeRock","Market":"ZH-CN","Hash":"6164478776","FullDateString":"2026 2月 19"},{"ImageContent":{"Description":"普氏野马从未被驯化，自始至终按照自己的方式生存，被认为是地球上最后的野马。它们曾广泛分布于中亚地区，但在20世纪60年代，由于狩猎、栖息地丧失以及与家畜竞争，普氏野马在野外一度消失。幸运的是，少数在20世纪初被带入圈养环境的个体保存了这个物种的火种，也孕育了今天所有的普氏野马。","Image":{"Url":"/th?id=OHR.PrzewalskisHorse_ZH-CN5785609662_1920x1080.webp","Wallpaper":"/th?id=OHR.PrzewalskisHorse_ZH-CN5785609662_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"生而自由，永不驯服","Title":"普氏野马","Copyright":"© Nemyrivskyi Viacheslav/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"早在两万年前，欧洲的洞穴壁画中就已描绘出类似普氏野马的野生马匹。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260218_PrzewalskisHorse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%99%ae%e6%b0%8f%e9%87%8e%e9%a9%ac&form=hpcapt&filters=HpDate:\"20260217_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260218_PrzewalskisHorse"},"Ssd":"20260218","Name":"PrzewalskisHorse","Market":"ZH-CN","Hash":"5785609662","FullDateString":"2026 2月 18"},{"ImageContent":{"Description":"过年好！今天是中国民间最隆重最富有特色的传统节日之一。其实每年从腊八或小年开始，到元宵节，都称之为过年。春节期间，中国全国各地人们都举办着感恩祈福、阖家团聚、除旧布新、迎禧接福、祈求丰年为主要内容的活动。而中国农历新年也在世界各地掀起了“中国风”，春节庆祝活动内容丰富多彩，具有重要的历史、艺术和文化价值。","Image":{"Url":"/th?id=OHR.SpringFestivalY26_ZH-CN0228318064_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringFestivalY26_ZH-CN0228318064_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"福气满满，马年大吉","Title":"中国春节传统汉字“福”","Copyright":"© DuKai摄影师/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"十二生肖的起源与动物崇拜有关。最早记载与现代相同的十二生肖的传世文献是东汉王充的《论衡》。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260217_SpringFestivalY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=2026%e9%a9%ac%e5%b9%b4%e6%98%a5%e8%8a%82&form=hpcapt&filters=HpDate:\"20260216_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260217_SpringFestivalY26"},"Ssd":"20260217","Name":"SpringFestivalY26","Market":"ZH-CN","Hash":"0228318064","FullDateString":"2026 2月 17"},{"ImageContent":{"Description":"除夕夜，街头的龙形灯笼正蜿蜒舒展，金鳞流转间仿佛蓄着时光的温度；而远处隐约响起的蹄声，恰似春风捎来骏马的问候——这是龙与马的相逢，是古老祥瑞与崭新朝气在岁月门楣的相会。","Image":{"Url":"/th?id=OHR.ChineseNewYearEveY26_ZH-CN7770318975_1920x1080.webp","Wallpaper":"/th?id=OHR.ChineseNewYearEveY26_ZH-CN7770318975_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"祝除夕团圆，新年顺遂！","Title":"庆祝春节的龙形灯笼，中国西安","Copyright":"© Pan Hong/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“龙马精神”是一个富有深厚文化意蕴的中文成语，其核心含义是形容人像龙和马一样，拥有昂扬抖擞、健旺非凡的精神面貌和奋发向上的生命力。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260216_ChineseNewYearEveY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%99%a4%e5%a4%95%e5%a4%9c&form=hpcapt&filters=HpDate:\"20260215_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260216_ChineseNewYearEveY26"},"Ssd":"20260216","Name":"ChineseNewYearEveY26","Market":"ZH-CN","Hash":"7770318975","FullDateString":"2026 2月 16"},{"ImageContent":{"Description":"世界鲸鱼日定于每年2月的第3个星期日，起源于20世纪80年代的夏威夷。当时，当地社区会庆祝座头鲸在迁徙季节重返近海。这一纪念日随后逐渐受到国际关注，尤其是在1986年国际捕鲸委员会通过商业捕鲸禁令之后，该举措成为全球鲸类保护的重要里程碑。","Image":{"Url":"/th?id=OHR.MontereyHumpbacks_ZH-CN5426789466_1920x1080.webp","Wallpaper":"/th?id=OHR.MontereyHumpbacks_ZH-CN5426789466_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"浪涛下的歌谣","Title":"蒙特雷湾的大翅鲸(座头鲸)，加利福尼亚州，美国","Copyright":"© Kiliii Fish/Cavan Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"座头鲸广泛分布于世界各大洋，在中国，它们的活动范围涵盖黄海、东海以及南海海域。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260215_MontereyHumpbacks\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%b2%b8%e9%b1%bc&form=hpcapt&filters=HpDate:\"20260214_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260215_MontereyHumpbacks"},"Ssd":"20260215","Name":"MontereyHumpbacks","Market":"ZH-CN","Hash":"5426789466","FullDateString":"2026 2月 15"},{"ImageContent":{"Description":"情人节象征着各种关于“心”的情感——热烈的、柔和的、充满希望的，或含蓄脆弱的。在众多象征之中，鲜少有植物能像荷包牡丹如此贴切地寓意情人节。它拥有醒目的心形花朵，每逢春季便悄然绽放，植株高约2英尺，展开宽度接近30英寸，营造出一种柔和优雅、富有诗意的景致。","Image":{"Url":"/th?id=OHR.ValentineHearts_ZH-CN5332774664_1920x1080.webp","Wallpaper":"/th?id=OHR.ValentineHearts_ZH-CN5332774664_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"爱意绽放