{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/2CWuZ7v7vDiJbFNiEuQGUziv1K4.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/cNrZP6gB97JvjtiV1MI24cGjP64.css?bu=CMsBzgH6AYcC_QH9Af0BxAI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7w/cir3,cc,nc/Utok7ck07gu22lmsIydejgWEtLY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/OxIDJ4QG2jMh5beFEICLkrgXd0s.css?bu=CIcD_QH9Ab4CmAL9Af0B_QE&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/5x/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/gfxk7HQathU-S3ZTgg0a2mpD9Dg.css?bu=AtEC9wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/5x/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":false,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-02T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"元宵节是中国农历新年的重要节日，通常在正月十五庆祝。人们会吃汤圆（象征团圆）并欣赏各式灯笼，寓意团圆、幸福与吉祥。节日期间，家庭聚会、赏灯和灯谜活动都非常受欢迎，是春节庆祝活动的延续。","Image":{"Url":"/th?id=OHR.LanternFestivalY26_ZH-CN9186685796_1920x1080.webp","Wallpaper":"/th?id=OHR.LanternFestivalY26_ZH-CN9186685796_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"花灯映月，团圆吉祥","Title":"元宵节期间悬挂的宫灯，北京自贡灯会现场，北京，中国","Copyright":"© Grisha Bruev/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"你知道吗？元宵节吃的汤圆最早源自汉代，当时被称作“浮圆”，是用糯米粉制成的小圆球，象征团圆与家庭和睦。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260303_LanternFestivalY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%85%83%e5%ae%b5%e8%8a%82&form=hpcapt&filters=HpDate:\"20260302_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260303_LanternFestivalY26"},"Ssd":"20260303","Name":"LanternFestivalY26","Market":"ZH-CN","Hash":"9186685796","FullDateString":"2026 3月 3"},{"ImageContent":{"Description":"别被远看时苏梅岛长尾船朴素的外表所迷惑，这些修长的船身凝聚了当地数十年的巧思。它们在泰语中被称为“RueaHangYao”，诞生于20世纪初，当时渔民将汽车发动机改装成动力，用以穿行于大型船只难以进入的浅水海域。每一艘长尾船都由工匠一块木板一块木板手工打造，承载着代代相传的技艺。船体上色彩大胆而醒目，船头常装点着彩布与鲜花——这些象征佛教祝福的装饰，寓意守护船只与船员一路平安。","Image":{"Url":"/th?id=OHR.SamuiThailand_ZH-CN3323790951_1920x1080.webp","Wallpaper":"/th?id=OHR.SamuiThailand_ZH-CN3323790951_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"漂浮的传承","Title":"苏梅岛的港口和长尾船, 泰国","Copyright":"© Foto2rich/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这座高耸的关羽雕像位于泰国苏梅岛华他农，见证着海南华人最早在岛上的定居历史。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260302_SamuiThailand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b3%b0%e5%9b%bd%e8%8b%8f%e6%a2%85%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260301_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260302_SamuiThailand"},"Ssd":"20260302","Name":"SamuiThailand","Market":"ZH-CN","Hash":"3323790951","FullDateString":"2026 3月 2"},{"ImageContent":{"Description":"今天，我们一同庆祝西班牙迷人的巴利阿里群岛。巴利阿里群岛日致敬这一片多样却紧密相连的地中海土地——马略卡、梅诺卡、伊维萨与福门特拉，共同构成独特的群岛身份。这个日子同时纪念《巴利阿里自治法》，该法案于1983年3月1日正式生效，确立群岛作为西班牙的一个自治区。","Image":{"Url":"/th?id=OHR.BalearesDay_ZH-CN5024902433_1920x1080.webp","Wallpaper":"/th?id=OHR.BalearesDay_ZH-CN5024902433_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"每一步，都是传承","Title":"伊维萨岛, 巴利阿里群岛, 西班牙","Copyright":"© tokar/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"伊维萨岛不仅是游客青睐的度假胜地，更因狂欢不息的夜生活文化而闻名世界，由此被誉为“世界派对之都”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260301_BalearesDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bc%8a%e7%bb%b4%e8%90%a8%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260228_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260301_BalearesDay"},"Ssd":"20260301","Name":"BalearesDay","Market":"ZH-CN","Hash":"5024902433","FullDateString":"2026 3月 1"},{"ImageContent":{"Description":"莫洛凯岛常被称为“最具夏威夷气息岛屿”，这里的节奏缓慢而从容，由自然环境与紧密相连的社区共同塑造。岛屿形成于一百多万年前的火山活动，占地约260平方英里，从太平洋中隆起，延展出修长的山脊与开阔的谷地。与喧闹的邻岛不同，莫洛凯岛拒绝大规模开发，保留了强烈的在地凝聚力，家庭、传统以及对土地的守护构成了这里的核心价值。人们的生活围绕着海洋、土地，以及代代相传的故事展开。","Image":{"Url":"/th?id=OHR.OloupenaFalls_ZH-CN2980118660_1920x1080.webp","Wallpaper":"/th?id=OHR.OloupenaFalls_ZH-CN2980118660_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"洋溢着社区氛围","Title":"奥洛乌佩纳瀑布, 莫洛凯岛, 夏威夷, 美国","Copyright":"© Andrew Aylett/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这些瀑布极为偏远，只能从空中或海上远望。附近既没有公路，也没有步道。最近的城镇是考纳卡凯，这是岛上的主要城镇。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260228_OloupenaFalls\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8e%ab%e6%b4%9b%e5%87%af%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260227_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260228_OloupenaFalls"},"Ssd":"20260228","Name":"OloupenaFalls","Market":"ZH-CN","Hash":"2980118660","FullDateString":"2026 2月 28"},{"ImageContent":{"Description":"2月27日是国际北极熊日，聚焦与冰封世界紧密相连的“北极巨兽”。作为世界上最大的陆地食肉动物，北极熊会为寻找食物在辽阔的极地景观中跋涉数百英里。它们高度适应海冰生活：宽大的前掌跨度可达约一英尺，不仅能稳稳踏雪行走，也能在冰冷海水中游出数英里。","Image":{"Url":"/th?id=OHR.ArcitcCub_ZH-CN2725049760_1920x1080.webp","Wallpaper":"/th?id=OHR.ArcitcCub_ZH-CN2725049760_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"薄冰上的生活","Title":"北极熊幼崽走过浮冰, 北极国家野生动物保护区, 阿拉斯加州, 美国","Copyright":"© Steven Kazlowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"根据国际自然保护联盟（IUCN）的评估，北极熊被列为易危物种，全球种群数量估计约22000至31000只。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260227_ArcitcCub\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8c%97%e6%9e%81%e7%86%8a&form=hpcapt&filters=HpDate:\"20260226_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260227_ArcitcCub"},"Ssd":"20260227","Name":"ArcitcCub","Market":"ZH-CN","Hash":"2725049760","FullDateString":"2026 2月 27"},{"ImageContent":{"Description":"大峡谷国家公园每天都有新的故事，但2月26日这一天格外特别，纪念的是1919年大峡谷正式成为国家公园的历史时刻。这一里程碑式的决定，守护了美国最具代表性的自然奇观。峡谷深处，科罗拉多河缓缓流淌，穿行于层叠的岩石之间，跨越数百英里，以季节为节拍，静静雕刻着峡谷的生命。","Image":{"Url":"/th?id=OHR.GrandSunset_ZH-CN1905986519_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandSunset_ZH-CN1905986519_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一幅壮丽的景象","Title":"大峡谷和科罗拉多河，亚利桑那州，美国","Copyright":"© Matt Anderson Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"国家公园管理局在园内多个观景点架设了实时网络摄像头，分享日出时刻、天气变化与峡谷的日常节律。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260226_GrandSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%be%8e%e5%9b%bd%e5%a4%a7%e5%b3%a1%e8%b0%b7%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260225_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260226_GrandSunset"},"Ssd":"20260226","Name":"GrandSunset","Market":"ZH-CN","Hash":"1905986519","FullDateString":"2026 2月 26"},{"ImageContent":{"Description":"阿拉斯加朱诺城外，门登霍尔冰川静静隐匿其间，内外皆仿佛幻境。走入罕见的蓝色冰洞，世界骤然安静，光线透过历经数百年压实的冰层，映照四周。冰川自朱诺冰原绵延约十三英里，缓缓流向下方山谷，在年复一年的流动中悄然改变形态。","Image":{"Url":"/th?id=OHR.MendenhallCave_ZH-CN1850649760_1920x1080.webp","Wallpaper":"/th?id=OHR.MendenhallCave_ZH-CN1850649760_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"冰，由内而外透出光芒","Title":"门登霍尔冰川的冰洞，阿拉斯加州，美国","Copyright":"© Designpics/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"2012年，冰川消退后，埋藏其下的树桩和原木逐渐显现，根系与树皮仍然完整。因长久埋藏在砾石之下，这层覆盖恰好成了天然的保护屏障，所以它们仍保持着原本的生长姿态。当这些遗存被揭开，科学家得以窥见冰川形成之前的生态环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260225_MendenhallCave\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%97%a8%e7%99%bb%e9%9c%8d%e5%b0%94%e5%86%b0%e5%b7%9d&form=hpcapt&filters=HpDate:\"20260224_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260225_MendenhallCave"},"Ssd":"20260225","Name":"MendenhallCave","Market":"ZH-CN","Hash":"1850649760","FullDateString":"2026 2月 25"}],"PreloadMediaContents":[{"ImageContent":{"Description":"你是否曾好奇，当火焰、冰霜和时间交汇于同一片土地，会发生什么？冰岛的赫韦拉韦利尔地热田或许能解答你的疑问。在这片高地热点地区，地球内部的能量与冰冷的地表相遇，引发了压力、温度和岩石之间一场激烈的对话。喷气孔嘶嘶作响，蒸汽袅袅升腾，大地被染成硫磺白、铁锈红和赭黄——这不仅是艺术，更是极端高温驱动的化学反应。在今天的照片中，布拉赫韦尔天然温泉呈现出耀眼的电光蓝。这种颜色源于富含矿物质和二氧化硅的泉水反射光线。","Image":{"Url":"/th?id=OHR.SpringIceland_ZH-CN9545282898_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringIceland_ZH-CN9545282898_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"霜下之火","Title":"赫韦拉韦利尔的布拉赫维尔地热池, 冰岛","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"冰岛赫韦拉韦利尔的布拉赫维尔地热蓝池是一处令人惊叹的温泉，以其湛蓝的水色和在偏远火山高地中喷腾的地热活动而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260310_SpringIceland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%86%b0%e5%b2%9b%e5%b8%83%e6%8b%89%e8%b5%ab%e7%bb%b4%e5%b0%94%e5%9c%b0%e7%83%ad%e6%b1%a0&form=hpcapt&filters=HpDate:\"20260309_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260310_SpringIceland"},"Ssd":"20260310","Name":"SpringIceland","Market":"ZH-CN","Hash":"9545282898","FullDateString":"2026 3月 10"},{"ImageContent":{"Description":"全国午睡日真是选得恰到好处。它恰逢夏令时开始后的星期一，届时时钟会拨快一小时，我们所有人都会少睡一个小时。不妨把今天当作一个正式的理由，放慢脚步，好好补补觉。这张照片中，一只在苏格兰海岸边酣睡的灰海豹，正是对这一天的绝佳提醒：休息至关重要。","Image":{"Url":"/th?id=OHR.NappingSeal_ZH-CN9424683964_1920x1080.webp","Wallpaper":"/th?id=OHR.NappingSeal_ZH-CN9424683964_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一次恰到好处的午睡","Title":"在海滩上睡觉的灰海豹, 奥克尼群岛, 苏格兰","Copyright":"© Andrew Mason/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"苏格兰奥克尼群岛的灰海豹是一种大型海洋哺乳动物，以其独特的斑点皮毛和在崎岖海岸上的活泼行为而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260309_NappingSeal\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%81%b0%e6%b5%b7%e8%b1%b9&form=hpcapt&filters=HpDate:\"20260308_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260309_NappingSeal"},"Ssd":"20260309","Name":"NappingSeal","Market":"ZH-CN","Hash":"9424683964","FullDateString":"2026 3月 9"},{"ImageContent":{"Description":"每年三月，美国大部分地区开始实行夏令时，时钟拨快以最大限度地利用日光。这一想法可以追溯到1784年，当时本杰明·富兰克林曾幽默地建议人们早起以节省蜡烛的使用。美国在第一次世界大战期间，于1918年正式采用夏令时，作为一项节能措施。经过多年执行不一之后，1966年的《统一时间法案》确立了全国范围内季节性时钟调整的标准。虽然如今大多数州都实行夏令时，但夏威夷州和亚利桑那州（纳瓦霍族保留地除外）不实行，理由是日光变化幅度很小，且出于气候方面的考虑。此外，美国的一些属地全年也保持标准时间。","Image":{"Url":"/th?id=OHR.UlmClock_ZH-CN9282560066_1920x1080.webp","Wallpaper":"/th?id=OHR.UlmClock_ZH-CN9282560066_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"节约日光的艺术","Title":"乌尔姆市政厅的天文钟, 德国","Copyright":"© Tomekbudujedomek/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"位于德国乌尔姆市市政厅的天文钟是一座历史悠久的时钟，以其精巧的机械结构和详尽的天文显示而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260308_UlmClock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a9%e6%96%87%e9%92%9f&form=hpcapt&filters=HpDate:\"20260307_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260308_UlmClock"},"Ssd":"20260308","Name":"UlmClock","Market":"ZH-CN","Hash":"9282560066","FullDateString":"2026 3月 8"},{"ImageContent":{"Description":"约旦佩特拉的群山不仅以其雄伟的规模令人叹为观止，更以其镌刻在石头上的故事而令人震撼。卡兹尼神殿（又称宝库）雕刻在玫瑰色的岩石上，是人类技艺和古代辉煌的有力见证。","Image":{"Url":"/th?id=OHR.PetraTomb_ZH-CN9151154968_1920x1080.webp","Wallpaper":"/th?id=OHR.PetraTomb_ZH-CN9151154968_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"时间的宝库","Title":"卡兹尼神殿（宝库）, 佩特拉, 约旦","Copyright":"© Frédéric Soltan/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"卡兹尼宝库是约旦佩特拉的标志性纳巴泰遗迹，以其雕刻于高耸砂岩峭壁上的宏伟立面而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260307_PetraTomb\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bd%a9%e7%89%b9%e6%8b%89%e7%9a%84%e5%8d%a1%e5%85%b9%e5%b0%bc%e5%ae%9d%e5%ba%93&form=hpcapt&filters=HpDate:\"20260306_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260307_PetraTomb"},"Ssd":"20260307","Name":"PetraTomb","Market":"ZH-CN","Hash":"9151154968","FullDateString":"2026 3月 7"},{"ImageContent":{"Description":"建筑融合了艺术与科技，并通过建筑形式得以展现。虽然许多设计主要侧重于功能，但也有一些建筑同样重视视觉冲击力。丹麦韦勒的“波浪”建筑群就是一个绝佳的例子，它将雕塑般的造型设计与实用的居住空间完美结合。","Image":{"Url":"/th?id=OHR.WaveDenmark_ZH-CN8825888678_1920x1080.webp","Wallpaper":"/th?id=OHR.WaveDenmark_ZH-CN8825888678_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"混凝土中铸造的波浪","Title":"波浪住宅楼, 瓦埃勒, 丹麦","Copyright":"© Frank Bach/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这座屡获殊荣的九层住宅楼代表着城市滨水区的复兴，也代表着丹麦小镇韦勒的新形象。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260306_WaveDenmark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%b9%e9%ba%a6%e7%93%a6%e5%9f%83%e5%8b%92%e6%b3%a2%e6%b5%aa%e5%a4%a7%e5%8e%a6&form=hpcapt&filters=HpDate:\"20260305_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260306_WaveDenmark"},"Ssd":"20260306","Name":"WaveDenmark","Market":"ZH-CN","Hash":"8825888678","FullDateString":"2026 3月 6"},{"ImageContent":{"Description":"黄昏时分，卡帕多西亚格雷梅地区的地貌逐渐显现。这片区域隶属于格雷梅国家公园与卡帕多西亚岩石遗址，1985年入选世界遗产名录。“精灵烟囱”等地貌源自安那托利亚火山喷发形成的火山灰层，随后经风与水长期侵蚀，雕刻出石柱、山脊与谷地。","Image":{"Url":"/th?id=OHR.GoremeTwilight_ZH-CN3731931947_1920x1080.webp","Wallpaper":"/th?id=OHR.GoremeTwilight_ZH-CN3731931947_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"古老岩石，现代灯光","Title":"格雷梅的傍晚, 卡帕多西亚, 土耳其","Copyright":"© ONNAJA/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"格雷梅是一座由火山岩凿刻而成的小镇，是通往格雷梅国家公园的门户。这里被列入联合国教科文组织世界遗产名录，保存着10至11世纪的洞穴教堂，并以“精灵烟囱”般的岩石地貌闻名，深受世界各地的背包客喜爱。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260305_GoremeTwilight\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%9f%e8%80%b3%e5%85%b6%e6%a0%bc%e9%9b%b7%e6%a2%85&form=hpcapt&filters=HpDate:\"20260304_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260305_GoremeTwilight"},"Ssd":"20260305","Name":"GoremeTwilight","Market":"ZH-CN","Hash":"3731931947","FullDateString":"2026 3月 5"},{"ImageContent":{"Description":"随着保加利亚西南部里拉山脉冬季寒意减退，番红花从积雪中破土而出，标志着该国最高山脉春天的来临。作为早春花卉，它们利用储存的养分，在寒冷条件下迅速生长，并在更高大的植物出现之前完成生命周期。成簇的花朵在高山草甸上绽放，如紫色缎带般铺展，与雪原形成鲜明对比，在清晨的光线中格外醒目。","Image":{"Url":"/th?id=OHR.RilaCrocuses_ZH-CN3650360951_1920x1080.webp","Wallpaper":"/th?id=OHR.RilaCrocuses_ZH-CN3650360951_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"聚光灯下的番红花","Title":"紫番红花, 里拉七湖, 保加利亚","Copyright":"© Maya Karkalicheva/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在人类文明的早期记载中，番红花就已出现，最重要的原因是它能产出藏红花。藏红花采自一种秋日开花的番红花属植物，其干燥的雌蕊既可调味，也可染色，是