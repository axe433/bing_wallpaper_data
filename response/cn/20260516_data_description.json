{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/yGmczKojHJKduLqf4TGLfVXKBY4.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/Z3RsRJM-Pfsyj_3ZanZL12q73Gg.css?bu=CPIB9QGWAqUCmQKZApkC5QI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/7r/cir3,cc,nc/OVhQdYvNy4P2Rc592GkE4q1a4ZY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/LnB2jfO0wyViNxCDNEQnRgUHG1A.css?bu=CJUDmQKZAt8CtQKZApkCmQI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2A/64/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvICgAM&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/64/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-05-16T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"究竟要多高，才能尽享绝佳美景？在美国东部，其实无需太高的海拔。位于弗吉尼亚州仙纳度国家公园（Shenandoah National Park）内的玳瑁峰（Hawksbill Mountain），海拔仅为4050英尺；这充分表明，对于这些古老的山脉而言，开阔的视野远比绝对的高度更为重要。该公园成立于1935年，其建立过程伴随着大规模农耕与伐木活动之后的植被恢复工作。如今，昔日的土地大都已重披林装，孕育着混交阔叶林、山月桂以及杜鹃花等丰富的植被。此外还有什么值得一提？公园内的部分岩石距今已逾10亿年，堪称该州最为古老的岩层之一。这里栖息着200多种鸟类和32种鱼类；同时，公园对宠物也十分友好，允许游客携带爱犬进入露营地及大多数步道。","Image":{"Url":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1080.webp","Wallpaper":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"静谧之巅，喧嚣之景","Title":"仙纳度国家公园的玳瑁峰, 弗吉尼亚州, 美国","Copyright":"© John Baggaley/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"约850种野花铺满仙纳度国家公园，全年呈现出美丽而多样的景观。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260517_ShenandoahSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bb%99%e7%ba%b3%e5%ba%a6%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260516_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260517_ShenandoahSunset"},"Ssd":"20260517","Name":"ShenandoahSunset","Market":"ZH-CN","Hash":"4399136794","FullDateString":"2026 5月 17"},{"ImageContent":{"Description":"你会如何称呼这样一个地方：在这里，是岩石在“攀登”，而人类却得拼命追赶？欢迎来到位于俄勒冈州的史密斯岩州立公园（Smith Rock State Park）——在这里，峭壁拔地而起，而借口却消散得更快。公园坐落于长达26英里的“弯曲河破火山口”（Crooked River Caldera）之中，这一地貌正是由多次火山喷发塑造而成。这里的凝灰岩峭壁由受压冷却后的火山灰经压缩凝结而成。弯曲河（Crooked River）在此鬼斧神工般地雕刻出了峡谷，而像“尖塔”（The Spire）这样的岩层则巍然耸立，高度直逼700英尺。","Image":{"Url":"/th?id=OHR.SmithRockPark_ZH-CN4210144402_1920x1080.webp","Wallpaper":"/th?id=OHR.SmithRockPark_ZH-CN4210144402_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"跌到谷底？这里可不是。","Title":"史密斯岩州立公园, 俄勒冈州, 美国","Copyright":"© Alex Ratson/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"公园内外野生动物资源丰富。骡鹿和许多小型哺乳动物在公园里很常见。水獭和海狸则栖息在公园的克鲁克德河沿岸。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260516_SmithRockPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8f%b2%e5%af%86%e6%96%af%e5%b2%a9%e5%b7%9e%e7%ab%8b%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260515_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260516_SmithRockPark"},"Ssd":"20260516","Name":"SmithRockPark","Market":"ZH-CN","Hash":"4210144402","FullDateString":"2026 5月 16"},{"ImageContent":{"Description":"集智慧、力量与惊人的深潜本领于一身——抹香鲸绝不满足于浅层的生存。在这个“濒危物种日”，让我们一同认识这位胸怀大志、潜得更深的海洋巨兽。","Image":{"Url":"/th?id=OHR.EndangeredWhales_ZH-CN4053106967_1920x1080.webp","Wallpaper":"/th?id=OHR.EndangeredWhales_ZH-CN4053106967_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"鲸鱼，你会救我吗？","Title":"一群抹香鲸, 印度洋","Copyright":"© Tony Wu/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“Cachalot”一词常用于指代抹香鲸，源自一个古法语词汇，意为“大牙齿”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260515_EndangeredWhales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%8a%b9%e9%a6%99%e9%b2%b8&form=hpcapt&filters=HpDate:\"20260514_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260515_EndangeredWhales"},"Ssd":"20260515","Name":"EndangeredWhales","Market":"ZH-CN","Hash":"4053106967","FullDateString":"2026 5月 15"},{"ImageContent":{"Description":"皮蒂利亚诺坐落在意大利托斯卡纳南部的一处凝灰岩山脊上，是一座小巧却个性十足的城镇。它的历史可以追溯到伊特鲁里亚时代，蜿蜒的街道至今仍回荡着昔日的痕迹，从中世纪的防御工事到文艺复兴时期的宫殿，处处可见历史的印记。漫步在狭窄的巷弄中，仿佛能感受到几个世纪的生活印记镌刻在石头上，而小巧的广场则邀请您驻足，品尝咖啡或意式冰淇淋。这座经久不衰的宝藏常被誉为“小耶路撒冷”，因为它拥有历史悠久的犹太区，那里有一座犹太教堂和一座古老的墓地，诉说着曾经繁荣的犹太社区的故事。","Image":{"Url":"/th?id=OHR.Pitigliano_ZH-CN1509921892_1920x1080.webp","Wallpaper":"/th?id=OHR.Pitigliano_ZH-CN1509921892_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一场穿越时空的旅程","Title":"中世纪古镇皮蒂利亚诺, 托斯卡纳, 意大利","Copyright":"© bluejayphoto/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"皮蒂利亚诺最令人期待的活动之一是“九月神圣节”（SettembreDivino），它每年与丰收节同时举行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260514_Pitigliano\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%9a%ae%e8%92%82%e5%88%a9%e4%ba%9a%e8%af%ba&form=hpcapt&filters=HpDate:\"20260513_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260514_Pitigliano"},"Ssd":"20260514","Name":"Pitigliano","Market":"ZH-CN","Hash":"1509921892","FullDateString":"2026 5月 14"},{"ImageContent":{"Description":"在今天这张照片中，阿拉巴马山的花岗岩拱门将银河框入加州东部内华达山脉崎岖的地貌之中。这片区域以其圆润的巨石和风化的岩层而闻名，大约在1亿年前由火山活动形成。水和风逐渐将岩石塑造成如今光滑的形状。游客可以探索天然拱门，在岩石间徒步，拍摄独特的景观，骑马或骑山地自行车，并欣赏季节性的野花盛开。","Image":{"Url":"/th?id=OHR.AlabamaHills_ZH-CN1387018045_1920x1080.webp","Wallpaper":"/th?id=OHR.AlabamaHills_ZH-CN1387018045_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"银河系，摇滚吧！","Title":"拱门与银河, 阿拉巴马山, 内华达山脉, 加利福尼亚州, 美国","Copyright":"© Tim Fitzharris/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在这片干旱的土地上，翠绿的沙漠橄榄）、黄柳和芦苇竞相绽放。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260513_AlabamaHills\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%98%bf%e6%8b%89%e5%b7%b4%e9%a9%ac%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260512_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260513_AlabamaHills"},"Ssd":"20260513","Name":"AlabamaHills","Market":"ZH-CN","Hash":"1387018045","FullDateString":"2026 5月 13"},{"ImageContent":{"Description":"在北大西洋崎岖的海岸线上，大西洋海鹦栖息于洞穴和峭壁缝隙中。这些羽毛黑白相间、喙色艳丽的海鸟，由于过度捕捞和海洋环境变化导致猎物数量减少，被世界自然保护联盟（IUCN）列为易危物种。每年春天，它们都会返回此地繁殖，在精心挖掘的洞穴中产下一枚卵。作为游泳健将，它们在捕食鲱鱼和沙鳗等小型鱼类时，会利用翅膀在水下“飞行”。","Image":{"Url":"/th?id=OHR.Fratercula_ZH-CN1239275412_1920x1080.webp","Wallpaper":"/th?id=OHR.Fratercula_ZH-CN1239275412_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"振翅, 潜水, 生存","Title":"北极海鹦, 威尔士","Copyright":"© FLPA/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"大西洋海鹦的飞行路线是直线飞行，通常在海面以上10米（35 英尺）处，比大多数其他海雀飞得更高。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260512_Fratercula\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8c%97%e6%9e%81%e6%b5%b7%e9%b9%a6&form=hpcapt&filters=HpDate:\"20260511_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260512_Fratercula"},"Ssd":"20260512","Name":"Fratercula","Market":"ZH-CN","Hash":"1239275412","FullDateString":"2026 5月 12"},{"ImageContent":{"Description":"世界最伟大的自然奇观之一，绵延在澳大利亚东北海岸线外的珊瑚海碧绿海水中。大堡礁沿着昆士兰海岸延伸，是世界上最大的珊瑚礁系统。它由近3000个独立的珊瑚礁和数百个岛屿组成，绵延超过1400英里。","Image":{"Url":"/th?id=OHR.QueenslandReef_ZH-CN1138150002_1920x1080.webp","Wallpaper":"/th?id=OHR.QueenslandReef_ZH-CN1138150002_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水下建筑","Title":"从上方俯瞰大堡礁, 昆士兰州, 澳大利亚","Copyright":"© Francesco Riccardo Iacomino/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"纬度和跨陆架多样性，加上水体深度的多样性，构成了全球独一无二的生态群落、栖息地和物种。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260511_QueenslandReef\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%be%b3%e5%a4%a7%e5%88%a9%e4%ba%9a%e5%a4%a7%e5%a0%a1%e7%a4%81&form=hpcapt&filters=HpDate:\"20260510_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260511_QueenslandReef"},"Ssd":"20260511","Name":"QueenslandReef","Market":"ZH-CN","Hash":"1138150002","FullDateString":"2026 5月 11"}],"PreloadMediaContents":[{"ImageContent":{"Description":"“欧洲公园日”旨在庆祝欧洲大陆上的自然保护区，并纪念1909年欧洲首批国家公园的诞生。这一节日提醒着世人：现今诸多最具代表性的自然景观，皆得益于长期的生态保育努力。今日的影像向我们展示了这一文化遗产的典范——位于意大利北部的三峰自然公园。","Image":{"Url":"/th?id=OHR.DolomitesPark_ZH-CN7134423478_1920x1080.webp","Wallpaper":"/th?id=OHR.DolomitesPark_ZH-CN7134423478_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"守护欧洲的自然净土","Title":"三峰自然公园，南蒂罗尔，意大利","Copyright":"© Adisorn Fineday Chutikunakorn/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"尽管这里以卓越的地质特征闻名，但它也承载着黑暗的历史。第一次世界大战期间，这片崎岖的景观曾是意大利和奥匈帝国军队展开残酷壕沟战的最前线，双方士兵曾在皑皑峰峦间忍受战火与雪崩的双重考验。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260524_DolomitesPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%84%8f%e5%a4%a7%e5%88%a9%e4%b8%89%e5%b3%b0%e8%87%aa%e7%84%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260523_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260524_DolomitesPark"},"Ssd":"20260524","Name":"DolomitesPark","Market":"ZH-CN","Hash":"7134423478","FullDateString":"2026 5月 24"},{"ImageContent":{"Description":"龟类不仅是引人入胜的生物，更在自然界中扮演着至关重要的角色。海龟有助于维持海草床与珊瑚礁生态系统的健康，而淡水及陆栖龟类则支撑着各自生境的生态平衡。龟壳实际上是其骨架的一部分，由数十块骨头融合而成；此外，部分物种还能够利用地球磁场进行导航，精准地回到它们的出生地。","Image":{"Url":"/th?id=OHR.ThreeTurtlesButterflies_ZH-CN7043849571_1920x1080.webp","Wallpaper":"/th?id=OHR.ThreeTurtlesButterflies_ZH-CN7043849571_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"为龟类喝彩！","Title":"与蝴蝶在一起的乌龟","Copyright":"© Patrick Gallet/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"全球共有七种海龟，其中五种正面临灭绝威胁。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260523_ThreeTurtlesButterflies\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e4%b9%8c%e9%be%9f%e6%97%a5&form=hpcapt&filters=HpDate:\"20260522_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260523_ThreeTurtlesButterflies"},"Ssd":"20260523","Name":"ThreeTurtlesButterflies","Market":"ZH-CN","Hash":"7043849571","FullDateString":"2026 5月 23"},{"ImageContent":{"Description":"每年5月22日为“国际生物多样性日”，它向全球发出提醒：地球上的生命远比肉眼所见更加丰富，却也更加脆弱。这一由联合国设立的纪念日，旨在强调保护动植物及其生态系统为何对粮食安全、药物研发、气候稳定以及人类的日常福祉至关重要。","Image":{"Url":"/th?id=OHR.KauehiAtollLagoon_ZH-CN9552036080_1920x1080.webp","Wallpaper":"/th?id=OHR.KauehiAtollLagoon_ZH-CN9552036080_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"海洋生命的律动","Title":"埃希环礁，土阿莫土群岛，法属波利尼西亚","Copyright":"© WaterFrame_dpr/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"考埃希环礁拥有独特的“三通道”入海口连接泻湖，这种结构形成了强劲的潮汐流，能显著提高湖水含氧量，为珍稀生物提供了绝佳的生存环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260522_KauehiAtollLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e7%94%9f%e7%89%a9%e5%a4%9a%e6%a0%b7%e6%80%a7%e6%97%a5&form=hpcapt&filters=HpDate:\"20260521_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260522_KauehiAtollLagoon"},"Ssd":"20260522","Name":"KauehiAtollLagoon","Market":"ZH-CN","Hash":"9552036080","FullDateString":"2026 5月 22"},{"ImageContent":{"Description":"“国际茶日”旨在礼赞一种将日常习俗与古老地貌紧密相连的饮品。只需瞥一眼中国四川省那层层叠叠的梯田茶园，便不难领略其深植的文化根基。这片位于中国西南部的云雾缭绕之地，乃是茶文化的早期发源地之一；早在两千多年前，当地居民便已在此饮茶、植茶。在邻近的蒙顶山上，一位名叫吴理真的学者曾在汉朝时期开辟了世界上首批人工管理的茶园，从而为后世一代又一代的茶农奠定了坚实的基础。","Image":{"Url":"/th?id=OHR.SichuanTea_ZH-CN6703437873_1920x1080.webp","Wallpaper":"/th?id=OHR.SichuanTea_ZH-CN6703437873_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"酿造传承","Title":"四川省的茶梯田, 中国","Copyright":"© lzf/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"该节日于每年的5月21日庆祝，旨在认可茶叶数百年来的历史遗产，及其对全球健康、文化和农村生计所做出的显著贡献。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260521_SichuanTea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e8%8c%b6%e6%97%a5&form=hpcapt&filters=HpDate:\"20260520_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260521_SichuanTea"},"Ssd":"20260521","Name":"SichuanTea","Market":"ZH-CN","Hash":"6703437873","FullDateString":"2026 5月 21"},{"ImageContent":{"Description":"一声轻柔的嗡嗡声，伴随着细微的花粉飞扬，足以塑造我们食物的未来。每年5月20日是“世界蜜蜂日”，这一节日旨在礼赞像图中这只大黄蜂一样的授粉昆虫，致敬它们那看似悄无声息却至关重要的辛勤工作。与许多昆虫不同，大黄蜂采用一种独特的“振动授粉”方式——通过振动飞行肌，将花粉从花朵中抖落出来；对于番茄、辣椒和蓝莓等农作物而言，这种授粉方式至关重要。","Image":{"Url":"/th?id=OHR.BumbleBee_ZH-CN6429376340_1920x1080.webp","Wallpaper":"/th?id=OHR.BumbleBee_ZH-CN6429376340_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"喧闹从这里开始","Title":"熊蜂在授粉, 伍斯特, 英格兰","Copyright":"© SimonEastwood87/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"蜜蜂有五只眼睛——两只大的，以及三只位于头部中央的小眼睛。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260520_BumbleBee\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e8%9c%9c%e8%9c%82%e6%97%a5&form=hpcapt&filters=HpDate:\"20260519_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260520_BumbleBee"},"Ssd":"20260520","Name":"BumbleBee","Market":"ZH-CN","Hash":"6429376340","FullDateString":"2026 5月 20"},{"ImageContent":{"Description":"在西班牙巴利阿里群岛中马略卡岛（Mallorca）的最北端，福门托尔灯塔（Formentor Lighthouse）巍然屹立于福门托尔角（Cap de Formentor）的陡峭悬崖之上。这处地势开阔的海角常被称为“风之汇聚地”。这座灯塔始建于1863年，并于当年9月30日首次点亮，它高耸于地中海海面近700英尺之上；若要抵达此处，需沿着一条狭窄蜿蜒的盘山公路前行，全程约8英里，起点位于波连萨港（Port de Pollença）。脚下是色泽浅淡的石灰岩——这些岩石由远古海洋生物遗骸历经漫长岁月沉积而成，随后在地壳运动的抬升与风化侵蚀的雕琢下，演化为如今这般气势磅礴的峭壁、海蚀洞穴及天然拱门。正是这种崎岖险峻的地质地貌，造就了该地区那种苍凉壮阔的独特美感与遗世独立的孤寂氛围。想要将这绝美景色尽收眼底吗？不妨沿着半岛上的徒步路线前行，或者挑战一段短促却陡峭的登高之路，攀至阿尔贝库奇瞭望塔（Talaia d'Albercutx）俯瞰全景，随后再继续前往灯塔。攀登途中请留意山坡：那些由早期家养羊群野化而来的野生山羊，正凭借着天生的平衡感，在险峻的岩架之间轻盈自如地跳跃穿梭。","Image":{"Url":"/th?id=OHR.SpainLighthouse_ZH-CN6024263415_1920x1080.webp","Wallpaper":"/th?id=OHR.SpainLighthouse_ZH-CN6024263415_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"马略卡岛的边缘","Title":"福门托尔灯塔, 马略卡, 巴利阿里群岛, 西班牙","Copyright":"© Allard Schager/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"它是巴利阿里群岛最高的灯塔，焦面高度位于海平面上方210米（690英尺），坐落于福门托尔角（Cap de Formentor）尖端的高耸悬崖之上。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260519_SpainLighthouse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e7%8f%ad%e7%89%99%e7%a6%8f%e9%97%a8%e6%89%98%e5%b0%94%e7%81%af%e5%a1%94&form=hpcapt&filters=HpDate:\"20260518_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260519_SpainLighthouse"},"Ssd":"20260519","Name":"SpainLighthouse","Market":"ZH-CN","Hash":"6024263415","FullDateString":"2026 5月 19"},{"ImageContent":{"Description":"当你步入博物馆，时光仿佛瞬间流转。一枚化石，诉说着数百万年前生命的印迹；一颗宝石，映照着肉眼难见的沧海桑田。正是这种深切的联结感，构成了“国际博物馆日”——这一由国际博物馆协会于1977年创立的节日——所旨在颂扬的核心精神。","Image":{"Url":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1080.webp","Wallpaper":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"大厅里的希望","Title":"伦敦自然历史博物馆, 英格兰","Copyright":"© Colm Keating/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"国际博物馆日（IMD）是由国际博物馆协会（ICOM）协调举办的国际性节日，于每年5月18日或前后举行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260518_MuseumLondon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e5%8d%9a%e7%89%a9%e9%a6%86%e6%97%a5&form=hpcapt&filters=HpDate:\"20260517_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260518_MuseumLondon"},"Ssd":"20260518","Name":"MuseumLondon","Market":"ZH-CN","Hash":"5602977820","FullDateString":"2026 5月 18"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"获取新版必应壁纸应用","LOC_BING_APP_TEXT":"在设备上获取必应壁纸","LOC_BING_APP_LINK_PC":"https://bing.microsof