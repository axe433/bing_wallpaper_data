{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/dYBhaTrEIEJQFZlJOP9faCdiXGc.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/3n1j3KN9PNLzWz-thbLaWuR5CMU.css?bu=COIB5QGRAp4ClAKUApQC2wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/7W/cir3,cc,nc/nEx341EseUAKfcxjSWaFs2yBrAI.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/qvfyWPiO69T4YxyZ8tmqL9ZhxWg.css?bu=CKEDlAKUAtUCrwKUApQClAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2A/5U/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AugCjgM&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/5U/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-04-13T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"海葵看起来像水下花朵，但实际上是动物——与水母和珊瑚是近亲。它们附着在岩石或珊瑚礁上，利用黏性基部和顶端挥动的触手（触手上长有细小的刺细胞）来捕获过往的猎物。这些刺细胞能麻痹小型鱼类，但有一种著名的“邻居”却对此免疫。","Image":{"Url":"/th?id=OHR.OcellarisClownfish_ZH-CN9362948727_1920x1080.webp","Wallpaper":"/th?id=OHR.OcellarisClownfish_ZH-CN9362948727_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"珊瑚礁邻居","Title":"海葵中的普通小丑鱼, 拉贾安帕特群岛, 印度尼西亚","Copyright":"© Magnus Lundgren/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"海葵是珊瑚和水母的近亲，是一种带刺的水螅体动物。它们大部分时间都附着在海底的岩石上或珊瑚礁上，等待鱼儿游近，然后用充满毒液的触手将其缠住。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260414_OcellarisClownfish\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b5%b7%e8%91%b5&form=hpcapt&filters=HpDate:\"20260413_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260414_OcellarisClownfish"},"Ssd":"20260414","Name":"OcellarisClownfish","Market":"ZH-CN","Hash":"9362948727","FullDateString":"2026 4月 14"},{"ImageContent":{"Description":"当夜幕降临，宇宙便开始上演一场壮丽的“光影秀”。每年四月举行的国际暗夜周，邀请人们重新发现夜晚的魅力，并了解为什么黑暗同样值得被保护。这项活动始于2003年，旨在提醒公众关注过度的人造光照对野生动物、人类健康、能源消耗以及我们观测星空能力所带来的影响。减少不必要的灯光并不意味着降低安全性——通过科学、合理的照明设计，完全可以在保证安全的同时减少光污染。","Image":{"Url":"/th?id=OHR.BorregoStars_ZH-CN8915519147_1920x1080.webp","Wallpaper":"/th?id=OHR.BorregoStars_ZH-CN8915519147_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"当灯光熄灭之后","Title":"安扎-博雷戈沙漠州立公园上空的银河, 加利福尼亚州, 美国","Copyright":"© Kevin Key/Slworking)/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"暗夜不仅让人们看到更多星星，也有助于天文学家观测微弱天体。减少光污染还能保护自然夜间环境的正常节律，让人类与自然都能共享真实而纯净的星空。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260413_BorregoStars\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%93%b6%e6%b2%b3&form=hpcapt&filters=HpDate:\"20260412_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260413_BorregoStars"},"Ssd":"20260413","Name":"BorregoStars","Market":"ZH-CN","Hash":"8915519147","FullDateString":"2026 4月 13"},{"ImageContent":{"Description":"今天，世界纪念国际载人航天日，这是联合国设立的纪念日，旨在纪念人类首次进入太空的旅程以及人类太空时代的开始。这个日期回忆起1961年4月12日，尤里·加加林绕地球飞行，证明人类可以离开地球并安全返回。","Image":{"Url":"/th?id=OHR.SpaceTrails_ZH-CN8377463217_1920x1080.webp","Wallpaper":"/th?id=OHR.SpaceTrails_ZH-CN8377463217_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"离开地球的第一步","Title":"城市灯光在下方划过, 拍摄于国际空间站","Copyright":"© NASA","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"联合国在2011年设立了国际人类航天日，距首次有人类航天飞行已有50年。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260412_SpaceTrails\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e4%ba%ba%e7%b1%bb%e8%88%aa%e5%a4%a9%e6%97%a5&form=hpcapt&filters=HpDate:\"20260411_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260412_SpaceTrails"},"Ssd":"20260412","Name":"SpaceTrails","Market":"ZH-CN","Hash":"8377463217","FullDateString":"2026 4月 12"},{"ImageContent":{"Description":"由火焰孕育而成的海滩很少能如此低调，而帕帕加约海滩正好做到了这一点。我们今天看到的海岸线位于西班牙加那利群岛兰萨罗特岛的南端。热带幻想？更像是火山般的精准。数百万年前，这片土地在海底火山喷发的推动下，逐层由玄武岩和火山灰堆积升起。","Image":{"Url":"/th?id=OHR.PlayaPapagayo_ZH-CN7708804019_1920x1080.webp","Wallpaper":"/th?id=OHR.PlayaPapagayo_ZH-CN7708804019_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"火山外衣","Title":"帕帕加约海滩, 兰萨罗特, 加那利群岛, 西班牙","Copyright":"© Gavin Hellier/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这片海滩是一个新月形的海湾，四周环绕着岩石悬崖和茂密的植被。沙子柔软而金黄，水清澈平静，非常适合游泳、浮潜和日光浴。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260411_PlayaPapagayo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e7%8f%ad%e7%89%99%e5%8a%a0%e9%82%a3%e5%88%a9%e7%be%a4%e5%b2%9b%e5%85%b0%e8%90%a8%e7%bd%97%e7%89%b9%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260410_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260411_PlayaPapagayo"},"Ssd":"20260411","Name":"PlayaPapagayo","Market":"ZH-CN","Hash":"7708804019","FullDateString":"2026 4月 11"},{"ImageContent":{"Description":"你有没有抓到过兄弟姐妹们密谋的场景？在爱沙尼亚的卡鲁拉国家公园，这两只红狐狸幼崽看起来像是在阴谋进行到一半时突然停住了，它们的表情中既有好奇也有谨慎。它们不仅仅是春天的毛茸茸小动物；它们是生存的学徒。红狐狸每胎平均生四到六只幼崽，它们成长迅速，地下洞穴成为它们的摔跤场、教室和试验场。年长的幼崽常常帮助喂养、看护并教导年幼的同伴，把游戏变成练习，把恶作剧变成肌肉记忆。在它们的家庭中，兄弟姐妹不仅是背景，更是后盾。","Image":{"Url":"/th?id=OHR.FoxSiblings_ZH-CN8133856518_1920x1080.webp","Wallpaper":"/th?id=OHR.FoxSiblings_ZH-CN8133856518_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"算计的小爪子","Title":"卡鲁拉国家公园的两只幼年赤狐, 爱沙尼亚","Copyright":"© Sven Zacek/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"卡鲁拉国家公园是该国最小的国家公园，但仍然是最迷人的之一。公园位于瓦尔加县和沃鲁县，其起伏的丘陵、原始的湖泊和宁静的森林使其成为自然爱好者和寻求宁静者的圣地。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260410_FoxSiblings\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b9%bc%e5%b9%b4%e8%b5%a4%e7%8b%90&form=hpcapt&filters=HpDate:\"20260409_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260410_FoxSiblings"},"Ssd":"20260410","Name":"FoxSiblings","Market":"ZH-CN","Hash":"8133856518","FullDateString":"2026 4月 10"},{"ImageContent":{"Description":"清澈的水流沿着岩壁整齐地倾泻而下，形成了这座瀑布，这是威尔士南部最具特色的瀑布之一。它的威尔士语名称意为“雪落瀑布”，形容水流像一层淡白色的水帘从岩壁上滑落。这座瀑布的独特之处在于可以从瀑布后方穿行。一条狭窄的小径将游客引到水帘背后，让人近距离感受水声、光线与水雾交织的自然景象。","Image":{"Url":"/th?id=OHR.WalesWaterfall_ZH-CN3175091833_1920x1080.webp","Wallpaper":"/th?id=OHR.WalesWaterfall_ZH-CN3175091833_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"光之水帘","Title":"雪落瀑布，布雷肯比肯斯国家公园，威尔士","Copyright":"© Guy Edwardes/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"布雷肯比肯斯国家公园中的雪落瀑布位于一片以瀑布步道闻名的自然区域。瀑布周围的峡谷生长着苔藓、蕨类和古老森林，常年水汽弥漫，形成清凉湿润的生态环境，是徒步和自然摄影的理想地点。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260409_WalesWaterfall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b8%83%e9%9b%b7%e8%82%af%e6%af%94%e8%82%af%e6%96%af%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260408_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260409_WalesWaterfall"},"Ssd":"20260409","Name":"WalesWaterfall","Market":"ZH-CN","Hash":"3175091833","FullDateString":"2026 4月 9"},{"ImageContent":{"Description":"每年4月7日的国际河狸日，旨在致敬这位默默工作的“小工程师”。河狸凭借一根根树枝，悄然改变着自然环境。河狸长着标志性的门牙和桨状尾巴，以勤劳著称。数百万年来，它们一直在重塑淡水生态环境。河狸拥有呈橙色、富含铁质的坚硬门牙，可以轻松啃倒树木，并利用树枝和泥土建造水坝。这些水坝能够减缓水流、改善水质，并形成湿地，从而为多种动植物提供栖息地。它们还会用树枝和泥土搭建坚固的巢穴，入口通常位于水下，不仅能躲避捕食者，也为整个家族提供安全的居所。","Image":{"Url":"/th?id=OHR.SeattleSunrise_ZH-CN2884575647_1920x1080.webp","Wallpaper":"/th?id=OHR.SeattleSunrise_ZH-CN2884575647_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"翡翠之城","Title":"西雅图，华盛顿州，美国","Copyright":"© Jim Patterson/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"画面中的“建筑师”是河狸。河狸是著名的“自然工程师”，会用树枝、泥土和石块在河流或溪流中建造水坝和巢穴。这些结构不仅为它们提供栖息地，也会改变水流环境，为鱼类、两栖动物和湿地植物创造新的生态空间。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260408_SeattleSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e9%9b%85%e5%9b%be&form=hpcapt&filters=HpDate:\"20260407_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260408_SeattleSunrise"},"Ssd":"20260408","Name":"SeattleSunrise","Market":"ZH-CN","Hash":"2884575647","FullDateString":"2026 4月 8"}],"PreloadMediaContents":[{"ImageContent":{"Description":"春季降临，我们迎来了一位身披短刺的“生态使者”：西欧刺猬，本次发现于法国。这种体型微小的食虫类动物兼具独特的生物防御形态；它们多为夜行性且具有领域独居意识，主要依靠嗅觉与听觉导向。其生态位职责明确：通过在落叶层中游走、嗅探，大量捕食蚯蚓、甲虫、蛞蝓及鳞翅目幼虫等无脊椎动物——这些物种不仅是维持生态系统运转的关键环节，也是园艺害虫防治的天然助力。面对威胁时，西欧刺猬既不交涉也不逃逸，而是迅速蜷缩成紧密的球状，依靠背部的棘刺进行物理防御。","Image":{"Url":"/th?id=OHR.SpringHedgehog_ZH-CN5232922916_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringHedgehog_ZH-CN5232922916_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"春季的“带刺巡逻兵”","Title":"西欧刺猬，法国","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"西欧刺猬的背部覆有 5,000 至 7,000 根棘刺，这些刺是由角蛋白构成的坚硬中空毛发；需注意其与豪猪的刺（Quills）在结构上有所不同，并非如豪猪般具有倒钩且易脱落的‘防御性棘毛’。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260421_SpringHedgehog\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e6%ac%a7%e5%88%ba%e7%8c%ac&form=hpcapt&filters=HpDate:\"20260420_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260421_SpringHedgehog"},"Ssd":"20260421","Name":"SpringHedgehog","Market":"ZH-CN","Hash":"5232922916","FullDateString":"2026 4月 21"},{"ImageContent":{"Description":"国家公园周，是你暂别日常、走向自然的最佳契机。这一为期九天的庆祝活动将于4月18日至26日举行，聚焦国家公园体系中400多处自然与文化遗产地。在这里，自然风光与人文历史交织，为人们带来难忘的户外体验。从海岸线与森林，到辽阔的沙漠景观，这些受保护的区域邀请人们走进自然，感受宁静，心怀敬畏。","Image":{"Url":"/th?id=OHR.SunsetKiva_ZH-CN3978606378_1920x1080.webp","Wallpaper":"/th?id=OHR.SunsetKiva_ZH-CN3978606378_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"日落之后，探索仍在继续","Title":"夕阳下的峡谷地国家公园，莫阿布，犹他州，美国","Copyright":"© Jason Hatfield/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"你看到的银河，其实并不是“实时画面”。 在像峡谷地国家公园这样光污染极低的地方，人眼可以看到的银河中心区域，距离地球约2.6万光年——也就是说，你看到的是2.6万年前发出的光。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260420_SunsetKiva\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b3%a1%e8%b0%b7%e5%9c%b0%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260419_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260420_SunsetKiva"},"Ssd":"20260420","Name":"SunsetKiva","Market":"ZH-CN","Hash":"3978606378","FullDateString":"2026 4月 20"},{"ImageContent":{"Description":"从空中俯瞰，巴西的镜面海滩宛如一幅可以走入其中的水彩画。浅色的悬崖、点缀在海岸线上的礁石，以及由潮汐形成的片片水潭，在退潮时清晰映出天空与云朵，也正因如此，这片海滩得名“镜面海滩”。它位于巴西东北部大西洋沿岸的巴伊亚州，坐落在塞古罗港的几座小渔村之间。通往这里需要经过土路和短途步道，这种相对不便的交通反而成为一种“天然限流”，让海滩始终保持着宁静而私密的氛围。它位于巴西东北部大西洋沿岸的巴伊亚州，坐落在塞古罗港的几座小渔村之间。通往这里需要经过土路和短途步道，这种相对不便的交通反而成为一种“天然限流”，让海滩始终保持着宁静而私密的氛围。","Image":{"Url":"/th?id=OHR.TranBA_ZH-CN3467060262_1920x1080.webp","Wallpaper":"/th?id=OHR.TranBA_ZH-CN3467060262_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"潮汐留下的印记","Title":"镜面海滩，塞古罗港，巴伊亚州，巴西","Copyright":"© Marcelo Nacinovic/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在镜面海滩，能否看到清晰倒影其实取决于环境条件。当风力较小、潮位较低时，浅水水潭会像天然镜子一样平静；但只要出现轻微的水波，倒影就会立刻被“打破”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260419_TranBA\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b7%b4%e8%a5%bf%e5%b7%b4%e4%bc%8a%e4%ba%9a%e5%b7%9e&form=hpcapt&filters=HpDate:\"20260418_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260419_TranBA"},"Ssd":"20260419","Name":"TranBA","Market":"ZH-CN","Hash":"3467060262","FullDateString":"2026 4月 19"},{"ImageContent":{"Description":"在今天的世界遗产日，人们将目光投向那些讲述人类共同历史的地方——这些地点因其卓越的文化或自然价值而受到保护。其中之一，便矗立在智利复活节岛的火山岩之上。在拉诺拉拉库，一座已熄灭火山的山坡曾是岛上绝大多数著名摩艾石像的雕刻工坊。画面展现的正是这一非凡的采石场：半成品的巨像从岩石中显现，仿佛在创作的瞬间被定格。","Image":{"Url":"/th?id=OHR.MaoiStatues_ZH-CN3219447748_1920x1080.webp","Wallpaper":"/th?id=OHR.MaoiStatues_ZH-CN3219447748_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"未完成巨像的静默","Title":"摩艾石像采石场，拉诺拉拉库，复活节岛，智利","Copyright":"© Gavin Hellier/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在拉诺拉拉库，许多摩艾石像长期以来只露出头部，仿佛被埋藏于地下。考古发掘发现，这些石像其实拥有完整的身体，背部还刻有精细的岩画纹饰，为了解拉帕努伊人的艺术风格与文化传统提供了重要线索。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260418_MaoiStatues\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e9%81%97%e4%ba%a7%e6%97%a5&form=hpcapt&filters=HpDate:\"20260417_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260418_MaoiStatues"},"Ssd":"20260418","Name":"MaoiStatues","Market":"ZH-CN","Hash":"3219447748","FullDateString":"2026 4月 18"},{"ImageContent":{"Description":"每年4月17日是“国际蝙蝠日”，这一天将目光投向地球的“夜班成员”——蝙蝠。作为分布在除南极洲外各大洲的飞行哺乳动物，全球已知蝙蝠种类超过1400种，在维持生态系统平衡方面发挥着重要作用。蝙蝠已经在地球上生存了超过5000万年。在众多种类中，真正以血液为食的“吸血蝙蝠”只有3种，且仅分布于美洲地区。绝大多数蝙蝠则以昆虫、水果、花蜜或花粉为食。在美国德克萨斯州的布拉肯洞穴（Bracken Cave），夏季最多可聚集约 2000 万只墨西哥无尾蝠，形成壮观的群居景象。许多蝙蝠通过捕食农作物害虫，有助于减少农药使用；还有一些则为野生龙舌兰授粉、传播种子，帮助森林恢复与再生。","Image":{"Url":"/th?id=OHR.FlyingFoxMom_ZH-CN2913012516_1920x1080.webp","Wallpaper":"/th?id=OHR.FlyingFoxMom_ZH-CN2913012516_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"蝙蝠信号：开启","Title":"灰头狐蝠母亲携幼崽，雅拉湾国家公园，澳大利亚","Copyright":"© Doug Gimesy/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“蝙蝠侠”只是虚构的角色，而现实中的“蝙蝠信号”则是对保护的呼唤——由于栖息地丧失和疾病影响，蝙蝠种群正不断缩减。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260417_FlyingFoxMom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%9d%99%e8%9d%a0&form=hpcapt&filters=HpDate:\"20260416_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260417_FlyingFoxMom"},"Ssd":"20260417","Name":"FlyingFoxMom","Market":"ZH-CN","Hash":"2913012516","FullDateString":"2026 4月 17"},{"ImageContent":{"Description":"每年春天，华盛顿州的斯卡吉特山谷都会变成一片色彩斑斓的花海，斯卡吉特山谷郁金香节在此欢庆花季的到来。整个四月，游客们可以漫步于郁金香花园和农田，欣赏成排盛开的郁金香，远眺群山美景。","Image":{"Url":"/th?id=OHR.SkagitTulips_ZH-CN4234324174_1920x1080.webp","Wallpaper":"/th?id=OHR.SkagitTulips_ZH-CN4234324174_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"花瓣巡游","Title":"斯卡吉特谷地郁金香花田, 华盛顿, 美国","Copyright":"© Alan Majchrowicz/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"郁金香谷农场占地15 英亩，种植着130种花卉，其中包括100多种郁金香。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260416_SkagitTulips\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8d%8e%e7%9b%9b%e9%a1%bf%e5%b7%9e%e6%96%af%e5%8d%a1%e5%90%89%e7%89%b9%e8%b0%b7&form=hpcapt&filters=HpDate:\"20260415_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260416_SkagitTulips"},"Ssd":"20260416","Name":"SkagitTulips","Market":"ZH-CN","Hash":"4234324174","FullDateString":"2026 4月 16"},{"ImageContent":{"Description":"艺术无处不在。创造力和自我表达是人类身份认同的重要组成部分，塑造着我们的过去和未来。有些人毕生致力于艺术，而另一些人则是艺术家作品的受益者。4月15日的世界艺术日旨在庆祝艺术创作与社会之间这种永恒的联系，正是这种联系塑造了我们的文化。","Image":{"Url":"/th?id=OHR.VanGoghFields_ZH-CN3495668941_1920x1080.webp","Wallpaper":"/th?id=OHR.VanGoghFields_ZH-CN3495668941_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"走进这幅鲜活的画布","Title":"光之采石场的文森特·梵高展览, 莱博德普罗旺斯, 法国","Copyright":"© Patrick Aventurier/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"世界艺术日定于4月15日，是为了纪念列奥纳多·达·芬奇的诞辰，表彰他对艺术和人类创造力的深远影响。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260415_VanGoghFields\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e8%89%ba%e6%9c%af%e6%97%a5&form=hpcapt&filters=HpDate:\"20260414_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260415_VanGoghFields"},"Ssd":"20260415","Name":"VanGoghFields","Market":"ZH-CN","Hash":"3495668941","FullDateString":"2026 4月 15"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"获取新版必应壁纸应用","LOC_BING_APP_TEXT":"在设备上获取必应壁纸","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adju