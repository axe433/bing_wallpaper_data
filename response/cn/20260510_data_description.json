{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/1jwggUbciaBbnMp71qwwtiVynfY.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/Z3RsRJM-Pfsyj_3ZanZL12q73Gg.css?bu=CPIB9QGWAqUCmQKZApkC5AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/7q/cir3,cc,nc/nCKJ4cRUetcQaVXAHVEjHeKyRqY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/L4qNmLd64xEbbb2t5SMs3Mm55tY.css?bu=CJQDmQKZAt4CtQKZApkCmQI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2A/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvEC_wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-05-10T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"世界最伟大的自然奇观之一，绵延在澳大利亚东北海岸线外的珊瑚海碧绿海水中。大堡礁沿着昆士兰海岸延伸，是世界上最大的珊瑚礁系统。它由近3000个独立的珊瑚礁和数百个岛屿组成，绵延超过1400英里。","Image":{"Url":"/th?id=OHR.QueenslandReef_ZH-CN1138150002_1920x1080.webp","Wallpaper":"/th?id=OHR.QueenslandReef_ZH-CN1138150002_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"水下建筑","Title":"从上方俯瞰大堡礁, 昆士兰州, 澳大利亚","Copyright":"© Francesco Riccardo Iacomino/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"纬度和跨陆架多样性，加上水体深度的多样性，构成了全球独一无二的生态群落、栖息地和物种。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260511_QueenslandReef\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%be%b3%e5%a4%a7%e5%88%a9%e4%ba%9a%e5%a4%a7%e5%a0%a1%e7%a4%81&form=hpcapt&filters=HpDate:\"20260510_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260511_QueenslandReef"},"Ssd":"20260511","Name":"QueenslandReef","Market":"ZH-CN","Hash":"1138150002","FullDateString":"2026 5月 11"},{"ImageContent":{"Description":"在母亲节这一天，我们向所有塑造生命、展现耐心和守护的母亲们致敬。在野外，这些品质在生存最为艰难的地方往往显得尤为重要。今天这张照片拍摄于加拿大曼尼托巴省北部的瓦普斯克国家公园，展现了一只北极熊妈妈和她的幼崽在北极苔原上嬉戏玩耍的温馨时刻。","Image":{"Url":"/th?id=OHR.MotherCub_ZH-CN0999123163_1920x1080.webp","Wallpaper":"/th?id=OHR.MotherCub_ZH-CN0999123163_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一份经久不衰的羁绊","Title":"北极熊妈妈和幼崽在瓦普斯克国家公园玩耍, 马尼托巴省, 加拿大","Copyright":"© Hao Jiang/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"母亲节是为了庆祝家庭或个人的母亲，以及母爱、母子情谊和母亲在社会中的影响而设立的节日。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260510_MotherCub\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%af%8d%e4%ba%b2%e8%8a%82&form=hpcapt&filters=HpDate:\"20260509_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260510_MotherCub"},"Ssd":"20260510","Name":"MotherCub","Market":"ZH-CN","Hash":"0999123163","FullDateString":"2026 5月 10"},{"ImageContent":{"Description":"水是克罗地亚克尔卡国家公园的缔造者，它沿着克尔卡河塑造了碧绿的水潭和层叠的瀑布。今天的照片重点展示了公园最著名的瀑布群——斯克拉丁斯基布克瀑布，多条溪流从洛佐瓦茨村附近茂密森林中的石灰华梯田倾泻而下。","Image":{"Url":"/th?id=OHR.SkradinskiBuk_ZH-CN0882603359_1920x1080.webp","Wallpaper":"/th?id=OHR.SkradinskiBuk_ZH-CN0882603359_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"克尔卡的造物主","Title":"克尔卡国家公园的斯克拉丁斯基布克瀑布, 克罗地亚","Copyright":"© Amazing Aerial Agency/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"斯克拉丁斯基布克瀑布是克尔卡河上的第七座、也是最后一座、最长的石灰华堰，同时也是欧洲最长的石灰华堰。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260509_SkradinskiBuk\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%85%8b%e7%bd%97%e5%9c%b0%e4%ba%9a%e5%85%8b%e5%b0%94%e5%8d%a1%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260508_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260509_SkradinskiBuk"},"Ssd":"20260509","Name":"SkradinskiBuk","Market":"ZH-CN","Hash":"0882603359","FullDateString":"2026 5月 9"},{"ImageContent":{"Description":"世界驴日旨在庆祝人类最默默无闻却能力出众的伙伴之一——驴。数千年来，驴一直与人类并肩工作，它们以耐力、敏锐的记忆力和在崎岖地形上稳健的步伐而备受推崇。人们常常误以为它们固执，但实际上它们是谨慎的思考者——它们会停下来评估风险，而不是贸然行事。","Image":{"Url":"/th?id=OHR.SardinianDonkey_ZH-CN0758031524_1920x1080.webp","Wallpaper":"/th?id=OHR.SardinianDonkey_ZH-CN0758031524_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"不仅仅是一声咿呀学语","Title":"撒丁岛母驴和幼崽, 法国","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"骡子是公驴和母马杂交产生的后代。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260508_SardinianDonkey\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%a9%b4&form=hpcapt&filters=HpDate:\"20260507_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260508_SardinianDonkey"},"Ssd":"20260508","Name":"SardinianDonkey","Market":"ZH-CN","Hash":"0758031524","FullDateString":"2026 5月 8"},{"ImageContent":{"Description":"横跨美国西南部亚利桑那州索诺兰沙漠的科法国家野生动物保护区，是一片由峭壁山峰、开阔天空与顽强生命共同构成的独特荒野。","Image":{"Url":"/th?id=OHR.Kofa_ZH-CN0584573563_1920x1080.webp","Wallpaper":"/th?id=OHR.Kofa_ZH-CN0584573563_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"广袤铺展的沙漠","Title":"科法国家野生动物保护区，亚利桑那州，美国","Copyright":"© Denis Tangney Jr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"科法的棕榈峡谷庇护着亚利桑那州唯一的原生棕榈。这些史前残遗物种躲藏在深邃遮阴的岩缝中，在酷热的沙漠里利用阴凉的微气候繁衍至今。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260507_Kofa\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%a7%91%e6%b3%95%e5%9b%bd%e5%ae%b6%e9%87%8e%e7%94%9f%e5%8a%a8%e7%89%a9%e4%bf%9d%e6%8a%a4%e5%8c%ba&form=hpcapt&filters=HpDate:\"20260506_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260507_Kofa"},"Ssd":"20260507","Name":"Kofa","Market":"ZH-CN","Hash":"0584573563","FullDateString":"2026 5月 7"},{"ImageContent":{"Description":"在壮阔的天幕下，保加利亚的两大平原展现了国家的农业核心。多瑙河平原横跨北部，起伏的田野与河谷受温带大陆性气候影响，炎热的夏季常催生强烈的雷暴。再往南是上色雷斯平原，地势更低且更温暖，受大陆系统及从爱琴海地区涌入的地中海气流共同影响。在这里，酷暑与马里查河流域的水汽交织，使该地区极易发生剧烈的夏季风暴——正如此刻在图像中平原上空上演的景象。","Image":{"Url":"/th?id=OHR.BulgariaPlains_ZH-CN3853985252_1920x1080.webp","Wallpaper":"/th?id=OHR.BulgariaPlains_ZH-CN3853985252_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"承受压力之下的平原","Title":"平原上空的雷暴，保加利亚","Copyright":"© Revolu7ion93/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"保加利亚坐落在巴尔干半岛东部，地处欧亚交汇的十字路口。在这里，古老文明、肥沃景观与多变的气候交相感应。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260506_BulgariaPlains\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bf%9d%e5%8a%a0%e5%88%a9%e4%ba%9a&form=hpcapt&filters=HpDate:\"20260505_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260506_BulgariaPlains"},"Ssd":"20260506","Name":"BulgariaPlains","Market":"ZH-CN","Hash":"3853985252","FullDateString":"2026 5月 6"},{"ImageContent":{"Description":"立夏之日，春意虽未尽，夏木已成阴。这是中国时令中一个充满生命力的转折点：蝼蝈鸣，蚯蚓出，王瓜生。告别了春日的繁花绚烂，北方的天空愈发高远明净，南方的雨水则带来了润物无声的翠绿。此时风物，不在于热烈，而在于那份“清和”——万物至此皆长大，天地间流淌着一种舒展而轻盈的力量。","Image":{"Url":"/th?id=OHR.BeginningofSummerY26_ZH-CN7628545617_1920x1080.webp","Wallpaper":"/th?id=OHR.BeginningofSummerY26_ZH-CN7628545617_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"藕花风起，首夏清和","Title":"莲花与莲花植株","Copyright":"© real444/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“活化石”植物： 荷花是地球上最古老的双子叶植物之一，其种子的生命力极其顽强，埋藏在土层中千年的“古莲子”在适宜条件下仍能萌芽开花。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260505_BeginningofSummerY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e7%9a%84%e8%8d%b7%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260504_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260505_BeginningofSummerY26"},"Ssd":"20260505","Name":"BeginningofSummerY26","Market":"ZH-CN","Hash":"7628545617","FullDateString":"2026 5月 5"}],"PreloadMediaContents":[{"ImageContent":{"Description":"当你步入博物馆，时光仿佛瞬间流转。一枚化石，诉说着数百万年前生命的印迹；一颗宝石，映照着肉眼难见的沧海桑田。正是这种深切的联结感，构成了“国际博物馆日”——这一由国际博物馆协会于1977年创立的节日——所旨在颂扬的核心精神。","Image":{"Url":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1080.webp","Wallpaper":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"大厅里的希望","Title":"伦敦自然历史博物馆, 英格兰","Copyright":"© Colm Keating/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"国际博物馆日（IMD）是由国际博物馆协会（ICOM）协调举办的国际性节日，于每年5月18日或前后举行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260518_MuseumLondon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e5%8d%9a%e7%89%a9%e9%a6%86%e6%97%a5&form=hpcapt&filters=HpDate:\"20260517_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260518_MuseumLondon"},"Ssd":"20260518","Name":"MuseumLondon","Market":"ZH-CN","Hash":"5602977820","FullDateString":"2026 5月 18"},{"ImageContent":{"Description":"究竟要多高，才能尽享绝佳美景？在美国东部，其实无需太高的海拔。位于弗吉尼亚州仙纳度国家公园（Shenandoah National Park）内的玳瑁峰（Hawksbill Mountain），海拔仅为4050英尺；这充分表明，对于这些古老的山脉而言，开阔的视野远比绝对的高度更为重要。该公园成立于1935年，其建立过程伴随着大规模农耕与伐木活动之后的植被恢复工作。如今，昔日的土地大都已重披林装，孕育着混交阔叶林、山月桂以及杜鹃花等丰富的植被。此外还有什么值得一提？公园内的部分岩石距今已逾10亿年，堪称该州最为古老的岩层之一。这里栖息着200多种鸟类和32种鱼类；同时，公园对宠物也十分友好，允许游客携带爱犬进入露营地及大多数步道。","Image":{"Url":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1080.webp","Wallpaper":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"静谧之巅，喧嚣之景","Title":"仙纳度国家公园的玳瑁峰, 弗吉尼亚州, 美国","Copyright":"© John Baggaley/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"约850种野花铺满仙纳度国家公园，全年呈现出美丽而多样的景观。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260517_ShenandoahSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bb%99%e7%ba%b3%e5%ba%a6%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260516_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260517_ShenandoahSunset"},"Ssd":"20260517","Name":"ShenandoahSunset","Market":"ZH-CN","Hash":"4399136794","FullDateString":"2026 5月 17"},{"ImageContent":{"Description":"你会如何称呼这样一个地方：在这里，是岩石在“攀登”，而人类却得拼命追赶？欢迎来到位于俄勒冈州的史密斯岩州立公园（Smith Rock State Park）——在这里，峭壁拔地而起，而借口却消散得更快。公园坐落于长达26英里的“弯曲河破火山口”（Crooked River Caldera）之中，这一地貌正是由多次火山喷发塑造而成。这里的凝灰岩峭壁由受压冷却后的火山灰经压缩凝结而成。弯曲河（Crooked River）在此鬼斧神工般地雕刻出了峡谷，而像“尖塔”（The Spire）这样的岩层则巍然耸立，高度直逼700英尺。","Image":{"Url":"/th?id=OHR.SmithRockPark_ZH-CN4210144402_1920x1080.webp","Wallpaper":"/th?id=OHR.SmithRockPark_ZH-CN4210144402_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"跌到谷底？这里可不是。","Title":"史密斯岩州立公园, 俄勒冈州, 美国","Copyright":"© Alex Ratson/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"公园内外野生动物资源丰富。骡鹿和许多小型哺乳动物在公园里很常见。水獭和海狸则栖息在公园的克鲁克德河沿岸。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260516_SmithRockPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8f%b2%e5%af%86%e6%96%af%e5%b2%a9%e5%b7%9e%e7%ab%8b%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260515_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260516_SmithRockPark"},"Ssd":"20260516","Name":"SmithRockPark","Market":"ZH-CN","Hash":"4210144402","FullDateString":"2026 5月 16"},{"ImageContent":{"Description":"集智慧、力量与惊人的深潜本领于一身——抹香鲸绝不满足于浅层的生存。在这个“濒危物种日”，让我们一同认识这位胸怀大志、潜得更深的海洋巨兽。","Image":{"Url":"/th?id=OHR.EndangeredWhales_ZH-CN4053106967_1920x1080.webp","Wallpaper":"/th?id=OHR.EndangeredWhales_ZH-CN4053106967_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"鲸鱼，你会救我吗？","Title":"一群抹香鲸, 印度洋","Copyright":"© Tony Wu/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“Cachalot”一词常用于指代抹香鲸，源自一个古法语词汇，意为“大牙齿”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260515_EndangeredWhales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%8a%b9%e9%a6%99%e9%b2%b8&form=hpcapt&filters=HpDate:\"20260514_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260515_EndangeredWhales"},"Ssd":"20260515","Name":"EndangeredWhales","Market":"ZH-CN","Hash":"4053106967","FullDateString":"2026 5月 15"},{"ImageContent":{"Description":"皮蒂利亚诺坐落在意大利托斯卡纳南部的一处凝灰岩山脊上，是一座小巧却个性十足的城镇。它的历史可以追溯到伊特鲁里亚时代，蜿蜒的街道至今仍回荡着昔日的痕迹，从中世纪的防御工事到文艺复兴时期的宫殿，处处可见历史的印记。漫步在狭窄的巷弄中，仿佛能感受到几个世纪的生活印记镌刻在石头上，而小巧的广场则邀请您驻足，品尝咖啡或意式冰淇淋。这座经久不衰的宝藏常被誉为“小耶路撒冷”，因为它拥有历史悠久的犹太区，那里有一座犹太教堂和一座古老的墓地，诉说着曾经繁荣的犹太社区的故事。","Image":{"Url":"/th?id=OHR.Pitigliano_ZH-CN1509921892_1920x1080.webp","Wallpaper":"/th?id=OHR.Pitigliano_ZH-CN1509921892_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一场穿越时空的旅程","Title":"中世纪古镇皮蒂利亚诺, 托斯卡纳, 意大利","Copyright":"© bluejayphoto/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"皮蒂利亚诺最令人期待的活动之一是“九月神圣节”（SettembreDivino），它每年与丰收节同时举行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260514_Pitigliano\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%9a%ae%e8%92%82%e5%88%a9%e4%ba%9a%e8%af%ba&form=hpcapt&filters=HpDate:\"20260513_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260514_Pitigliano"},"Ssd":"20260514","Name":"Pitigliano","Market":"ZH-CN","Hash":"1509921892","FullDateString":"2026 5月 14"},{"ImageContent":{"Description":"在今天这张照片中，阿拉巴马山的花岗岩拱门将银河框入加州东部内华达山脉崎岖的地貌之中。这片区域以其圆润的巨石和风化的岩层而闻名，大约在1亿年前由火山活动形成。水和风逐渐将岩石塑造成如今光滑的形状。游客可以探索天然拱门，在岩石间徒步，拍摄独特的景观，骑马或骑山地自行车，并欣赏季节性的野花盛开。","Image":{"Url":"/th?id=OHR.AlabamaHills_ZH-CN1387018045_1920x1080.webp","Wallpaper":"/th?id=OHR.AlabamaHills_ZH-CN1387018045_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"银河系，摇滚吧！","Title":"拱门与银河, 阿拉巴马山, 内华达山脉, 加利福尼亚州, 美国","Copyright":"© Tim Fitzharris/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在这片干旱的土地上，翠绿的沙漠橄榄）、黄柳和芦苇竞相绽放。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260513_AlabamaHills\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%98%bf%e6%8b%89%e5%b7%b4%e9%a9%ac%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260512_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260513_AlabamaHills"},"Ssd":"20260513","Name":"AlabamaHills","Market":"ZH-CN","Hash":"1387018045","FullDateString":"2026 5月 13"},{"ImageContent":{"Description":"在北大西洋崎岖的海岸线上，大西洋海鹦栖息于洞穴和峭壁缝隙中。这些羽毛黑白相间、喙色艳丽的海鸟，由于过度捕捞和海洋环境变化导致猎物数量减少，被世界自然保护联盟（IUCN）列为易危物种。每年春天，它们都会返回此地繁殖，在精心挖掘的洞穴中产下一枚卵。作为游泳健将，它们在捕食鲱鱼和沙鳗等小型鱼类时，会利用翅膀在水下“飞行”。","Image":{"Url":"/th?id=OHR.Fratercula_ZH-CN1239275412_1920x1080.webp","Wallpaper":"/th?id=OHR.Fratercula_ZH-CN1239275412_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"振翅, 潜水, 生存","Title":"北极海鹦, 威尔士","Copyright":"© FLPA/Alamy","SocialGoo