{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/yGmczKojHJKduLqf4TGLfVXKBY4.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/Z3RsRJM-Pfsyj_3ZanZL12q73Gg.css?bu=CPUB-AGZAqgCnAKcApwC5AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2B/7q/cir3,cc,nc/OVhQdYvNy4P2Rc592GkE4q1a4ZY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/LnB2jfO0wyViNxCDNEQnRgUHG1A.css?bu=CJQDnAKcAt4CuAKcApwCnAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2B/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvEC_wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2B/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-05-23T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"龟类不仅是引人入胜的生物，更在自然界中扮演着至关重要的角色。海龟有助于维持海草床与珊瑚礁生态系统的健康，而淡水及陆栖龟类则支撑着各自生境的生态平衡。龟壳实际上是其骨架的一部分，由数十块骨头融合而成；此外，部分物种还能够利用地球磁场进行导航，精准地回到它们的出生地。","Image":{"Url":"/th?id=OHR.ThreeTurtlesButterflies_ZH-CN7043849571_1920x1080.webp","Wallpaper":"/th?id=OHR.ThreeTurtlesButterflies_ZH-CN7043849571_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"为龟类喝彩！","Title":"与蝴蝶在一起的乌龟","Copyright":"© Patrick Gallet/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"全球共有七种海龟，其中五种正面临灭绝威胁。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260523_ThreeTurtlesButterflies\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e4%b9%8c%e9%be%9f%e6%97%a5&form=hpcapt&filters=HpDate:\"20260522_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260523_ThreeTurtlesButterflies"},"Ssd":"20260523","Name":"ThreeTurtlesButterflies","Market":"ZH-CN","Hash":"7043849571","FullDateString":"2026 5月 23"},{"ImageContent":{"Description":"每年5月22日为“国际生物多样性日”，它向全球发出提醒：地球上的生命远比肉眼所见更加丰富，却也更加脆弱。这一由联合国设立的纪念日，旨在强调保护动植物及其生态系统为何对粮食安全、药物研发、气候稳定以及人类的日常福祉至关重要。","Image":{"Url":"/th?id=OHR.KauehiAtollLagoon_ZH-CN9552036080_1920x1080.webp","Wallpaper":"/th?id=OHR.KauehiAtollLagoon_ZH-CN9552036080_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"海洋生命的律动","Title":"埃希环礁，土阿莫土群岛，法属波利尼西亚","Copyright":"© WaterFrame_dpr/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"考埃希环礁拥有独特的“三通道”入海口连接泻湖，这种结构形成了强劲的潮汐流，能显著提高湖水含氧量，为珍稀生物提供了绝佳的生存环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260522_KauehiAtollLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e7%94%9f%e7%89%a9%e5%a4%9a%e6%a0%b7%e6%80%a7%e6%97%a5&form=hpcapt&filters=HpDate:\"20260521_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260522_KauehiAtollLagoon"},"Ssd":"20260522","Name":"KauehiAtollLagoon","Market":"ZH-CN","Hash":"9552036080","FullDateString":"2026 5月 22"},{"ImageContent":{"Description":"“国际茶日”旨在礼赞一种将日常习俗与古老地貌紧密相连的饮品。只需瞥一眼中国四川省那层层叠叠的梯田茶园，便不难领略其深植的文化根基。这片位于中国西南部的云雾缭绕之地，乃是茶文化的早期发源地之一；早在两千多年前，当地居民便已在此饮茶、植茶。在邻近的蒙顶山上，一位名叫吴理真的学者曾在汉朝时期开辟了世界上首批人工管理的茶园，从而为后世一代又一代的茶农奠定了坚实的基础。","Image":{"Url":"/th?id=OHR.SichuanTea_ZH-CN6703437873_1920x1080.webp","Wallpaper":"/th?id=OHR.SichuanTea_ZH-CN6703437873_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"酿造传承","Title":"四川省的茶梯田, 中国","Copyright":"© lzf/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"该节日于每年的5月21日庆祝，旨在认可茶叶数百年来的历史遗产，及其对全球健康、文化和农村生计所做出的显著贡献。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260521_SichuanTea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e8%8c%b6%e6%97%a5&form=hpcapt&filters=HpDate:\"20260520_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260521_SichuanTea"},"Ssd":"20260521","Name":"SichuanTea","Market":"ZH-CN","Hash":"6703437873","FullDateString":"2026 5月 21"},{"ImageContent":{"Description":"一声轻柔的嗡嗡声，伴随着细微的花粉飞扬，足以塑造我们食物的未来。每年5月20日是“世界蜜蜂日”，这一节日旨在礼赞像图中这只大黄蜂一样的授粉昆虫，致敬它们那看似悄无声息却至关重要的辛勤工作。与许多昆虫不同，大黄蜂采用一种独特的“振动授粉”方式——通过振动飞行肌，将花粉从花朵中抖落出来；对于番茄、辣椒和蓝莓等农作物而言，这种授粉方式至关重要。","Image":{"Url":"/th?id=OHR.BumbleBee_ZH-CN6429376340_1920x1080.webp","Wallpaper":"/th?id=OHR.BumbleBee_ZH-CN6429376340_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"喧闹从这里开始","Title":"熊蜂在授粉, 伍斯特, 英格兰","Copyright":"© SimonEastwood87/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"蜜蜂有五只眼睛——两只大的，以及三只位于头部中央的小眼睛。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260520_BumbleBee\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e8%9c%9c%e8%9c%82%e6%97%a5&form=hpcapt&filters=HpDate:\"20260519_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260520_BumbleBee"},"Ssd":"20260520","Name":"BumbleBee","Market":"ZH-CN","Hash":"6429376340","FullDateString":"2026 5月 20"},{"ImageContent":{"Description":"在西班牙巴利阿里群岛中马略卡岛（Mallorca）的最北端，福门托尔灯塔（Formentor Lighthouse）巍然屹立于福门托尔角（Cap de Formentor）的陡峭悬崖之上。这处地势开阔的海角常被称为“风之汇聚地”。这座灯塔始建于1863年，并于当年9月30日首次点亮，它高耸于地中海海面近700英尺之上；若要抵达此处，需沿着一条狭窄蜿蜒的盘山公路前行，全程约8英里，起点位于波连萨港（Port de Pollença）。脚下是色泽浅淡的石灰岩——这些岩石由远古海洋生物遗骸历经漫长岁月沉积而成，随后在地壳运动的抬升与风化侵蚀的雕琢下，演化为如今这般气势磅礴的峭壁、海蚀洞穴及天然拱门。正是这种崎岖险峻的地质地貌，造就了该地区那种苍凉壮阔的独特美感与遗世独立的孤寂氛围。想要将这绝美景色尽收眼底吗？不妨沿着半岛上的徒步路线前行，或者挑战一段短促却陡峭的登高之路，攀至阿尔贝库奇瞭望塔（Talaia d'Albercutx）俯瞰全景，随后再继续前往灯塔。攀登途中请留意山坡：那些由早期家养羊群野化而来的野生山羊，正凭借着天生的平衡感，在险峻的岩架之间轻盈自如地跳跃穿梭。","Image":{"Url":"/th?id=OHR.SpainLighthouse_ZH-CN6024263415_1920x1080.webp","Wallpaper":"/th?id=OHR.SpainLighthouse_ZH-CN6024263415_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"马略卡岛的边缘","Title":"福门托尔灯塔, 马略卡, 巴利阿里群岛, 西班牙","Copyright":"© Allard Schager/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"它是巴利阿里群岛最高的灯塔，焦面高度位于海平面上方210米（690英尺），坐落于福门托尔角（Cap de Formentor）尖端的高耸悬崖之上。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260519_SpainLighthouse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e7%8f%ad%e7%89%99%e7%a6%8f%e9%97%a8%e6%89%98%e5%b0%94%e7%81%af%e5%a1%94&form=hpcapt&filters=HpDate:\"20260518_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260519_SpainLighthouse"},"Ssd":"20260519","Name":"SpainLighthouse","Market":"ZH-CN","Hash":"6024263415","FullDateString":"2026 5月 19"},{"ImageContent":{"Description":"当你步入博物馆，时光仿佛瞬间流转。一枚化石，诉说着数百万年前生命的印迹；一颗宝石，映照着肉眼难见的沧海桑田。正是这种深切的联结感，构成了“国际博物馆日”——这一由国际博物馆协会于1977年创立的节日——所旨在颂扬的核心精神。","Image":{"Url":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1080.webp","Wallpaper":"/th?id=OHR.MuseumLondon_ZH-CN5602977820_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"大厅里的希望","Title":"伦敦自然历史博物馆, 英格兰","Copyright":"© Colm Keating/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"国际博物馆日（IMD）是由国际博物馆协会（ICOM）协调举办的国际性节日，于每年5月18日或前后举行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260518_MuseumLondon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e5%8d%9a%e7%89%a9%e9%a6%86%e6%97%a5&form=hpcapt&filters=HpDate:\"20260517_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260518_MuseumLondon"},"Ssd":"20260518","Name":"MuseumLondon","Market":"ZH-CN","Hash":"5602977820","FullDateString":"2026 5月 18"},{"ImageContent":{"Description":"究竟要多高，才能尽享绝佳美景？在美国东部，其实无需太高的海拔。位于弗吉尼亚州仙纳度国家公园（Shenandoah National Park）内的玳瑁峰（Hawksbill Mountain），海拔仅为4050英尺；这充分表明，对于这些古老的山脉而言，开阔的视野远比绝对的高度更为重要。该公园成立于1935年，其建立过程伴随着大规模农耕与伐木活动之后的植被恢复工作。如今，昔日的土地大都已重披林装，孕育着混交阔叶林、山月桂以及杜鹃花等丰富的植被。此外还有什么值得一提？公园内的部分岩石距今已逾10亿年，堪称该州最为古老的岩层之一。这里栖息着200多种鸟类和32种鱼类；同时，公园对宠物也十分友好，允许游客携带爱犬进入露营地及大多数步道。","Image":{"Url":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1080.webp","Wallpaper":"/th?id=OHR.ShenandoahSunset_ZH-CN4399136794_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"静谧之巅，喧嚣之景","Title":"仙纳度国家公园的玳瑁峰, 弗吉尼亚州, 美国","Copyright":"© John Baggaley/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"约850种野花铺满仙纳度国家公园，全年呈现出美丽而多样的景观。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260517_ShenandoahSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bb%99%e7%ba%b3%e5%ba%a6%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260516_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260517_ShenandoahSunset"},"Ssd":"20260517","Name":"ShenandoahSunset","Market":"ZH-CN","Hash":"4399136794","FullDateString":"2026 5月 17"}],"PreloadMediaContents":[{"ImageContent":{"Description":"平原斑马身上鲜明的黑白条纹并不只是装饰，它们能够干扰捕食者的视觉判断，让猎手难以锁定单独个体。每只斑马的纹路都独一无二，但当它们聚集行动时，交错的条纹会形成复杂的视觉迷阵，增加捕食难度。这种生存策略十分有效。如今，数十万只平原斑马分布于非洲各地，在埃托沙等自然保护区中依然维持着稳定数量。","Image":{"Url":"/th?id=OHR.EquusQuagga_ZH-CN9323988132_1920x1080.webp","Wallpaper":"/th?id=OHR.EquusQuagga_ZH-CN9323988132_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"读懂黑白之间","Title":"平原斑马幼崽，埃托沙国家公园，纳米比亚","Copyright":"© Sharon Heald/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"平原斑马幼崽幼崽刚出生时，身上的条纹通常呈棕白色，而不是成年斑马鲜明的黑白配色。随着成长，它们的条纹会逐渐加深，更适合融入非洲干燥草原的自然环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260530_EquusQuagga\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b9%b3%e5%8e%9f%e6%96%91%e9%a9%ac&form=hpcapt&filters=HpDate:\"20260529_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260530_EquusQuagga"},"Ssd":"20260530","Name":"EquusQuagga","Market":"ZH-CN","Hash":"9323988132","FullDateString":"2026 5月 30"},{"ImageContent":{"Description":"在尼泊尔的萨加玛塔国家公园，珠穆朗玛峰于暮色中巍然显现，平静而沉稳。1953年5月29日，这片宁静被历史性的一刻打破。经过数年的筹备与数周艰苦攀登，新西兰登山家埃德蒙·希拉里与夏尔巴登山家丹增·诺尔盖成功登顶珠穆朗玛峰。在海拔超过29000英尺（约8848米）的高度上，他们成为已知最早成功抵达人类所知地球最高点的人。","Image":{"Url":"/th?id=OHR.SummitEverest_ZH-CN9252833251_1920x1080.webp","Wallpaper":"/th?id=OHR.SummitEverest_ZH-CN9252833251_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"巅峰历史时刻","Title":"珠穆朗玛峰峰顶，萨加玛塔国家公园，尼泊尔","Copyright":"© fotoVoyager/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"珠穆朗玛峰所在的喜马拉雅山脉至今仍在缓慢抬升。由于印度板块与欧亚板块持续碰撞，珠峰的海拔每年都会发生微小变化，因此其官方高度也会随着新的测绘结果不断更新。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260529_SummitEverest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%ba%ba%e7%b1%bb%e9%a6%96%e6%ac%a1%e5%be%81%e6%9c%8d%e4%b8%96%e7%95%8c%e6%9c%80%e9%ab%98%e5%b3%b0&form=hpcapt&filters=HpDate:\"20260528_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260529_SummitEverest"},"Ssd":"20260529","Name":"SummitEverest","Market":"ZH-CN","Hash":"9252833251","FullDateString":"2026 5月 29"},{"ImageContent":{"Description":"当夜幕降临在韩国水原，这里所呈现的华城堡古城墙证明了一点：功能并不一定会削弱美感，反而可以孕育出美。华城建于1794年至1796年间，由朝鲜王朝的正祖下令修建，它不仅仅是一道防御屏障，更是一种“以石为策”的体现——一场以务实为导向、兼具深层个人动机的改革尝试，旨在打造一个更加精简、高效运作的国家。正祖修建华城，一方面是为了纪念他的父亲，另一方面也意在强化这个追求更智慧治理体系、而不仅仅依赖加厚城墙的王国。","Image":{"Url":"/th?id=OHR.HwaesongFortress_ZH-CN8225341972_1920x1080.webp","Wallpaper":"/th?id=OHR.HwaesongFortress_ZH-CN8225341972_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"设计与秩序相结合","Title":"华城堡的古城墙，水原，韩国","Copyright":"© aomam/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"韩国水原的华城堡通过隐蔽城门与弯曲城墙设计，在提升防御能力的同时，也与周围地形自然融合。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260528_HwaesongFortress\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9f%a9%e5%9b%bd%e6%b0%b4%e5%8e%9f%e7%9a%84%e5%8d%8e%e5%9f%8e%e5%a0%a1&form=hpcapt&filters=HpDate:\"20260527_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260528_HwaesongFortress"},"Ssd":"20260528","Name":"HwaesongFortress","Market":"ZH-CN","Hash":"8225341972","FullDateString":"2026 5月 28"},{"ImageContent":{"Description":"在世界水獭日这一天，不妨看看这只在美国阿拉斯加卡奇马克湾水域中畅游的小可爱！水獭是极具魅力的动物，在维持生态系统健康方面发挥着关键作用。在水獭专家组（OSG）的支持下——这一致力于保护全部14种水獭的全球专业网络——这一纪念日强调了水獭对自然环境的重要贡献。它们以活泼的行为和出色的智慧著称，也是水域健康的重要指示物种。然而，随着栖息地减少和污染加剧，水獭正面临日益严峻的生存挑战。","Image":{"Url":"/th?id=OHR.OtterDay_ZH-CN7735013625_1920x1080.webp","Wallpaper":"/th?id=OHR.OtterDay_ZH-CN7735013625_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"它们“獭”独一无二","Title":"海獭，霍默卡奇马克湾，阿拉斯加州，美国","Copyright":"© roclwyr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"世界水獭日在每年5月的最后一个星期三举行，旨在提升全球对水獭保护的关注。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260527_OtterDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b0%b4%e7%8d%ad%e6%97%a5&form=hpcapt&filters=HpDate:\"20260526_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260527_OtterDay"},"Ssd":"20260527","Name":"OtterDay","Market":"ZH-CN","Hash":"7735013625","FullDateString":"2026 5月 27"},{"ImageContent":{"Description":"随着春季席卷北加利福尼亚州，大地在蓝色、紫色与白色交织的羽扇豆花海中焕然一新。这些野生物种在当地的地中海气候下生长繁茂，为蜜蜂、蝴蝶及甲虫等授粉媒介提供了至关重要的花蜜来源。羽扇豆在全球拥有200多个物种，其分布极其广泛，涵盖了从沿海地带到高山草甸的多种生境。除了显著的观赏价值外，羽扇豆在生态系统中亦发挥着关键作用：通过地下的固氮作用，它们能够显著提高土壤肥力，即便是在贫瘠的环境中也能支持周边植物的生长。","Image":{"Url":"/th?id=OHR.LupineBloom_ZH-CN7639721663_1920x1080.webp","Wallpaper":"/th?id=OHR.LupineBloom_ZH-CN7639721663_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"羽扇豆书写的季节","Title":"盛开的羽扇豆，北加利福尼亚州，美国","Copyright":"© Jeffrey Lewis/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“羽扇豆（Lupine）”之名源自拉丁语“Lupus”，意为“狼”。过去人们曾错误地认为，这种植物会像狼一样“吞噬”或损耗土壤中的养分。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260526_LupineBloom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%be%bd%e6%89%87%e8%b1%86&form=hpcapt&filters=HpDate:\"20260525_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260526_LupineBloom"},"Ssd":"20260526","Name":"LupineBloom","Market":"ZH-CN","Hash":"7639721663","FullDateString":"2026 5月 26"},{"ImageContent":{"Description":"如果建筑能够“呼吸”，那会是怎样一番景象？坐落于斋浦尔市中心的风之宫（Hawa Mahal）便实现了这一点——它吸纳清风、排出热气，将建筑设计转化为一场静谧的科学实验。与其说它是一座宫殿，倒不如说是一次精准的“吐故纳新”。它确实名副其实：一座实至名归的“风之宫殿”。","Image":{"Url":"/th?id=OHR.HawaMahal2026_ZH-CN7233246545_1920x1080.webp","Wallpaper":"/th?id=OHR.HawaMahal2026_ZH-CN7233246545_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"石间的清风","Title":"从风之宫殿俯瞰斋浦尔市景，拉贾斯坦邦，印度","Copyright":"© byheaven/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"风之宫是世界上最高的一座没有传统地基的建筑；尽管结构轻薄且呈弧形，它仅依靠科学的物理配重和金字塔形状便在地面上稳立了两个多世纪。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260525_HawaMahal2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%a3%8e%e4%b9%8b%e5%ae%ab&form=hpcapt&filters=HpDate:\"20260524_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260525_HawaMahal2026"},"Ssd":"20260525","Name":"HawaMahal2026","Market":"ZH-CN","Hash":"7233246545","FullDateString":"2026 5月 25"},{"ImageContent":{"Description":"“欧洲公园日”旨在庆祝欧洲大陆上的自然保护区，并纪念1909年欧洲首批国家公园的诞生。这一节日提醒着世人：现今诸多最具代表性的自然景观，皆得益于长期的生态保育努力。今日的影像向我们展示了这一文化遗产的典范——位于意大利北部的三峰自然公园。","Image":{"Url":"/th?id=OHR.DolomitesPark_ZH-CN7134423478_1920x1080.webp","Wallpaper":"/th?id=OHR.DolomitesPark_ZH-CN7134423478_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"守护欧洲的自然净土","Title":"三峰自然公园，南蒂罗尔，意大利","Copyright":"© Adisorn Fineday Chutikunakorn/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"尽管这里以卓越的地质特征闻名，但它也承载着黑暗的历史。第一次世界大战期间，这片崎岖的景观曾是意大利和奥匈帝国军队展开残酷壕沟战的最前线，双方士兵曾在皑皑峰峦间忍受战火与雪崩的双重考验。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260524_DolomitesPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%84%8f%e5%a4%a7%e5%88%a9%e4%b8%89%e5%b3%b0%e8%87%aa%e7%84%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260523_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260524_DolomitesPark"},"Ssd":"20260524","Name":"DolomitesPark","Market":"ZH-CN","Hash":"7134423478","FullDateString":"2026 5月 24"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.m