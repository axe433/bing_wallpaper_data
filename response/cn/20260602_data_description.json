{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/HIczNNNhyj9WcIfqTM5nQ-y5ZFA.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/kiAvf1MfH3VyL_uWmI1ajs_O8Tc.css?bu=CPUB-AGZAqgCnAKcApwC5AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7q/cir3,cc,nc/OVhQdYvNy4P2Rc592GkE4q1a4ZY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/xfWfIezn50p0S9yAcx-nPPgS1R0.css?bu=CJQDnAKcAt4CuAKcApwCnAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvEC_wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":false,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-02T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"在青藏高原北缘、中国西部的荒漠之中，西台吉乃尔湖以一种超现实的姿态横跨在偏远的柴达木盆地。315国道的一段延伸线直接纵贯其浅水区，营造出一种公路悬浮于两个世界之间的视觉错觉。受卤水中矿物质浓度差异的影响，湖水呈现出鲜明的对比：一侧常显深邃的蓝色，另一侧则呈现柔和的绿色。","Image":{"Url":"/th?id=OHR.Qinghai_ZH-CN9899656327_1920x1080.webp","Wallpaper":"/th?id=OHR.Qinghai_ZH-CN9899656327_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"穿行于蓝色之间","Title":"穿越西台吉乃尔湖的公路，青海省，中国","Copyright":"© Kaicheng Xu/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这种独特的“双色湖”现象源于公路的阻隔作用。虽然湖水两侧均富含锂、铜、镁等矿物元素，但由于两侧的蒸发速率与水深各异，导致其对光的吸收与折射产生了明显的物理差异。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260602_Qinghai\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e6%9f%b4%e8%be%be%e6%9c%a8%e7%9b%86%e5%9c%b0&form=hpcapt&filters=HpDate:\"20260601_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260602_Qinghai"},"Ssd":"20260602","Name":"Qinghai","Market":"ZH-CN","Hash":"9899656327","FullDateString":"2026 6月 2"},{"ImageContent":{"Description":"巴勒莫（Palermo）坐落于意大利南部，是西西里岛的首府。这是一座历史、艺术与文化交织的城市，呈现出一种生动且带有几分繁杂之美的和谐。它由腓尼基人始建，后历经罗马人、阿拉伯人、诺曼人及西班牙人的雕琢，承载了地中海沿岸诸多文明迁移的印记。这种厚重的历史底蕴在建筑中清晰可见：从被联合国教科文组织（UNESCO）列入名录的阿拉伯-诺曼式宫殿与教堂，到勾勒出历史街区轮廓的巴洛克式立面，无不昭示着往昔的辉煌。","Image":{"Url":"/th?id=OHR.OlivaPalermo_ZH-CN9639920195_1920x1080.webp","Wallpaper":"/th?id=OHR.OlivaPalermo_ZH-CN9639920195_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"历史的况味","Title":"巴勒莫暮色下的天际线，西西里岛，意大利","Copyright":"© Sean Pavone/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"您知道吗？巴勒莫的马西莫剧院（Teatro Massimo）是意大利最大的歌剧院。它以近乎完美的音效闻名于世，同时也是电影《教父3》那段震撼人心的结尾戏的取景地。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260601_OlivaPalermo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%84%8f%e5%a4%a7%e5%88%a9%e5%b7%b4%e5%8b%92%e8%8e%ab&form=hpcapt&filters=HpDate:\"20260531_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260601_OlivaPalermo"},"Ssd":"20260601","Name":"OlivaPalermo","Market":"ZH-CN","Hash":"9639920195","FullDateString":"2026 6月 1"},{"ImageContent":{"Description":"今天是美国湿地月的最后一天，但对湿地生态的关注并不应随之结束。每年 5 月举行的这一全国性活动，旨在让更多人了解湿地这一美国最具生产力的重要生态系统之一。而位于佛罗里达州的大沼泽地国家公园，正是展现湿地力量的典型代表。从空中俯瞰，浅水、锯齿草、红树林与蜿蜒水道共同构成广阔景观，淡水从奥基乔比湖缓缓向南流动，塑造出独特生态环境。","Image":{"Url":"/th?id=OHR.EvergladesWetlands_ZH-CN9515366484_1920x1080.webp","Wallpaper":"/th?id=OHR.EvergladesWetlands_ZH-CN9515366484_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"顺流而行","Title":"大沼泽地国家公园航拍景观，佛罗里达州，美国","Copyright":"© Tetra Images/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"大沼泽地国家公园是地球上少数同时栖息着短吻鳄与鳄鱼的地区之一。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260531_EvergladesWetlands\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a7%e6%b2%bc%e6%b3%bd%e5%9c%b0%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260530_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260531_EvergladesWetlands"},"Ssd":"20260531","Name":"EvergladesWetlands","Market":"ZH-CN","Hash":"9515366484","FullDateString":"2026 5月 31"},{"ImageContent":{"Description":"平原斑马身上鲜明的黑白条纹并不只是装饰，它们能够干扰捕食者的视觉判断，让猎手难以锁定单独个体。每只斑马的纹路都独一无二，但当它们聚集行动时，交错的条纹会形成复杂的视觉迷阵，增加捕食难度。这种生存策略十分有效。如今，数十万只平原斑马分布于非洲各地，在埃托沙等自然保护区中依然维持着稳定数量。","Image":{"Url":"/th?id=OHR.EquusQuagga_ZH-CN9323988132_1920x1080.webp","Wallpaper":"/th?id=OHR.EquusQuagga_ZH-CN9323988132_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"读懂黑白之间","Title":"平原斑马幼崽，埃托沙国家公园，纳米比亚","Copyright":"© Sharon Heald/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"平原斑马幼崽幼崽刚出生时，身上的条纹通常呈棕白色，而不是成年斑马鲜明的黑白配色。随着成长，它们的条纹会逐渐加深，更适合融入非洲干燥草原的自然环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260530_EquusQuagga\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b9%b3%e5%8e%9f%e6%96%91%e9%a9%ac&form=hpcapt&filters=HpDate:\"20260529_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260530_EquusQuagga"},"Ssd":"20260530","Name":"EquusQuagga","Market":"ZH-CN","Hash":"9323988132","FullDateString":"2026 5月 30"},{"ImageContent":{"Description":"在尼泊尔的萨加玛塔国家公园，珠穆朗玛峰于暮色中巍然显现，平静而沉稳。1953年5月29日，这片宁静被历史性的一刻打破。经过数年的筹备与数周艰苦攀登，新西兰登山家埃德蒙·希拉里与夏尔巴登山家丹增·诺尔盖成功登顶珠穆朗玛峰。在海拔超过29000英尺（约8848米）的高度上，他们成为已知最早成功抵达人类所知地球最高点的人。","Image":{"Url":"/th?id=OHR.SummitEverest_ZH-CN9252833251_1920x1080.webp","Wallpaper":"/th?id=OHR.SummitEverest_ZH-CN9252833251_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"巅峰历史时刻","Title":"珠穆朗玛峰峰顶，萨加玛塔国家公园，尼泊尔","Copyright":"© fotoVoyager/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"珠穆朗玛峰所在的喜马拉雅山脉至今仍在缓慢抬升。由于印度板块与欧亚板块持续碰撞，珠峰的海拔每年都会发生微小变化，因此其官方高度也会随着新的测绘结果不断更新。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260529_SummitEverest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%ba%ba%e7%b1%bb%e9%a6%96%e6%ac%a1%e5%be%81%e6%9c%8d%e4%b8%96%e7%95%8c%e6%9c%80%e9%ab%98%e5%b3%b0&form=hpcapt&filters=HpDate:\"20260528_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260529_SummitEverest"},"Ssd":"20260529","Name":"SummitEverest","Market":"ZH-CN","Hash":"9252833251","FullDateString":"2026 5月 29"},{"ImageContent":{"Description":"当夜幕降临在韩国水原，这里所呈现的华城堡古城墙证明了一点：功能并不一定会削弱美感，反而可以孕育出美。华城建于1794年至1796年间，由朝鲜王朝的正祖下令修建，它不仅仅是一道防御屏障，更是一种“以石为策”的体现——一场以务实为导向、兼具深层个人动机的改革尝试，旨在打造一个更加精简、高效运作的国家。正祖修建华城，一方面是为了纪念他的父亲，另一方面也意在强化这个追求更智慧治理体系、而不仅仅依赖加厚城墙的王国。","Image":{"Url":"/th?id=OHR.HwaesongFortress_ZH-CN8225341972_1920x1080.webp","Wallpaper":"/th?id=OHR.HwaesongFortress_ZH-CN8225341972_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"设计与秩序相结合","Title":"华城堡的古城墙，水原，韩国","Copyright":"© aomam/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"韩国水原的华城堡通过隐蔽城门与弯曲城墙设计，在提升防御能力的同时，也与周围地形自然融合。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260528_HwaesongFortress\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9f%a9%e5%9b%bd%e6%b0%b4%e5%8e%9f%e7%9a%84%e5%8d%8e%e5%9f%8e%e5%a0%a1&form=hpcapt&filters=HpDate:\"20260527_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260528_HwaesongFortress"},"Ssd":"20260528","Name":"HwaesongFortress","Market":"ZH-CN","Hash":"8225341972","FullDateString":"2026 5月 28"},{"ImageContent":{"Description":"在世界水獭日这一天，不妨看看这只在美国阿拉斯加卡奇马克湾水域中畅游的小可爱！水獭是极具魅力的动物，在维持生态系统健康方面发挥着关键作用。在水獭专家组（OSG）的支持下——这一致力于保护全部14种水獭的全球专业网络——这一纪念日强调了水獭对自然环境的重要贡献。它们以活泼的行为和出色的智慧著称，也是水域健康的重要指示物种。然而，随着栖息地减少和污染加剧，水獭正面临日益严峻的生存挑战。","Image":{"Url":"/th?id=OHR.OtterDay_ZH-CN7735013625_1920x1080.webp","Wallpaper":"/th?id=OHR.OtterDay_ZH-CN7735013625_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"它们“獭”独一无二","Title":"海獭，霍默卡奇马克湾，阿拉斯加州，美国","Copyright":"© roclwyr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"世界水獭日在每年5月的最后一个星期三举行，旨在提升全球对水獭保护的关注。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260527_OtterDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b0%b4%e7%8d%ad%e6%97%a5&form=hpcapt&filters=HpDate:\"20260526_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260527_OtterDay"},"Ssd":"20260527","Name":"OtterDay","Market":"ZH-CN","Hash":"7735013625","FullDateString":"2026 5月 27"}],"PreloadMediaContents":[{"ImageContent":{"Description":"韦尔纳扎是意大利利古里亚大区五渔村的一个海滨小镇。它围绕着该地区唯一的天然港口而建，自古以来就与大海紧密相连。韦尔纳扎最早的文字记载可追溯到1080年，当时它是一个设防的定居点和海上基地，后来成为热那亚共和国海岸防御体系的一部分。时至今日，小镇依然保留着昔日的风貌，多利亚城堡的遗址和俯瞰海湾的瞭望塔诉说着它的历史。在水边，矗立着圣玛格丽塔·安提阿教堂，这座教堂最早的文字记载可追溯到1318年，并在之后的几个世纪中不断扩建，如今教堂的钟楼俯瞰着港口。房屋和狭窄的街道上方，陡峭的梯田上种植着葡萄园和橄榄树，这些梯田是由一代又一代的工匠用石头精心雕琢而成，构成了五渔村国家公园的景观，而五渔村国家公园本身也是联合国教科文组织世界遗产的一部分。想象一下这里的餐前小酌：一杯当地白葡萄酒，港口景色尽收眼底，还有利古里亚的特色美食，如佛卡夏面包和罗勒香蒜酱——简直就是一张可以品尝的明信片。","Image":{"Url":"/th?id=OHR.CTNPVernazza_ZH-CN3971102271_1920x1080.webp","Wallpaper":"/th?id=OHR.CTNPVernazza_ZH-CN3971102271_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"品尝日落","Title":"韦尔纳扎, 五渔村, 利古里亚, 意大利","Copyright":"© Kelly Cheng/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"韦尔纳扎港湾的日落被认为是意大利最常被拍摄的景观之一。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260609_CTNPVernazza\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%84%8f%e5%a4%a7%e5%88%a9%e9%9f%a6%e5%b0%94%e7%ba%b3%e6%89%8e%e4%ba%94%e6%b8%94%e6%9d%91&form=hpcapt&filters=HpDate:\"20260608_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260609_CTNPVernazza"},"Ssd":"20260609","Name":"CTNPVernazza","Market":"ZH-CN","Hash":"3971102271","FullDateString":"2026 6月 9"},{"ImageContent":{"Description":"今天是世界海洋日，让我们跟随这种随波逐流的生物的脚步吧！想看看狮鬃水母吗？那就去寒冷的北方海域寻找吧。它的伞状体分为八个瓣状结构，伞状体下方垂着长长的触手和口腕。随着水流漂移，它身上的刺细胞会捕获浮游生物和小鱼。对人类来说，被蜇一下会很疼。每个人的反应都不一样，即使是搁浅在海里的触手也可能造成疼痛。所以，记住一条简单的原则：欣赏它，然后就不要打扰它。北极水域的一些狮鬃水母伞状体直径超过6英尺（约1.8米），但大多数目击到的都是风暴或强流过后靠近海岸的小型个体。","Image":{"Url":"/th?id=OHR.Cyanea_ZH-CN3858079050_1920x1080.webp","Wallpaper":"/th?id=OHR.Cyanea_ZH-CN3858079050_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"随波逐流","Title":"在海洋中游动的狮鬃水母","Copyright":"© Alexander Semenov Images/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"虽然大部分是水，但狮鬃水母的长度可达 120 英尺——甚至超过了蓝鲸。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260608_Cyanea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b5%b7%e6%b4%8b%e6%97%a5&form=hpcapt&filters=HpDate:\"20260607_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260608_Cyanea"},"Ssd":"20260608","Name":"Cyanea","Market":"ZH-CN","Hash":"3858079050","FullDateString":"2026 6月 8"},{"ImageContent":{"Description":"在邓塞弗里克城堡，历史仿佛就悬挂在原地——确切地说，就悬挂在原地。残垣断壁依附在大西洋上方的玄武岩峭壁上，证明即使是废墟也能屹立不倒。两千年前，这里是爱尔兰五大道路之一——斯莱格·米德卢赫拉（Slige Midluachra）的终点，这条道路连接着通往塔拉山（Hill of Tara）王室的旅人。据说，公元5世纪，圣帕特里克曾到访此地，并为当地居民奥尔坎（Olcán）施洗。传说中，用于为爱尔兰国王加冕的“命运之石”（Lia Fáil）就是从这片海岸被带往苏格兰的。","Image":{"Url":"/th?id=OHR.DunseverickCastle2026_ZH-CN3036266326_1920x1080.webp","Wallpaper":"/th?id=OHR.DunseverickCastle2026_ZH-CN3036266326_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"最后一堵墙矗立着","Title":"邓塞弗里克城堡遗址, 安特里姆郡, 北爱尔兰","Copyright":"© Krzysztof Rogalski/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"邓塞弗里克城堡所依托的玄武岩地基在地质上与附近的巨人之路火山熔岩地貌相连。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260607_DunseverickCastle2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%82%93%e5%a1%9e%e5%bc%97%e9%87%8c%e5%85%8b%e5%9f%8e%e5%a0%a1++&form=hpcapt&filters=HpDate:\"20260606_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260607_DunseverickCastle2026"},"Ssd":"20260607","Name":"DunseverickCastle2026","Market":"ZH-CN","Hash":"3036266326","FullDateString":"2026 6月 7"},{"ImageContent":{"Description":"如果你最近沉迷于电子屏幕，今天正是改变的好时机——我们建议你去徒步旅行。","Image":{"Url":"/th?id=OHR.HikingNatchez_ZH-CN2495512699_1920x1080.webp","Wallpaper":"/th?id=OHR.HikingNatchez_ZH-CN2495512699_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"多走走，多思考","Title":"纳奇兹小径公园大道, 图珀洛, 密西西比州, 美国","Copyright":"© The best photo is earned/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"纳奇兹古道曾是商人将货物顺流运至新奥尔良后返回内陆的重要陆路通道。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260606_HikingNatchez\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%ba%b3%e5%a5%87%e5%85%b9%e5%b0%8f%e5%be%84%e6%97%a5%e5%87%ba%e6%ad%a5%e9%81%93&form=hpcapt&filters=HpDate:\"20260605_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260606_HikingNatchez"},"Ssd":"20260606","Name":"HikingNatchez","Market":"ZH-CN","Hash":"2495512699","FullDateString":"2026 6月 6"},{"ImageContent":{"Description":"如果大自然也有“请勿打扰”的标志，那它一定会挂在萨雷克国家公园上空，这里常被称为“欧洲最后的荒野”。在世界环境日这一天，瑞典拉普兰的这片偏远角落提醒我们，当人类退后一步，让大自然主导一切时，地球会是什么样子。","Image":{"Url":"/th?id=OHR.WedLapland_ZH-CN2365942547_1920x1080.webp","Wallpaper":"/th?id=OHR.WedLapland_ZH-CN2365942547_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"无人问津之地的静默力量","Title":"从斯基尔夫山俯瞰拉帕达伦河三角洲, 萨雷克国家公园, 拉波尼亚, 瑞典拉普兰","Copyright":"© Robert Haasmann/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"斯基尔费悬崖提供约700米近乎垂直的俯瞰视角，可观赏下方拉帕达伦辫状河三角洲。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260605_WedLapland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e7%8e%af%e5%a2%83%e6%97%a5&form=hpcapt&filters=HpDate:\"20260604_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260605_WedLapland"},"Ssd":"20260605","Name":"WedLapland","Market":"ZH-CN","Hash":"2365942547","FullDateString":"2026 6月 5"},{"ImageContent":{"Description":"名如其诗，形亦如画。这就是雪鹭（Snowy egret）——通体洁白的羽衣，衬托着黑色长腿下明黄色的“脚掌”，构成了一幅极具视觉冲击力的画面。曾几何时，人类对这种鹭鸟在繁殖季节长出的装饰性婚羽（形似蕾丝般轻柔飘逸的丝状羽毛）有着极大的市场需求，用于点缀时尚女帽。这一嗜好险些让该物种走向灭绝，幸而后续的自然保护行动成功挽救了它们。","Image":{"Url":"/th?id=OHR.PreeningEgret_ZH-CN2216012708_1920x1080.webp","Wallpaper":"/th?id=OHR.PreeningEgret_ZH-CN2216012708_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"优雅羽饰","Title":"梳理羽毛的雪鹭，佛罗里达州中部，美国","Copyright":"© Donald M. Jones/Minden Pictures","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"雪鹭常与苍鹭成群觅食，利用大型鹭鸟惊扰出的水底动向，从而锁定并捕食那些原本隐藏的猎物。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260604_PreeningEgret\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9b%aa%e9%b9%ad&form=hpcapt&filters=HpDate:\"20260603_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260604_PreeningEgret"},"Ssd":"20260604","Name":"PreeningEgret","Market":"ZH-CN","Hash":"2216012708","FullDateString":"2026 6月 4"},{"ImageContent":{"Description":"虽然日常的通勤之路或许不像今日画面中那般波澜壮阔，但这并不妨碍我们跨上单车，开始蹬踏。在“世界自行车日”到来之际，联合国向全球发出倡议，邀我们重新审视两轮出行的无限可能——无论是在穿梭于现代都市，还是纵贯于偏远荒原。每年的6月3日，这一由联合国发起的国际纪念日旨在认可自行车作为一种务实的出行方式，在促进公众健康、降低碳排放以及提升交通普惠性方面所发挥的关键作用。","Image":{"Url":"/th?id=OHR.BardenasReales_ZH-CN0480548935_1920x1080.webp","Wallpaper":"/th?id=OHR.BardenasReales_ZH-CN0480548935_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"路之所止，行之所启","Title":"骑行者，巴德纳斯雷亚莱斯自然公园与生物圈保护区，纳瓦拉，西班牙","Copyright":"© Artur Debat/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"巴德纳斯雷亚莱斯因其酷似火星地表而闻名，美国国家航空航天局（NASA）的科学家曾利用这里来研究火星地貌是如何在数千年间经受风蚀演化的。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260603_BardenasReales\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e8%87%aa%e8%a1%8c%e8%bd%a6%e6%97%a5&form=hpcapt&filters=HpDate:\"20260602_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260603_BardenasReales"},"Ssd":"20260603","Name":"BardenasReales","Market":"ZH-CN","Hash":"0480548935","FullDateString":"2026 6月 3"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"获取新版必应壁纸应用","LOC_BING_APP_TEXT":"在设备上获取必应壁纸","LOC_BING_APP_LINK_PC":"https://bing.microsof