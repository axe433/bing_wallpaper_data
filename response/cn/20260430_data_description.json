{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/UBBzZ0VFwPvtDNX-yY8JD5YpozU.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/Z3RsRJM-Pfsyj_3ZanZL12q73Gg.css?bu=CPIB9QGZAqgCnAKcApwC6gI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/7Q/cir3,cc,nc/nEx341EseUAKfcxjSWaFs2yBrAI.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/x1tOfBUE9eG4i-ZqjibvWc-H6iQ.css?bu=CJsDnAKcAuQCuQKcApwCnAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2A/69/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2A/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvcChgM&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2A/69/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-04-30T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"五月的中国北方，仿佛刚从春天的画卷中苏醒，带着清新的气息与恰到好处的温度，向远方的旅人发出邀请。无论是在古城街巷间寻访历史的回声，还是沿着万里长城的脊线远望群山，五月的北方都以其明净与舒展，呈现出一年中最适合出行的模样。此时出发，不仅能避开盛夏的炎热，也能在恰好的光影与温度中，收获一段轻盈而难忘的旅途。","Image":{"Url":"/th?id=OHR.MayLaborDayY26_ZH-CN7554485395_1920x1080.webp","Wallpaper":"/th?id=OHR.MayLaborDayY26_ZH-CN7554485395_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"初夏·翠微长城","Title":"中国的长城","Copyright":"© aphotostory/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"长城并非一条首尾相连的孤线，而是由历代王朝因地制宜、悉心营建的宏大防御体系。从大漠深处的夯土堡垒，到崇山峻岭间的砖石屏障，长城的每一寸肌理都闪烁着先民顺应自然、化繁为简的智慧光芒，堪称人类建筑史上与地理环境完美融合的典范。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260501_MayLaborDayY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%95%bf%e5%9f%8e&form=hpcapt&filters=HpDate:\"20260430_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260501_MayLaborDayY26"},"Ssd":"20260501","Name":"MayLaborDayY26","Market":"ZH-CN","Hash":"7554485395","FullDateString":"2026 5月 1"},{"ImageContent":{"Description":"想象一下，一朵花引发了一场金融狂潮。听起来不太可能，对吧？然而，在17世纪30年代，郁金香在荷兰却做到了这一点。在郁金香狂热时期，稀有的郁金香球茎成了奢侈品，交易价格惊人——有些球茎的价值甚至堪比一栋房子。为什么如此珍贵？因为颜色和条纹图案独特的郁金香稀少且难以预测，收藏家们想要找到他们所能找到的最稀有的品种。","Image":{"Url":"/th?id=OHR.DutchTulips_ZH-CN6394892537_1920x1080.webp","Wallpaper":"/th?id=OHR.DutchTulips_ZH-CN6394892537_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"郁金香是这里的主角","Title":"葡萄风信子和郁金香, 库肯霍夫花园, 利塞, 荷兰","Copyright":"© Martin Ruegner/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"花园现占地32公顷（79英亩），展示了100家参与公司的产品。这得益于人工种植的700万株球茎。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260430_DutchTulips\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%ba%93%e8%82%af%e9%9c%8d%e5%a4%ab%e8%8a%b1%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260429_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260430_DutchTulips"},"Ssd":"20260430","Name":"DutchTulips","Market":"ZH-CN","Hash":"6394892537","FullDateString":"2026 4月 30"},{"ImageContent":{"Description":"昔日，离开里斯本的船只在驶向浩瀚的大西洋之前，都会经过一座小小的石塔。这座矗立在塔霍河畔的石塔，既是守护者，也是告别的象征。让我们一起来认识贝伦塔——这座见证葡萄牙扬帆起航，迈入大航海时代的堡垒。","Image":{"Url":"/th?id=OHR.BelemTowerBank_ZH-CN6235906597_1920x1080.webp","Wallpaper":"/th?id=OHR.BelemTowerBank_ZH-CN6235906597_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"历史镌刻于石上","Title":"塔霍河岸边的贝伦塔, 里斯本, 葡萄牙","Copyright":"© f9photos/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"贝伦塔于1983年被列入联合国教科文组织世界遗产名录，是里斯本市和葡萄牙在世界上的标志性建筑。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260429_BelemTowerBank\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%b4%9d%e4%bc%a6%e5%a1%94&form=hpcapt&filters=HpDate:\"20260428_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260429_BelemTowerBank"},"Ssd":"20260429","Name":"BelemTowerBank","Market":"ZH-CN","Hash":"6235906597","FullDateString":"2026 4月 29"},{"ImageContent":{"Description":"眼镜熊，又称安第斯熊，是熊科中唯一的南美洲熊类。它们栖息于安第斯山脉北部和中部，主要生活在森林地区，以嫩芽和果实为食。眼睛周围的浅色斑纹酷似眼镜，因此得名“眼镜熊”。","Image":{"Url":"/th?id=OHR.AndeanBear_ZH-CN6152330738_1920x1080.webp","Wallpaper":"/th?id=OHR.AndeanBear_ZH-CN6152330738_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"野外奇观","Title":"眼镜熊在树上休息, 厄瓜多尔","Copyright":"© Andy Rouse/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"每只眼镜熊都有独特的面部标记，科学家利用这些标记来识别和追踪野生个体。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260428_AndeanBear\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%9c%bc%e9%95%9c%e7%86%8a&form=hpcapt&filters=HpDate:\"20260427_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260428_AndeanBear"},"Ssd":"20260428","Name":"AndeanBear","Market":"ZH-CN","Hash":"6152330738","FullDateString":"2026 4月 28"},{"ImageContent":{"Description":"由建筑师朱塞佩·门戈尼设计，于1877年竣工的维托里奥·埃马努埃莱二世拱廊位于意大利米兰，是世界上最古老、最著名的购物拱廊之一。它坐落于米兰大教堂广场和斯卡拉广场之间，拥有令人惊艳的玻璃铁艺屋顶和优雅的八角形布局。这条拱廊被亲切地称为“米兰的客厅”，汇集了众多高端精品店、历史悠久的咖啡馆以及知名餐厅。","Image":{"Url":"/th?id=OHR.MilanGalleria_ZH-CN6060869879_1920x1080.webp","Wallpaper":"/th?id=OHR.MilanGalleria_ZH-CN6060869879_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"有格调的玻璃","Title":"维托里奥·埃马努埃莱二世拱廊的玻璃穹顶, 米兰, 意大利","Copyright":"© PhillipMinnis/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"当时，意大利正经历着艰难的统一时期，门戈尼将这座拱廊视为凝聚人心的途径。因此，拱廊内的马赛克镶嵌画充满了爱国主义符号，旨在激励团结。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260427_MilanGalleria\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9f%83%e9%a9%ac%e5%8a%aa%e5%9f%83%e8%8e%b1%e4%ba%8c%e4%b8%96%e6%8b%b1%e5%bb%8a&form=hpcapt&filters=HpDate:\"20260426_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260427_MilanGalleria"},"Ssd":"20260427","Name":"MilanGalleria","Market":"ZH-CN","Hash":"6060869879","FullDateString":"2026 4月 27"},{"ImageContent":{"Description":"春天，苹果树绽放出朵朵柔和的粉色花朵，生机盎然。娇嫩的花瓣点缀着果园和山坡，在湛蓝的天空映衬下格外醒目，标志着季节从寒冬走向温暖。这些花朵吸引着蜜蜂和蝴蝶等授粉昆虫，帮助果树结出丰硕的果实，为来年晚些时候的苹果生长做好准备。","Image":{"Url":"/th?id=OHR.AppleBlossoms_ZH-CN5887711928_1920x1080.webp","Wallpaper":"/th?id=OHR.AppleBlossoms_ZH-CN5887711928_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"繁花盛放","Title":"粉红色的苹果花, 阿维拉海滩, 加利福尼亚州, 美国","Copyright":"© Mimi Ditchie Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"苹果花可以新鲜食用，也可以晒干后食用，香气浓郁，带有甜美的花香，是各种烹饪用途的理想食材。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260426_AppleBlossoms\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8b%b9%e6%9e%9c%e6%a0%91&form=hpcapt&filters=HpDate:\"20260425_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260426_AppleBlossoms"},"Ssd":"20260426","Name":"AppleBlossoms","Market":"ZH-CN","Hash":"5887711928","FullDateString":"2026 4月 26"},{"ImageContent":{"Description":"企鹅通常让人联想到南极，但这些可爱的不会飞的海鸟并非总是追随冰雪而来。在世界企鹅日，图中这些加拉帕戈斯企鹅为我们展现了一个鲜明的对比。这种企鹅仅分布于加拉帕戈斯群岛——位于厄瓜多尔海岸约600英里外的火山群岛——是所有企鹅中分布最北的物种。凉爽且富含营养的洋流为它们提供了食物，并将周围水域的温度维持在适宜生存的范围内，从而使这种赤道栖息地成为可能。这些体型紧凑、行动敏捷的企鹅一天中的大部分时间都待在水中以保持凉爽。","Image":{"Url":"/th?id=OHR.GalapagosPenguins_ZH-CN5791845489_1920x1080.webp","Wallpaper":"/th?id=OHR.GalapagosPenguins_ZH-CN5791845489_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"打破企鹅规则","Title":"加拉帕戈斯企鹅游泳, 加拉帕戈斯群岛, 厄瓜多尔","Copyright":"© Henley Spiers/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"每只企鹅都有自己独特的叫声。这有助于它们在庞大的企鹅群落中找到伴侣和幼崽，这些企鹅群落的数量从几百只到几万只不等。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260425_GalapagosPenguins\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e4%bc%81%e9%b9%85%e6%97%a5&form=hpcapt&filters=HpDate:\"20260424_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260425_GalapagosPenguins"},"Ssd":"20260425","Name":"GalapagosPenguins","Market":"ZH-CN","Hash":"5791845489","FullDateString":"2026 4月 25"}],"PreloadMediaContents":[{"ImageContent":{"Description":"世界驴日旨在庆祝人类最默默无闻却能力出众的伙伴之一——驴。数千年来，驴一直与人类并肩工作，它们以耐力、敏锐的记忆力和在崎岖地形上稳健的步伐而备受推崇。人们常常误以为它们固执，但实际上它们是谨慎的思考者——它们会停下来评估风险，而不是贸然行事。","Image":{"Url":"/th?id=OHR.SardinianDonkey_ZH-CN0758031524_1920x1080.webp","Wallpaper":"/th?id=OHR.SardinianDonkey_ZH-CN0758031524_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"不仅仅是一声咿呀学语","Title":"撒丁岛母驴和幼崽, 法国","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"骡子是公驴和母马杂交产生的后代。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260508_SardinianDonkey\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%a9%b4&form=hpcapt&filters=HpDate:\"20260507_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260508_SardinianDonkey"},"Ssd":"20260508","Name":"SardinianDonkey","Market":"ZH-CN","Hash":"0758031524","FullDateString":"2026 5月 8"},{"ImageContent":{"Description":"横跨美国西南部亚利桑那州索诺兰沙漠的科法国家野生动物保护区，是一片由峭壁山峰、开阔天空与顽强生命共同构成的独特荒野。","Image":{"Url":"/th?id=OHR.Kofa_ZH-CN0584573563_1920x1080.webp","Wallpaper":"/th?id=OHR.Kofa_ZH-CN0584573563_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"广袤铺展的沙漠","Title":"科法国家野生动物保护区，亚利桑那州，美国","Copyright":"© Denis Tangney Jr/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"科法的棕榈峡谷庇护着亚利桑那州唯一的原生棕榈。这些史前残遗物种躲藏在深邃遮阴的岩缝中，在酷热的沙漠里利用阴凉的微气候繁衍至今。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260507_Kofa\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%a7%91%e6%b3%95%e5%9b%bd%e5%ae%b6%e9%87%8e%e7%94%9f%e5%8a%a8%e7%89%a9%e4%bf%9d%e6%8a%a4%e5%8c%ba&form=hpcapt&filters=HpDate:\"20260506_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260507_Kofa"},"Ssd":"20260507","Name":"Kofa","Market":"ZH-CN","Hash":"0584573563","FullDateString":"2026 5月 7"},{"ImageContent":{"Description":"在壮阔的天幕下，保加利亚的两大平原展现了国家的农业核心。多瑙河平原横跨北部，起伏的田野与河谷受温带大陆性气候影响，炎热的夏季常催生强烈的雷暴。再往南是上色雷斯平原，地势更低且更温暖，受大陆系统及从爱琴海地区涌入的地中海气流共同影响。在这里，酷暑与马里查河流域的水汽交织，使该地区极易发生剧烈的夏季风暴——正如此刻在图像中平原上空上演的景象。","Image":{"Url":"/th?id=OHR.BulgariaPlains_ZH-CN3853985252_1920x1080.webp","Wallpaper":"/th?id=OHR.BulgariaPlains_ZH-CN3853985252_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"承受压力之下的平原","Title":"平原上空的雷暴，保加利亚","Copyright":"© Revolu7ion93/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"保加利亚坐落在巴尔干半岛东部，地处欧亚交汇的十字路口。在这里，古老文明、肥沃景观与多变的气候交相感应。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260506_BulgariaPlains\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bf%9d%e5%8a%a0%e5%88%a9%e4%ba%9a&form=hpcapt&filters=HpDate:\"20260505_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260506_BulgariaPlains"},"Ssd":"20260506","Name":"BulgariaPlains","Market":"ZH-CN","Hash":"3853985252","FullDateString":"2026 5月 6"},{"ImageContent":{"Description":"立夏之日，春意虽未尽，夏木已成阴。这是中国时令中一个充满生命力的转折点：蝼蝈鸣，蚯蚓出，王瓜生。告别了春日的繁花绚烂，北方的天空愈发高远明净，南方的雨水则带来了润物无声的翠绿。此时风物，不在于热烈，而在于那份“清和”——万物至此皆长大，天地间流淌着一种舒展而轻盈的力量。","Image":{"Url":"/th?id=OHR.BeginningofSummerY26_ZH-CN7628545617_1920x1080.webp","Wallpaper":"/th?id=OHR.BeginningofSummerY26_ZH-CN7628545617_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"藕花风起，首夏清和","Title":"莲花与莲花植株","Copyright":"© real444/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“活化石”植物： 荷花是地球上最古老的双子叶植物之一，其种子的生命力极其顽强，埋藏在土层中千年的“古莲子”在适宜条件下仍能萌芽开花。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260505_BeginningofSummerY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e7%9a%84%e8%8d%b7%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260504_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260505_BeginningofSummerY26"},"Ssd":"20260505","Name":"BeginningofSummerY26","Market":"ZH-CN","Hash":"7628545617","FullDateString":"2026 5月 5"},{"ImageContent":{"Description":"“愿原力与你同在！”在星球大战日这一天，现实仿佛披上科幻的外衣，让人一时难以分辨虚实。画面将我们带到突尼斯南部塔塔温地区的乌莱德·索尔坦克萨尔，这里层层堆叠的土坯粮仓宛如沙色堡垒，充满异域与未来感。这座建筑群始建于 15 世纪，由当地柏柏尔人修建，用于保护粮食免受高温、盗窃和时间侵蚀。它的设计首先服务于实用功能，而独特的美感则在不经意间自然呈现——仿佛现实中的“科幻场景”。","Image":{"Url":"/th?id=OHR.KsarOuledSoltane_ZH-CN3569810663_1920x1080.webp","Wallpaper":"/th?id=OHR.KsarOuledSoltane_ZH-CN3569810663_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"科幻源于现实","Title":"乌莱德·索尔坦克萨尔，塔塔温区，突尼斯南部","Copyright":"© Dark_Eni/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"突尼斯索尔塔纳堡的多层土窖（Ghorfas）助力社区在严酷的沙漠气候中实现集体储粮与防御。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260504_KsarOuledSoltane\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%98%9f%e7%90%83%e5%a4%a7%e6%88%98%e6%97%a5&form=hpcapt&filters=HpDate:\"20260503_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260504_KsarOuledSoltane"},"Ssd":"20260504","Name":"KsarOuledSoltane","Market":"ZH-CN","Hash":"3569810663","FullDateString":"2026 5月 4"},{"ImageContent":{"Description":"在肯尼亚马赛马拉萨瓦纳草原的高处，一只豹蜷缩在树枝上，在落日的余晖中静静小憩。在5月3日“国际豹类日”之际，我们共同致敬这种世界上适应力最强的大型猫科动物之一。豹的足迹遍布非洲及亚洲部分地区，无论是茂密的森林、险峻的山脉，还是开阔的萨瓦纳草原，它们都能茁壮成长。每只豹身上的斑点都是独一无二的，如同人类的指纹；而它们高超的攀爬技巧，则能将猎物拖至高树顶端，从而避开其他食腐动物的抢夺。","Image":{"Url":"/th?id=OHR.MasaiLeopard_ZH-CN3406483238_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiLeopard_ZH-CN3406483238_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"萨瓦纳的晚霞","Title":"萨瓦纳草原的树上睡觉的豹子，马赛马拉国家保护区，肯尼亚","Copyright":"© Klein & Hubert/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"豹已丧失了约75%的历史分布区，并被世界自然保护联盟（IUCN）列为“易危”物种。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260503_MasaiLeopard\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e8%b1%b9%e7%b1%bb%e6%97%a5&form=hpcapt&filters=HpDate:\"20260502_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260503_MasaiLeopard"},"Ssd":"20260503","Name":"MasaiLeopard","Market":"ZH-CN","Hash":"3406483238","FullDateString":"2026 5月 3"},{"ImageContent":{"Description":"你能想象一片面积超过1.1万平方公里的受保护荒野吗？这便是位于加拿大阿尔伯塔省的贾斯珀国家公园。它始建于1907年，是加拿大落基山脉日益完善的保护地网络中的重要一环，并于1930年正式被命名为国家公园。贾斯珀不仅展现了现代自然保护的成果，更承载着悠久的原住民文化底蕴，其中包括纳科达族（Nakoda）和塞克维潘族（Secwépemc）等民族与这片土地跨越千年的联系。公园内的地形地貌极为宏伟多样：从冰川融水汇聚而成的河川，到生机勃勃的高山草甸，再到由云杉和松树构成的茂密针叶林，共同构建出了一幅原始而壮丽的自然画卷。","Image":{"Url":"/th?id=OHR.GreenJasper_ZH-CN3030401138_1920x1080.webp","Wallpaper":"/th?id=OHR.GreenJasper_ZH-CN3030401138_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"贾斯珀的自然魅力","Title":"阿尔伯塔省贾斯珀国家公园中的小型湖泊与湿地，加拿大","Copyright":"© Don White/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"贾斯珀遍布冰川形成的壶穴湖，水温较主河流更暖，是西蟾蜍等两栖类重要的育婴室。环绕湖泊的泥炭沼泽宛如“生物海绵”，通过泥炭藓蓄纳雪水并调节径流，既保护了流域生态，也是调节气候的关键碳库。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260502_GreenJasper\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%98%bf%e5%b0%94%e4%bc%af%e5%a1%94%e7%9c%81%e8%b4%be%e6%96%af%e7%8f%80%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260501_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260502_GreenJasper"},"Ssd":"20260502","Name":"GreenJasper","Market":"ZH-CN","Hash":"3030401138","FullDateString":"2026 5月 2"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"获取新版必应壁纸应用","LOC_BING_APP_TEXT":"在设备上获取必应壁纸","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adjust=nk9xri2_dzfz5n2","LOC_BING_APP_LINK_MOBILE":"https://app.adjust.com/d93ddtl_a75k0gg?deeplink=sapphire%3A%2F%2Fwallpaper","LOC_BING_APP_DOWNLOAD_TEXT":"移动应用","LOC_BING_WP_APP_DOWNLOAD_TEXT":"桌面应用","LOC_BING_APP_TEXT_MOBILE":"使用必应应用获取每日照片","LOC_BING_APP_DOWNLOAD_TEXT_MOBILE":"获取","LOC_HOMEPAGE_VERTICAL_SCROLL_TOB":"必应热门资讯","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB":"必应上的热点","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_NEXT":"换一批","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_Close":"隐藏必应上的热点","LOC_HOMEPAGE_TOB_TAG_NEW":