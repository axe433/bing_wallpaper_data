{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/XZsmWBUJgDgwzyUH8iR7Ev0cdLQ.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/kiAvf1MfH3VyL_uWmI1ajs_O8Tc.css?bu=CPUB-AGZAqgCnAKcApwC5AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2B/7q/cir3,cc,nc/CUCSI1SFeWrmYnIaftq0iQdznqQ.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/7bkdUAEXrvdyzV_QGkZNo3m3x_U.css?bu=CJQDnAKcAt4CuAKcApwCnAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2B/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2B/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvEC_wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2B/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-11T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"乌尔萨海滩（Praia da Ursa）深藏在欧洲大陆最西端——罗卡角（Cabo da Roca）附近的陡峭悬崖之下，置身其中，仿佛来到了大陆的尽头。沿着一条狭窄崎岖的小径便可抵达这片隐秘的沙滩。在葡萄牙的大西洋沿岸，风、岩石与惊涛骇浪共同塑造了这里的地貌。当潮水退去，海岸线短暂地变得宽阔，平滑的岩石显露出来，随之而来的还有微小的生命迹象。帽贝紧紧贴在裸露的岩石上，在海浪平日拍打的地方顽强地驻守。","Image":{"Url":"/th?id=OHR.Limpets_ZH-CN4991771513_1920x1080.webp","Wallpaper":"/th?id=OHR.Limpets_ZH-CN4991771513_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"沉静的力量","Title":"退潮时裸露在乌尔萨海滩海岸上的帽贝, 葡萄牙","Copyright":"© Theo Bosboom/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这片海滩的名字“乌尔萨”（熊）源于当地的一个神话。传说中，一只母熊在冰川融化期间拒绝离开海岸；众神将她变成了石头，让她永远留在那里。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260611_Limpets\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%91%a1%e8%90%84%e7%89%99%e4%b9%8c%e5%b0%94%e8%90%a8%e6%b5%b7%e6%bb%a9&form=hpcapt&filters=HpDate:\"20260610_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260611_Limpets"},"Ssd":"20260611","Name":"Limpets","Market":"ZH-CN","Hash":"4991771513","FullDateString":"2026 6月 11"},{"ImageContent":{"Description":"从空中俯瞰，湖泊平静的湖面与周围崎岖的地形形成鲜明对比。赫瑙萨波鲁尔火山口湖（也称布拉赫鲁尔湖）位于菲亚拉巴克自然保护区的中心地带，这片位于冰岛高地的偏远地区，其地貌更多地受到火山活动而非人类活动的影响。火山口的形成源于岩浆与地下水的接触，引发了一场爆炸，最终雕琢出如今可见的圆形盆地。","Image":{"Url":"/th?id=OHR.Hnausapollur_ZH-CN4075343976_1920x1080.webp","Wallpaper":"/th?id=OHR.Hnausapollur_ZH-CN4075343976_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一抹蓝色","Title":"赫瑙萨波鲁尔火山口, 菲亚拉巴克自然保护区, 兰德曼纳劳加尔, 冰岛","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"深邃的水位与贫瘠的营养限制了藻类生长。这种清澈度使光线得以被强烈吸收，从而造就了其深蓝色调。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260610_Hnausapollur\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%86%b0%e5%b2%9b%e8%b5%ab%e7%91%99%e8%90%a8%e6%b3%a2%e9%b2%81%e5%b0%94&form=hpcapt&filters=HpDate:\"20260609_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260610_Hnausapollur"},"Ssd":"20260610","Name":"Hnausapollur","Market":"ZH-CN","Hash":"4075343976","FullDateString":"2026 6月 10"},{"ImageContent":{"Description":"韦尔纳扎是意大利利古里亚大区五渔村的一个海滨小镇。它围绕着该地区唯一的天然港口而建，自古以来就与大海紧密相连。韦尔纳扎最早的文字记载可追溯到1080年，当时它是一个设防的定居点和海上基地，后来成为热那亚共和国海岸防御体系的一部分。时至今日，小镇依然保留着昔日的风貌，多利亚城堡的遗址和俯瞰海湾的瞭望塔诉说着它的历史。在水边，矗立着圣玛格丽塔·安提阿教堂，这座教堂最早的文字记载可追溯到1318年，并在之后的几个世纪中不断扩建，如今教堂的钟楼俯瞰着港口。房屋和狭窄的街道上方，陡峭的梯田上种植着葡萄园和橄榄树，这些梯田是由一代又一代的工匠用石头精心雕琢而成，构成了五渔村国家公园的景观，而五渔村国家公园本身也是联合国教科文组织世界遗产的一部分。想象一下这里的餐前小酌：一杯当地白葡萄酒，港口景色尽收眼底，还有利古里亚的特色美食，如佛卡夏面包和罗勒香蒜酱——简直就是一张可以品尝的明信片。","Image":{"Url":"/th?id=OHR.CTNPVernazza_ZH-CN3971102271_1920x1080.webp","Wallpaper":"/th?id=OHR.CTNPVernazza_ZH-CN3971102271_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"品尝日落","Title":"韦尔纳扎, 五渔村, 利古里亚, 意大利","Copyright":"© Kelly Cheng/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"韦尔纳扎港湾的日落被认为是意大利最常被拍摄的景观之一。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260609_CTNPVernazza\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%84%8f%e5%a4%a7%e5%88%a9%e9%9f%a6%e5%b0%94%e7%ba%b3%e6%89%8e%e4%ba%94%e6%b8%94%e6%9d%91&form=hpcapt&filters=HpDate:\"20260608_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260609_CTNPVernazza"},"Ssd":"20260609","Name":"CTNPVernazza","Market":"ZH-CN","Hash":"3971102271","FullDateString":"2026 6月 9"},{"ImageContent":{"Description":"今天是世界海洋日，让我们跟随这种随波逐流的生物的脚步吧！想看看狮鬃水母吗？那就去寒冷的北方海域寻找吧。它的伞状体分为八个瓣状结构，伞状体下方垂着长长的触手和口腕。随着水流漂移，它身上的刺细胞会捕获浮游生物和小鱼。对人类来说，被蜇一下会很疼。每个人的反应都不一样，即使是搁浅在海里的触手也可能造成疼痛。所以，记住一条简单的原则：欣赏它，然后就不要打扰它。北极水域的一些狮鬃水母伞状体直径超过6英尺（约1.8米），但大多数目击到的都是风暴或强流过后靠近海岸的小型个体。","Image":{"Url":"/th?id=OHR.Cyanea_ZH-CN3858079050_1920x1080.webp","Wallpaper":"/th?id=OHR.Cyanea_ZH-CN3858079050_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"随波逐流","Title":"在海洋中游动的狮鬃水母","Copyright":"© Alexander Semenov Images/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"虽然大部分是水，但狮鬃水母的长度可达 120 英尺——甚至超过了蓝鲸。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260608_Cyanea\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b5%b7%e6%b4%8b%e6%97%a5&form=hpcapt&filters=HpDate:\"20260607_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260608_Cyanea"},"Ssd":"20260608","Name":"Cyanea","Market":"ZH-CN","Hash":"3858079050","FullDateString":"2026 6月 8"},{"ImageContent":{"Description":"在邓塞弗里克城堡，历史仿佛就悬挂在原地——确切地说，就悬挂在原地。残垣断壁依附在大西洋上方的玄武岩峭壁上，证明即使是废墟也能屹立不倒。两千年前，这里是爱尔兰五大道路之一——斯莱格·米德卢赫拉（Slige Midluachra）的终点，这条道路连接着通往塔拉山（Hill of Tara）王室的旅人。据说，公元5世纪，圣帕特里克曾到访此地，并为当地居民奥尔坎（Olcán）施洗。传说中，用于为爱尔兰国王加冕的“命运之石”（Lia Fáil）就是从这片海岸被带往苏格兰的。","Image":{"Url":"/th?id=OHR.DunseverickCastle2026_ZH-CN3036266326_1920x1080.webp","Wallpaper":"/th?id=OHR.DunseverickCastle2026_ZH-CN3036266326_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"最后一堵墙矗立着","Title":"邓塞弗里克城堡遗址, 安特里姆郡, 北爱尔兰","Copyright":"© Krzysztof Rogalski/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"邓塞弗里克城堡所依托的玄武岩地基在地质上与附近的巨人之路火山熔岩地貌相连。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260607_DunseverickCastle2026\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%82%93%e5%a1%9e%e5%bc%97%e9%87%8c%e5%85%8b%e5%9f%8e%e5%a0%a1++&form=hpcapt&filters=HpDate:\"20260606_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260607_DunseverickCastle2026"},"Ssd":"20260607","Name":"DunseverickCastle2026","Market":"ZH-CN","Hash":"3036266326","FullDateString":"2026 6月 7"},{"ImageContent":{"Description":"如果你最近沉迷于电子屏幕，今天正是改变的好时机——我们建议你去徒步旅行。","Image":{"Url":"/th?id=OHR.HikingNatchez_ZH-CN2495512699_1920x1080.webp","Wallpaper":"/th?id=OHR.HikingNatchez_ZH-CN2495512699_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"多走走，多思考","Title":"纳奇兹小径公园大道, 图珀洛, 密西西比州, 美国","Copyright":"© The best photo is earned/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"纳奇兹古道曾是商人将货物顺流运至新奥尔良后返回内陆的重要陆路通道。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260606_HikingNatchez\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%ba%b3%e5%a5%87%e5%85%b9%e5%b0%8f%e5%be%84%e6%97%a5%e5%87%ba%e6%ad%a5%e9%81%93&form=hpcapt&filters=HpDate:\"20260605_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260606_HikingNatchez"},"Ssd":"20260606","Name":"HikingNatchez","Market":"ZH-CN","Hash":"2495512699","FullDateString":"2026 6月 6"},{"ImageContent":{"Description":"如果大自然也有“请勿打扰”的标志，那它一定会挂在萨雷克国家公园上空，这里常被称为“欧洲最后的荒野”。在世界环境日这一天，瑞典拉普兰的这片偏远角落提醒我们，当人类退后一步，让大自然主导一切时，地球会是什么样子。","Image":{"Url":"/th?id=OHR.WedLapland_ZH-CN2365942547_1920x1080.webp","Wallpaper":"/th?id=OHR.WedLapland_ZH-CN2365942547_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"无人问津之地的静默力量","Title":"从斯基尔夫山俯瞰拉帕达伦河三角洲, 萨雷克国家公园, 拉波尼亚, 瑞典拉普兰","Copyright":"© Robert Haasmann/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"斯基尔费悬崖提供约700米近乎垂直的俯瞰视角，可观赏下方拉帕达伦辫状河三角洲。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260605_WedLapland\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e7%8e%af%e5%a2%83%e6%97%a5&form=hpcapt&filters=HpDate:\"20260604_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260605_WedLapland"},"Ssd":"20260605","Name":"WedLapland","Market":"ZH-CN","Hash":"2365942547","FullDateString":"2026 6月 5"}],"PreloadMediaContents":[{"ImageContent":{"Description":"萨克塞华曼（Sacsayhuamán）坐落于秘鲁库斯科的高处，通过石材展现了印加帝国的宏大雄心。这座宏伟的建筑群始建于15世纪，曾是印加帝国神圣都城的一部分。从高空俯瞰，其布局清晰呈现：梯田、开阔的广场以及塔楼遗迹，共同构成了一座经过精密规划的卫城。其中最为壮观的墙体由巨型石块砌成，至今依然屹立不倒。部分石材高度超过 27 英尺（约 8.2 米），且在未使用灰浆的情况下实现了极度精确的无缝拼接，这使得该结构历经数百年的地震仍完好无损。","Image":{"Url":"/th?id=OHR.Saqsaywaman_ZH-CN2584038469_1920x1080.webp","Wallpaper":"/th?id=OHR.Saqsaywaman_ZH-CN2584038469_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"坚如磐石的奇观","Title":"萨克赛瓦曼遗址俯瞰图，库斯科，秘鲁","Copyright":"© Creative-Family/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"萨克塞华曼遗址（位于库斯科，秘鲁）中最重的单体巨石重量超过 120 吨，是在完全没有使用轮式工具的情况下，仅凭人力从数英里外的采石场搬运而来的。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260618_Saqsaywaman\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%a7%98%e9%b2%81%e8%90%a8%e5%85%8b%e5%a1%9e%e5%8d%8e%e6%9b%bc&form=hpcapt&filters=HpDate:\"20260617_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260618_Saqsaywaman"},"Ssd":"20260618","Name":"Saqsaywaman","Market":"ZH-CN","Hash":"2584038469","FullDateString":"2026 6月 18"},{"ImageContent":{"Description":"沿着那如丝带般盘旋的连续弯道，您将领略到瑞士最具传奇色彩的驾驶路线之一：特雷莫拉公路（Tremola Road）。它是位于艾罗洛（Airolo）上方、通往圣哥达山口（Saint Gotthard Pass）的历史悠久的南坡入口。该公路始建于 19 世纪初期，并在 1951 年的重建中基本定型，被公认为瑞士最长的历史道路建筑纪念碑。其最引人入胜的一段路程在短短 2.5 英里（约 4 公里）内爬升了约 980 英尺（约 300 米），在花岗岩鹅卵石铺就的 24 个著名发卡弯中盘旋而上，路缘筑有坚固的挡土墙。全路段长约 7 英里（约 11 公里），总计 37 个弯道。请减速慢行——每一处曲线都像是一场穿越时空的旅行，虽然牺牲了车速，却能换取壮丽的山地景观，并俯瞰上勒文蒂纳山谷（upper Leventina Valley）的广阔视野。无论您是驾驶、骑行还是停车拍照，都请留意那个以此标志性“之”字形道路为背景的“瑞士环游之路”（Grand Tour of Switzerland）摄影打卡点。","Image":{"Url":"/th?id=OHR.TremolaRoad_ZH-CN8810749250_1920x1080.webp","Wallpaper":"/th?id=OHR.TremolaRoad_ZH-CN8810749250_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"蜿蜒而上","Title":"特雷莫拉公路在圣哥达山口，艾罗洛，瑞士","Copyright":"© Sandro Bisaro/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“特雷莫拉”一词源于意大利语“tremolare”（意为颤动），生动地描述了往昔马车在特雷莫拉公路（位于艾罗洛，瑞士）的鹅卵石路面上行驶时产生的剧烈震动。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260617_TremolaRoad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%89%b9%e9%9b%b7%e8%8e%ab%e6%8b%89%e5%85%ac%e8%b7%af&form=hpcapt&filters=HpDate:\"20260616_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260617_TremolaRoad"},"Ssd":"20260617","Name":"TremolaRoad","Market":"ZH-CN","Hash":"8810749250","FullDateString":"2026 6月 17"},{"ImageContent":{"Description":"世界海龟日”聚焦于海洋中最古老的“航行者”——这些爬行动物已在地球上生存了超过一亿年。每年的6月 16日定为世界海龟日，旨在提高公众对海龟生态重要性及其面临日益严峻威胁的关注。海龟在维持海草床和珊瑚礁系统健康方面发挥着核心作用，而这些生态系统支撑着多样化的海洋生物。在觅食地与筑巢地之间的长途迁徙是其生命周期的关键环节。尽管海龟具有极强的韧性，但目前所有物种都面临着栖息地丧失、塑料污染、气候变化以及渔具误捕的威胁。","Image":{"Url":"/th?id=OHR.SevenMileTurtle_ZH-CN4346512721_1920x1080.webp","Wallpaper":"/th?id=OHR.SevenMileTurtle_ZH-CN4346512721_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"蔚蓝海礁的守护者","Title":"七英里海滩附近的玳瑁海龟伴侣，大开曼岛，开曼群岛","Copyright":"© Alex Mustard/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"海龟卵孵化期间的沙子温度，决定了新生幼体是雄性还是雌性。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260616_SevenMileTurtle\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b5%b7%e9%be%9f%e6%97%a5&form=hpcapt&filters=HpDate:\"20260615_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260616_SevenMileTurtle"},"Ssd":"20260616","Name":"SevenMileTurtle","Market":"ZH-CN","Hash":"4346512721","FullDateString":"2026 6月 16"},{"ImageContent":{"Description":"这片山脉历经了漫长地质岁月的雕琢，而1934年6月15日的法令则让它们获得了长久的保护——就在这一天，横跨田纳西州与北卡罗来纳州的大烟山国家公园正式建立。该公园占地面积超过522,000英亩（约21.1万公顷），其名称源于常年环绕在其嵴线之上的天然蓝色烟雾。作为阿巴拉契亚山脉的一部分，这些山峰的形成史可以追溯到3亿多年前。","Image":{"Url":"/th?id=OHR.ParkEstd_ZH-CN3419035151_1920x1080.webp","Wallpaper":"/th?id=OHR.ParkEstd_ZH-CN3419035151_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"岁月雕琢，风景始成","Title":"大烟山国家公园，田纳西州，美国","Copyright":"© Mint Images/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"每年六月，大烟山国家公园都会迎来同步发光萤火虫。它们齐声闪烁，上演一场罕见而壮观的天然灯光秀。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260615_ParkEstd\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a7%e7%83%9f%e5%b1%b1%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260614_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260615_ParkEstd"},"Ssd":"20260615","Name":"ParkEstd","Market":"ZH-CN","Hash":"3419035151","FullDateString":"2026 6月 15"},{"ImageContent":{"Description":"拂晓时分，绿头鸭掠过平静的水面，宛如画笔划过画布。其波光粼粼的羽衣在晨光下熠熠生辉——雄鸟那标志性的翠绿色头部与雌鸟斑驳的褐色羽毛形成了鲜明对比。从法国卡马格的沼泽湿地到荷兰阿姆斯特丹的城市运河，随处可见它们的身影，它们堪称欧洲水生生态景观中最为常见的标志性物种。","Image":{"Url":"/th?id=OHR.DuckPond_ZH-CN1683101997_1920x1080.webp","Wallpaper":"/th?id=OHR.DuckPond_ZH-CN1683101997_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"潜羽探清波","Title":"绿头鸭","Copyright":"© Philippe Paternolli/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"绿头鸭具有极强的适应能力，是全球分布最广的鸭科鸟类。从天然湿地到城市公园及运河等人工环境，它们均能良好繁衍。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260614_DuckPond\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%bb%bf%e5%a4%b4%e9%b8%ad&form=hpcapt&filters=HpDate:\"20260613_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260614_DuckPond"},"Ssd":"20260614","Name":"DuckPond","Market":"ZH-CN","Hash":"1683101997","FullDateString":"2026 6月 14"},{"ImageContent":{"Description":"层叠的嵴线横跨南达科他州的恶地国家公园。随着光影变幻，饱受侵蚀的山峰与沟谷悉数呈现在眼前，其间交织着粉红、灰白与金黄的岩层条带。时至今日，风力和流水仍在持续重塑这片地貌，不断剥蚀着质地松软的沉积岩，从而让数百万年的地球历史展露无遗。这些岩层分别由远古河流的沉积物、火山灰，以及该区域曾被浅海覆盖时期的沉积物交替堆积而成。","Image":{"Url":"/th?id=OHR.BadSunset_ZH-CN9050997938_1920x1080.webp","Wallpaper":"/th?id=OHR.BadSunset_ZH-CN9050997938_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"岁月的层峦","Title":"落日，恶地国家公园，南达科他州，美国","Copyright":"© Troy Harrison/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"恶地公园的黄土丘揭示了 3400 万年前的一场重大气候剧变——当时的温暖海域逐渐干涸，演变为气候更凉爽的陆地地貌。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260613_BadSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%81%b6%e5%9c%b0%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260612_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260613_BadSunset"},"Ssd":"20260613","Name":"BadSunset","Market":"ZH-CN","Hash":"9050997938","FullDateString":"2026 6月 13"},{"ImageContent":{"Description":"一抹绚丽的色彩掠过朦胧的野花丛，那是黄喉蜂虎正掠空而过。在展翅捕食间，其羽翼闪烁着青金石绿、金黄与栗红交织的光泽，并通过敏捷的空中转体在飞行中捕捉昆虫。蜜蜂和马蜂是它们最青睐的猎物。在进食前，这种鸟类通常会先拔除猎物的尾刺——这一行为能有效降低自身受伤的风险。在气候温暖的月份里，黄喉蜂虎广泛繁殖于欧洲南部、地中海地区以及亚洲西部等部分地区。","Image":{"Url":"/th?id=OHR.SpainBeeEater_ZH-CN4424052851_1920x1080.webp","Wallpaper":"/th?id=OHR.SpainBeeEater_ZH-CN4424052851_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"惊鸿一瞥","Title":"黄喉蜂虎，格拉萨莱马山自然公园，加的斯，西班牙","Copyright":"© Andres M. Dominguez/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"黄喉蜂虎能挖掘长达3米的筑巢隧道，它们仅凭喙部和双足，就能清理出超过7公斤的泥土。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260612_SpainBeeEater\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%bb%84%e5%96%89%e8%9c%82%e8%99%8e&form=hpcapt&filters=HpDate:\"20260611_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260612_SpainBeeEater"},"Ssd":"20260612","Name":"SpainBeeEater","Market":"ZH-CN","Hash":"4424052851","FullDateString":"2026 6月 12"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息"