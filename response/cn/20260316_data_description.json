{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ISva1e1BF8aTvOXmJMI9uzdbqMA.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/ntdm4jZm9GyjMjm--kT8KtaATHk.css?bu=CMwBzwH7AYgC_gH-Af4BxQI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7x/cir3,cc,nc/Utok7ck07gu22lmsIydejgWEtLY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/OxIDJ4QG2jMh5beFEICLkrgXd0s.css?bu=CIgD_gH-Ab8CmQL-Af4B_gE&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/5y/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/gfxk7HQathU-S3ZTgg0a2mpD9Dg.css?bu=AtIC-AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/5y/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":false,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-16T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"圣帕特里克是爱尔兰的守护圣人，约生于公元4世纪末至5世纪初的罗马不列颠。据传说，他在16岁时被爱尔兰掠夺者绑架，带到爱尔兰成为奴隶。逃回家乡后，他成为传教士，将基督教传播到整个爱尔兰岛。后来的传统中，他以三叶草来解释三位一体而闻名。圣帕特里克的信仰遗产，使得圣帕特里克节成为全球性的庆典。","Image":{"Url":"/th?id=OHR.DonegalFort_ZH-CN0718842170_1920x1080.webp","Wallpaper":"/th?id=OHR.DonegalFort_ZH-CN0718842170_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"爱尔兰的精神十字路口","Title":"艾利赫格里安南环形堡，多内加尔，爱尔兰","Copyright":"© Lukassek/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"艾利赫格里安南环形堡曾是阿尔斯特国王的居所，其铁器时代的石墙与结构展示了古凯尔特人的防御智慧和社会组织能力。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260317_DonegalFort\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%a3%e5%b8%95%e7%89%b9%e9%87%8c%e5%85%8b%e8%8a%82&form=hpcapt&filters=HpDate:\"20260316_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260317_DonegalFort"},"Ssd":"20260317","Name":"DonegalFort","Market":"ZH-CN","Hash":"0718842170","FullDateString":"2026 3月 17"},{"ImageContent":{"Description":"凭借黑白相间的毛色与温顺的性格，大熊猫已成为全球保护的象征。每年的3月16日被定为国家熊猫日，以关注这一标志性物种及其面临的保护挑战。大熊猫原产于中国，由于栖息地破坏和低出生率，曾一度濒临灭绝。得益于全球保护努力，它们的数量正在缓慢回升，但仍需更多工作来保障其未来。","Image":{"Url":"/th?id=OHR.PandaForest_ZH-CN0545156080_1920x1080.webp","Wallpaper":"/th?id=OHR.PandaForest_ZH-CN0545156080_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"走进熊猫世界","Title":"正在吃竹子的大熊猫，中国","Copyright":"© Entwicklungsknecht/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"虽然属于食肉动物，大熊猫的食物几乎全是竹子。由于竹子的营养价值不高，它们每天需要花费数小时进食才能满足能量需求。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260316_PandaForest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a7%e7%86%8a%e7%8c%ab&form=hpcapt&filters=HpDate:\"20260315_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260316_PandaForest"},"Ssd":"20260316","Name":"PandaForest","Market":"ZH-CN","Hash":"0545156080","FullDateString":"2026 3月 16"},{"ImageContent":{"Description":"在加拿大，“太平洋沿岸鲸鱼节”庆祝成千上万头灰鲸每年春季的迁徙盛况——它们沿着岛屿西海岸近岸而行，场面壮观。这项节日由当地社区于20世纪80年代发起，旨在纪念灰鲸从墨西哥下加利福尼亚的繁殖潟湖启程，踏上北返旅程的重要时刻。","Image":{"Url":"/th?id=OHR.PacificRimNP_ZH-CN0350089584_1920x1080.webp","Wallpaper":"/th?id=OHR.PacificRimNP_ZH-CN0350089584_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"掠海而过","Title":"太平洋沿岸国家公园保护区，温哥华岛，加拿大","Copyright":"© EmilyNorton/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"太平洋沿岸鲸鱼节不仅是观鲸活动，还包括海洋主题艺术展、社区巡游和公众讲座，体现了当地居民对海洋文化的长期关注与参与。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260315_PacificRimNP\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%8e%af%e5%a4%aa%e5%b9%b3%e6%b4%8b%e9%b2%b8%e9%b1%bc%e8%8a%82&form=hpcapt&filters=HpDate:\"20260314_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260315_PacificRimNP"},"Ssd":"20260315","Name":"PacificRimNP","Market":"ZH-CN","Hash":"0350089584","FullDateString":"2026 3月 15"},{"ImageContent":{"Description":"在圆周率尚未有名字之前，人们就被它的奥秘所吸引。每年的3月14日，被定为“圆周率日”，以纪念数学中最著名的常数之一。这个日期正好对应圆周率π的前三位数字(3.14)，即圆的周长与直径之比。圆周率无穷且不循环的小数部分长期以来一直令学者们着迷。现代的庆祝活动始于1988年，当时物理学家拉里·肖(Larry Shaw)用一种特别的方式纪念这一天：享用美味的派(pie)。","Image":{"Url":"/th?id=OHR.CornwallDolmen_ZH-CN0045468799_1920x1080.webp","Wallpaper":"/th?id=OHR.CornwallDolmen_ZH-CN0045468799_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"圆周率的古老启示","Title":"兰扬石门，位于英格兰康沃尔郡的一座兰扬新石器时代石棚墓，英国","Copyright":"© Helen Hotson/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"兰扬石门的巨石排列展示了新石器时代工匠对材料选择和空间布局的智慧。它不仅是墓葬遗迹，也体现了当时人类对环境与自然力量的适应能力。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260314_CornwallDolmen\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%86%e5%91%a8%e7%8e%87%e6%97%a5&form=hpcapt&filters=HpDate:\"20260313_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260314_CornwallDolmen"},"Ssd":"20260314","Name":"CornwallDolmen","Market":"ZH-CN","Hash":"0045468799","FullDateString":"2026 3月 14"},{"ImageContent":{"Description":"在法国西部海滨小镇莱萨布勒多洛讷的邦港圣母堂拱顶下，石质拱肋依旧引导着视线向上。高耸的拱顶自1646年开始建造，这座教堂自1993年被列为法国历史古迹，坐落在一座13世纪小礼拜堂的旧址上，静静讲述着大西洋沿岸悠久的精神文化与历史故事。","Image":{"Url":"/th?id=OHR.VendeeVaults_ZH-CN9885568795_1920x1080.webp","Wallpaper":"/th?id=OHR.VendeeVaults_ZH-CN9885568795_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"静谧的石之杰作","Title":"邦港圣母教堂拱顶，莱萨布勒多洛讷，法国","Copyright":"© Helmut Meyer zur Capellen/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"邦港圣母堂的18世纪管风琴，是教堂内的艺术珍宝，节日期间为音乐增添独特氛围。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260313_VendeeVaults\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b3%95%e5%9b%bd%e8%8e%b1%e8%90%a8%e5%b8%83%e5%8b%92%e5%a4%9a%e6%b4%9b%e8%ae%b7&form=hpcapt&filters=HpDate:\"20260312_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260313_VendeeVaults"},"Ssd":"20260313","Name":"VendeeVaults","Market":"ZH-CN","Hash":"9885568795","FullDateString":"2026 3月 13"},{"ImageContent":{"Description":"在厄瓜多尔的云雾森林高处，一只幼年日鳽展开翅膀进行早期展示，橙色、黑色和白色的斑纹在透过树叶的绿色光影中闪现。突如其来的色彩对比穿透覆盖苔藓的枝干和叶影下的林下层，呈现出这一物种戏剧性的翅膀斑纹。成年的日鳽通常在防御展示时才会显露这些醒目的斑纹，短暂地将这只原本隐秘的鸟变成引人注目的视觉奇观。","Image":{"Url":"/th?id=OHR.SunbitternEcuador_ZH-CN9772788253_1920x1080.webp","Wallpaper":"/th?id=OHR.SunbitternEcuador_ZH-CN9772788253_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"排练中的翅膀","Title":"幼年日鳽在巢穴附近展示求偶行为, 厄瓜多尔","Copyright":"© Andy Rouse/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"日鳽的翅膀上有类似眼睛的斑纹，通常在昏暗的森林中展开翅膀展示时显现出来。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260312_SunbitternEcuador\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%97%a5%e9%b3%bd&form=hpcapt&filters=HpDate:\"20260311_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260312_SunbitternEcuador"},"Ssd":"20260312","Name":"SunbitternEcuador","Market":"ZH-CN","Hash":"9772788253","FullDateString":"2026 3月 12"},{"ImageContent":{"Description":"在谢萨，春天的到来别具一格。它并非缓缓展开，而是色彩缤纷，绚烂夺目。每年二月至三月，这座位于西班牙穆尔西亚地区的小城便成为“花期”（La Floración）的中心，也就是桃树盛开的季节。短短几天内，超过12000英亩的土地——西班牙最大的城市桃园——便会变成我们今天看到的这片色彩斑斓的海洋。","Image":{"Url":"/th?id=OHR.PeachBloom_ZH-CN9660251274_1920x1080.webp","Wallpaper":"/th?id=OHR.PeachBloom_ZH-CN9660251274_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一个美好的春天","Title":"盛开的桃树, 谢萨, 穆尔西亚, 西班牙","Copyright":"© Juan Maria Coy Vergara/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"西班牙穆尔西亚的锡耶萨以春季盛开的桃花而闻名，粉白色的花海为大地披上了美丽的色彩。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260311_PeachBloom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%a5%bf%e7%8f%ad%e7%89%99%e8%b0%a2%e8%90%a8&form=hpcapt&filters=HpDate:\"20260310_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260311_PeachBloom"},"Ssd":"20260311","Name":"PeachBloom","Market":"ZH-CN","Hash":"9660251274","FullDateString":"2026 3月 11"}],"PreloadMediaContents":[{"ImageContent":{"Description":"从空中俯瞰，中国武汉的东湖樱花园宛如一朵淡紫色的云，轻柔地停驻在大地之上。成千上万株樱花同时盛放，浅色花瓣在公园中心一座金色五层宝塔周围织就出一片生机盎然的花海穹顶。宝塔以沉静而对称的姿态挺立，层层飞檐在柔和的春日色彩映衬下熠熠生辉。","Image":{"Url":"/th?id=OHR.WuhanCherryBlossom_ZH-CN1031985926_1920x1080.webp","Wallpaper":"/th?id=OHR.WuhanCherryBlossom_ZH-CN1031985926_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"春天的形状","Title":"东湖樱花园的樱花，武汉，中国","Copyright":"© Zhang Qiao/VCG/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"武汉樱花花期很短，单株3—5天盛放，最佳观赏期常不足一周。气温每升高1℃，花期都会提前。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260324_WuhanCherryBlossom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e6%ad%a6%e6%b1%89%e4%b8%9c%e6%b9%96%e6%a8%b1%e8%8a%b1%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260323_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260324_WuhanCherryBlossom"},"Ssd":"20260324","Name":"WuhanCherryBlossom","Market":"ZH-CN","Hash":"1031985926","FullDateString":"2026 3月 24"},{"ImageContent":{"Description":"今天是世界水日。该纪念日由联合国于1992年设立，并于次年首次举行。人类已不能再随波逐流——我们必须守护那些维系生命的水流。在非洲东部大裂谷的坦噶尼喀湖，几乎最能体现这种紧迫感。从太空俯瞰，它宛如一条长约420英里（约676公里）的蓝色丝带，连接着坦桑尼亚、布隆迪、刚果民主共和国和赞比亚。在湖岸边，它则是一处拥有约1000万年历史的裂谷盆地，由地壳缓慢张裂形成。","Image":{"Url":"/th?id=OHR.SonoranStorm_ZH-CN0579792563_1920x1080.webp","Wallpaper":"/th?id=OHR.SonoranStorm_ZH-CN0579792563_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"当水划出界线","Title":"坦噶尼喀湖，非洲","Copyright":"© BEST-BACKGROUNDS/NASA/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"坦噶尼喀湖是世界上最长的淡水湖，也是世界第二深湖，仅次于俄罗斯的贝加尔湖。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260323_SonoranStorm\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b0%b4%e6%97%a5&form=hpcapt&filters=HpDate:\"20260322_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260323_SonoranStorm"},"Ssd":"20260323","Name":"SonoranStorm","Market":"ZH-CN","Hash":"0579792563","FullDateString":"2026 3月 23"},{"ImageContent":{"Description":"今天是世界水日。该纪念日由联合国于1992年设立，并于次年首次举行。人类已不能再随波逐流——我们必须守护那些维系生命的水流。在非洲东部大裂谷的坦噶尼喀湖，几乎最能体现这种紧迫感。从太空俯瞰，它宛如一条长约420英里（约676公里）的蓝色丝带，连接着坦桑尼亚、布隆迪、刚果民主共和国和赞比亚。在湖岸边，它则是一处拥有约1000万年历史的裂谷盆地，由地壳缓慢张裂形成。","Image":{"Url":"/th?id=OHR.TanganyikaWater_ZH-CN4884850067_1920x1080.webp","Wallpaper":"/th?id=OHR.TanganyikaWater_ZH-CN4884850067_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"当水划出界线","Title":"坦噶尼喀湖，非洲","Copyright":"© BEST-BACKGROUNDS/NASA/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"坦噶尼喀湖是世界上最长的淡水湖，也是世界第二深湖，仅次于俄罗斯的贝加尔湖。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260322_TanganyikaWater\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b0%b4%e6%97%a5&form=hpcapt&filters=HpDate:\"20260321_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260322_TanganyikaWater"},"Ssd":"20260322","Name":"TanganyikaWater","Market":"ZH-CN","Hash":"4884850067","FullDateString":"2026 3月 22"},{"ImageContent":{"Description":"如果地球有一支“维护团队”，森林一定会冲在最前线。它们吸收碳排放，减少水土流失，保护生物多样性，影响降雨，并帮助维持清洁的水源。目前，森林仍覆盖着全球约31%的陆地面积，但其持续减少表明，这些自然系统正变得愈发脆弱。大片森林仍在被开垦，用于农业生产、基础设施建设和资源开发，使生态系统以令人担忧的速度不断削弱。","Image":{"Url":"/th?id=OHR.LeteaForest_ZH-CN4153496399_1920x1080.webp","Wallpaper":"/th?id=OHR.LeteaForest_ZH-CN4153496399_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"根系自由生长的地方","Title":"莱泰亚森林，多瑙河三角洲，罗马尼亚","Copyright":"© Wild Wonders of Europe/Widstrand/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"联合国粮食及农业组织估计，每年约有2470万英亩（约1000万公顷）的森林被砍伐。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260321_LeteaForest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e6%a3%ae%e6%9e%97%e6%97%a5&form=hpcapt&filters=HpDate:\"20260320_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260321_LeteaForest"},"Ssd":"20260321","Name":"LeteaForest","Market":"ZH-CN","Hash":"4153496399","FullDateString":"2026 3月 21"},{"ImageContent":{"Description":"在中国，春天的到来常常与樱花的绽放紧密相连。从南方到北方，公园与河畔逐渐被轻柔的花瓣装点，宛如铺展开来的粉色云霞。樱花象征着新生、希望，以及春日短暂却动人的美丽。每到花开时节，人们纷纷走进赏花胜地，感受早春的温暖与生机。","Image":{"Url":"/th?id=OHR.SpringEquinoxY26_ZH-CN7450181382_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringEquinoxY26_ZH-CN7450181382_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"春日绯梦","Title":"春日樱花，上海，中国","Copyright":"© junyyeung/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"如今种植在中国各地的许多樱花树，属于一百多年前引入的观赏品种。不同品种的花期略有差异，因此在一些城市，从三月初到四月中旬，人们都能欣赏到延续数周的樱花盛放景象。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260320_SpringEquinoxY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e7%9a%84%e6%a8%b1%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260319_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260320_SpringEquinoxY26"},"Ssd":"20260320","Name":"SpringEquinoxY26","Market":"ZH-CN","Hash":"7450181382","FullDateString":"2026 3月 20"},{"ImageContent":{"Description":"一种会下蛋的哺乳动物。没有牙齿。爬行动物般的步态。自带“盔甲”。如果说短喙针鼹听起来像一份矛盾清单，那是因为它确实如此——而且玩得很自如。它原产于澳大利亚、塔斯马尼亚及新几内亚部分地区，是现存为数不多的单孔类动物之一，也就是会下蛋的哺乳动物。尽管常常登上新闻头条，它仍然完全属于哺乳动物：有毛发、会分泌乳汁、体温恒定。特别之处在于，它的乳汁不是通过乳头，而是通过特殊皮肤区域分泌，小针鼹靠舔食来摄取乳汁。","Image":{"Url":"/th?id=OHR.EchidnaAustralia_ZH-CN0913792118_1920x1080.webp","Wallpaper":"/th?id=OHR.EchidnaAustralia_ZH-CN0913792118_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"激发你的好奇心","Title":"澳洲针鼹，阿德莱德山，澳大利亚","Copyright":"© Etienne Littlefair/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"短喙针鼹用电感受器探测地下猎物，粘舌捕食，刺毛防御，是自然界独特的小“全能战士”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260319_EchidnaAustralia\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%be%b3%e6%b4%b2%e9%92%88%e9%bc%b9&form=hpcapt&filters=HpDate:\"20260318_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260319_EchidnaAustralia"},"Ssd":"20260319","Name":"EchidnaAustralia","Market":"ZH-CN","Hash":"0913792118","FullDateString":"2026 3月 19"},{"ImageContent":{"Description":"汤姆·麦考尔滨水公园位于俄勒冈州波特兰威拉米特河畔，占地36英亩，是这座城市最受欢迎的绿地之一。每年春季——通常从3月中旬到4月初——公园会被粉色与白色的樱花覆盖，仿佛置身花海。沿着风景优美的步道漫步，这些充满生机的樱树为城市中心提供了一片宁静的休憩空间。公园内还有多处著名景点，如萨蒙街喷泉（Salmon Street Springs），一个拥有众多水柱的互动喷泉，以及波特兰周六市场（Portland Saturday Market），是当地居民和游客喜爱的热门去处。","Image":{"Url":"/th?id=OHR.PortlandBlossoms_ZH-CN0814501668_1920x1080.webp","Wallpaper":"/th?id=OHR.PortlandBlossoms_ZH-CN0814501668_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"城市花开","Title":"汤姆·麦考尔滨水公园的樱花，