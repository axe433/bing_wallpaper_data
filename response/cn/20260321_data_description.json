{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/L98s5ius_7FQHBVSccS9vJeL414.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/ntdm4jZm9GyjMjm--kT8KtaATHk.css?bu=CMwBzwH7AYgC_gH-Af4BxQI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7x/cir3,cc,nc/Utok7ck07gu22lmsIydejgWEtLY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/OxIDJ4QG2jMh5beFEICLkrgXd0s.css?bu=CIgD_gH-Ab8CmQL-Af4B_gE&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/5y/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/gfxk7HQathU-S3ZTgg0a2mpD9Dg.css?bu=AtIC-AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/5y/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-03-21T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"今天是世界水日。该纪念日由联合国于1992年设立，并于次年首次举行。人类已不能再随波逐流——我们必须守护那些维系生命的水流。在非洲东部大裂谷的坦噶尼喀湖，几乎最能体现这种紧迫感。从太空俯瞰，它宛如一条长约420英里（约676公里）的蓝色丝带，连接着坦桑尼亚、布隆迪、刚果民主共和国和赞比亚。在湖岸边，它则是一处拥有约1000万年历史的裂谷盆地，由地壳缓慢张裂形成。","Image":{"Url":"/th?id=OHR.TanganyikaWater_ZH-CN4884850067_1920x1080.webp","Wallpaper":"/th?id=OHR.TanganyikaWater_ZH-CN4884850067_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"当水划出界线","Title":"坦噶尼喀湖，非洲","Copyright":"© BEST-BACKGROUNDS/NASA/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"坦噶尼喀湖是世界上最长的淡水湖，也是世界第二深湖，仅次于俄罗斯的贝加尔湖。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260322_TanganyikaWater\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b0%b4%e6%97%a5&form=hpcapt&filters=HpDate:\"20260321_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260322_TanganyikaWater"},"Ssd":"20260322","Name":"TanganyikaWater","Market":"ZH-CN","Hash":"4884850067","FullDateString":"2026 3月 22"},{"ImageContent":{"Description":"如果地球有一支“维护团队”，森林一定会冲在最前线。它们吸收碳排放，减少水土流失，保护生物多样性，影响降雨，并帮助维持清洁的水源。目前，森林仍覆盖着全球约31%的陆地面积，但其持续减少表明，这些自然系统正变得愈发脆弱。大片森林仍在被开垦，用于农业生产、基础设施建设和资源开发，使生态系统以令人担忧的速度不断削弱。","Image":{"Url":"/th?id=OHR.LeteaForest_ZH-CN4153496399_1920x1080.webp","Wallpaper":"/th?id=OHR.LeteaForest_ZH-CN4153496399_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"根系自由生长的地方","Title":"莱泰亚森林，多瑙河三角洲，罗马尼亚","Copyright":"© Wild Wonders of Europe/Widstrand/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"联合国粮食及农业组织估计，每年约有2470万英亩（约1000万公顷）的森林被砍伐。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260321_LeteaForest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e6%a3%ae%e6%9e%97%e6%97%a5&form=hpcapt&filters=HpDate:\"20260320_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260321_LeteaForest"},"Ssd":"20260321","Name":"LeteaForest","Market":"ZH-CN","Hash":"4153496399","FullDateString":"2026 3月 21"},{"ImageContent":{"Description":"在中国，春天的到来常常与樱花的绽放紧密相连。从南方到北方，公园与河畔逐渐被轻柔的花瓣装点，宛如铺展开来的粉色云霞。樱花象征着新生、希望，以及春日短暂却动人的美丽。每到花开时节，人们纷纷走进赏花胜地，感受早春的温暖与生机。","Image":{"Url":"/th?id=OHR.SpringEquinoxY26_ZH-CN7450181382_1920x1080.webp","Wallpaper":"/th?id=OHR.SpringEquinoxY26_ZH-CN7450181382_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"春日绯梦","Title":"春日樱花，上海，中国","Copyright":"© junyyeung/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"如今种植在中国各地的许多樱花树，属于一百多年前引入的观赏品种。不同品种的花期略有差异，因此在一些城市，从三月初到四月中旬，人们都能欣赏到延续数周的樱花盛放景象。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260320_SpringEquinoxY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e7%9a%84%e6%a8%b1%e8%8a%b1&form=hpcapt&filters=HpDate:\"20260319_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260320_SpringEquinoxY26"},"Ssd":"20260320","Name":"SpringEquinoxY26","Market":"ZH-CN","Hash":"7450181382","FullDateString":"2026 3月 20"},{"ImageContent":{"Description":"一种会下蛋的哺乳动物。没有牙齿。爬行动物般的步态。自带“盔甲”。如果说短喙针鼹听起来像一份矛盾清单，那是因为它确实如此——而且玩得很自如。它原产于澳大利亚、塔斯马尼亚及新几内亚部分地区，是现存为数不多的单孔类动物之一，也就是会下蛋的哺乳动物。尽管常常登上新闻头条，它仍然完全属于哺乳动物：有毛发、会分泌乳汁、体温恒定。特别之处在于，它的乳汁不是通过乳头，而是通过特殊皮肤区域分泌，小针鼹靠舔食来摄取乳汁。","Image":{"Url":"/th?id=OHR.EchidnaAustralia_ZH-CN0913792118_1920x1080.webp","Wallpaper":"/th?id=OHR.EchidnaAustralia_ZH-CN0913792118_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"激发你的好奇心","Title":"澳洲针鼹，阿德莱德山，澳大利亚","Copyright":"© Etienne Littlefair/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"短喙针鼹用电感受器探测地下猎物，粘舌捕食，刺毛防御，是自然界独特的小“全能战士”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260319_EchidnaAustralia\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%be%b3%e6%b4%b2%e9%92%88%e9%bc%b9&form=hpcapt&filters=HpDate:\"20260318_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260319_EchidnaAustralia"},"Ssd":"20260319","Name":"EchidnaAustralia","Market":"ZH-CN","Hash":"0913792118","FullDateString":"2026 3月 19"},{"ImageContent":{"Description":"汤姆·麦考尔滨水公园位于俄勒冈州波特兰威拉米特河畔，占地36英亩，是这座城市最受欢迎的绿地之一。每年春季——通常从3月中旬到4月初——公园会被粉色与白色的樱花覆盖，仿佛置身花海。沿着风景优美的步道漫步，这些充满生机的樱树为城市中心提供了一片宁静的休憩空间。公园内还有多处著名景点，如萨蒙街喷泉（Salmon Street Springs），一个拥有众多水柱的互动喷泉，以及波特兰周六市场（Portland Saturday Market），是当地居民和游客喜爱的热门去处。","Image":{"Url":"/th?id=OHR.PortlandBlossoms_ZH-CN0814501668_1920x1080.webp","Wallpaper":"/th?id=OHR.PortlandBlossoms_ZH-CN0814501668_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"城市花开","Title":"汤姆·麦考尔滨水公园的樱花，波特兰，俄勒冈州，美国","Copyright":"© Eric Vogt/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"汤姆·麦考尔滨水公园曾是港口和工业区，但经过城市改造，如今成为市民休闲和文化活动的核心空间。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260318_PortlandBlossoms\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b1%a4%e5%a7%86%c2%b7%e9%ba%a6%e8%80%83%e5%b0%94%e6%bb%a8%e6%b0%b4%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260317_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260318_PortlandBlossoms"},"Ssd":"20260318","Name":"PortlandBlossoms","Market":"ZH-CN","Hash":"0814501668","FullDateString":"2026 3月 18"},{"ImageContent":{"Description":"圣帕特里克是爱尔兰的守护圣人，约生于公元4世纪末至5世纪初的罗马不列颠。据传说，他在16岁时被爱尔兰掠夺者绑架，带到爱尔兰成为奴隶。逃回家乡后，他成为传教士，将基督教传播到整个爱尔兰岛。后来的传统中，他以三叶草来解释三位一体而闻名。圣帕特里克的信仰遗产，使得圣帕特里克节成为全球性的庆典。","Image":{"Url":"/th?id=OHR.DonegalFort_ZH-CN0718842170_1920x1080.webp","Wallpaper":"/th?id=OHR.DonegalFort_ZH-CN0718842170_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"爱尔兰的精神十字路口","Title":"艾利赫格里安南环形堡，多内加尔，爱尔兰","Copyright":"© Lukassek/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"艾利赫格里安南环形堡曾是阿尔斯特国王的居所，其铁器时代的石墙与结构展示了古凯尔特人的防御智慧和社会组织能力。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260317_DonegalFort\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%a3%e5%b8%95%e7%89%b9%e9%87%8c%e5%85%8b%e8%8a%82&form=hpcapt&filters=HpDate:\"20260316_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260317_DonegalFort"},"Ssd":"20260317","Name":"DonegalFort","Market":"ZH-CN","Hash":"0718842170","FullDateString":"2026 3月 17"},{"ImageContent":{"Description":"凭借黑白相间的毛色与温顺的性格，大熊猫已成为全球保护的象征。每年的3月16日被定为国家熊猫日，以关注这一标志性物种及其面临的保护挑战。大熊猫原产于中国，由于栖息地破坏和低出生率，曾一度濒临灭绝。得益于全球保护努力，它们的数量正在缓慢回升，但仍需更多工作来保障其未来。","Image":{"Url":"/th?id=OHR.PandaForest_ZH-CN0545156080_1920x1080.webp","Wallpaper":"/th?id=OHR.PandaForest_ZH-CN0545156080_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"走进熊猫世界","Title":"正在吃竹子的大熊猫，中国","Copyright":"© Entwicklungsknecht/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"虽然属于食肉动物，大熊猫的食物几乎全是竹子。由于竹子的营养价值不高，它们每天需要花费数小时进食才能满足能量需求。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260316_PandaForest\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a7%e7%86%8a%e7%8c%ab&form=hpcapt&filters=HpDate:\"20260315_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260316_PandaForest"},"Ssd":"20260316","Name":"PandaForest","Market":"ZH-CN","Hash":"0545156080","FullDateString":"2026 3月 16"}],"PreloadMediaContents":[{"ImageContent":{"Description":"佩吉湾是新斯科舍省崎岖海岸线上一个迷人而小巧的村庄，展现了海滨生活的一角。村里最著名的地标是佩吉角灯塔（也称佩吉湾灯塔），它最初建于1868年，后于1915年被现在的灯塔所取代。一个多世纪以来，它指引着船只穿梭于变幻莫测的大西洋，成为海岸生活永恒的象征。周围的景色，海风吹拂，波涛汹涌，仿佛时间在这里停滞。","Image":{"Url":"/th?id=OHR.PeggysLighthouse_ZH-CN5730463973_1920x1080.webp","Wallpaper":"/th?id=OHR.PeggysLighthouse_ZH-CN5730463973_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"海边的宁静","Title":"佩吉角灯塔, 大西洋海岸, 新斯科舍省, 加拿大","Copyright":"© Prashanth Bala/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"佩吉湾村周围是佩吉湾保护区，这是一片占地 1000 英亩的受保护土地，拥有敏感的生态系统。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260329_PeggysLighthouse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bd%a9%e5%90%89%e8%a7%92%e7%81%af%e5%a1%94&form=hpcapt&filters=HpDate:\"20260328_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260329_PeggysLighthouse"},"Ssd":"20260329","Name":"PeggysLighthouse","Market":"ZH-CN","Hash":"5730463973","FullDateString":"2026 3月 29"},{"ImageContent":{"Description":"非洲水牛体型庞大，威风凛凛，漫步于坦桑尼亚的稀树草原和湿地，尤其是在恩戈罗恩戈罗保护区（NCA）内。它们以硕大弯曲的牛角和庞大的体型而闻名，是“非洲五霸”（水牛、大象、豹子、犀牛、狮子）之一，并因其力量和适应力而备受尊崇。恩戈罗恩戈罗保护区是联合国教科文组织世界遗产，为观察这些令人敬畏的食草动物提供了壮丽而丰富的生态环境。","Image":{"Url":"/th?id=OHR.CapeBuffalo_ZH-CN5591123662_1920x1080.webp","Wallpaper":"/th?id=OHR.CapeBuffalo_ZH-CN5591123662_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"未驯服的精神","Title":"非洲水牛, 恩戈罗恩戈罗火山口, 坦桑尼亚","Copyright":"© jesuss8/500px/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"非洲水牛的视力和听力都比较差，但嗅觉却很灵敏。它们似乎也比较难调节体温——这也是它们主要在夜间觅食的原因。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260328_CapeBuffalo\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%9d%9e%e6%b4%b2%e6%b0%b4%e7%89%9b&form=hpcapt&filters=HpDate:\"20260327_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260328_CapeBuffalo"},"Ssd":"20260328","Name":"CapeBuffalo","Market":"ZH-CN","Hash":"5591123662","FullDateString":"2026 3月 28"},{"ImageContent":{"Description":"乍一看，无线电城音乐厅的内部装潢无疑会吸引你的目光，让你兴奋不已。仿佛置身于纽约市中心的阳光下——这是装饰艺术风格狂热的化身，展现了20世纪30年代人们对未来的憧憬。每年的3月27日是世界戏剧日，人们都会庆祝这种令人叹为观止的震撼体验。","Image":{"Url":"/th?id=OHR.RadioCityHall_ZH-CN5492649461_1920x1080.webp","Wallpaper":"/th?id=OHR.RadioCityHall_ZH-CN5492649461_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"依然明亮地燃烧着","Title":"纽约市的无线电城音乐厅, 美国","Copyright":"© Clarence Holmes Photography/Alamy","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"世界戏剧日由国际戏剧协会（ITI）创立，并于1962年3月27日首次庆祝，当天也是巴黎“民族剧院”演出季的开幕日。此后，每年的这一天，世界戏剧日都会在全球范围内庆祝。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260327_RadioCityHall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%88%8f%e5%89%a7%e6%97%a5&form=hpcapt&filters=HpDate:\"20260326_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260327_RadioCityHall"},"Ssd":"20260327","Name":"RadioCityHall","Market":"ZH-CN","Hash":"5492649461","FullDateString":"2026 3月 27"},{"ImageContent":{"Description":"沿着加拿大温哥华岛西南部偏远海岸延伸的西海岸步道，是该国最具传奇色彩的徒步路线之一。这条步道位于 太平洋沿岸国家公园保护区，全长约47英里，穿越雨林、沙滩和岩石海岸线。该步道始建于1907年，最初是一条为海难幸存者设立的救生通道，沿线海域曾被水手称为“太平洋墓地”。","Image":{"Url":"/th?id=OHR.LoganCreek_ZH-CN5372283365_1920x1080.webp","Wallpaper":"/th?id=OHR.LoganCreek_ZH-CN5372283365_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"凌驾荒野之上","Title":"洛根溪吊桥，西海岸步道，加拿大","Copyright":"© Tandem Stock/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"由于泥泞路段、木梯、河流以及多变而严酷的海岸天气，西海岸步道 通常需要6至8天才能完成。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260326_LoganCreek\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8a%a0%e6%8b%bf%e5%a4%a7%e8%a5%bf%e6%b5%b7%e5%b2%b8%e6%ad%a5%e9%81%93&form=hpcapt&filters=HpDate:\"20260325_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260326_LoganCreek"},"Ssd":"20260326","Name":"LoganCreek","Market":"ZH-CN","Hash":"5372283365","FullDateString":"2026 3月 26"},{"ImageContent":{"Description":"海牛看起来行动缓慢、昏昏欲睡，但在水下却有不少令人惊讶的“本领”。首先，它们是少数会持续更换牙齿的哺乳动物之一。首先，它们是少数会持续更换牙齿的哺乳动物之一。当臼齿因咀嚼含沙的海草而磨损时，新牙会像传送带一样缓缓向前移动、替换旧牙——这对每天进食可达8小时的它们来说尤为重要。","Image":{"Url":"/th?id=OHR.ManateeSpring_ZH-CN5252847120_1920x1080.webp","Wallpaper":"/th?id=OHR.ManateeSpring_ZH-CN5252847120_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"海牛的秘密生活","Title":"淡水泉中的幼年海牛，水晶河，佛罗里达州，美国","Copyright":"© Gregory Sweeney/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"海牛的新陈代谢非常缓慢，静息时心率通常只有每分钟约25次，比许多同体型哺乳动物都低。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260325_ManateeSpring\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e6%b5%b7%e7%89%9b%e6%97%a5&form=hpcapt&filters=HpDate:\"20260324_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260325_ManateeSpring"},"Ssd":"20260325","Name":"ManateeSpring","Market":"ZH-CN","Hash":"5252847120","FullDateString":"2026 3月 25"},{"ImageContent":{"Description":"从空中俯瞰，中国武汉的东湖樱花园宛如一朵淡紫色的云，轻柔地停驻在大地之上。成千上万株樱花同时盛放，浅色花瓣在公园中心一座金色五层宝塔周围织就出一片生机盎然的花海穹顶。宝塔以沉静而对称的姿态挺立，层层飞檐在柔和的春日色彩映衬下熠熠生辉。","Image":{"Url":"/th?id=OHR.WuhanCherryBlossom_ZH-CN1031985926_1920x1080.webp","Wallpaper":"/th?id=OHR.WuhanCherryBlossom_ZH-CN1031985926_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":false},"Headline":"春天的形状","Title":"东湖樱花园的樱花，武汉，中国","Copyright":"© Zhang Qiao/VCG/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"武汉樱花花期很短，单株3—5天盛放，最佳观赏期常不足一周。气温每升高1℃，花期都会提前。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260324_WuhanCherryBlossom\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%ad%e5%9b%bd%e6%ad%a6%e6%b1%89%e4%b8%9c%e6%b9%96%e6%a8%b1%e8%8a%b1%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260323_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260324_WuhanCherryBlossom"},"Ssd":"20260324","Name":"WuhanCherryBlossom","Market":"ZH-CN","Hash":"1031985926","FullDateString":"2026 3月 24"},{"ImageContent":{"Description":"今天是世界水日。该纪念日由联合国于1992年设立，并于次年首次举行。人类已不能再随波逐流——我们必须守护那些维系生命的水流。在非洲东部大裂谷的坦噶尼喀湖，几乎最能体现这种紧迫感。从太空俯瞰，它宛如一条长约420英里（约676公里）的蓝色丝带，连接着坦桑尼亚、布隆迪、刚果民主共和国和赞比亚。在湖岸边，它则是一处拥有约1000万年历史的裂谷盆地，由地壳缓慢张裂形成。","Image":{"Url":"/th?id=OHR.SonoranStorm_ZH-CN0579792563_1920x1080.webp","Wallpaper":"/th?id=OHR.SonoranStorm_ZH-CN0579792563_1920x1