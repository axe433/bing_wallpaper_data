{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/XZsmWBUJgDgwzyUH8iR7Ev0cdLQ.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/oaKw3Xf5yBWquCOx4GI3JZoUubI.css?bu=CPUB-AGZAqgCnAKcApwC5AI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7q/cir3,cc,nc/CUCSI1SFeWrmYnIaftq0iQdznqQ.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/xAIM9GK6AwVkMfo-UN96AOzkznQ.css?bu=CJQDnAKcAt4CuAKcApwCnAI&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/zmTB4hEk3xeY-WDa-Zn8LizFCcg.css?bu=AvEC_wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/63/cc,nc/pZ5R_tJWe7QpulmAzB8Jp71qd-o.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2PortalFullScreen":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-06-26T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"议会大厦、钟楼和巨型摩天轮有什么共同之处？它们都矗立在泰晤士河畔，仿佛伦敦为了营造戏剧性效果而精心布局了这些标志性建筑。","Image":{"Url":"/th?id=OHR.ThamesSummer_ZH-CN5292532714_1920x1080.webp","Wallpaper":"/th?id=OHR.ThamesSummer_ZH-CN5292532714_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"时事","Title":"泰晤士河, 伦敦, 英格兰","Copyright":"© Daniel Lange/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"泰晤士河防洪闸于1984年建成，是世界上规模最大的可移动防洪设施之一，用于保护伦敦免受北海风暴潮引发的洪水威胁。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260626_ThamesSummer\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b3%b0%e6%99%a4%e5%a3%ab%e6%b2%b3&form=hpcapt&filters=HpDate:\"20260625_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260626_ThamesSummer"},"Ssd":"20260626","Name":"ThamesSummer","Market":"ZH-CN","Hash":"5292532714","FullDateString":"2026 6月 26"},{"ImageContent":{"Description":"在比利时，很少有哪个广场能像大广场那样承载如此丰富的历史。广场周围的建筑，正如照片所示，最初都是行会会所，每座会所都由特定的行业出资兴建。酿酒师、面包师、商人和工匠们将建筑视为一种语言，通过浮雕、纹章和大量的金箔，将工作、地位和竞争关系凝结于石头之上。各种建筑风格在此交融碰撞，毫不拘束。哥特式的垂直线条与巴洛克式的曲线并肩而立，而市政厅——这座比周围建筑更古老、造型大胆不对称的建筑——则将整个建筑群和谐地连接起来。","Image":{"Url":"/th?id=OHR.GrandPlace_ZH-CN8806496436_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandPlace_ZH-CN8806496436_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"在广场中感受历史","Title":"布鲁塞尔大广场上的建筑群, 比利时","Copyright":"© Vladislav Zolotov/Getty Images Plus","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"布鲁塞尔大广场并非严格的正方形，而是略呈梯形，这种微妙的透视结构会产生“视觉矫正”效果，使市政厅在空间中显得更加居中与平衡。该遗址于1998年被列入联合国教科文组织世界遗产名录。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260625_GrandPlace\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b8%83%e9%b2%81%e5%a1%9e%e5%b0%94%e5%a4%a7%e5%b9%bf%e5%9c%ba&form=hpcapt&filters=HpDate:\"20260624_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260625_GrandPlace"},"Ssd":"20260625","Name":"GrandPlace","Market":"ZH-CN","Hash":"8806496436","FullDateString":"2026 6月 25"},{"ImageContent":{"Description":"放大观察维持大地生机的微小交易：一只蝴蝶停在黄色的花朵上，吮吸着花蜜。它吸食花蜜的同时，花粉沾满了它的身体，搭上了前往下一朵花的“顺风车”——这是开花植物悄无声息的繁殖方式之一。传粉者并非只有蜜蜂。蝴蝶、鸟类、蝙蝠、甲虫以及许多其他昆虫都在帮助传播花粉，从而支持野生植物以及我们食用的许多水果和蔬菜的生长。","Image":{"Url":"/th?id=OHR.BFPollin_ZH-CN7654067396_1920x1080.webp","Wallpaper":"/th?id=OHR.BFPollin_ZH-CN7654067396_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"花粉与翅膀相遇","Title":"蝴蝶正在黄花上授粉","Copyright":"© lzh/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"我们所吃的食物中，大约有三分之一要归功于授粉昆虫。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260624_BFPollin\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%9d%b4%e8%9d%b6%e6%8e%88%e7%b2%89&form=hpcapt&filters=HpDate:\"20260623_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260624_BFPollin"},"Ssd":"20260624","Name":"BFPollin","Market":"ZH-CN","Hash":"7654067396","FullDateString":"2026 6月 24"},{"ImageContent":{"Description":"富士山是日本最高峰，海拔12,389英尺（约3700米），耸立于本州岛，位于东京西南约60英里（约97公里）处。这座近乎完美的锥形山峰是一座火山——自1707年12月最后一次喷发后便一直处于休眠状态，但仍被归类为活火山。那次大规模喷发被称为宝荣喷发，火山灰和其他火山碎屑喷涌而出，席卷日本东部，甚至远至江户（今东京）。除了地质学意义之外，富士山长期以来被视为神圣的景观和朝圣登山的目的地，这体现了日本自然、宗教和日常生活的交融。这种经久不衰的文化魅力也是它于2013年被联合国教科文组织列为世界遗产的原因之一，被誉为“神圣之地和艺术灵感的源泉”。众所周知，在晴朗的日子里，富士山从远处就能清晰可见，但这并非必然——云层可能在几分钟内将其遮蔽。无论您是徒步攀登，还是只是从火车车窗瞥见它，它依然是日本地平线上的标志性景观。","Image":{"Url":"/th?id=OHR.Fujisan_ZH-CN7203975085_1920x1080.webp","Wallpaper":"/th?id=OHR.Fujisan_ZH-CN7203975085_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"天际线上的印记","Title":"本州岛上的富士山, 日本","Copyright":"© phutthiseth thongtae/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"富士山通常从10月开始积雪，山顶白雪往往能持续半年以上，也因此成为日本“四季景观”意象的重要组成部分。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260623_Fujisan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%af%8c%e5%a3%ab%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260622_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260623_Fujisan"},"Ssd":"20260623","Name":"Fujisan","Market":"ZH-CN","Hash":"7203975085","FullDateString":"2026 6月 23"},{"ImageContent":{"Description":"6月22日是世界雨林日，这是一个全球性的日子，也是全年呼吁人们保护世界剩余雨林的行动。这些生态系统并非地图上的点点星罗棋布。它们遍布热带地区及其他地区，却仅覆盖地球表面约6%的面积。想想南美洲的亚马逊雨林、非洲的刚果盆地以及东南亚的森林吧。","Image":{"Url":"/th?id=OHR.QuinaultFerns_ZH-CN6696428927_1920x1080.webp","Wallpaper":"/th?id=OHR.QuinaultFerns_ZH-CN6696428927_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一个郁郁葱葱的王国","Title":"奎诺尔特雨林, 奥林匹克国家公园, 华盛顿州, 美国","Copyright":"© Chris Moore/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"尽管热带雨林仅占地球表面积的 6%，但却是世界上一半以上物种的家园。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260622_QuinaultFerns\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b8%96%e7%95%8c%e9%9b%a8%e6%9e%97%e6%97%a5&form=hpcapt&filters=HpDate:\"20260621_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260622_QuinaultFerns"},"Ssd":"20260622","Name":"QuinaultFerns","Market":"ZH-CN","Hash":"6696428927","FullDateString":"2026 6月 22"},{"ImageContent":{"Description":"六月的第三个星期日是父亲节——一个感谢那些默默守护、悉心照料孩子成长的长辈们的日子。在世界各地，父亲的角色可以呈现出令人意想不到的非凡形式。","Image":{"Url":"/th?id=OHR.EggDad_ZH-CN6045387630_1920x1080.webp","Wallpaper":"/th?id=OHR.EggDad_ZH-CN6045387630_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"鸟类好爸爸","Title":"企鹅爸爸正在检查蛋的情况","Copyright":"© McDonald Wildlife Photography Inc./Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"对海马而言，雄性会将受精卵放入自己的育儿袋中，并在孵化前为它们提供氧气、养分和全方位的保护。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260621_EggDad\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%88%b6%e4%ba%b2%e8%8a%82&form=hpcapt&filters=HpDate:\"20260620_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260621_EggDad"},"Ssd":"20260621","Name":"EggDad","Market":"ZH-CN","Hash":"6045387630","FullDateString":"2026 6月 21"},{"ImageContent":{"Description":"在南极半岛沿岸，一道冰雕般的拱形结构从南大洋拔地而起，而南极半岛是地球上变暖速度最快的地区之一。这道拱形结构最初是由积雪压实而成，历经数千年演变为冰川。最终，冰川或漂浮冰架的一部分断裂脱落——这一过程被称为冰崩——形成了漂浮的冰山。","Image":{"Url":"/th?id=OHR.ArchedIceberg_ZH-CN2698040371_1920x1080.webp","Wallpaper":"/th?id=OHR.ArchedIceberg_ZH-CN2698040371_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"海洋中冰封的大教堂","Title":"漂浮在南极半岛西部海域的拱形冰山, 南大洋","Copyright":"© Steven Kazlowski/Nature Picture Library","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"冰山在融化过程中可能因重心变化突然翻转，其释放的能量甚至足以在平静海面上掀起较大波浪。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260620_ArchedIceberg\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%86%b0%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260619_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260620_ArchedIceberg"},"Ssd":"20260620","Name":"ArchedIceberg","Market":"ZH-CN","Hash":"2698040371","FullDateString":"2026 6月 20"}],"PreloadMediaContents":[{"ImageContent":{"Description":"在冈山县（Okayama Prefecture），当湿润的空气笼罩在溪流之上，被称为“hotaru”的日本萤火虫便开始发出信号。在温暖无风的夜晚，如果条件理想，它们通常会在日落约两小时后开始发光，发散出一种水边独有的静谧感。","Image":{"Url":"/th?id=OHR.FirefliesJapan_ZH-CN1624602654_1920x1080.webp","Wallpaper":"/th?id=OHR.FirefliesJapan_ZH-CN1624602654_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"流光之诗","Title":"小溪上方的萤火虫，冈山县，日本","Copyright":"© tdub303/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"环境健康的生物指标在冈山县，日本表现得尤为典型，特别是源氏萤（Luciola cruciata）对水质极其敏感，它们需要含氧量高且清澈的流动水源以及极低的光污染环境才能完成其复杂的生命周期","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260703_FirefliesJapan\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%90%a4%e7%81%ab%e8%99%ab&form=hpcapt&filters=HpDate:\"20260702_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260703_FirefliesJapan"},"Ssd":"20260703","Name":"FirefliesJapan","Market":"ZH-CN","Hash":"1624602654","FullDateString":"2026 7月 3"},{"ImageContent":{"Description":"在埃及卢克索以南的埃斯纳神庙（Temple of Esna），游客将步入一个充满生机的世界，这里供奉着公羊头神——赫努姆（Khnum）；传说他曾用尼罗河的黏土塑造了人类。这座神庙主要建于托勒密王朝和罗马统治时期，其现存的大厅由24根高耸的石柱支撑，每根柱子上都雕刻着精美的浮雕与颂扬诸神的仪式铭文。","Image":{"Url":"/th?id=OHR.TempleEsna_ZH-CN1160040488_1920x1080.webp","Wallpaper":"/th?id=OHR.TempleEsna_ZH-CN1160040488_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"走进埃斯纳神圣的世界","Title":"埃斯纳神庙穹顶天花板, 埃及","Copyright":"© Nick Brundle Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"数个世纪以来，埃斯纳神庙的大部分区域曾被淤泥和周边建筑掩埋，这在一定程度上减少了风化作用，使许多雕刻得以较好保存。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260702_TempleEsna\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9f%83%e5%8f%8a%e5%9f%83%e6%96%af%e7%ba%b3%e7%a5%9e%e5%ba%99&form=hpcapt&filters=HpDate:\"20260701_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260702_TempleEsna"},"Ssd":"20260702","Name":"TempleEsna","Market":"ZH-CN","Hash":"1160040488","FullDateString":"2026 7月 2"},{"ImageContent":{"Description":"位于纽芬兰岛博纳维斯塔半岛的地牢省立公园，长期受到大西洋海浪的塑造与侵蚀。公园最著名的景观“地牢（Dungeon）”实际上是一处巨大的塌陷海蚀洞，其顶部因持续侵蚀而坍塌，形成直通天空的壮观开口。这一地貌生动展示了海洋作用如何在数千年间不断改造坚硬岩石。","Image":{"Url":"/th?id=OHR.DungeonPark_ZH-CN9770424653_1920x1080.webp","Wallpaper":"/th?id=OHR.DungeonPark_ZH-CN9770424653_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"大西洋雕琢而成的加拿大","Title":"地牢省立公园, 纽芬兰和拉布拉多省, 加拿大","Copyright":"© Kaitlyn McLachlan/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"“地牢”塌陷海洞形成了天然的半封闭空间，海浪拍击时产生的回声会随着海况变化而改变，形成独特的海岸声学现象。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260701_DungeonPark\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9c%b0%e7%89%a2%e7%9c%81%e7%ab%8b%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260630_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260701_DungeonPark"},"Ssd":"20260701","Name":"DungeonPark","Market":"ZH-CN","Hash":"9770424653","FullDateString":"2026 7月 1"},{"ImageContent":{"Description":"当夕阳在马赛马拉国家保护区缓缓西沉，马赛长颈鹿的剪影映衬着绚烂如火的天空与辽阔原野，显得格外醒目。这座保护区位于肯尼亚西南部，与坦桑尼亚的塞伦盖蒂国家公园接壤，占地约580平方英里；随着夜幕降临，这里又度过了精彩的一天。这是一片广袤无垠的土地，也是世界上最壮观的野生动物乐园之一。起伏的草原、零星点缀的金合欢树，以及孕育万物的马拉河，共同构成了上演难忘邂逅的绝佳舞台。","Image":{"Url":"/th?id=OHR.MasaiGiraffe_ZH-CN9505171695_1920x1080.webp","Wallpaper":"/th?id=OHR.MasaiGiraffe_ZH-CN9505171695_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"阴影被拉得修长之处","Title":"马赛马拉国家保护区日落时分的长颈鹿, 肯尼亚","Copyright":"© danm/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"长颈鹿的心脏重量可超过11千克（25磅），能够将血液克服重力输送至近2米高的头部，是陆地动物中极为强大的循环系统之一。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260630_MasaiGiraffe\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%a9%ac%e8%b5%9b%e9%a9%ac%e6%8b%89%e5%9b%bd%e5%ae%b6%e4%bf%9d%e6%8a%a4%e5%8c%ba&form=hpcapt&filters=HpDate:\"20260629_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260630_MasaiGiraffe"},"Ssd":"20260630","Name":"MasaiGiraffe","Market":"ZH-CN","Hash":"9505171695","FullDateString":"2026 6月 30"},{"ImageContent":{"Description":"“国际热带日”于每年6月29日纪念，旨在聚焦北回归线与南回归线之间那片广阔的区域——在这里，温暖的气候与充沛的降水塑造着人们的日常生活。该区域虽仅占地球表面积的约40%，却承载了全球约80%的生物多样性，对于地球生态健康与人类文化而言至关重要。","Image":{"Url":"/th?id=OHR.BoraBoraLagoon_ZH-CN9234363590_1920x1080.webp","Wallpaper":"/th?id=OHR.BoraBoraLagoon_ZH-CN9234363590_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"生于烈火，拥于碧水","Title":"波拉波拉岛及其泻湖, 南太平洋, 法属波利尼西亚","Copyright":"© Frederick Millett/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"波拉波拉岛的泻湖栖息着鹰魟，它们常成群活动，在太平洋最清澈的海域之一的沙质海底优雅滑行。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260629_BoraBoraLagoon\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%bd%e9%99%85%e7%83%ad%e5%b8%a6%e6%97%a5&form=hpcapt&filters=HpDate:\"20260628_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260629_BoraBoraLagoon"},"Ssd":"20260629","Name":"BoraBoraLagoon","Market":"ZH-CN","Hash":"9234363590","FullDateString":"2026 6月 29"},{"ImageContent":{"Description":"在索诺拉沙漠，作为生存大师的巨人柱仙人掌赋予了“坚守”（stick around）一词新的含义。这种巨型植物伸展着躯干与枝臂，向四面八方昂然挺立，已然成为美国西南部的标志性象征。","Image":{"Url":"/th?id=OHR.SaguaroSun_ZH-CN5820504732_1920x1080.webp","Wallpaper":"/th?id=OHR.SaguaroSun_ZH-CN5820504732_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"看起来很精神","Title":"温德盖特山口附近的巨柱仙人掌, 麦克道尔山脉, 亚利桑那州, 美国","Copyright":"© Eric Mischke/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"巨柱仙人掌洁白的花朵是亚利桑那州的州花。它们在晚春短暂盛开，能够吸引大量蜜蜂采蜜，并孕育出广受欢迎的沙漠蜂蜜。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260628_SaguaroSun\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%b7%a8%e4%ba%ba%e6%9f%b1%e4%bb%99%e4%ba%ba%e6%8e%8c&form=hpcapt&filters=HpDate:\"20260627_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260628_SaguaroSun"},"Ssd":"20260628","Name":"SaguaroSun","Market":"ZH-CN","Hash":"5820504732","FullDateString":"2026 6月 28"},{"ImageContent":{"Description":"在美国南卡罗来纳州亨廷岛州立公园内的博尼亚德海滩，最先映入眼帘的是那些树木。紧接着，一个疑问便会浮现：为何一根根被海水漂白的树干和裸露的树根散落在沙滩上，仿佛一幕正在坍塌的景象被按下了暂停键？自20世纪80年代以来，亨廷岛一直面临严重的海滩侵蚀问题，其侵蚀速率位居美国东海岸前列。在部分区域，海岸线每年后退幅度最高可达约30英尺（约9米）。","Image":{"Url":"/th?id=OHR.BoneyardBeach_ZH-CN5540590570_1920x1080.webp","Wallpaper":"/th?id=OHR.BoneyardBeach_ZH-CN5540590570_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"逐渐失去立足之地的树木","Title":"博尼亚德海滩上的漂流木, 亨廷岛, 南卡罗来纳州, 美国","Copyright":"© Frances/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"博尼亚德海滩上许多仍然矗立的枯树遗骸因长期受到盐分环境影响而减缓腐朽过程，从而形成独特的海岸自然雕塑景观。","LinkUrl":"","LinkText":""},"Trivi