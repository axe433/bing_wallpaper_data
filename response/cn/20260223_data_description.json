{"IsEnSearch":false,"EnableEnSearchSwitchTab":true,"Scripts":[{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/2CWuZ7v7vDiJbFNiEuQGUziv1K4.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true},{"Path":"/rp/ICf9X-WMafiZOnS_3M9RpM8994E.gz.js","Postloaded":true}],"Styles":[{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/G7s_ivxNo18k20Hyx5VCTJyA7XI.css?bu=CMsBzgH6AYcC_QH9Af0BxAI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/7w/cir3,cc,nc/Utok7ck07gu22lmsIydejgWEtLY.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/3wC_ht4ipmmpqzz_nMCVPQvHB-A.css?bu=CIcD_QH9Ab4CmAL9Af0B_QE&or=w","Postloaded":true},{"Path":"https://r.bing.com/rs/2C/5x/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":true},{"Path":"https://r.bing.com/rb/2C/cir3,cc,nc/gfxk7HQathU-S3ZTgg0a2mpD9Dg.css?bu=AtEC9wI&or=w","Postloaded":false},{"Path":"https://r.bing.com/rs/2C/5x/cc,nc/QoOx-NWTSUhoq1mkQCAxER7HnX4.css?or=w","Postloaded":false}],"EnableTrendingOnBingBelowSearchbox":true,"HasTrendingOnBingClose":false,"EnableTrendingOnbingCNRefresh":true,"EnableHPSBHover2":true,"EnableNTPLikeBorder":false,"EnableNTPLikeShadow":false,"EnableASSearchButton":false,"HPSearchButtonNewStr":false,"EnableInlineSB":false,"EnableExpandedSB":true,"EnableEntireClick":true,"GLikeSB":false,"EnableHPPinSB":false,"EnableInPrivateInlineSB":false,"EnableLargerSB":true,"EnableHPV2":false,"EnableHPV2Search":false,"EnableHPV2Portal":false,"EnableHPV2NoCopilot":false,"EnableRubyFeed":false,"EnableInfiniteNav":false,"CustomFields":null,"ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2026-02-23T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"漂浮的睡莲点缀着澄澈如玻璃般的水池，隐藏着一个宁静的水下世界。这里是墨西哥图卢姆的大天然井，由数千年前石灰岩塌陷形成，地下淡水缓缓填满洞室，并与幽深的地下洞穴网相连。目光线停留在平静的水面上，睡莲缓缓漂浮，宽阔的叶片盛满阳光，滋养着整个水域的生态系统。作为地球上古老的开花植物谱系之一，睡莲已有约一亿二千五百万年的演化历史，它们通过花香、形态与花期吸引传粉者，在水中延续生命。","Image":{"Url":"/th?id=OHR.TulumLilies_ZH-CN0959403613_1920x1080.webp","Wallpaper":"/th?id=OHR.TulumLilies_ZH-CN0959403613_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"池底的生命律动","Title":"大天坑里的睡莲，图卢姆，墨西哥","Copyright":"© Christian Vizl/Tandem Stills + Motion","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在墨西哥，仅尤卡坦半岛一地就分布着约一万座天然井。这些充满清水的陷穴由石灰岩塌陷自然形成，散布在半岛各处。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260224_TulumLilies\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%9b%be%e5%8d%a2%e5%a7%86%e5%a4%a7%e5%a4%a9%e5%9d%91&form=hpcapt&filters=HpDate:\"20260223_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260224_TulumLilies"},"Ssd":"20260224","Name":"TulumLilies","Market":"ZH-CN","Hash":"0959403613","FullDateString":"2026 2月 24"},{"ImageContent":{"Description":"洁白的羽毛、修长的脖颈和鲜亮的黄喙，让大白鹭在湿地中格外醒目。这种大型鹭鸟分布广泛，几乎遍布全球，能适应多种水域环境。成年大白鹭体长约94至104厘米，翼展1.3至1.45米，体重约1公斤，身形高挑优雅。作为肉食性鸟类，大白鹭主要以鱼类为食，同时也捕食两栖动物、昆虫、小型哺乳动物和爬行动物。它们常在水边一动不动地耐心等待，随后以极快的速度完成一次精准的捕食。","Image":{"Url":"/th?id=OHR.BavariaEgret_ZH-CN0521643213_1920x1080.webp","Wallpaper":"/th?id=OHR.BavariaEgret_ZH-CN0521643213_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"雪原之王","Title":"大白鹭，上巴伐利亚州，德国","Copyright":"© Konrad Wothe/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"大白鹭是一种适应性极强、分布广泛的物种，其活动范围仍在不断扩大，广泛出现在全球温带与热带地区的多种栖息环境中。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260223_BavariaEgret\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%a4%a7%e7%99%bd%e9%b9%ad&form=hpcapt&filters=HpDate:\"20260222_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260223_BavariaEgret"},"Ssd":"20260223","Name":"BavariaEgret","Market":"ZH-CN","Hash":"0521643213","FullDateString":"2026 2月 23"},{"ImageContent":{"Description":"“颤抖的山”这个绰号听起来颇具戏剧性，但对马姆托尔来说，却是数百年来的真实写照。它耸立在英格兰峰区国家公园的卡斯尔顿上方，这里也是英国首个国家公园，占地约555平方英里。这座地标的名字源自古英语，“mam”意为“母亲”，暗指它仿佛怀抱着周围起伏的小丘。然而，这座“母亲之山”却以不稳定而闻名：页岩与砂岩层层叠加，使山体长期滑动，1979年的一次坍塌甚至导致A625公路永久关闭。","Image":{"Url":"/th?id=OHR.MamTorSunrise_ZH-CN9698497298_1920x1080.webp","Wallpaper":"/th?id=OHR.MamTorSunrise_ZH-CN9698497298_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"群山的母亲","Title":"马姆托尔山，德比郡，英格兰","Copyright":"© john finney photography/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"在这座山丘之巅，矗立着一处始建于青铜时代晚期至铁器时代早期的单壕山堡，周围还保留着两座青铜时代的碗状坟冢。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260222_MamTorSunrise\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%a9%ac%e5%a7%86%e6%89%98%e5%b0%94%e5%b1%b1&form=hpcapt&filters=HpDate:\"20260221_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260222_MamTorSunrise"},"Ssd":"20260222","Name":"MamTorSunrise","Market":"ZH-CN","Hash":"9698497298","FullDateString":"2026 2月 22"},{"ImageContent":{"Description":"大雪纷飞中，一只赤狐站在大提顿国家公园的雪地里。这一刻不仅美得纯粹，也让人窥见赤狐在严寒中自如生存的力量。锐利的目光、浓密而火红的毛皮，让它立刻显得与众不同，即便在怀俄明州严酷的冬季，也能安然生存。积雪会吞没声音，但赤狐异常灵敏的听觉，仍能捕捉到雪层之下猎物的细微动静。你几乎可以想象它在飞雪中短暂停步，耳朵微转，身形凝固，专注等待那一丝几不可闻的声响。","Image":{"Url":"/th?id=OHR.TetonFox_ZH-CN9461948674_1920x1080.webp","Wallpaper":"/th?id=OHR.TetonFox_ZH-CN9461948674_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"冬日的低语","Title":"一只红狐狸站在雪地里，大提顿国家公园，怀俄明州，美国","Copyright":"© Radomir Jakubowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"赤狐起源于欧亚大陆，早可追溯至至少40万年前的中更新世，并在约13万年前扩散至北美地区。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260221_TetonFox\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%b5%a4%e7%8b%90&form=hpcapt&filters=HpDate:\"20260220_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260221_TetonFox"},"Ssd":"20260221","Name":"TetonFox","Market":"ZH-CN","Hash":"9461948674","FullDateString":"2026 2月 21"},{"ImageContent":{"Description":"今天，是安塞尔·亚当斯的诞辰。正是他的镜头，塑造了世人心中优胜美地的形象。这座国家公园以雄伟的花岗岩岩壁、壮观的瀑布和变幻莫测的光线闻名，持续激发着一代又一代艺术家的创作灵感。而其中最令人着迷的景象，是被称作“火瀑”的奇观。这一名称，其实源自优胜美地历史中的两种不同景象。在过去，人们曾聚集在冰川点，观看一种人工制造的奇观：炽热的余烬被推下悬崖，在夜幕中倾泻而下，宛如一条燃烧的火流。","Image":{"Url":"/th?id=OHR.AdamsFirefall_ZH-CN9409143565_1920x1080.webp","Wallpaper":"/th?id=OHR.AdamsFirefall_ZH-CN9409143565_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"光照之处","Title":"约塞米蒂国家公园里的火瀑布，加利福尼亚州，美国","Copyright":"© Jorge Villalba/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"唯有水量充沛、天空澄明，且阳光以恰当的角度洒落，火焰般的水幕才会显现。而这样的奇遇，并不会每年发生。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260220_AdamsFirefall\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%ba%a6%e5%a1%9e%e7%b1%b3%e8%92%82%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad%e9%87%8c%e7%9a%84%e7%81%ab%e7%80%91%e5%b8%83&form=hpcapt&filters=HpDate:\"20260219_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260220_AdamsFirefall"},"Ssd":"20260220","Name":"AdamsFirefall","Market":"ZH-CN","Hash":"9409143565","FullDateString":"2026 2月 20"},{"ImageContent":{"Description":"“龙之眼”这个名字听起来像是出自传说，而当你站在挪威罗弗敦群岛的乌塔克莱夫海滩上时，你很容易就能明白为什么它会得此美名。这处地貌由古老的岩石雕琢而成，四周环绕着沙滩和大海，看起来栩栩如生，仿佛大地本身正在注视着你。它历经数千年的冰雪和海水的侵蚀塑造而成，如今已成为该地区最迷人的景点之一。","Image":{"Url":"/th?id=OHR.DragonsEyeRock_ZH-CN6164478776_1920x1080.webp","Wallpaper":"/th?id=OHR.DragonsEyeRock_ZH-CN6164478776_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"大地凝视着我们","Title":"乌塔克莱夫海滩的“龙之眼”岩层，挪威","Copyright":"© reisegraf/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"乌塔克莱夫是一个小社区，只有22名常住居民。除了“龙眼”岩层之外，该地区还以在沙丘上自由漫步和吃草的绵羊而闻名。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260219_DragonsEyeRock\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%b9%8c%e5%a1%94%e5%85%8b%e8%8e%b1%e5%a4%ab%e6%b5%b7%e6%bb%a9&form=hpcapt&filters=HpDate:\"20260218_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260219_DragonsEyeRock"},"Ssd":"20260219","Name":"DragonsEyeRock","Market":"ZH-CN","Hash":"6164478776","FullDateString":"2026 2月 19"},{"ImageContent":{"Description":"普氏野马从未被驯化，自始至终按照自己的方式生存，被认为是地球上最后的野马。它们曾广泛分布于中亚地区，但在20世纪60年代，由于狩猎、栖息地丧失以及与家畜竞争，普氏野马在野外一度消失。幸运的是，少数在20世纪初被带入圈养环境的个体保存了这个物种的火种，也孕育了今天所有的普氏野马。","Image":{"Url":"/th?id=OHR.PrzewalskisHorse_ZH-CN5785609662_1920x1080.webp","Wallpaper":"/th?id=OHR.PrzewalskisHorse_ZH-CN5785609662_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"生而自由，永不驯服","Title":"普氏野马","Copyright":"© Nemyrivskyi Viacheslav/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"早在两万年前，欧洲的洞穴壁画中就已描绘出类似普氏野马的野生马匹。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260218_PrzewalskisHorse\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%99%ae%e6%b0%8f%e9%87%8e%e9%a9%ac&form=hpcapt&filters=HpDate:\"20260217_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260218_PrzewalskisHorse"},"Ssd":"20260218","Name":"PrzewalskisHorse","Market":"ZH-CN","Hash":"5785609662","FullDateString":"2026 2月 18"}],"PreloadMediaContents":[{"ImageContent":{"Description":"元宵节是中国农历新年的重要节日，通常在正月十五庆祝。人们会吃汤圆（象征团圆）并欣赏各式灯笼，寓意团圆、幸福与吉祥。节日期间，家庭聚会、赏灯和灯谜活动都非常受欢迎，是春节庆祝活动的延续。","Image":{"Url":"/th?id=OHR.LanternFestivalY26_ZH-CN9186685796_1920x1080.webp","Wallpaper":"/th?id=OHR.LanternFestivalY26_ZH-CN9186685796_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"花灯映月，团圆吉祥","Title":"元宵节期间悬挂的宫灯，北京自贡灯会现场，北京，中国","Copyright":"© Grisha Bruev/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"你知道吗？元宵节吃的汤圆最早源自汉代，当时被称作“浮圆”，是用糯米粉制成的小圆球，象征团圆与家庭和睦。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260303_LanternFestivalY26\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%85%83%e5%ae%b5%e8%8a%82&form=hpcapt&filters=HpDate:\"20260302_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260303_LanternFestivalY26"},"Ssd":"20260303","Name":"LanternFestivalY26","Market":"ZH-CN","Hash":"9186685796","FullDateString":"2026 3月 3"},{"ImageContent":{"Description":"别被远看时苏梅岛长尾船朴素的外表所迷惑，这些修长的船身凝聚了当地数十年的巧思。它们在泰语中被称为“RueaHangYao”，诞生于20世纪初，当时渔民将汽车发动机改装成动力，用以穿行于大型船只难以进入的浅水海域。每一艘长尾船都由工匠一块木板一块木板手工打造，承载着代代相传的技艺。船体上色彩大胆而醒目，船头常装点着彩布与鲜花——这些象征佛教祝福的装饰，寓意守护船只与船员一路平安。","Image":{"Url":"/th?id=OHR.SamuiThailand_ZH-CN3323790951_1920x1080.webp","Wallpaper":"/th?id=OHR.SamuiThailand_ZH-CN3323790951_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"漂浮的传承","Title":"苏梅岛的港口和长尾船, 泰国","Copyright":"© Foto2rich/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这座高耸的关羽雕像位于泰国苏梅岛华他农，见证着海南华人最早在岛上的定居历史。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260302_SamuiThailand\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e6%b3%b0%e5%9b%bd%e8%8b%8f%e6%a2%85%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260301_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260302_SamuiThailand"},"Ssd":"20260302","Name":"SamuiThailand","Market":"ZH-CN","Hash":"3323790951","FullDateString":"2026 3月 2"},{"ImageContent":{"Description":"今天，我们一同庆祝西班牙迷人的巴利阿里群岛。巴利阿里群岛日致敬这一片多样却紧密相连的地中海土地——马略卡、梅诺卡、伊维萨与福门特拉，共同构成独特的群岛身份。这个日子同时纪念《巴利阿里自治法》，该法案于1983年3月1日正式生效，确立群岛作为西班牙的一个自治区。","Image":{"Url":"/th?id=OHR.BalearesDay_ZH-CN5024902433_1920x1080.webp","Wallpaper":"/th?id=OHR.BalearesDay_ZH-CN5024902433_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"每一步，都是传承","Title":"伊维萨岛, 巴利阿里群岛, 西班牙","Copyright":"© tokar/Shutterstock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"伊维萨岛不仅是游客青睐的度假胜地，更因狂欢不息的夜生活文化而闻名世界，由此被誉为“世界派对之都”。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260301_BalearesDay\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e4%bc%8a%e7%bb%b4%e8%90%a8%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260228_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260301_BalearesDay"},"Ssd":"20260301","Name":"BalearesDay","Market":"ZH-CN","Hash":"5024902433","FullDateString":"2026 3月 1"},{"ImageContent":{"Description":"莫洛凯岛常被称为“最具夏威夷气息岛屿”，这里的节奏缓慢而从容，由自然环境与紧密相连的社区共同塑造。岛屿形成于一百多万年前的火山活动，占地约260平方英里，从太平洋中隆起，延展出修长的山脊与开阔的谷地。与喧闹的邻岛不同，莫洛凯岛拒绝大规模开发，保留了强烈的在地凝聚力，家庭、传统以及对土地的守护构成了这里的核心价值。人们的生活围绕着海洋、土地，以及代代相传的故事展开。","Image":{"Url":"/th?id=OHR.OloupenaFalls_ZH-CN2980118660_1920x1080.webp","Wallpaper":"/th?id=OHR.OloupenaFalls_ZH-CN2980118660_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"洋溢着社区氛围","Title":"奥洛乌佩纳瀑布, 莫洛凯岛, 夏威夷, 美国","Copyright":"© Andrew Aylett/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"这些瀑布极为偏远，只能从空中或海上远望。附近既没有公路，也没有步道。最近的城镇是考纳卡凯，这是岛上的主要城镇。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260228_OloupenaFalls\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e8%8e%ab%e6%b4%9b%e5%87%af%e5%b2%9b&form=hpcapt&filters=HpDate:\"20260227_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260228_OloupenaFalls"},"Ssd":"20260228","Name":"OloupenaFalls","Market":"ZH-CN","Hash":"2980118660","FullDateString":"2026 2月 28"},{"ImageContent":{"Description":"2月27日是国际北极熊日，聚焦与冰封世界紧密相连的“北极巨兽”。作为世界上最大的陆地食肉动物，北极熊会为寻找食物在辽阔的极地景观中跋涉数百英里。它们高度适应海冰生活：宽大的前掌跨度可达约一英尺，不仅能稳稳踏雪行走，也能在冰冷海水中游出数英里。","Image":{"Url":"/th?id=OHR.ArcitcCub_ZH-CN2725049760_1920x1080.webp","Wallpaper":"/th?id=OHR.ArcitcCub_ZH-CN2725049760_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"薄冰上的生活","Title":"北极熊幼崽走过浮冰, 北极国家野生动物保护区, 阿拉斯加州, 美国","Copyright":"© Steven Kazlowski/naturepl.com","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"根据国际自然保护联盟（IUCN）的评估，北极熊被列为易危物种，全球种群数量估计约22000至31000只。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260227_ArcitcCub\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e5%8c%97%e6%9e%81%e7%86%8a&form=hpcapt&filters=HpDate:\"20260226_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260227_ArcitcCub"},"Ssd":"20260227","Name":"ArcitcCub","Market":"ZH-CN","Hash":"2725049760","FullDateString":"2026 2月 27"},{"ImageContent":{"Description":"大峡谷国家公园每天都有新的故事，但2月26日这一天格外特别，纪念的是1919年大峡谷正式成为国家公园的历史时刻。这一里程碑式的决定，守护了美国最具代表性的自然奇观。峡谷深处，科罗拉多河缓缓流淌，穿行于层叠的岩石之间，跨越数百英里，以季节为节拍，静静雕刻着峡谷的生命。","Image":{"Url":"/th?id=OHR.GrandSunset_ZH-CN1905986519_1920x1080.webp","Wallpaper":"/th?id=OHR.GrandSunset_ZH-CN1905986519_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"一幅壮丽的景象","Title":"大峡谷和科罗拉多河，亚利桑那州，美国","Copyright":"© Matt Anderson Photography/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"国家公园管理局在园内多个观景点架设了实时网络摄像头，分享日出时刻、天气变化与峡谷的日常节律。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260226_GrandSunset\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e7%be%8e%e5%9b%bd%e5%a4%a7%e5%b3%a1%e8%b0%b7%e5%9b%bd%e5%ae%b6%e5%85%ac%e5%9b%ad&form=hpcapt&filters=HpDate:\"20260225_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260226_GrandSunset"},"Ssd":"20260226","Name":"GrandSunset","Market":"ZH-CN","Hash":"1905986519","FullDateString":"2026 2月 26"},{"ImageContent":{"Description":"阿拉斯加朱诺城外，门登霍尔冰川静静隐匿其间，内外皆仿佛幻境。走入罕见的蓝色冰洞，世界骤然安静，光线透过历经数百年压实的冰层，映照四周。冰川自朱诺冰原绵延约十三英里，缓缓流向下方山谷，在年复一年的流动中悄然改变形态。","Image":{"Url":"/th?id=OHR.MendenhallCave_ZH-CN1850649760_1920x1080.webp","Wallpaper":"/th?id=OHR.MendenhallCave_ZH-CN1850649760_1920x1200.jpg&rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"冰，由内而外透出光芒","Title":"门登霍尔冰川的冰洞，阿拉斯加州，美国","Copyright":"© Designpics/Adobe Stock","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"2012年，冰川消退后，埋藏其下的树桩和原木逐渐显现，根系与树皮仍然完整。因长久埋藏在砾石之下，这层覆盖恰好成了天然的保护屏障，所以它们仍保持着原本的生长姿态。当这些遗存被揭开，科学家得以窥见冰川形成之前的生态环境。","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz&filters=WQOskey:\"HPQuiz_20260225_MendenhallCave\"&FORM=HPQUIZ","BackstageUrl":"/search?q=%e9%97%a8%e7%99%bb%e9%9c%8d%e5%b0%94%e5%86%b0%e5%b7%9d&form=hpcapt&filters=HpDate:\"20260224_1600\"+mgzv3configlist:\"BingQA_Encyclopedia_Layout\"","TriviaId":"HPQuiz_20260225_MendenhallCave"},"Ssd":"20260225","Name":"MendenhallCave","Market":"ZH-CN","Hash":"1850649760","FullDateString":"2026 2月 25"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"每日一图","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"了解更多","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"立即捐赠","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"速览:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"近期的主页图片","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"{0} 的主页图像","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"历史上的今天","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"在这一天，在 {0}中，{1}","LOC_HOMEPAGE_SHARE_TOOLTIP":"共享今日必应主页","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"下载今日美图。仅限用作桌面壁纸。","LOC_MUSCARD_DOWNLOAD_LINK":"下载此图像","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"此图片不能下载用作壁纸。","LOC_HOMEPAGE_INFO_TEXT":"信息","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"获取新版必应壁纸应用","LOC_BING_APP_TEXT":"在设备上获取必应壁纸","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.net/bing/?adjust=nk9xri2_dzfz5n2","LOC_BING_APP_LINK_MOBILE":"https://app.adjust.com/d93ddtl_a75k0gg?deeplink=sapphire%3A%2F%2Fwallpaper","LOC_BING_APP_DOWNLOAD_TEXT":"移动应用","LOC_BING_WP_APP_DOWNLOAD_TEXT":"桌面应用","LOC_BING_APP_TEXT_MOBILE":"使用必应应用获取每日照片","LOC_BING_APP_DOWNLOAD_TEXT_MOBILE":"获取","LOC_HOMEPAGE_VERTICAL_SCROLL_TOB":"必应热门资讯","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB":"必应上的热点","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_NEXT":"换一批","LOC_HOMEPAGE_BELOW_SEARCHBOX_TOB_Close":"隐藏必应上的热点","LOC_HOMEPAGE_TOB_TAG_NEW":"新建","LOC_HOMEPAGE_TOB_TAG_HOT":"热","LOC_HOMEP